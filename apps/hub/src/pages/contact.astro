---
import '@shared/styles/global.css';
import SaaSLayout from '../layouts/SaaSLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const pageTitle = formatSeoTitle('Contact Us', 'GramSeva Mitra');
const pageDescription =
  'Get in touch with the GramSeva Mitra team — questions, feedback, partnerships, and support.';

const TURNSTILE_SITE_KEY = '0x4AAAAAADkEvAfoc0ocjgR2';

const subjectOptions = [
  'General Inquiry',
  'Bug Report',
  'Feature Request',
  'Partnership / Business',
  'Other',
] as const;

const fieldClass =
  'w-full rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20';
---

<SaaSLayout title={pageTitle} description={pageDescription} activeNav="contact">
  <Fragment slot="head">
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </Fragment>

  <div class="px-4 py-10 sm:px-6 sm:py-12">
    <header class="mb-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-emerald-700">Contact</p>
      <h1 class="mt-2 text-3xl font-bold text-slate-900 sm:text-4xl">Get in touch</h1>
      <p class="mt-3 text-sm leading-relaxed text-slate-600 sm:text-base">
        Questions, feedback, or partnership ideas — we read every message.
        You can also email us directly at
        <a
          href="mailto:contact@gramsevamitra.com"
          class="font-medium text-emerald-700 underline decoration-emerald-300 underline-offset-2 hover:text-emerald-800"
        >
          contact@gramsevamitra.com
        </a>.
      </p>
    </header>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm sm:p-8">
      <form id="contact-form" class="space-y-5" novalidate>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-700">Name</span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            maxlength="120"
            class={fieldClass}
            placeholder="Your name"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-700">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            maxlength="254"
            class={fieldClass}
            placeholder="you@example.com"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-700">Subject</span>
          <select name="subject" required class={fieldClass}>
            {subjectOptions.map((option) => (
              <option value={option}>{option}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-700">Message</span>
          <textarea
            name="message"
            required
            rows={6}
            maxlength={5000}
            class={`${fieldClass} resize-y`}
            placeholder="How can we help?"
          ></textarea>
        </label>

        <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY}></div>

        <div id="contact-status" class="hidden rounded-lg border px-3 py-2 text-sm" role="status" aria-live="polite"></div>

        <button
          type="submit"
          id="contact-submit"
          class="inline-flex w-full items-center justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800 sm:w-auto"
        >
          Send message
        </button>
      </form>
    </section>
  </div>
</SaaSLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const statusEl = document.getElementById('contact-status') as HTMLDivElement | null;

  const defaultSubmitLabel = submitBtn?.textContent ?? 'Send message';

  function showStatus(type: 'success' | 'error', message: string) {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.classList.remove(
      'hidden',
      'border-emerald-200',
      'bg-emerald-50',
      'text-emerald-800',
      'border-rose-200',
      'bg-rose-50',
      'text-rose-800',
      'border-emerald-800/60',
      'bg-emerald-950/40',
      'text-emerald-300',
      'border-rose-800/60',
      'bg-rose-950/40',
      'text-rose-300'
    );
    if (type === 'success') {
      statusEl.classList.add('border-emerald-200', 'bg-emerald-50', 'text-emerald-800');
    } else {
      statusEl.classList.add('border-rose-200', 'bg-rose-50', 'text-rose-800');
    }
  }

  function resetTurnstile() {
    const turnstile = (window as Window & { turnstile?: { reset: () => void } }).turnstile;
    try {
      turnstile?.reset();
    } catch {
      /* widget may not be ready */
    }
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form || !submitBtn) return;

    const formData = new FormData(form);
    const payload = {
      name: formData.get('name'),
      email: formData.get('email'),
      subject: formData.get('subject'),
      message: formData.get('message'),
      'cf-turnstile-response': formData.get('cf-turnstile-response'),
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    statusEl?.classList.add('hidden');

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const result = (await response.json()) as { success?: boolean; message?: string; error?: string };

      if (response.ok && result.success) {
        form.reset();
        resetTurnstile();
        showStatus('success', result.message ?? 'Message sent successfully!');
      } else {
        resetTurnstile();
        showStatus('error', result.error ?? 'Something went wrong. Please try again.');
      }
    } catch {
      resetTurnstile();
      showStatus('error', 'Network error. Please check your connection and try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = defaultSubmitLabel;
    }
  });
</script>
