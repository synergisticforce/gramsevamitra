---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import { formatSeoTitle } from '@shared/config/seo';

const pageTitle = formatSeoTitle('Contact Us', 'GramSeva Mitra');
const pageDescription =
  'Get in touch with the GramSeva Mitra team — questions, feedback, partnerships, and support.';

const TURNSTILE_SITE_KEY = '0x4AAAAAADkEBQKhSMeqypp1';

const subjectOptions = [
  'General Inquiry',
  'Bug Report',
  'Feature Request',
  'Partnership / Business',
  'Other',
] as const;
---

<BaseLayout title={pageTitle} description={pageDescription} site="hub">
  <Fragment slot="head">
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </Fragment>

  <Header slot="header" active="hub" />

  <div class="mx-auto max-w-2xl px-4 py-10 sm:px-6 sm:py-14">
    <header class="mb-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-emerald-400">Contact</p>
      <h1 class="mt-2 text-3xl font-bold text-white sm:text-4xl">Get in touch</h1>
      <p class="mt-3 text-sm leading-relaxed text-slate-400 sm:text-base">
        Questions, feedback, or partnership ideas — we read every message.
        You can also email us directly at
        <a
          href="mailto:contact@gramsevamitra.com"
          class="font-medium text-emerald-400 underline decoration-emerald-600 underline-offset-2 hover:text-emerald-300"
        >
          contact@gramsevamitra.com
        </a>.
      </p>
    </header>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-8">
      <form id="contact-form" class="space-y-5" novalidate>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Name</span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            maxlength="120"
            class="input-field w-full"
            placeholder="Your name"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            maxlength="254"
            class="input-field w-full"
            placeholder="you@example.com"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Subject</span>
          <select name="subject" required class="input-field w-full">
            {subjectOptions.map((option) => (
              <option value={option}>{option}</option>
            ))}
          </select>
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Message</span>
          <textarea
            name="message"
            required
            rows={6}
            maxlength={5000}
            class="input-field w-full resize-y"
            placeholder="How can we help?"
          ></textarea>
        </label>

        <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY}></div>

        <div id="contact-status" class="hidden rounded-lg border px-3 py-2 text-sm" role="status" aria-live="polite"></div>

        <button type="submit" id="contact-submit" class="btn-primary w-full sm:w-auto">
          Send message
        </button>
      </form>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const statusEl = document.getElementById('contact-status') as HTMLDivElement | null;

  const defaultSubmitLabel = submitBtn?.textContent ?? 'Send message';

  function showStatus(type: 'success' | 'error', message: string) {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.classList.remove('hidden', 'border-emerald-800/60', 'bg-emerald-950/40', 'text-emerald-300', 'border-rose-800/60', 'bg-rose-950/40', 'text-rose-300');
    if (type === 'success') {
      statusEl.classList.add('border-emerald-800/60', 'bg-emerald-950/40', 'text-emerald-300');
    } else {
      statusEl.classList.add('border-rose-800/60', 'bg-rose-950/40', 'text-rose-300');
    }
  }

  function resetTurnstile() {
    const turnstile = (window as Window & { turnstile?: { reset: () => void } }).turnstile;
    try {
      turnstile?.reset();
    } catch {
      /* widget may not be ready */
    }
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form || !submitBtn) return;

    const formData = new FormData(form);
    const payload = {
      name: formData.get('name'),
      email: formData.get('email'),
      subject: formData.get('subject'),
      message: formData.get('message'),
      'cf-turnstile-response': formData.get('cf-turnstile-response'),
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    statusEl?.classList.add('hidden');

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const result = (await response.json()) as { success?: boolean; message?: string; error?: string };

      if (response.ok && result.success) {
        form.reset();
        resetTurnstile();
        showStatus('success', result.message ?? 'Message sent successfully!');
      } else {
        resetTurnstile();
        showStatus('error', result.error ?? 'Something went wrong. Please try again.');
      }
    } catch {
      resetTurnstile();
      showStatus('error', 'Network error. Please check your connection and try again.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = defaultSubmitLabel;
    }
  });
</script>
