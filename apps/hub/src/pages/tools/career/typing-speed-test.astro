---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import TypingTestTool from '../../../components/tools/TypingTestTool';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Typing Speed Test';
const toolDescription =
  'Practice typing with a 60-second timer — live WPM and accuracy for professional and job typing test prep. 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="career"
>
  <div class="typing-speed-test">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/career')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Career Prep Room
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Monkeytype-style test — 15, 25, or 50 words. Timer starts on your first keystroke with live WPM timeline.
      </p>
    </header>

    <TypingTestTool client:load />
  </div>
</ToolsLayout>
