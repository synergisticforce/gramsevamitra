---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import DraftSavedBadge from '../../../components/tools/DraftSavedBadge.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { SITES, utilitiesHref } from '@shared/config/sites';

const toolName = 'ATS Resume Keyword Matcher';
const toolDescription =
  'Paste your resume and a job description — get an ATS match score, matched keywords, and missing terms. Exact, fuzzy, and phrase matching, 100% offline.';
const resumeScannerUrl = SITES.resume.url;
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="career"
>
  <div class="ats-keyword-matcher">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/career')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Career Prep Room
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Client-side keyword analysis — stop-word filtering, fuzzy matching, and actionable missing-keyword lists.
      </p>
    </header>

    <a
      href={resumeScannerUrl}
      data-astro-reload
      target="_blank"
      rel="noopener noreferrer"
      class="mb-5 block rounded-xl border border-emerald-800/40 bg-emerald-950/30 px-4 py-3 text-sm text-slate-300 transition hover:border-emerald-600/50"
    >
      Need deep ATS scoring with PDF upload?
      <span class="font-semibold text-emerald-400"> Open full Resume Scanner ↗</span>
    </a>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="ats-resume-heading"
      >
        <h2 id="ats-resume-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Paste your resume
        </h2>
        <textarea
          id="ats-resume"
          rows="14"
          placeholder="Paste resume text here…"
          class="input-field mt-4 w-full resize-y text-sm leading-relaxed"
        ></textarea>
      </section>

      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="ats-jd-heading"
      >
        <h2 id="ats-jd-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Paste job description
        </h2>
        <textarea
          id="ats-jd"
          rows="14"
          placeholder="Paste the full job description…"
          class="input-field mt-4 w-full resize-y text-sm leading-relaxed"
        ></textarea>
        <button type="button" id="ats-analyze" class="btn-primary mt-4 w-full text-sm">Analyze match</button>
        <DraftSavedBadge />
      </section>
    </div>

    <section class="mt-6 space-y-4" aria-labelledby="ats-results-heading" aria-live="polite">
      <h2 id="ats-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
        Match analysis
      </h2>

      <div class="result-card text-center">
        <p class="text-xs uppercase tracking-wider text-slate-500">ATS match score</p>
        <p id="ats-score" class="mt-1 text-5xl font-extrabold tabular-nums text-emerald-400">—</p>
        <div class="mx-auto mt-4 h-2.5 max-w-md overflow-hidden rounded-full bg-slate-800">
          <div id="ats-score-bar" class="h-full rounded-full bg-emerald-500 transition-all duration-300" style="width: 0%"></div>
        </div>
        <p id="ats-summary" class="mt-3 text-xs text-slate-500">Paste both texts to analyze.</p>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <article class="result-card">
          <h3 class="text-sm font-bold text-emerald-400">
            Matched keywords <span id="ats-matched-count" class="text-slate-500">(0)</span>
          </h3>
          <ul id="ats-matched" class="mt-3 flex flex-wrap gap-2">
            <li class="text-xs text-slate-500">Run analysis to see matches.</li>
          </ul>
        </article>

        <article class="result-card">
          <h3 class="text-sm font-bold text-rose-400">
            Missing keywords <span id="ats-missing-count" class="text-slate-500">(0)</span>
          </h3>
          <ul id="ats-missing" class="mt-3 flex flex-wrap gap-2">
            <li class="text-xs text-slate-500">Run analysis to see gaps.</li>
          </ul>
          <button type="button" id="ats-copy-missing" class="btn-secondary mt-4 w-full text-xs" disabled>
            Copy missing keywords
          </button>
        </article>
      </div>
    </section>
  </div>

  <style>
    .result-card {
      @apply rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/30 to-slate-900/60 p-4 shadow-lg sm:p-5;
    }
    .kw-tag {
      @apply rounded-lg border px-2.5 py-1 text-xs font-medium;
    }
    .kw-tag.matched {
      @apply border-emerald-800/60 bg-emerald-950/40 text-emerald-300;
    }
    .kw-tag.missing {
      @apply border-rose-800/60 bg-rose-950/40 text-rose-300;
    }
    .kw-tag .match-type {
      @apply ml-1 text-[10px] uppercase text-slate-500;
    }
  </style>

  <script>
    import { matchResumeToJob } from '@shared/utils/atsKeywordMatch';
    import { showDraftSaved } from '../../../lib/storage/draftSaved';

    const STORAGE_KEY = 'gsm-tools:ats-keyword-matcher';

    const resumeEl = document.getElementById('ats-resume') as HTMLTextAreaElement;
    const jdEl = document.getElementById('ats-jd') as HTMLTextAreaElement;
    const analyzeBtn = document.getElementById('ats-analyze') as HTMLButtonElement;
    const copyMissingBtn = document.getElementById('ats-copy-missing') as HTMLButtonElement;
    const scoreEl = document.getElementById('ats-score')!;
    const scoreBar = document.getElementById('ats-score-bar') as HTMLElement;
    const summaryEl = document.getElementById('ats-summary')!;
    const matchedEl = document.getElementById('ats-matched')!;
    const missingEl = document.getElementById('ats-missing')!;
    const matchedCount = document.getElementById('ats-matched-count')!;
    const missingCount = document.getElementById('ats-missing-count')!;

    let lastMissing: string[] = [];

    function renderMatched(items: ReturnType<typeof matchResumeToJob>['matched']): void {
      matchedEl.innerHTML = '';
      if (items.length === 0) {
        matchedEl.innerHTML = '<li class="text-xs text-slate-500">No keyword matches yet.</li>';
        return;
      }
      items.forEach((m) => {
        const li = document.createElement('li');
        li.className = 'kw-tag matched';
        li.textContent =
          m.matchType === 'exact' ? `${m.keyword} (${m.matchType})` : `${m.keyword} → ${m.matchedAs} (${m.matchType})`;
        matchedEl.appendChild(li);
      });
    }

    function renderMissing(items: string[]): void {
      missingEl.innerHTML = '';
      if (items.length === 0) {
        missingEl.innerHTML = '<li class="text-xs text-slate-500">No gaps — strong keyword overlap!</li>';
        return;
      }
      items.forEach((kw) => {
        const li = document.createElement('li');
        li.className = 'kw-tag missing';
        li.textContent = kw;
        missingEl.appendChild(li);
      });
    }

    function analyze(): void {
      const resume = resumeEl.value.trim();
      const jd = jdEl.value.trim();

      if (!jd) {
        scoreEl.textContent = '—';
        scoreBar.style.width = '0%';
        summaryEl.textContent = 'Paste a job description to analyze.';
        matchedCount.textContent = '(0)';
        missingCount.textContent = '(0)';
        renderMatched([]);
        renderMissing([]);
        copyMissingBtn.disabled = true;
        return;
      }

      const result = matchResumeToJob(resume, jd);
      lastMissing = result.missing;

      scoreEl.textContent = `${result.score}%`;
      scoreBar.style.width = `${result.score}%`;
      matchedCount.textContent = `(${result.matched.length})`;
      missingCount.textContent = `(${result.missing.length})`;
      summaryEl.textContent = `${result.matched.length} of ${result.jdKeywords.length} JD keywords found in your resume.`;
      renderMatched(result.matched);
      renderMissing(result.missing);
      copyMissingBtn.disabled = result.missing.length === 0;

      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ resume: resumeEl.value, jd: jdEl.value }));
        showDraftSaved();
      } catch {
        /* ignore */
      }
    }

    analyzeBtn.addEventListener('click', analyze);
    [resumeEl, jdEl].forEach((el) => el.addEventListener('input', analyze));

    copyMissingBtn.addEventListener('click', async () => {
      if (lastMissing.length === 0) return;
      try {
        await navigator.clipboard.writeText(lastMissing.join(', '));
        const orig = copyMissingBtn.textContent;
        copyMissingBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyMissingBtn.textContent = orig;
        }, 2000);
      } catch {
        copyMissingBtn.textContent = 'Copy failed';
      }
    });

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const data = JSON.parse(saved) as { resume?: string; jd?: string };
        resumeEl.value = data.resume ?? '';
        jdEl.value = data.jd ?? '';
        showDraftSaved();
      }
    } catch {
      /* ignore */
    }

    analyze();
  </script>
</ToolsLayout>
