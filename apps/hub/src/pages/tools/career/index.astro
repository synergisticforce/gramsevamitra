---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import ToolGridCard from '../../../components/tools/ToolGridCard.astro';
import { getWorkspaceMeta, getWorkspaceTools } from '../../../config/toolsRegistry';
import { getToolsForSegment, WORKSPACE_SEGMENT_DEFS } from '../../../config/workspaceSegments';
import { formatSeoTitle } from '@shared/config/seo';
import { SITES, utilitiesHref } from '@shared/config/sites';

const workspace = getWorkspaceMeta('career');
const careerTools = getWorkspaceTools('career');
const careerSegmentDefs = WORKSPACE_SEGMENT_DEFS.career.filter((s) => s.id !== 'all');
const resumeScannerUrl = SITES.resume.url;
---

<ToolsLayout
  title={formatSeoTitle(workspace.label, 'Free Offline Tools')}
  description={workspace.description}
  activeNav="career"
>
  <div class="career-dashboard">
    <!-- ATS Resume Scanner — cross-link to dedicated subdomain app -->
    <a
      href={resumeScannerUrl}
      data-astro-reload
      target="_blank"
      rel="noopener noreferrer"
      class="group mb-6 block overflow-hidden rounded-2xl border-2 border-emerald-500/50 bg-gradient-to-br from-emerald-950/70 via-emerald-900/30 to-slate-900/80 p-5 shadow-xl transition hover:border-emerald-400/70 hover:shadow-emerald-900/30 sm:p-6"
    >
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="min-w-0 flex-1">
          <p class="text-[10px] font-bold uppercase tracking-widest text-emerald-400">Free · Separate app</p>
          <h2 class="mt-1 text-xl font-extrabold text-white sm:text-2xl">ATS Resume Scanner</h2>
          <p class="mt-2 max-w-xl text-sm leading-relaxed text-slate-300">
            Paste a job description, upload your resume, and get an instant match score with missing keywords —
            before you send your next application.
          </p>
          <p class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-emerald-400 group-hover:text-emerald-300">
            Open resume.gramsevamitra.com
            <span aria-hidden="true">↗</span>
          </p>
        </div>
        <div
          class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl border border-emerald-600/40 bg-emerald-950/60 text-3xl sm:h-20 sm:w-20"
          aria-hidden="true"
        >
          📄
        </div>
      </div>
    </a>

    <!-- Job Hunt Overview widget -->
    <section
      class="widget-card mb-8"
      aria-labelledby="job-hunt-heading"
      aria-live="polite"
    >
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <h2 id="job-hunt-heading" class="widget-title">Job hunt overview</h2>
          <p class="mt-1 text-xs text-slate-500">Synced from your offline job tracker</p>
        </div>
        <a href={utilitiesHref('/tools/career/job-tracker')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
          Open tracker →
        </a>
      </div>

      <div class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="stat-tile">
          <p class="stat-label">Applied</p>
          <p id="stat-applied" class="stat-value text-sky-400">0</p>
        </div>
        <div class="stat-tile">
          <p class="stat-label">Interview</p>
          <p id="stat-interview" class="stat-value text-amber-400">0</p>
        </div>
        <div class="stat-tile hidden sm:block">
          <p class="stat-label">Offers</p>
          <p id="stat-offer" class="stat-value text-emerald-400">0</p>
        </div>
        <div class="stat-tile hidden sm:block">
          <p class="stat-label">Wishlist</p>
          <p id="stat-wishlist" class="stat-value text-slate-300">0</p>
        </div>
      </div>

      <p id="job-hunt-summary" class="mt-4 text-center text-sm text-slate-500">
        No applications tracked yet — add jobs in the tracker to see live stats here.
      </p>
    </section>

    <!-- Career tools grid -->
    <section aria-labelledby="career-tools-heading">
      <h2 id="career-tools-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
        {careerTools.length} career prep tools
      </h2>
      {
        careerSegmentDefs.map((segment) => {
          const tools = getToolsForSegment('career', segment.id);
          if (tools.length === 0) return null;
          return (
            <div id={segment.id} class="scroll-mt-24 mt-8">
              <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">{segment.label}</h3>
              <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {tools.map((tool) => (
                  <ToolGridCard tool={tool} />
                ))}
              </div>
            </div>
          );
        })
      }
    </section>
  </div>

  <style>
    .widget-card {
      @apply rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/30 to-slate-900/60 p-4 shadow-xl sm:p-5;
    }
    .widget-title {
      @apply text-sm font-semibold uppercase tracking-wider text-emerald-400/80;
    }
    .stat-tile {
      @apply rounded-xl border border-slate-800 bg-slate-950/50 px-3 py-4 text-center;
    }
    .stat-label {
      @apply text-[10px] font-semibold uppercase tracking-wider text-slate-500;
    }
    .stat-value {
      @apply mt-1 text-3xl font-extrabold tabular-nums;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:job-tracker';

    interface JobCard {
      id: string;
    }

    type BoardState = {
      wishlist: JobCard[];
      applied: JobCard[];
      interview: JobCard[];
      offer: JobCard[];
      rejected: JobCard[];
    };

    const statApplied = document.getElementById('stat-applied')!;
    const statInterview = document.getElementById('stat-interview')!;
    const statOffer = document.getElementById('stat-offer')!;
    const statWishlist = document.getElementById('stat-wishlist')!;
    const summaryEl = document.getElementById('job-hunt-summary')!;

    function emptyBoard(): BoardState {
      return { wishlist: [], applied: [], interview: [], offer: [], rejected: [] };
    }

    function loadBoard(): BoardState {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return emptyBoard();
        const parsed = JSON.parse(raw) as Partial<BoardState>;
        const board = emptyBoard();
        (Object.keys(board) as (keyof BoardState)[]).forEach((key) => {
          const items = parsed[key];
          board[key] = Array.isArray(items) ? items : [];
        });
        return board;
      } catch {
        return emptyBoard();
      }
    }

    function renderOverview(): void {
      const board = loadBoard();
      const applied = board.applied.length;
      const interview = board.interview.length;
      const offer = board.offer.length;
      const wishlist = board.wishlist.length;
      const total = applied + interview + offer + wishlist + board.rejected.length;

      statApplied.textContent = String(applied);
      statInterview.textContent = String(interview);
      statOffer.textContent = String(offer);
      statWishlist.textContent = String(wishlist);

      if (total === 0) {
        summaryEl.textContent =
          'No applications tracked yet — add jobs in the tracker to see live stats here.';
        return;
      }

      const parts: string[] = [];
      if (applied > 0) parts.push(`${applied} in Applied`);
      if (interview > 0) parts.push(`${interview} in Interview`);
      if (offer > 0) parts.push(`${offer} offer${offer === 1 ? '' : 's'}`);
      summaryEl.textContent = `${total} total · ${parts.join(' · ')}`;
    }

    renderOverview();

    window.addEventListener('storage', (event) => {
      if (event.key === STORAGE_KEY) renderOverview();
    });

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') renderOverview();
    });
  </script>
</ToolsLayout>
