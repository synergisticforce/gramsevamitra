---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import CoverLetterGenerator from '../../../components/tools/CoverLetterGenerator';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Cold Email & Networking Builder';
const toolDescription =
  'Generate cover letters, LinkedIn connection requests, and cold emails from your details — copy-ready, 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="career"
>
  <div class="cold-email-builder">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/career')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Career Prep Room
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Dynamic matching blocks update cover letter, LinkedIn, and cold email templates as you type.
      </p>
    </header>

    <CoverLetterGenerator client:load />
  </div>
</ToolsLayout>
