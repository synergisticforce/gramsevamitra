---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import DraftSavedBadge from '../../../components/tools/DraftSavedBadge.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Legal Templates';
const toolDescription =
  'Fill-in NDA, rental agreement, and simple contract templates — preview updates live, download as .txt.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="career"
>
  <div class="legal-templates">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/career')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Career Prep Room
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Draft basic legal documents offline. Not a substitute for professional legal advice.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="lt-form-heading"
      >
        <h2 id="lt-form-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Template &amp; fields
        </h2>

        <label class="mt-4 block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Document type</span>
          <select id="lt-type" class="input-field w-full">
            <option value="nda">Non-Disclosure Agreement (NDA)</option>
            <option value="rental">Rental Agreement</option>
            <option value="contract">Simple Contract</option>
          </select>
        </label>

        <div id="lt-fields" class="mt-4 space-y-4"></div>

        <button type="button" id="lt-download" class="btn-primary mt-6 w-full text-sm">Download .txt</button>
        <DraftSavedBadge />
      </section>

      <section aria-labelledby="lt-preview-heading">
        <h2 id="lt-preview-heading" class="mb-4 text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Live preview
        </h2>
        <article class="preview-card">
          <pre id="lt-preview" class="preview-body">Select a template and fill in the fields.</pre>
          <button type="button" id="lt-copy" class="copy-btn mt-3 w-full">Copy text</button>
        </article>
      </section>
    </div>
  </div>

  <style>
    .preview-card {
      @apply rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/30 to-slate-900/60 p-4 shadow-lg sm:p-5;
    }
    .preview-body {
      @apply max-h-[32rem] overflow-y-auto whitespace-pre-wrap rounded-xl border border-slate-800 bg-slate-950/50 p-3 font-sans text-xs leading-relaxed text-slate-300 sm:text-sm;
    }
    .copy-btn {
      @apply rounded-lg border border-emerald-700/60 bg-emerald-950/40 px-3 py-2 text-xs font-semibold text-emerald-400 transition hover:border-emerald-500 hover:text-emerald-300 focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
  </style>

  <script>
    import { showDraftSaved } from '../../../lib/storage/draftSaved';

    const STORAGE_KEY = 'gsm-tools:legal-templates';

    interface FieldDef {
      id: string;
      label: string;
      placeholder: string;
    }

    const TEMPLATES: Record<string, { fields: FieldDef[]; build: (v: Record<string, string>) => string }> = {
      nda: {
        fields: [
          { id: 'party1', label: 'Disclosing party', placeholder: 'e.g. Acme Pvt Ltd' },
          { id: 'party2', label: 'Receiving party', placeholder: 'e.g. John Doe' },
          { id: 'purpose', label: 'Purpose', placeholder: 'e.g. evaluation of a business partnership' },
          { id: 'duration', label: 'Duration (years)', placeholder: 'e.g. 2' },
          { id: 'jurisdiction', label: 'Jurisdiction', placeholder: 'e.g. Mumbai, Maharashtra' },
          { id: 'date', label: 'Effective date', placeholder: 'e.g. 1 January 2026' },
        ],
        build: (v) => `NON-DISCLOSURE AGREEMENT

This Non-Disclosure Agreement ("Agreement") is entered into on ${v.date || '[Effective Date]'} between:

Disclosing Party: ${v.party1 || '[Disclosing Party]'}
Receiving Party: ${v.party2 || '[Receiving Party]'}

1. PURPOSE
The parties wish to explore ${v.purpose || '[Purpose]'} and may share confidential information in connection therewith.

2. CONFIDENTIAL INFORMATION
"Confidential Information" means any non-public information disclosed by either party, whether oral, written, or electronic.

3. OBLIGATIONS
The Receiving Party shall:
(a) Use Confidential Information solely for the Purpose stated above;
(b) Not disclose Confidential Information to third parties without prior written consent;
(c) Protect Confidential Information with reasonable care.

4. TERM
This Agreement shall remain in effect for ${v.duration || '[Duration]'} year(s) from the Effective Date.

5. GOVERNING LAW
This Agreement shall be governed by the laws applicable in ${v.jurisdiction || '[Jurisdiction]'}.

6. ENTIRE AGREEMENT
This document constitutes the entire agreement between the parties regarding confidentiality.

IN WITNESS WHEREOF, the parties have executed this Agreement as of the Effective Date.

_________________________          _________________________
${v.party1 || '[Disclosing Party]'}              ${v.party2 || '[Receiving Party]'}`,
      },
      rental: {
        fields: [
          { id: 'landlord', label: 'Landlord name', placeholder: 'e.g. Ramesh Kumar' },
          { id: 'tenant', label: 'Tenant name', placeholder: 'e.g. Anita Sharma' },
          { id: 'address', label: 'Property address', placeholder: 'e.g. Flat 4B, Green Park, Delhi' },
          { id: 'rent', label: 'Monthly rent (₹)', placeholder: 'e.g. 25000' },
          { id: 'deposit', label: 'Security deposit (₹)', placeholder: 'e.g. 50000' },
          { id: 'start', label: 'Lease start date', placeholder: 'e.g. 1 April 2026' },
          { id: 'term', label: 'Lease term (months)', placeholder: 'e.g. 11' },
        ],
        build: (v) => `RENTAL AGREEMENT

This Rental Agreement is made on ${v.start || '[Start Date]'} between:

Landlord: ${v.landlord || '[Landlord Name]'}
Tenant: ${v.tenant || '[Tenant Name]'}

PROPERTY
The Landlord agrees to let and the Tenant agrees to take on rent the residential premises at:
${v.address || '[Property Address]'}

RENT & DEPOSIT
- Monthly rent: ₹${v.rent || '[Rent Amount]'} payable by the 5th of each month.
- Security deposit: ₹${v.deposit || '[Deposit Amount]'} refundable at vacating, subject to deductions for damages or dues.

TERM
The lease shall be for ${v.term || '[Term]'} months commencing from ${v.start || '[Start Date]'}.

TENANT OBLIGATIONS
The Tenant shall:
(a) Pay rent on time;
(b) Use the premises for residential purposes only;
(c) Not sublet without written consent;
(d) Maintain the premises in good condition.

LANDLORD OBLIGATIONS
The Landlord shall:
(a) Provide peaceful possession;
(b) Carry out structural repairs;
(c) Return the security deposit within 30 days of vacating, less lawful deductions.

TERMINATION
Either party may terminate with one month's written notice, subject to the terms above.

SIGNATURES

_________________________          _________________________
Landlord: ${v.landlord || '[Landlord]'}         Tenant: ${v.tenant || '[Tenant]'}`,
      },
      contract: {
        fields: [
          { id: 'client', label: 'Client name', placeholder: 'e.g. Startup Labs Pvt Ltd' },
          { id: 'provider', label: 'Service provider', placeholder: 'e.g. Dev Studio' },
          { id: 'services', label: 'Services description', placeholder: 'e.g. website design and development' },
          { id: 'fee', label: 'Total fee (₹)', placeholder: 'e.g. 150000' },
          { id: 'timeline', label: 'Timeline', placeholder: 'e.g. 6 weeks from signing' },
          { id: 'payment', label: 'Payment terms', placeholder: 'e.g. 50% advance, 50% on delivery' },
          { id: 'date', label: 'Agreement date', placeholder: 'e.g. 10 June 2026' },
        ],
        build: (v) => `SIMPLE SERVICE CONTRACT

This Service Contract ("Contract") is entered into on ${v.date || '[Agreement Date]'} between:

Client: ${v.client || '[Client Name]'}
Service Provider: ${v.provider || '[Service Provider]'}

1. SERVICES
The Provider agrees to deliver: ${v.services || '[Services Description]'}.

2. TIMELINE
Work shall be completed within ${v.timeline || '[Timeline]'}.

3. COMPENSATION
Total fee: ₹${v.fee || '[Total Fee]'}
Payment terms: ${v.payment || '[Payment Terms]'}.

4. INTELLECTUAL PROPERTY
Upon full payment, deliverables shall belong to the Client unless otherwise agreed in writing.

5. CONFIDENTIALITY
Both parties shall keep proprietary information confidential.

6. LIMITATION OF LIABILITY
Neither party shall be liable for indirect or consequential damages beyond the contract value.

7. TERMINATION
Either party may terminate with 15 days written notice. Client shall pay for work completed to date.

8. GOVERNING LAW
This Contract is governed by the laws of India.

SIGNATURES

_________________________          _________________________
Client: ${v.client || '[Client]'}            Provider: ${v.provider || '[Provider]'}`,
      },
    };

    const typeEl = document.getElementById('lt-type') as HTMLSelectElement;
    const fieldsContainer = document.getElementById('lt-fields')!;
    const previewEl = document.getElementById('lt-preview')!;
    const downloadBtn = document.getElementById('lt-download') as HTMLButtonElement;
    const copyBtn = document.getElementById('lt-copy') as HTMLButtonElement;

    const fieldValues: Record<string, Record<string, string>> = {};

    function getCurrentType(): string {
      return typeEl.value;
    }

    function renderFields(): void {
      const type = getCurrentType();
      const def = TEMPLATES[type];
      if (!def) return;

      if (!fieldValues[type]) fieldValues[type] = {};

      fieldsContainer.innerHTML = '';
      def.fields.forEach((field) => {
        const label = document.createElement('label');
        label.className = 'block';
        label.innerHTML = `
          <span class="mb-1 block text-sm font-medium text-slate-300">${field.label}</span>
          <input type="text" data-field="${field.id}" placeholder="${field.placeholder}" class="input-field w-full" value="${fieldValues[type][field.id] ?? ''}" />
        `;
        fieldsContainer.appendChild(label);
      });

      fieldsContainer.querySelectorAll<HTMLInputElement>('input[data-field]').forEach((input) => {
        input.addEventListener('input', () => {
          fieldValues[type][input.dataset.field!] = input.value;
          renderPreview();
          saveState();
        });
      });

      renderPreview();
    }

    function getValues(): Record<string, string> {
      const type = getCurrentType();
      return fieldValues[type] ?? {};
    }

    function renderPreview(): void {
      const type = getCurrentType();
      const def = TEMPLATES[type];
      if (!def) return;
      previewEl.textContent = def.build(getValues());
    }

    function saveState(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ type: getCurrentType(), values: fieldValues }));
        showDraftSaved();
      } catch { /* ignore */ }
    }

    function downloadTxt(): void {
      const text = previewEl.textContent ?? '';
      const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${getCurrentType()}-template.txt`;
      a.click();
      URL.revokeObjectURL(url);
    }

    typeEl.addEventListener('change', () => {
      renderFields();
      saveState();
    });

    downloadBtn.addEventListener('click', downloadTxt);

    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(previewEl.textContent ?? '');
        const orig = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = orig; }, 2000);
      } catch {
        copyBtn.textContent = 'Copy failed';
        setTimeout(() => { copyBtn.textContent = 'Copy text'; }, 2000);
      }
    });

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const data = JSON.parse(saved) as { type: string; values: Record<string, Record<string, string>> };
        if (data.type) typeEl.value = data.type;
        if (data.values) Object.assign(fieldValues, data.values);
        showDraftSaved();
      }
    } catch { /* ignore */ }

    renderFields();
  </script>
</ToolsLayout>
