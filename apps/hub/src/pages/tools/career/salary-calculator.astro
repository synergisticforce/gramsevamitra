---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Salary & Take-Home Calculator';
const toolDescription =
  'Estimate monthly in-hand salary from annual CTC with standard EPF deductions — free, instant, and 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="career"
>
  <div class="salary-calculator">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/career')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Career Prep Room
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Simplified EPF estimate — your numbers never leave this device.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="salary-inputs-heading"
      >
        <h2 id="salary-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Compensation
        </h2>

        <div class="mt-5 space-y-4">
          <label class="block">
            <span class="mb-2 block text-sm font-medium text-slate-300">Annual CTC (₹)</span>
            <input
              id="annual-ctc"
              type="number"
              min="0"
              step="10000"
              inputmode="numeric"
              placeholder="e.g. 1200000"
              class="input-field w-full tabular-nums"
            />
          </label>

          <div class="flex flex-wrap gap-2">
            {[600000, 900000, 1200000, 1800000, 2400000].map((amt) => (
              <button type="button" class="ctc-preset" data-ctc={amt}>
                {amt >= 100000 ? `₹${amt / 100000}L` : `₹${amt}`}
              </button>
            ))}
          </div>
        </div>

        <p class="mt-4 text-xs leading-relaxed text-slate-500">
          Assumes Basic = 50% of CTC and employee EPF = 12% of Basic. Actual deductions vary by company policy,
          tax regime, and allowances.
        </p>

        <button type="button" id="reset-salary" class="btn-secondary mt-6 w-full text-sm">Reset</button>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="salary-results-heading"
        aria-live="polite"
      >
        <h2 id="salary-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Estimated breakdown
        </h2>

        <div class="mt-5 rounded-xl border border-emerald-800/40 bg-slate-950/50 px-4 py-5 text-center">
          <p class="text-xs font-medium uppercase tracking-wider text-slate-400">Monthly take-home (est.)</p>
          <p id="result-takehome" class="mt-1 text-3xl font-extrabold tabular-nums text-emerald-400 sm:text-4xl">
            ₹0
          </p>
        </div>

        <dl class="mt-5 space-y-3 rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4 text-sm">
          <div class="flex justify-between gap-3">
            <dt class="text-slate-400">Annual CTC</dt>
            <dd id="result-annual" class="font-semibold tabular-nums text-white">₹0</dd>
          </div>
          <div class="flex justify-between gap-3 border-t border-slate-800 pt-3">
            <dt class="text-slate-400">Monthly gross (CTC ÷ 12)</dt>
            <dd id="result-monthly-gross" class="font-semibold tabular-nums text-slate-200">₹0</dd>
          </div>
          <div class="flex justify-between gap-3">
            <dt class="text-slate-400">Monthly basic (50% of gross)</dt>
            <dd id="result-basic" class="font-semibold tabular-nums text-slate-200">₹0</dd>
          </div>
          <div class="flex justify-between gap-3">
            <dt class="text-slate-400">Employee EPF (12% of basic)</dt>
            <dd id="result-epf" class="font-semibold tabular-nums text-amber-400">− ₹0</dd>
          </div>
          <div class="flex justify-between gap-3 border-t border-emerald-800/40 pt-3">
            <dt class="font-medium text-emerald-200">Net take-home</dt>
            <dd id="result-net-line" class="font-bold tabular-nums text-emerald-400">₹0</dd>
          </div>
        </dl>

        <p id="salary-note" class="mt-4 text-center text-xs text-slate-500">
          Enter your CTC to see the estimated monthly in-hand amount.
        </p>
      </section>
    </div>
  </div>

  <style>
    .ctc-preset {
      @apply rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-1.5 text-xs font-semibold text-slate-300 transition hover:border-emerald-600 hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:salary-calculator';
    const BASIC_RATIO = 0.5;
    const EPF_RATE = 0.12;

    const ctcInput = document.getElementById('annual-ctc') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-salary') as HTMLButtonElement;
    const resultTakehome = document.getElementById('result-takehome')!;
    const resultAnnual = document.getElementById('result-annual')!;
    const resultMonthlyGross = document.getElementById('result-monthly-gross')!;
    const resultBasic = document.getElementById('result-basic')!;
    const resultEpf = document.getElementById('result-epf')!;
    const resultNetLine = document.getElementById('result-net-line')!;
    const salaryNote = document.getElementById('salary-note')!;

    function formatInr(value: number, decimals = 0): string {
      if (!Number.isFinite(value)) return '₹0';
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        minimumFractionDigits: decimals,
        maximumFractionDigits: decimals,
      }).format(value);
    }

    interface SalaryResult {
      annualCtc: number;
      monthlyGross: number;
      monthlyBasic: number;
      epfDeduction: number;
      takeHome: number;
    }

    function calculate(annualCtc: number): SalaryResult | null {
      if (annualCtc <= 0) return null;

      const monthlyGross = annualCtc / 12;
      const monthlyBasic = monthlyGross * BASIC_RATIO;
      const epfDeduction = monthlyBasic * EPF_RATE;
      const takeHome = monthlyGross - epfDeduction;

      return { annualCtc, monthlyGross, monthlyBasic, epfDeduction, takeHome };
    }

    function renderEmpty(): void {
      resultTakehome.textContent = '₹0';
      resultAnnual.textContent = '₹0';
      resultMonthlyGross.textContent = '₹0';
      resultBasic.textContent = '₹0';
      resultEpf.textContent = '− ₹0';
      resultNetLine.textContent = '₹0';
      salaryNote.textContent = 'Enter your CTC to see the estimated monthly in-hand amount.';
    }

    function render(result: SalaryResult): void {
      resultTakehome.textContent = formatInr(Math.round(result.takeHome));
      resultAnnual.textContent = formatInr(result.annualCtc);
      resultMonthlyGross.textContent = formatInr(Math.round(result.monthlyGross));
      resultBasic.textContent = formatInr(Math.round(result.monthlyBasic));
      resultEpf.textContent = `− ${formatInr(Math.round(result.epfDeduction))}`;
      resultNetLine.textContent = formatInr(Math.round(result.takeHome));
      salaryNote.textContent = `Est. in-hand after employee EPF only — excludes income tax, professional tax, and other deductions.`;
    }

    function recalculate(): void {
      const ctc = Number(ctcInput.value) || 0;
      const result = calculate(ctc);
      if (!result) {
        renderEmpty();
      } else {
        render(result);
      }
      try {
        localStorage.setItem(STORAGE_KEY, ctcInput.value);
      } catch {
        /* ignore */
      }
    }

    ctcInput.addEventListener('input', recalculate);

    document.querySelectorAll<HTMLButtonElement>('.ctc-preset').forEach((btn) => {
      btn.addEventListener('click', () => {
        const val = Number(btn.dataset.ctc);
        if (Number.isFinite(val)) {
          ctcInput.value = String(val);
          recalculate();
        }
      });
    });

    resetBtn.addEventListener('click', () => {
      ctcInput.value = '';
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
      renderEmpty();
    });

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) ctcInput.value = saved;
    } catch {
      /* ignore */
    }

    recalculate();
  </script>
</ToolsLayout>
