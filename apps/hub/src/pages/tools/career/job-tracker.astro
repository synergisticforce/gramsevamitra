---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import JobTrackerTool from '../../../components/tools/JobTrackerTool';
import { formatSeoTitle } from '@shared/config/seo';
import { SITES, utilitiesHref } from '@shared/config/sites';

const toolName = 'Job Application Tracker';
const toolDescription =
  'Offline Kanban board for tracking job applications — drag cards across Wishlist, Applied, Interviewing, Offer, and Rejected. Saved locally on your device.';
const atsScannerUrl = SITES.resume.url;
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="career"
>
  <div class="job-tracker">
    <header class="mb-4">
      <a href={utilitiesHref('/tools/career')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Career Prep Room
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">Drag jobs across stages — your hunt stays private and offline.</p>
    </header>

    <a
      href={atsScannerUrl}
      data-astro-reload
      target="_blank"
      rel="noopener noreferrer"
      class="group mb-5 flex items-center justify-between gap-3 rounded-xl border border-emerald-700/40 bg-gradient-to-r from-emerald-950/60 to-slate-900/60 px-4 py-3 transition hover:border-emerald-500/60"
    >
      <p class="text-sm text-slate-300">
        Is your resume ready for these applications?
        <span class="font-semibold text-emerald-400 group-hover:text-emerald-300"> Try our free ATS Scanner →</span>
      </p>
    </a>

    <JobTrackerTool client:load />
  </div>
</ToolsLayout>
