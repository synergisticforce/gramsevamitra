---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'GST Calculator';
const toolDescription =
  'Calculate Indian GST with CGST/SGST split — add or remove tax from any amount. Free, instant, and 100% offline.';
const GST_SLABS = [5, 12, 18, 28] as const;
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="money"
>
  <div class="gst-calculator">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/money')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Money &amp; Gig Ledger
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Standard Indian GST slabs with CGST + SGST breakdown — runs entirely on your device.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="gst-inputs-heading"
      >
        <h2 id="gst-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Amount &amp; slab
        </h2>

        <div class="mt-5 space-y-6">
          <div>
            <label for="gst-amount" class="mb-2 block text-sm font-medium text-slate-300">Amount (₹)</label>
            <input
              id="gst-amount"
              type="number"
              min="0"
              step="1"
              inputmode="decimal"
              placeholder="1000"
              class="input-field w-full tabular-nums"
            />
          </div>

          <fieldset>
            <legend class="mb-2 text-sm font-medium text-slate-300">GST slab</legend>
            <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="GST rate">
              {GST_SLABS.map((rate) => (
                <label class="gst-pill">
                  <input
                    type="radio"
                    name="gst-rate"
                    value={rate}
                    class="sr-only peer"
                    checked={rate === 18}
                  />
                  <span class="gst-pill-label">{rate}%</span>
                </label>
              ))}
            </div>
          </fieldset>

          <fieldset>
            <legend class="mb-2 text-sm font-medium text-slate-300">Calculation mode</legend>
            <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="Add or remove GST">
              <label class="gst-pill">
                <input type="radio" name="gst-mode" value="add" class="sr-only peer" checked />
                <span class="gst-pill-label">Add GST</span>
              </label>
              <label class="gst-pill">
                <input type="radio" name="gst-mode" value="remove" class="sr-only peer" />
                <span class="gst-pill-label">Remove GST</span>
              </label>
            </div>
            <p id="mode-hint" class="mt-2 text-xs text-slate-500">
              Enter the base (pre-tax) amount; GST will be added on top.
            </p>
          </fieldset>
        </div>

        <button type="button" id="reset-gst" class="btn-secondary mt-6 w-full text-sm">
          Reset
        </button>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="gst-receipt-heading"
        aria-live="polite"
      >
        <h2 id="gst-receipt-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Tax receipt
        </h2>

        <div class="mt-5 rounded-xl border border-dashed border-slate-700 bg-slate-950/50 p-4 sm:p-5">
          <div class="mb-4 border-b border-slate-800 pb-3 text-center">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500">GST breakdown</p>
            <p id="receipt-slab" class="mt-1 text-sm font-medium text-emerald-400">18% GST · Add mode</p>
          </div>

          <dl class="space-y-3 text-sm">
            <div class="flex items-center justify-between gap-3">
              <dt id="label-net" class="text-slate-400">Net amount (pre-tax)</dt>
              <dd id="result-net" class="font-semibold tabular-nums text-white">₹0.00</dd>
            </div>
            <div class="flex items-center justify-between gap-3 border-t border-slate-800/80 pt-3">
              <dt class="text-slate-400">
                CGST <span id="cgst-rate-label" class="text-slate-500">(9%)</span>
              </dt>
              <dd id="result-cgst" class="font-semibold tabular-nums text-amber-300">₹0.00</dd>
            </div>
            <div class="flex items-center justify-between gap-3">
              <dt class="text-slate-400">
                SGST <span id="sgst-rate-label" class="text-slate-500">(9%)</span>
              </dt>
              <dd id="result-sgst" class="font-semibold tabular-nums text-amber-300">₹0.00</dd>
            </div>
            <div class="flex items-center justify-between gap-3 border-t border-slate-800/80 pt-3">
              <dt class="text-slate-400">Total GST</dt>
              <dd id="result-gst-total" class="font-semibold tabular-nums text-amber-400">₹0.00</dd>
            </div>
            <div class="flex items-center justify-between gap-3 rounded-lg border border-emerald-800/40 bg-emerald-950/30 px-3 py-3">
              <dt class="font-medium text-emerald-200">Gross amount</dt>
              <dd id="result-gross" class="text-lg font-bold tabular-nums text-emerald-400">₹0.00</dd>
            </div>
          </dl>
        </div>

        <p id="gst-note" class="mt-4 text-center text-xs text-slate-500">
          Enter an amount to see the itemized GST breakdown.
        </p>
      </section>
    </div>
  </div>

  <style>
    .gst-pill-label {
      @apply inline-flex cursor-pointer items-center rounded-full border border-slate-700 bg-slate-950/60 px-4 py-2 text-sm font-semibold text-slate-300 transition hover:border-emerald-600 hover:text-white;
    }
    .gst-pill :global(input:checked) + .gst-pill-label {
      @apply border-emerald-500 bg-emerald-950/50 text-emerald-300 ring-2 ring-emerald-400/40;
    }
    .gst-pill :global(input:focus-visible) + .gst-pill-label {
      @apply outline-none ring-2 ring-emerald-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:gst-calculator';

    const DEFAULTS = {
      amount: 1000,
      rate: 18,
      mode: 'add' as 'add' | 'remove',
    };

    interface SavedState {
      amount: number;
      rate: number;
      mode: 'add' | 'remove';
    }

    interface GstResult {
      net: number;
      cgst: number;
      sgst: number;
      gstTotal: number;
      gross: number;
      rate: number;
      mode: 'add' | 'remove';
    }

    const amountInput = document.getElementById('gst-amount') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-gst') as HTMLButtonElement;
    const modeHint = document.getElementById('mode-hint')!;
    const receiptSlab = document.getElementById('receipt-slab')!;
    const labelNet = document.getElementById('label-net')!;
    const resultNet = document.getElementById('result-net')!;
    const resultCgst = document.getElementById('result-cgst')!;
    const resultSgst = document.getElementById('result-sgst')!;
    const resultGstTotal = document.getElementById('result-gst-total')!;
    const resultGross = document.getElementById('result-gross')!;
    const cgstRateLabel = document.getElementById('cgst-rate-label')!;
    const sgstRateLabel = document.getElementById('sgst-rate-label')!;
    const gstNote = document.getElementById('gst-note')!;

    function formatInr(value: number): string {
      if (!Number.isFinite(value)) return '₹0.00';
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }).format(value);
    }

    function getSelectedRate(): number {
      const checked = document.querySelector<HTMLInputElement>('input[name="gst-rate"]:checked');
      return Number(checked?.value) || DEFAULTS.rate;
    }

    function getSelectedMode(): 'add' | 'remove' {
      const checked = document.querySelector<HTMLInputElement>('input[name="gst-mode"]:checked');
      return checked?.value === 'remove' ? 'remove' : 'add';
    }

    function calculateGst(amount: number, ratePct: number, mode: 'add' | 'remove'): GstResult | null {
      if (amount < 0 || ratePct <= 0) return null;

      const rate = ratePct / 100;
      let net: number;
      let gross: number;
      let gstTotal: number;

      if (mode === 'add') {
        net = amount;
        gstTotal = net * rate;
        gross = net + gstTotal;
      } else {
        gross = amount;
        net = gross / (1 + rate);
        gstTotal = gross - net;
      }

      const halfRate = ratePct / 2;
      const cgst = gstTotal / 2;
      const sgst = gstTotal / 2;

      return { net, cgst, sgst, gstTotal, gross, rate: ratePct, mode };
    }

    function readState(): SavedState {
      return {
        amount: Math.max(0, Number(amountInput.value) || 0),
        rate: getSelectedRate(),
        mode: getSelectedMode(),
      };
    }

    function applyState(state: SavedState): void {
      amountInput.value = state.amount > 0 ? String(state.amount) : '';
      const rateInput = document.querySelector<HTMLInputElement>(
        `input[name="gst-rate"][value="${state.rate}"]`
      );
      if (rateInput) rateInput.checked = true;
      const modeInput = document.querySelector<HTMLInputElement>(
        `input[name="gst-mode"][value="${state.mode}"]`
      );
      if (modeInput) modeInput.checked = true;
    }

    function saveState(state: SavedState): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      } catch {
        /* ignore */
      }
    }

    function loadState(): SavedState {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { ...DEFAULTS };
        const parsed = JSON.parse(raw) as Partial<SavedState>;
        return {
          amount: typeof parsed.amount === 'number' && parsed.amount >= 0 ? parsed.amount : DEFAULTS.amount,
          rate: [5, 12, 18, 28].includes(parsed.rate as number) ? (parsed.rate as number) : DEFAULTS.rate,
          mode: parsed.mode === 'remove' ? 'remove' : 'add',
        };
      } catch {
        return { ...DEFAULTS };
      }
    }

    function renderResults(result: GstResult | null): void {
      if (!result || result.gross <= 0) {
        resultNet.textContent = '₹0.00';
        resultCgst.textContent = '₹0.00';
        resultSgst.textContent = '₹0.00';
        resultGstTotal.textContent = '₹0.00';
        resultGross.textContent = '₹0.00';
        cgstRateLabel.textContent = '(—)';
        sgstRateLabel.textContent = '(—)';
        receiptSlab.textContent = '—';
        gstNote.textContent = 'Enter an amount to see the itemized GST breakdown.';
        return;
      }

      const half = result.rate / 2;
      resultNet.textContent = formatInr(result.net);
      resultCgst.textContent = formatInr(result.cgst);
      resultSgst.textContent = formatInr(result.sgst);
      resultGstTotal.textContent = formatInr(result.gstTotal);
      resultGross.textContent = formatInr(result.gross);
      cgstRateLabel.textContent = `(${half}%)`;
      sgstRateLabel.textContent = `(${half}%)`;

      const modeLabel = result.mode === 'add' ? 'Add mode' : 'Remove mode';
      receiptSlab.textContent = `${result.rate}% GST · ${modeLabel}`;

      if (result.mode === 'add') {
        labelNet.textContent = 'Net amount (pre-tax)';
        modeHint.textContent = 'Enter the base (pre-tax) amount; GST will be added on top.';
        gstNote.textContent = `Gross = Net + ${result.rate}% GST (CGST ${half}% + SGST ${half}%).`;
      } else {
        labelNet.textContent = 'Net amount (excl. GST)';
        modeHint.textContent = 'Enter the gross (tax-inclusive) amount; GST will be extracted.';
        gstNote.textContent = `Net extracted from gross inclusive of ${result.rate}% GST.`;
      }
    }

    function recalculate(): void {
      const state = readState();
      const result = state.amount > 0 ? calculateGst(state.amount, state.rate, state.mode) : null;
      renderResults(result);
      saveState(state);
    }

    amountInput.addEventListener('input', recalculate);
    document.querySelectorAll<HTMLInputElement>('input[name="gst-rate"], input[name="gst-mode"]').forEach((el) => {
      el.addEventListener('change', recalculate);
    });

    resetBtn.addEventListener('click', () => {
      applyState({ ...DEFAULTS });
      recalculate();
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    applyState(loadState());
    recalculate();
  </script>
</ToolsLayout>
