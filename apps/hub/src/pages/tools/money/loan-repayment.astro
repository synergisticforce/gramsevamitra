---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Loan Repayment Planner';
const toolDescription =
  'Plan prepayments and view amortization schedules — EMI, interest saved, and month-by-month breakdown offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="money"
>
  <div class="loan-repayment">
    <header class="mb-6">
      <a href="/tools/money" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Money &amp; Gig Ledger
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        See how a lump prepayment reduces interest — standard amortization, fully offline.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="loan-inputs-heading"
      >
        <h2 id="loan-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Loan details
        </h2>

        <div class="mt-5 space-y-5">
          <div>
            <label for="loan-amount" class="mb-2 block text-sm font-medium text-slate-300">Loan amount (₹)</label>
            <input
              id="loan-amount"
              type="number"
              min="1000"
              step="1000"
              inputmode="numeric"
              class="input-field w-full tabular-nums"
            />
          </div>

          <div>
            <label for="interest-rate" class="mb-2 block text-sm font-medium text-slate-300">Interest rate (% p.a.)</label>
            <input
              id="interest-rate"
              type="number"
              min="0"
              max="30"
              step="0.05"
              inputmode="decimal"
              class="input-field w-full tabular-nums"
            />
          </div>

          <div>
            <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
              <label for="tenure-value" class="text-sm font-medium text-slate-300">Tenure</label>
              <div class="flex items-center gap-2">
                <input
                  id="tenure-value"
                  type="number"
                  min="1"
                  max="600"
                  step="1"
                  inputmode="numeric"
                  class="input-field w-20 text-right tabular-nums"
                />
                <select id="tenure-unit" class="select-field w-28 py-2 text-sm">
                  <option value="years">Years</option>
                  <option value="months">Months</option>
                </select>
              </div>
            </div>
          </div>

          <div class="rounded-xl border border-amber-900/30 bg-amber-950/20 px-4 py-4">
            <label for="prepayment" class="mb-2 block text-sm font-medium text-amber-200/90">
              Lump prepayment (₹) <span class="font-normal text-slate-500">— optional, after month 1</span>
            </label>
            <input
              id="prepayment"
              type="number"
              min="0"
              step="1000"
              inputmode="numeric"
              placeholder="0"
              class="input-field w-full tabular-nums"
            />
          </div>
        </div>

        <button type="button" id="reset-loan" class="btn-secondary mt-6 w-full text-sm">
          Reset to defaults
        </button>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="loan-results-heading"
        aria-live="polite"
      >
        <h2 id="loan-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Summary
        </h2>

        <div class="mt-5 space-y-4">
          <div class="rounded-xl border border-emerald-800/40 bg-slate-950/50 px-4 py-5 text-center">
            <p class="text-xs font-medium uppercase tracking-wider text-slate-400">Monthly EMI</p>
            <p id="result-emi" class="mt-1 text-3xl font-extrabold tabular-nums text-emerald-400 sm:text-4xl">
              ₹0
            </p>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Total interest</p>
              <p id="result-interest" class="mt-1 text-lg font-bold tabular-nums text-amber-400">₹0</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Interest saved</p>
              <p id="result-saved" class="mt-1 text-lg font-bold tabular-nums text-emerald-400">₹0</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Months to close</p>
              <p id="result-months" class="mt-1 text-lg font-bold tabular-nums text-white">—</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Total paid</p>
              <p id="result-total" class="mt-1 text-lg font-bold tabular-nums text-white">₹0</p>
            </div>
          </div>

          <p id="loan-note" class="text-center text-xs text-slate-500">
            Adjust loan details to see EMI and prepayment impact.
          </p>
        </div>
      </section>
    </div>

    <section
      class="mt-6 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40"
      aria-labelledby="schedule-heading"
    >
      <div class="border-b border-slate-800 bg-slate-950/60 px-4 py-3 sm:px-5">
        <h2 id="schedule-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Amortization schedule <span class="font-normal normal-case text-slate-600">(first 12 months + totals)</span>
        </h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[640px] text-left text-sm">
          <thead class="border-b border-slate-800 bg-slate-950/40 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
            <tr>
              <th class="px-4 py-3">Month</th>
              <th class="px-4 py-3 text-right">Opening</th>
              <th class="px-4 py-3 text-right">EMI</th>
              <th class="px-4 py-3 text-right">Principal</th>
              <th class="px-4 py-3 text-right">Interest</th>
              <th class="px-4 py-3 text-right">Prepay</th>
              <th class="px-4 py-3 text-right">Closing</th>
            </tr>
          </thead>
          <tbody id="schedule-body">
            <tr>
              <td colspan="7" class="px-4 py-8 text-center text-sm text-slate-500">
                Enter loan details to generate the schedule.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <style>
    .schedule-row td {
      @apply border-b border-slate-800/80 px-4 py-2.5 align-middle tabular-nums;
    }
    .schedule-row:last-child td {
      @apply border-b-0;
    }
    .schedule-totals td {
      @apply border-t-2 border-emerald-800/40 bg-emerald-950/20 px-4 py-3 font-semibold tabular-nums;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:loan-repayment';

    const DEFAULTS = {
      loanAmount: 2500000,
      interestRate: 8.5,
      tenureValue: 20,
      tenureUnit: 'years' as 'years' | 'months',
      prepayment: 0,
    };

    interface SavedState {
      loanAmount: number;
      interestRate: number;
      tenureValue: number;
      tenureUnit: 'years' | 'months';
      prepayment: number;
    }

    interface ScheduleRow {
      month: number;
      opening: number;
      emi: number;
      principal: number;
      interest: number;
      prepay: number;
      closing: number;
    }

    interface LoanSummary {
      emi: number;
      totalInterest: number;
      totalPaid: number;
      months: number;
      schedule: ScheduleRow[];
      interestWithoutPrepay: number;
      interestSaved: number;
    }

    const loanAmountInput = document.getElementById('loan-amount') as HTMLInputElement;
    const interestRateInput = document.getElementById('interest-rate') as HTMLInputElement;
    const tenureValueInput = document.getElementById('tenure-value') as HTMLInputElement;
    const tenureUnitSelect = document.getElementById('tenure-unit') as HTMLSelectElement;
    const prepaymentInput = document.getElementById('prepayment') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-loan') as HTMLButtonElement;

    const resultEmi = document.getElementById('result-emi')!;
    const resultInterest = document.getElementById('result-interest')!;
    const resultSaved = document.getElementById('result-saved')!;
    const resultMonths = document.getElementById('result-months')!;
    const resultTotal = document.getElementById('result-total')!;
    const loanNote = document.getElementById('loan-note')!;
    const scheduleBody = document.getElementById('schedule-body')!;

    function formatInr(value: number): string {
      if (!Number.isFinite(value)) return '₹0';
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        maximumFractionDigits: 0,
      }).format(value);
    }

    function clamp(value: number, min: number, max: number): number {
      return Math.min(max, Math.max(min, value));
    }

    function tenureToMonths(value: number, unit: 'years' | 'months'): number {
      const months = unit === 'years' ? value * 12 : value;
      return Math.round(clamp(months, 1, 600));
    }

    function calculateEmi(principal: number, annualRatePct: number, months: number): number {
      if (principal <= 0 || months <= 0) return 0;
      if (annualRatePct === 0) return principal / months;
      const r = annualRatePct / 12 / 100;
      const compound = Math.pow(1 + r, months);
      return (principal * r * compound) / (compound - 1);
    }

    function buildSchedule(
      principal: number,
      annualRatePct: number,
      maxMonths: number,
      emi: number,
      lumpPrepay: number
    ): { schedule: ScheduleRow[]; totalInterest: number; totalPaid: number } {
      const schedule: ScheduleRow[] = [];
      let balance = principal;
      let totalInterest = 0;
      let totalPaid = 0;
      const monthlyRate = annualRatePct / 12 / 100;
      let prepayApplied = false;

      for (let month = 1; month <= maxMonths && balance > 0.01; month++) {
        const opening = balance;
        const interest = annualRatePct === 0 ? 0 : balance * monthlyRate;
        let principalPart = emi - interest;
        if (principalPart > balance) principalPart = balance;
        let emiPaid = principalPart + interest;
        let prepay = 0;

        if (month === 1 && lumpPrepay > 0 && !prepayApplied) {
          prepay = Math.min(lumpPrepay, Math.max(0, balance - principalPart));
          prepayApplied = true;
        }

        let closing = balance - principalPart - prepay;
        if (closing < 0) closing = 0;

        schedule.push({
          month,
          opening,
          emi: emiPaid,
          principal: principalPart,
          interest,
          prepay,
          closing,
        });

        totalInterest += interest;
        totalPaid += emiPaid + prepay;
        balance = closing;
      }

      return { schedule, totalInterest, totalPaid };
    }

    function analyzeLoan(
      principal: number,
      annualRatePct: number,
      months: number,
      lumpPrepay: number
    ): LoanSummary | null {
      if (principal <= 0 || months <= 0 || annualRatePct < 0) return null;

      const emi = calculateEmi(principal, annualRatePct, months);
      if (!Number.isFinite(emi) || emi <= 0) return null;

      const withoutPrepay = buildSchedule(principal, annualRatePct, months, emi, 0);
      const withPrepay = buildSchedule(principal, annualRatePct, months, emi, lumpPrepay);
      const interestSaved = Math.max(0, withoutPrepay.totalInterest - withPrepay.totalInterest);

      return {
        emi,
        totalInterest: withPrepay.totalInterest,
        totalPaid: withPrepay.totalPaid,
        months: withPrepay.schedule.length,
        schedule: withPrepay.schedule,
        interestWithoutPrepay: withoutPrepay.totalInterest,
        interestSaved,
      };
    }

    function readState(): SavedState {
      return {
        loanAmount: clamp(Number(loanAmountInput.value) || 0, 1000, 100_000_000),
        interestRate: clamp(Number(interestRateInput.value) || 0, 0, 30),
        tenureValue: clamp(Number(tenureValueInput.value) || 1, 1, 600),
        tenureUnit: tenureUnitSelect.value as 'years' | 'months',
        prepayment: Math.max(0, Number(prepaymentInput.value) || 0),
      };
    }

    function applyState(state: SavedState): void {
      loanAmountInput.value = String(state.loanAmount);
      interestRateInput.value = String(state.interestRate);
      tenureUnitSelect.value = state.tenureUnit;
      tenureValueInput.value = String(state.tenureValue);
      prepaymentInput.value = state.prepayment > 0 ? String(state.prepayment) : '';
    }

    function saveState(state: SavedState): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      } catch {
        /* ignore */
      }
    }

    function loadState(): SavedState {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { ...DEFAULTS };
        const parsed = JSON.parse(raw) as Partial<SavedState>;
        return {
          loanAmount:
            typeof parsed.loanAmount === 'number' && parsed.loanAmount > 0
              ? parsed.loanAmount
              : DEFAULTS.loanAmount,
          interestRate:
            typeof parsed.interestRate === 'number' && parsed.interestRate >= 0
              ? parsed.interestRate
              : DEFAULTS.interestRate,
          tenureValue:
            typeof parsed.tenureValue === 'number' && parsed.tenureValue > 0
              ? parsed.tenureValue
              : DEFAULTS.tenureValue,
          tenureUnit: parsed.tenureUnit === 'months' ? 'months' : 'years',
          prepayment:
            typeof parsed.prepayment === 'number' && parsed.prepayment >= 0
              ? parsed.prepayment
              : DEFAULTS.prepayment,
        };
      } catch {
        return { ...DEFAULTS };
      }
    }

    function renderSchedule(summary: LoanSummary): void {
      scheduleBody.innerHTML = '';

      const displayRows = summary.schedule.slice(0, 12);
      const totals = summary.schedule.reduce(
        (acc, row) => ({
          emi: acc.emi + row.emi,
          principal: acc.principal + row.principal,
          interest: acc.interest + row.interest,
          prepay: acc.prepay + row.prepay,
        }),
        { emi: 0, principal: 0, interest: 0, prepay: 0 }
      );

      displayRows.forEach((row) => {
        const tr = document.createElement('tr');
        tr.className = 'schedule-row';
        tr.innerHTML = `
          <td class="font-medium text-slate-300">${row.month}</td>
          <td class="text-right text-slate-400">${formatInr(Math.round(row.opening))}</td>
          <td class="text-right text-white">${formatInr(Math.round(row.emi))}</td>
          <td class="text-right text-emerald-400/90">${formatInr(Math.round(row.principal))}</td>
          <td class="text-right text-amber-400/90">${formatInr(Math.round(row.interest))}</td>
          <td class="text-right ${row.prepay > 0 ? 'font-semibold text-emerald-300' : 'text-slate-600'}">${row.prepay > 0 ? formatInr(Math.round(row.prepay)) : '—'}</td>
          <td class="text-right text-slate-300">${formatInr(Math.round(row.closing))}</td>
        `;
        scheduleBody.appendChild(tr);
      });

      if (summary.schedule.length > 12) {
        const ellipsis = document.createElement('tr');
        ellipsis.className = 'schedule-row';
        ellipsis.innerHTML = `
          <td colspan="7" class="py-3 text-center text-xs text-slate-500">
            … ${summary.schedule.length - 12} more months …
          </td>
        `;
        scheduleBody.appendChild(ellipsis);
      }

      const totalsRow = document.createElement('tr');
      totalsRow.className = 'schedule-totals';
      totalsRow.innerHTML = `
        <td class="text-emerald-300">Full loan totals</td>
        <td class="text-right text-slate-500">—</td>
        <td class="text-right text-white">${formatInr(Math.round(totals.emi))}</td>
        <td class="text-right text-emerald-400">${formatInr(Math.round(totals.principal))}</td>
        <td class="text-right text-amber-400">${formatInr(Math.round(totals.interest))}</td>
        <td class="text-right text-emerald-300">${totals.prepay > 0 ? formatInr(Math.round(totals.prepay)) : '—'}</td>
        <td class="text-right text-slate-500">—</td>
      `;
      scheduleBody.appendChild(totalsRow);
    }

    function renderResults(summary: LoanSummary | null, state: SavedState, months: number): void {
      if (!summary) {
        resultEmi.textContent = '₹0';
        resultInterest.textContent = '₹0';
        resultSaved.textContent = '₹0';
        resultMonths.textContent = '—';
        resultTotal.textContent = '₹0';
        loanNote.textContent = 'Enter valid loan details to calculate.';
        scheduleBody.innerHTML = `
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-sm text-slate-500">
              Enter loan details to generate the schedule.
            </td>
          </tr>
        `;
        return;
      }

      resultEmi.textContent = formatInr(Math.round(summary.emi));
      resultInterest.textContent = formatInr(Math.round(summary.totalInterest));
      resultSaved.textContent = formatInr(Math.round(summary.interestSaved));
      resultMonths.textContent = `${summary.months} mo`;
      resultTotal.textContent = formatInr(Math.round(summary.totalPaid));

      if (state.prepayment > 0) {
        loanNote.textContent = `₹${new Intl.NumberFormat('en-IN').format(state.prepayment)} prepayment after month 1 saves ${formatInr(Math.round(summary.interestSaved))} in interest.`;
      } else {
        loanNote.textContent = `${months}-month loan at ${state.interestRate}% p.a. — add a prepayment to see savings.`;
      }

      renderSchedule(summary);
    }

    function recalculate(): void {
      const state = readState();
      const months = tenureToMonths(state.tenureValue, state.tenureUnit);
      const summary = analyzeLoan(state.loanAmount, state.interestRate, months, state.prepayment);
      renderResults(summary, state, months);
      saveState(state);
    }

    [loanAmountInput, interestRateInput, tenureValueInput, prepaymentInput].forEach((el) => {
      el.addEventListener('input', recalculate);
    });
    tenureUnitSelect.addEventListener('change', recalculate);

    resetBtn.addEventListener('click', () => {
      applyState({ ...DEFAULTS });
      recalculate();
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    applyState(loadState());
    recalculate();
  </script>
</ToolsLayout>
