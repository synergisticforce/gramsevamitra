---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Meeting Cost Calculator';
const toolDescription =
  'Estimate the rupee cost of meetings by attendee count and average hourly salary — free, instant, and 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="money"
>
  <div class="meeting-cost">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/money')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Money &amp; Gig Ledger
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        See what a meeting really costs in salary time — runs entirely on your device.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="meeting-inputs-heading"
      >
        <h2 id="meeting-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Meeting details
        </h2>

        <div class="mt-5 space-y-6">
          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <label for="attendees" class="text-sm font-medium text-slate-300">Number of attendees</label>
              <input
                id="attendees"
                type="number"
                min="1"
                max="500"
                step="1"
                inputmode="numeric"
                class="input-field w-28 text-right tabular-nums"
              />
            </div>
            <input
              id="attendees-slider"
              type="range"
              min="1"
              max="50"
              step="1"
              class="w-full accent-emerald-500"
              aria-label="Attendees slider"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>1</span>
              <span>50</span>
            </div>
          </div>

          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <label for="hourly-salary" class="text-sm font-medium text-slate-300">Avg hourly salary (₹)</label>
              <input
                id="hourly-salary"
                type="number"
                min="0"
                max="100000"
                step="50"
                inputmode="decimal"
                class="input-field w-36 text-right tabular-nums sm:w-40"
              />
            </div>
            <input
              id="hourly-salary-slider"
              type="range"
              min="100"
              max="5000"
              step="50"
              class="w-full accent-emerald-500"
              aria-label="Hourly salary slider"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>₹100/hr</span>
              <span>₹5,000/hr</span>
            </div>
          </div>

          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <label for="duration" class="text-sm font-medium text-slate-300">Duration (minutes)</label>
              <input
                id="duration"
                type="number"
                min="1"
                max="480"
                step="1"
                inputmode="numeric"
                class="input-field w-28 text-right tabular-nums"
              />
            </div>
            <input
              id="duration-slider"
              type="range"
              min="15"
              max="180"
              step="15"
              class="w-full accent-emerald-500"
              aria-label="Duration slider"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>15 min</span>
              <span>180 min</span>
            </div>
          </div>
        </div>

        <button type="button" id="reset-meeting" class="btn-secondary mt-6 w-full text-sm">
          Reset to defaults
        </button>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="meeting-results-heading"
        aria-live="polite"
      >
        <h2 id="meeting-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Cost estimate
        </h2>

        <div class="mt-5 space-y-4">
          <div class="rounded-xl border border-emerald-800/40 bg-slate-950/50 px-4 py-5 text-center">
            <p class="text-xs font-medium uppercase tracking-wider text-slate-400">Total meeting cost</p>
            <p id="result-total" class="mt-1 text-3xl font-extrabold tabular-nums text-emerald-400 sm:text-4xl">
              ₹0
            </p>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Cost per minute</p>
              <p id="result-per-minute" class="mt-1 text-lg font-bold tabular-nums text-amber-400">₹0</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Person-hours</p>
              <p id="result-person-hours" class="mt-1 text-lg font-bold tabular-nums text-white">0</p>
            </div>
          </div>

          <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4">
            <dl class="space-y-2 text-sm">
              <div class="flex justify-between gap-3">
                <dt class="text-slate-400">Attendees × duration</dt>
                <dd id="result-breakdown" class="font-medium tabular-nums text-slate-300">—</dd>
              </div>
              <div class="flex justify-between gap-3">
                <dt class="text-slate-400">Hourly rate used</dt>
                <dd id="result-rate" class="font-medium tabular-nums text-slate-300">—</dd>
              </div>
            </dl>
          </div>

          <p id="meeting-note" class="text-center text-xs text-slate-500">
            Adjust meeting details to see the cost instantly.
          </p>
        </div>
      </section>
    </div>
  </div>

  <script>
    const STORAGE_KEY = 'gsm-tools:meeting-cost';

    const DEFAULTS = {
      attendees: 8,
      hourlySalary: 800,
      durationMinutes: 60,
    };

    interface SavedState {
      attendees: number;
      hourlySalary: number;
      durationMinutes: number;
    }

    interface MeetingResult {
      totalCost: number;
      costPerMinute: number;
      personHours: number;
    }

    const attendeesInput = document.getElementById('attendees') as HTMLInputElement;
    const attendeesSlider = document.getElementById('attendees-slider') as HTMLInputElement;
    const hourlySalaryInput = document.getElementById('hourly-salary') as HTMLInputElement;
    const hourlySalarySlider = document.getElementById('hourly-salary-slider') as HTMLInputElement;
    const durationInput = document.getElementById('duration') as HTMLInputElement;
    const durationSlider = document.getElementById('duration-slider') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-meeting') as HTMLButtonElement;

    const resultTotal = document.getElementById('result-total')!;
    const resultPerMinute = document.getElementById('result-per-minute')!;
    const resultPersonHours = document.getElementById('result-person-hours')!;
    const resultBreakdown = document.getElementById('result-breakdown')!;
    const resultRate = document.getElementById('result-rate')!;
    const meetingNote = document.getElementById('meeting-note')!;

    function formatInr(value: number): string {
      if (!Number.isFinite(value)) return '₹0';
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        maximumFractionDigits: 0,
      }).format(value);
    }

    function clamp(value: number, min: number, max: number): number {
      return Math.min(max, Math.max(min, value));
    }

    function calculate(attendees: number, hourlySalary: number, durationMinutes: number): MeetingResult | null {
      if (attendees <= 0 || hourlySalary < 0 || durationMinutes <= 0) return null;

      const hours = durationMinutes / 60;
      const personHours = attendees * hours;
      const totalCost = personHours * hourlySalary;
      const costPerMinute = totalCost / durationMinutes;

      return { totalCost, costPerMinute, personHours };
    }

    function readState(): SavedState {
      return {
        attendees: clamp(Math.round(Number(attendeesInput.value) || 0), 1, 500),
        hourlySalary: clamp(Number(hourlySalaryInput.value) || 0, 0, 100_000),
        durationMinutes: clamp(Math.round(Number(durationInput.value) || 0), 1, 480),
      };
    }

    function applyState(state: SavedState): void {
      attendeesInput.value = String(state.attendees);
      attendeesSlider.value = String(clamp(state.attendees, Number(attendeesSlider.min), Number(attendeesSlider.max)));
      hourlySalaryInput.value = String(state.hourlySalary);
      hourlySalarySlider.value = String(
        clamp(state.hourlySalary, Number(hourlySalarySlider.min), Number(hourlySalarySlider.max))
      );
      durationInput.value = String(state.durationMinutes);
      durationSlider.value = String(clamp(state.durationMinutes, Number(durationSlider.min), Number(durationSlider.max)));
    }

    function saveState(state: SavedState): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      } catch {
        /* ignore */
      }
    }

    function loadState(): SavedState {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { ...DEFAULTS };
        const parsed = JSON.parse(raw) as Partial<SavedState>;
        return {
          attendees:
            typeof parsed.attendees === 'number' && parsed.attendees > 0 ? parsed.attendees : DEFAULTS.attendees,
          hourlySalary:
            typeof parsed.hourlySalary === 'number' && parsed.hourlySalary >= 0
              ? parsed.hourlySalary
              : DEFAULTS.hourlySalary,
          durationMinutes:
            typeof parsed.durationMinutes === 'number' && parsed.durationMinutes > 0
              ? parsed.durationMinutes
              : DEFAULTS.durationMinutes,
        };
      } catch {
        return { ...DEFAULTS };
      }
    }

    function renderResults(result: MeetingResult | null, state: SavedState): void {
      if (!result) {
        resultTotal.textContent = '₹0';
        resultPerMinute.textContent = '₹0';
        resultPersonHours.textContent = '0';
        resultBreakdown.textContent = '—';
        resultRate.textContent = '—';
        meetingNote.textContent = 'Enter valid meeting details to calculate cost.';
        return;
      }

      resultTotal.textContent = formatInr(Math.round(result.totalCost));
      resultPerMinute.textContent = formatInr(Math.round(result.costPerMinute));
      resultPersonHours.textContent = result.personHours.toFixed(2);
      resultBreakdown.textContent = `${state.attendees} × ${state.durationMinutes} min`;
      resultRate.textContent = `${formatInr(state.hourlySalary)}/hr`;
      meetingNote.textContent = `${state.attendees} people in a ${state.durationMinutes}-minute meeting at ${formatInr(state.hourlySalary)}/hr each.`;
    }

    function recalculate(): void {
      const state = readState();
      const result = calculate(state.attendees, state.hourlySalary, state.durationMinutes);
      renderResults(result, state);
      saveState(state);
    }

    function bindDualControl(input: HTMLInputElement, slider: HTMLInputElement, onChange: () => void): void {
      input.addEventListener('input', () => {
        const val = Number(input.value);
        if (Number.isFinite(val)) {
          slider.value = String(clamp(val, Number(slider.min), Number(slider.max)));
        }
        onChange();
      });
      slider.addEventListener('input', () => {
        input.value = slider.value;
        onChange();
      });
    }

    bindDualControl(attendeesInput, attendeesSlider, recalculate);
    bindDualControl(hourlySalaryInput, hourlySalarySlider, recalculate);
    bindDualControl(durationInput, durationSlider, recalculate);

    resetBtn.addEventListener('click', () => {
      applyState({ ...DEFAULTS });
      recalculate();
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    applyState(loadState());
    recalculate();
  </script>
</ToolsLayout>
