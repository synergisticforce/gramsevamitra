---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'EMI Calculator';
const toolDescription =
  'Calculate monthly loan EMI, total interest, and repayment amount — free, instant, and 100% offline in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="money"
>
  <div class="emi-calculator">
    <header class="mb-6">
      <a href="/tools/money" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Money &amp; Gig Ledger
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Standard amortization formula — your numbers never leave this device.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Input panel -->
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="emi-inputs-heading"
      >
        <h2 id="emi-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Loan details
        </h2>

        <div class="mt-5 space-y-6">
          <!-- Loan amount -->
          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <label for="loan-amount" class="text-sm font-medium text-slate-300">Loan amount (₹)</label>
              <input
                id="loan-amount"
                type="number"
                min="1000"
                max="100000000"
                step="1000"
                inputmode="numeric"
                class="input-field w-36 text-right tabular-nums sm:w-40"
                aria-describedby="loan-amount-slider"
              />
            </div>
            <input
              id="loan-amount-slider"
              type="range"
              min="100000"
              max="10000000"
              step="10000"
              class="w-full accent-emerald-500"
              aria-label="Loan amount slider"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>₹1L</span>
              <span>₹1Cr</span>
            </div>
          </div>

          <!-- Interest rate -->
          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <label for="interest-rate" class="text-sm font-medium text-slate-300">Interest rate (% p.a.)</label>
              <input
                id="interest-rate"
                type="number"
                min="0"
                max="30"
                step="0.05"
                inputmode="decimal"
                class="input-field w-36 text-right tabular-nums sm:w-40"
                aria-describedby="interest-rate-slider"
              />
            </div>
            <input
              id="interest-rate-slider"
              type="range"
              min="0"
              max="24"
              step="0.1"
              class="w-full accent-emerald-500"
              aria-label="Interest rate slider"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>0%</span>
              <span>24%</span>
            </div>
          </div>

          <!-- Tenure -->
          <div>
            <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
              <label for="tenure-value" class="text-sm font-medium text-slate-300">Loan tenure</label>
              <div class="flex items-center gap-2">
                <input
                  id="tenure-value"
                  type="number"
                  min="1"
                  max="600"
                  step="1"
                  inputmode="numeric"
                  class="input-field w-20 text-right tabular-nums"
                  aria-describedby="tenure-slider tenure-unit"
                />
                <select id="tenure-unit" class="select-field w-28 py-2 text-sm" aria-label="Tenure unit">
                  <option value="years">Years</option>
                  <option value="months">Months</option>
                </select>
              </div>
            </div>
            <input
              id="tenure-slider"
              type="range"
              min="1"
              max="30"
              step="1"
              class="w-full accent-emerald-500"
              aria-label="Loan tenure slider"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span id="tenure-min-label">1 yr</span>
              <span id="tenure-max-label">30 yr</span>
            </div>
          </div>
        </div>

        <button type="button" id="reset-emi" class="btn-secondary mt-6 w-full text-sm">
          Reset to defaults
        </button>
      </section>

      <!-- Results panel -->
      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="emi-results-heading"
        aria-live="polite"
      >
        <h2 id="emi-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Your results
        </h2>

        <div class="mt-5 space-y-4">
          <div class="rounded-xl border border-emerald-800/40 bg-slate-950/50 px-4 py-5 text-center">
            <p class="text-xs font-medium uppercase tracking-wider text-slate-400">Monthly EMI</p>
            <p id="result-emi" class="mt-1 text-3xl font-extrabold tabular-nums text-emerald-400 sm:text-4xl">
              ₹0
            </p>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Total interest</p>
              <p id="result-interest" class="mt-1 text-lg font-bold tabular-nums text-amber-400">₹0</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Total amount</p>
              <p id="result-total" class="mt-1 text-lg font-bold tabular-nums text-white">₹0</p>
            </div>
          </div>

          <!-- Principal vs interest breakdown -->
          <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4">
            <div class="mb-2 flex items-center justify-between text-xs">
              <span class="font-medium text-slate-400">Payment breakdown</span>
              <span id="breakdown-ratio" class="tabular-nums text-slate-500">—</span>
            </div>

            <div
              class="flex h-4 w-full overflow-hidden rounded-full bg-slate-800"
              role="img"
              aria-labelledby="breakdown-legend"
            >
              <div
                id="bar-principal"
                class="h-full bg-emerald-500 transition-all duration-300 ease-out"
                style="width: 50%"
              ></div>
              <div
                id="bar-interest"
                class="h-full bg-amber-500 transition-all duration-300 ease-out"
                style="width: 50%"
              ></div>
            </div>

            <ul id="breakdown-legend" class="mt-3 grid grid-cols-2 gap-2 text-xs">
              <li class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 shrink-0 rounded-full bg-emerald-500" aria-hidden="true"></span>
                <span class="text-slate-400">Principal</span>
                <span id="legend-principal" class="ml-auto font-semibold tabular-nums text-emerald-400">₹0</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 shrink-0 rounded-full bg-amber-500" aria-hidden="true"></span>
                <span class="text-slate-400">Interest</span>
                <span id="legend-interest" class="ml-auto font-semibold tabular-nums text-amber-400">₹0</span>
              </li>
            </ul>
          </div>

          <p id="result-note" class="text-center text-xs text-slate-500">
            Adjust loan details to see your EMI instantly.
          </p>
        </div>
      </section>
    </div>
  </div>

  <script>
    const STORAGE_KEY = 'gsm-tools:emi-calculator';

    const DEFAULTS = {
      loanAmount: 2500000,
      interestRate: 8.5,
      tenureValue: 20,
      tenureUnit: 'years' as 'years' | 'months',
    };

    interface SavedState {
      loanAmount: number;
      interestRate: number;
      tenureValue: number;
      tenureUnit: 'years' | 'months';
    }

    interface EmiResult {
      emi: number;
      totalPayment: number;
      totalInterest: number;
      principal: number;
      principalPct: number;
      interestPct: number;
    }

    const loanAmountInput = document.getElementById('loan-amount') as HTMLInputElement;
    const loanAmountSlider = document.getElementById('loan-amount-slider') as HTMLInputElement;
    const interestRateInput = document.getElementById('interest-rate') as HTMLInputElement;
    const interestRateSlider = document.getElementById('interest-rate-slider') as HTMLInputElement;
    const tenureValueInput = document.getElementById('tenure-value') as HTMLInputElement;
    const tenureUnitSelect = document.getElementById('tenure-unit') as HTMLSelectElement;
    const tenureSlider = document.getElementById('tenure-slider') as HTMLInputElement;
    const tenureMinLabel = document.getElementById('tenure-min-label')!;
    const tenureMaxLabel = document.getElementById('tenure-max-label')!;
    const resetBtn = document.getElementById('reset-emi') as HTMLButtonElement;

    const resultEmi = document.getElementById('result-emi')!;
    const resultInterest = document.getElementById('result-interest')!;
    const resultTotal = document.getElementById('result-total')!;
    const resultNote = document.getElementById('result-note')!;
    const breakdownRatio = document.getElementById('breakdown-ratio')!;
    const barPrincipal = document.getElementById('bar-principal') as HTMLDivElement;
    const barInterest = document.getElementById('bar-interest') as HTMLDivElement;
    const legendPrincipal = document.getElementById('legend-principal')!;
    const legendInterest = document.getElementById('legend-interest')!;

    function formatInr(value: number): string {
      if (!Number.isFinite(value)) return '₹0';
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        maximumFractionDigits: 0,
      }).format(value);
    }

    function clamp(value: number, min: number, max: number): number {
      return Math.min(max, Math.max(min, value));
    }

    function tenureToMonths(value: number, unit: 'years' | 'months'): number {
      const months = unit === 'years' ? value * 12 : value;
      return Math.round(clamp(months, 1, 600));
    }

    function syncTenureSliderBounds(): void {
      const unit = tenureUnitSelect.value as 'years' | 'months';
      if (unit === 'years') {
        tenureSlider.min = '1';
        tenureSlider.max = '30';
        tenureSlider.step = '1';
        tenureMinLabel.textContent = '1 yr';
        tenureMaxLabel.textContent = '30 yr';
      } else {
        tenureSlider.min = '6';
        tenureSlider.max = '360';
        tenureSlider.step = '6';
        tenureMinLabel.textContent = '6 mo';
        tenureMaxLabel.textContent = '360 mo';
      }
    }

    /**
     * E = P * r * (1 + r)^n / ((1 + r)^n - 1)
     * P = principal, r = monthly rate (decimal), n = months
     */
    function calculateEmi(principal: number, annualRatePct: number, months: number): EmiResult | null {
      if (principal <= 0 || months <= 0 || annualRatePct < 0) return null;

      const P = principal;
      const n = months;
      let emi: number;

      if (annualRatePct === 0) {
        emi = P / n;
      } else {
        const r = annualRatePct / 12 / 100;
        const compound = Math.pow(1 + r, n);
        emi = (P * r * compound) / (compound - 1);
      }

      if (!Number.isFinite(emi) || emi <= 0) return null;

      const totalPayment = emi * n;
      const totalInterest = Math.max(0, totalPayment - P);
      const principalPct = totalPayment > 0 ? (P / totalPayment) * 100 : 50;
      const interestPct = totalPayment > 0 ? (totalInterest / totalPayment) * 100 : 50;

      return {
        emi,
        totalPayment,
        totalInterest,
        principal: P,
        principalPct,
        interestPct,
      };
    }

    function readState(): SavedState {
      return {
        loanAmount: clamp(Number(loanAmountInput.value) || 0, 1000, 100_000_000),
        interestRate: clamp(Number(interestRateInput.value) || 0, 0, 30),
        tenureValue: clamp(Number(tenureValueInput.value) || 1, 1, 600),
        tenureUnit: tenureUnitSelect.value as 'years' | 'months',
      };
    }

    function applyState(state: SavedState): void {
      loanAmountInput.value = String(state.loanAmount);
      loanAmountSlider.value = String(clamp(state.loanAmount, Number(loanAmountSlider.min), Number(loanAmountSlider.max)));
      interestRateInput.value = String(state.interestRate);
      interestRateSlider.value = String(clamp(state.interestRate, Number(interestRateSlider.min), Number(interestRateSlider.max)));
      tenureUnitSelect.value = state.tenureUnit;
      syncTenureSliderBounds();
      tenureValueInput.value = String(state.tenureValue);
      tenureSlider.value = String(
        clamp(state.tenureValue, Number(tenureSlider.min), Number(tenureSlider.max))
      );
    }

    function saveState(state: SavedState): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      } catch {
        /* quota / private mode — ignore */
      }
    }

    function loadState(): SavedState {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { ...DEFAULTS };
        const parsed = JSON.parse(raw) as Partial<SavedState>;
        return {
          loanAmount:
            typeof parsed.loanAmount === 'number' && parsed.loanAmount > 0
              ? parsed.loanAmount
              : DEFAULTS.loanAmount,
          interestRate:
            typeof parsed.interestRate === 'number' && parsed.interestRate >= 0
              ? parsed.interestRate
              : DEFAULTS.interestRate,
          tenureValue:
            typeof parsed.tenureValue === 'number' && parsed.tenureValue > 0
              ? parsed.tenureValue
              : DEFAULTS.tenureValue,
          tenureUnit: parsed.tenureUnit === 'months' ? 'months' : 'years',
        };
      } catch {
        return { ...DEFAULTS };
      }
    }

    function renderResults(result: EmiResult | null, months: number): void {
      if (!result) {
        resultEmi.textContent = '₹0';
        resultInterest.textContent = '₹0';
        resultTotal.textContent = '₹0';
        legendPrincipal.textContent = '₹0';
        legendInterest.textContent = '₹0';
        breakdownRatio.textContent = '—';
        barPrincipal.style.width = '50%';
        barInterest.style.width = '50%';
        resultNote.textContent = 'Enter valid loan details to calculate EMI.';
        return;
      }

      resultEmi.textContent = formatInr(Math.round(result.emi));
      resultInterest.textContent = formatInr(Math.round(result.totalInterest));
      resultTotal.textContent = formatInr(Math.round(result.totalPayment));
      legendPrincipal.textContent = formatInr(Math.round(result.principal));
      legendInterest.textContent = formatInr(Math.round(result.totalInterest));
      breakdownRatio.textContent = `${result.principalPct.toFixed(0)}% / ${result.interestPct.toFixed(0)}%`;
      barPrincipal.style.width = `${result.principalPct}%`;
      barInterest.style.width = `${result.interestPct}%`;

      const unit = tenureUnitSelect.value === 'years' ? 'year' : 'month';
      const tenureDisplay = tenureUnitSelect.value === 'years' ? months / 12 : months;
      const tenureWord = tenureDisplay === 1 ? unit : `${unit}s`;
      resultNote.textContent = `Over ${tenureDisplay} ${tenureWord} (${months} months) at ${interestRateInput.value}% p.a.`;
    }

    function recalculate(): void {
      const state = readState();
      const months = tenureToMonths(state.tenureValue, state.tenureUnit);
      const result = calculateEmi(state.loanAmount, state.interestRate, months);
      renderResults(result, months);
      saveState(state);
    }

    function bindDualControl(
      input: HTMLInputElement,
      slider: HTMLInputElement,
      onChange: () => void
    ): void {
      input.addEventListener('input', () => {
        const val = Number(input.value);
        if (Number.isFinite(val)) {
          slider.value = String(clamp(val, Number(slider.min), Number(slider.max)));
        }
        onChange();
      });
      slider.addEventListener('input', () => {
        input.value = slider.value;
        onChange();
      });
    }

    bindDualControl(loanAmountInput, loanAmountSlider, recalculate);
    bindDualControl(interestRateInput, interestRateSlider, recalculate);

    tenureValueInput.addEventListener('input', () => {
      const val = Number(tenureValueInput.value);
      if (Number.isFinite(val)) {
        tenureSlider.value = String(clamp(val, Number(tenureSlider.min), Number(tenureSlider.max)));
      }
      recalculate();
    });

    tenureSlider.addEventListener('input', () => {
      tenureValueInput.value = tenureSlider.value;
      recalculate();
    });

    tenureUnitSelect.addEventListener('change', () => {
      syncTenureSliderBounds();
      const val = Number(tenureValueInput.value);
      tenureSlider.value = String(clamp(val, Number(tenureSlider.min), Number(tenureSlider.max)));
      recalculate();
    });

    resetBtn.addEventListener('click', () => {
      applyState({ ...DEFAULTS });
      recalculate();
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    applyState(loadState());
    recalculate();
  </script>
</ToolsLayout>
