---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import EmiCalculatorTool from '../../../components/tools/EmiCalculatorTool';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'EMI Calculator';
const toolDescription =
  'Calculate monthly loan EMI, total interest, prepayments, and full amortization — free, instant, and 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="money"
>
  <div>
    <header class="mb-6">
      <a href={utilitiesHref('/tools/money')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Money &amp; Gig Ledger
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Advanced loan analysis with prepayments, charts, and sortable amortization — your numbers never leave this device.
      </p>
    </header>
    <EmiCalculatorTool client:load />
  </div>
</ToolsLayout>
