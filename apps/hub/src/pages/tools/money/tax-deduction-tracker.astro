---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Tax Deduction Tracker';
const toolDescription =
  'Log deductible expenses for year-end tax planning — stored locally on your device, 100% offline.';
const CATEGORIES = [
  '80C (PPF, ELSS, LIC)',
  '80D (Health Insurance)',
  'HRA / Rent',
  'Home Loan Interest',
  'NPS (80CCD)',
  'Education Loan (80E)',
  'Donations (80G)',
  'Professional Expenses',
  'Other',
] as const;
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="money"
>
  <div class="tax-deduction-tracker">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/money')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Money &amp; Gig Ledger
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Track deductions through the year — data stays in your browser via localStorage.
      </p>
    </header>

    <div class="mb-5 rounded-2xl border border-emerald-900/40 bg-emerald-950/20 px-4 py-3 sm:px-5">
      <p class="text-xs font-semibold uppercase tracking-wider text-emerald-400/80">Year-to-date total</p>
      <p id="ytd-total" class="mt-1 text-2xl font-extrabold tabular-nums text-emerald-400">₹0</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="deduction-form-heading"
      >
        <h2 id="deduction-form-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Add deduction
        </h2>

        <form id="deduction-form" class="mt-5 space-y-4">
          <label class="block min-w-0">
            <span class="mb-2 block text-sm font-medium text-slate-300">Category</span>
            <select id="entry-category" class="select-field w-full py-2.5 text-sm" required>
              {CATEGORIES.map((cat) => (
                <option value={cat}>{cat}</option>
              ))}
            </select>
          </label>

          <label class="block min-w-0">
            <span class="mb-2 block text-sm font-medium text-slate-300">Amount (₹)</span>
            <input
              id="entry-amount"
              type="number"
              min="0"
              step="1"
              inputmode="decimal"
              required
              placeholder="0"
              class="input-field w-full tabular-nums"
            />
          </label>

          <label class="block min-w-0">
            <span class="mb-2 block text-sm font-medium text-slate-300">Date</span>
            <input id="entry-date" type="date" required class="input-field w-full" />
          </label>

          <label class="block min-w-0">
            <span class="mb-2 block text-sm font-medium text-slate-300">Note <span class="text-slate-500">(optional)</span></span>
            <input
              id="entry-note"
              type="text"
              placeholder="e.g. PPF deposit, policy number"
              class="input-field w-full"
              autocomplete="off"
            />
          </label>

          <button type="submit" class="btn-primary w-full text-sm">Add entry</button>
        </form>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="breakdown-heading"
        aria-live="polite"
      >
        <h2 id="breakdown-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Category breakdown
        </h2>

        <ul id="category-breakdown" class="mt-5 space-y-2">
          <li class="text-sm text-slate-500">No entries yet — add your first deduction.</li>
        </ul>
      </section>
    </div>

    <section class="mt-6 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40" aria-labelledby="entries-heading">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-800 bg-slate-950/60 px-4 py-3 sm:px-5">
        <h2 id="entries-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          All entries
        </h2>
        <button type="button" id="export-csv" class="export-btn" disabled>Download CSV</button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[560px] text-left text-sm">
          <thead class="border-b border-slate-800 bg-slate-950/40 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
            <tr>
              <th class="px-4 py-3">Date</th>
              <th class="px-4 py-3">Category</th>
              <th class="px-4 py-3">Note</th>
              <th class="px-4 py-3 text-right">Amount</th>
              <th class="px-4 py-3 text-right"><span class="sr-only">Delete</span></th>
            </tr>
          </thead>
          <tbody id="entries-body">
            <tr id="entries-empty">
              <td colspan="5" class="px-4 py-8 text-center text-sm text-slate-500">
                No deductions logged yet.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <style>
    .entry-row td {
      @apply border-b border-slate-800/80 px-4 py-3 align-middle;
    }
    .entry-row:last-child td {
      @apply border-b-0;
    }
    .breakdown-row {
      @apply flex items-center justify-between gap-3 rounded-lg border border-slate-800/80 bg-slate-950/40 px-3 py-2.5 text-sm;
    }
    .export-btn {
      @apply rounded-lg border border-emerald-700/60 bg-emerald-950/40 px-3 py-1.5 text-xs font-semibold text-emerald-400 transition hover:border-emerald-500 hover:bg-emerald-900/40 hover:text-emerald-300 focus:outline-none focus:ring-2 focus:ring-emerald-400 disabled:cursor-not-allowed disabled:opacity-40;
    }
  </style>

  <script>
    import { buildCsv, downloadCsv } from '../../../lib/export/toolExport';
    const STORAGE_KEY = 'gsm-tools:tax-deductions';

    interface DeductionEntry {
      id: string;
      category: string;
      amount: number;
      date: string;
      note: string;
    }

    const form = document.getElementById('deduction-form') as HTMLFormElement;
    const categoryInput = document.getElementById('entry-category') as HTMLSelectElement;
    const amountInput = document.getElementById('entry-amount') as HTMLInputElement;
    const dateInput = document.getElementById('entry-date') as HTMLInputElement;
    const noteInput = document.getElementById('entry-note') as HTMLInputElement;
    const ytdTotalEl = document.getElementById('ytd-total')!;
    const categoryBreakdown = document.getElementById('category-breakdown')!;
    const entriesBody = document.getElementById('entries-body')!;
    const exportCsvBtn = document.getElementById('export-csv') as HTMLButtonElement;

    let entries: DeductionEntry[] = [];

    function createId(): string {
      return `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    }

    function formatInr(value: number): string {
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        maximumFractionDigits: 0,
      }).format(value);
    }

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function formatDisplayDate(iso: string): string {
      const d = new Date(iso + 'T12:00:00');
      if (Number.isNaN(d.getTime())) return iso;
      return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function currentYear(): number {
      return new Date().getFullYear();
    }

    function ytdEntries(): DeductionEntry[] {
      const year = currentYear();
      return entries.filter((e) => {
        const d = new Date(e.date + 'T12:00:00');
        return d.getFullYear() === year;
      });
    }

    function saveEntries(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
      } catch {
        /* ignore */
      }
    }

    function loadEntries(): DeductionEntry[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw) as DeductionEntry[];
        if (!Array.isArray(parsed)) return [];
        return parsed
          .filter((e) => e && typeof e.id === 'string')
          .map((e) => ({
            id: e.id,
            category: String(e.category ?? 'Other'),
            amount: Number(e.amount) || 0,
            date: String(e.date ?? ''),
            note: String(e.note ?? ''),
          }));
      } catch {
        return [];
      }
    }

    function categoryTotals(ytd: DeductionEntry[]): Map<string, number> {
      const map = new Map<string, number>();
      ytd.forEach((e) => {
        map.set(e.category, (map.get(e.category) ?? 0) + e.amount);
      });
      return map;
    }

    function renderBreakdown(ytd: DeductionEntry[]): void {
      categoryBreakdown.innerHTML = '';

      if (ytd.length === 0) {
        categoryBreakdown.innerHTML =
          '<li class="text-sm text-slate-500">No entries yet — add your first deduction.</li>';
        return;
      }

      const totals = categoryTotals(ytd);
      const sorted = [...totals.entries()].sort((a, b) => b[1] - a[1]);
      const ytdSum = ytd.reduce((s, e) => s + e.amount, 0);

      sorted.forEach(([category, amount]) => {
        const pct = ytdSum > 0 ? (amount / ytdSum) * 100 : 0;
        const li = document.createElement('li');
        li.className = 'breakdown-row';
        li.innerHTML = `
          <div class="min-w-0 flex-1">
            <p class="truncate font-medium text-slate-200">${escapeHtml(category)}</p>
            <div class="mt-1 h-1.5 w-full overflow-hidden rounded-full bg-slate-800">
              <div class="h-full rounded-full bg-emerald-500" style="width: ${pct.toFixed(1)}%"></div>
            </div>
          </div>
          <span class="shrink-0 font-semibold tabular-nums text-emerald-400">${escapeHtml(formatInr(amount))}</span>
        `;
        categoryBreakdown.appendChild(li);
      });
    }

    function renderTable(): void {
      entriesBody.innerHTML = '';

      if (entries.length === 0) {
        entriesBody.innerHTML = `
          <tr id="entries-empty">
            <td colspan="5" class="px-4 py-8 text-center text-sm text-slate-500">
              No deductions logged yet.
            </td>
          </tr>
        `;
        return;
      }

      const sorted = [...entries].sort((a, b) => b.date.localeCompare(a.date));

      sorted.forEach((entry) => {
        const tr = document.createElement('tr');
        tr.className = 'entry-row';
        tr.dataset.id = entry.id;
        tr.innerHTML = `
          <td class="whitespace-nowrap text-slate-300">${escapeHtml(formatDisplayDate(entry.date))}</td>
          <td class="max-w-[160px] truncate text-white">${escapeHtml(entry.category)}</td>
          <td class="max-w-[180px] truncate text-slate-400">${entry.note ? escapeHtml(entry.note) : '—'}</td>
          <td class="text-right font-semibold tabular-nums text-emerald-400">${escapeHtml(formatInr(entry.amount))}</td>
          <td class="text-right">
            <button type="button" class="entry-delete rounded-lg px-2 py-1 text-xs text-slate-500 transition hover:bg-rose-950/50 hover:text-rose-400" aria-label="Delete entry">✕</button>
          </td>
        `;
        entriesBody.appendChild(tr);
      });
    }

    function render(): void {
      const ytd = ytdEntries();
      const total = ytd.reduce((s, e) => s + e.amount, 0);
      ytdTotalEl.textContent = formatInr(total);
      renderBreakdown(ytd);
      renderTable();
      exportCsvBtn.disabled = entries.length === 0;
    }

    exportCsvBtn.addEventListener('click', () => {
      if (entries.length === 0) return;
      const sorted = [...entries].sort((a, b) => b.date.localeCompare(a.date));
      const content = buildCsv(
        ['Date', 'Category', 'Note', 'Amount (₹)'],
        sorted.map((e) => [e.date, e.category, e.note, e.amount]),
      );
      downloadCsv('tax-deductions', content);
      const original = exportCsvBtn.textContent;
      exportCsvBtn.textContent = 'Downloaded!';
      setTimeout(() => {
        exportCsvBtn.textContent = original ?? 'Download CSV';
      }, 2000);
    });

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const category = categoryInput.value;
      const amount = parseFloat(amountInput.value);
      const date = dateInput.value;
      const note = noteInput.value.trim();

      if (!category || !date || !Number.isFinite(amount) || amount <= 0) return;

      entries.push({ id: createId(), category, amount, date, note });
      saveEntries();
      render();

      amountInput.value = '';
      noteInput.value = '';
      amountInput.focus();
    });

    entriesBody.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const btn = target.closest('.entry-delete');
      if (!btn) return;
      const row = btn.closest<HTMLElement>('tr');
      const id = row?.dataset.id;
      if (!id) return;
      entries = entries.filter((e) => e.id !== id);
      saveEntries();
      render();
    });

    dateInput.value = new Date().toISOString().slice(0, 10);
    entries = loadEntries();
    render();
  </script>
</ToolsLayout>
