---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import ToolGridCard from '../../../components/tools/ToolGridCard.astro';
import { getWorkspaceMeta, getWorkspaceTools } from '../../../config/toolsRegistry';
import { getToolsForSegment, WORKSPACE_SEGMENT_DEFS } from '../../../config/workspaceSegments';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const workspace = getWorkspaceMeta('money');
const calculatorTools = getWorkspaceTools('money');
const moneySegmentDefs = WORKSPACE_SEGMENT_DEFS.money.filter((s) => s.id !== 'all');
---

<ToolsLayout
  title={formatSeoTitle(workspace.label, 'Free Offline Tools')}
  description={workspace.description}
  activeNav="money"
>
  <div class="money-dashboard">
    <!-- Dashboard mode switcher -->
    <div class="mb-6" role="tablist" aria-label="Money dashboard sections">
      <div class="inline-flex w-full max-w-md rounded-lg bg-slate-100 p-1">
        <button
          type="button"
          role="tab"
          id="tab-calculators"
          class="dashboard-segment flex-1 rounded-md px-3 py-2 text-center text-xs font-semibold transition sm:text-sm"
          data-tab="calculators"
          aria-selected="true"
          aria-controls="panel-calculators"
        >
          Calculators
        </button>
        <button
          type="button"
          role="tab"
          id="tab-gig"
          class="dashboard-segment flex-1 rounded-md px-3 py-2 text-center text-xs font-semibold transition sm:text-sm"
          data-tab="gig"
          aria-selected="false"
          aria-controls="panel-gig"
        >
          Gig Income
        </button>
        <button
          type="button"
          role="tab"
          id="tab-envelope"
          class="dashboard-segment flex-1 rounded-md px-3 py-2 text-center text-xs font-semibold transition sm:text-sm"
          data-tab="envelope"
          aria-selected="false"
          aria-controls="panel-envelope"
        >
          Envelope Budget
        </button>
      </div>
    </div>

    <!-- Tab 1: Quick Calculators -->
    <section
      id="panel-calculators"
      role="tabpanel"
      aria-labelledby="tab-calculators"
      class="dashboard-panel"
      data-panel="calculators"
    >
      <p class="mb-4 text-sm text-slate-600">
        {calculatorTools.length} offline calculators for loans, tips, invoices, and more.
      </p>
      {
        moneySegmentDefs.map((segment) => {
          const tools = getToolsForSegment('money', segment.id);
          if (tools.length === 0) return null;
          return (
            <div id={segment.id} class="scroll-mt-24 not-first:mt-8">
              <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">{segment.label}</h2>
              <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {tools.map((tool) => (
                  <ToolGridCard tool={tool} />
                ))}
              </div>
            </div>
          );
        })
      }
    </section>

    <!-- Tab 2: Gig Income Tracker -->
    <section
      id="panel-gig"
      role="tabpanel"
      aria-labelledby="tab-gig"
      class="dashboard-panel hidden"
      data-panel="gig"
    >
      <div class="rounded-2xl border border-emerald-900/40 bg-emerald-950/20 px-4 py-3 sm:px-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-emerald-400/80">This month</p>
        <p id="gig-month-total" class="mt-1 text-2xl font-extrabold tabular-nums text-emerald-400">₹0</p>
      </div>

      <form id="gig-form" class="mt-5 rounded-2xl border border-slate-800 bg-slate-900/60 p-4 sm:p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Log gig income</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <label class="min-w-0">
            <span class="label">Date</span>
            <input id="gig-date" type="date" required class="input-field w-full" />
          </label>
          <label class="min-w-0 sm:col-span-2">
            <span class="label">Source</span>
            <input
              id="gig-source"
              type="text"
              required
              placeholder="e.g. Swiggy, freelance client"
              class="input-field w-full"
              autocomplete="off"
            />
          </label>
          <label class="min-w-0">
            <span class="label">Amount (₹)</span>
            <input
              id="gig-amount"
              type="number"
              required
              min="0"
              step="1"
              inputmode="decimal"
              placeholder="0"
              class="input-field w-full tabular-nums"
            />
          </label>
        </div>
        <button type="submit" class="btn-primary mt-4 w-full text-sm sm:w-auto">Add entry</button>
      </form>

      <div class="mt-5 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[520px] text-left text-sm">
            <thead class="border-b border-slate-800 bg-slate-950/60 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
              <tr>
                <th class="px-4 py-3">Date</th>
                <th class="px-4 py-3">Source</th>
                <th class="px-4 py-3 text-right">Amount</th>
                <th class="px-4 py-3 text-right"><span class="sr-only">Remove</span></th>
              </tr>
            </thead>
            <tbody id="gig-table-body">
              <tr id="gig-empty-row">
                <td colspan="4" class="px-4 py-8 text-center text-sm text-slate-500">
                  No gig income logged yet. Add your first entry above.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Tab 3: Envelope Budget -->
    <section
      id="panel-envelope"
      role="tabpanel"
      aria-labelledby="tab-envelope"
      class="dashboard-panel hidden"
      data-panel="envelope"
    >
      <div class="rounded-2xl border border-amber-900/40 bg-amber-950/20 px-4 py-3 sm:px-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-amber-400/80">Total monthly budget</p>
        <p id="envelope-total" class="mt-1 text-2xl font-extrabold tabular-nums text-amber-400">₹0</p>
      </div>

      <form id="envelope-form" class="mt-5 rounded-2xl border border-slate-800 bg-slate-900/60 p-4 sm:p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Add envelope</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <label class="min-w-0">
            <span class="label">Envelope name</span>
            <input
              id="envelope-name"
              type="text"
              required
              placeholder="e.g. Groceries, Rent, EMIs"
              class="input-field w-full"
              autocomplete="off"
            />
          </label>
          <label class="min-w-0">
            <span class="label">Budget (₹)</span>
            <input
              id="envelope-amount"
              type="number"
              required
              min="0"
              step="1"
              inputmode="decimal"
              placeholder="0"
              class="input-field w-full tabular-nums"
            />
          </label>
        </div>
        <button type="submit" class="btn-primary mt-4 w-full text-sm sm:w-auto">Add envelope</button>
      </form>

      <div class="mt-5 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[400px] text-left text-sm">
            <thead class="border-b border-slate-800 bg-slate-950/60 text-[10px] font-semibold uppercase tracking-wider text-slate-500">
              <tr>
                <th class="px-4 py-3">Envelope</th>
                <th class="px-4 py-3 text-right">Budget</th>
                <th class="px-4 py-3 text-right"><span class="sr-only">Remove</span></th>
              </tr>
            </thead>
            <tbody id="envelope-table-body">
              <tr id="envelope-empty-row">
                <td colspan="3" class="px-4 py-8 text-center text-sm text-slate-500">
                  No envelopes yet. Create categories for rent, food, savings, and more.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </div>

  <style>
    .dashboard-segment {
      @apply text-slate-600 hover:text-slate-900;
    }
    .dashboard-segment[aria-selected='true'] {
      @apply bg-white text-slate-900 shadow-sm;
    }
    .data-row td {
      @apply border-b border-slate-800/80 px-4 py-3 align-middle;
    }
    .data-row:last-child td {
      @apply border-b-0;
    }
  </style>

  <script>
    const GIG_STORAGE_KEY = 'gsm-tools:money-gig-income';
    const ENVELOPE_STORAGE_KEY = 'gsm-tools:money-envelope-budget';
    const TAB_STORAGE_KEY = 'gsm-tools:money-dashboard-tab';

    type TabId = 'calculators' | 'gig' | 'envelope';

    interface GigEntry {
      id: string;
      date: string;
      source: string;
      amount: number;
    }

    interface EnvelopeEntry {
      id: string;
      name: string;
      amount: number;
    }

    const tabButtons = document.querySelectorAll<HTMLButtonElement>('.dashboard-segment');
    const panels = document.querySelectorAll<HTMLElement>('.dashboard-panel');

    const gigForm = document.getElementById('gig-form') as HTMLFormElement;
    const gigDate = document.getElementById('gig-date') as HTMLInputElement;
    const gigSource = document.getElementById('gig-source') as HTMLInputElement;
    const gigAmount = document.getElementById('gig-amount') as HTMLInputElement;
    const gigTableBody = document.getElementById('gig-table-body')!;
    const gigMonthTotal = document.getElementById('gig-month-total')!;

    const envelopeForm = document.getElementById('envelope-form') as HTMLFormElement;
    const envelopeName = document.getElementById('envelope-name') as HTMLInputElement;
    const envelopeAmount = document.getElementById('envelope-amount') as HTMLInputElement;
    const envelopeTableBody = document.getElementById('envelope-table-body')!;
    const envelopeTotalEl = document.getElementById('envelope-total')!;

    let gigEntries: GigEntry[] = [];
    let envelopeEntries: EnvelopeEntry[] = [];

    function createId(): string {
      return `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    }

    function formatInr(value: number): string {
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        maximumFractionDigits: 0,
      }).format(value);
    }

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function formatDisplayDate(iso: string): string {
      const d = new Date(iso + 'T12:00:00');
      if (Number.isNaN(d.getTime())) return iso;
      return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function switchTab(tabId: TabId): void {
      tabButtons.forEach((btn) => {
        const active = btn.dataset.tab === tabId;
        btn.setAttribute('aria-selected', String(active));
      });
      panels.forEach((panel) => {
        const show = panel.dataset.panel === tabId;
        panel.classList.toggle('hidden', !show);
      });
      try {
        localStorage.setItem(TAB_STORAGE_KEY, tabId);
      } catch {
        /* ignore */
      }
    }

    function loadTab(): TabId {
      try {
        const saved = localStorage.getItem(TAB_STORAGE_KEY);
        if (saved === 'gig' || saved === 'envelope' || saved === 'calculators') return saved;
      } catch {
        /* ignore */
      }
      return 'calculators';
    }

    function saveGig(): void {
      try {
        localStorage.setItem(GIG_STORAGE_KEY, JSON.stringify(gigEntries));
      } catch {
        /* ignore */
      }
    }

    function loadGig(): GigEntry[] {
      try {
        const raw = localStorage.getItem(GIG_STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw) as GigEntry[];
        if (!Array.isArray(parsed)) return [];
        return parsed
          .filter((e) => e && typeof e.id === 'string')
          .map((e) => ({
            id: e.id,
            date: String(e.date ?? ''),
            source: String(e.source ?? ''),
            amount: Number(e.amount) || 0,
          }));
      } catch {
        return [];
      }
    }

    function saveEnvelopes(): void {
      try {
        localStorage.setItem(ENVELOPE_STORAGE_KEY, JSON.stringify(envelopeEntries));
      } catch {
        /* ignore */
      }
    }

    function loadEnvelopes(): EnvelopeEntry[] {
      try {
        const raw = localStorage.getItem(ENVELOPE_STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw) as EnvelopeEntry[];
        if (!Array.isArray(parsed)) return [];
        return parsed
          .filter((e) => e && typeof e.id === 'string')
          .map((e) => ({
            id: e.id,
            name: String(e.name ?? ''),
            amount: Number(e.amount) || 0,
          }));
      } catch {
        return [];
      }
    }

    function monthTotal(entries: GigEntry[]): number {
      const now = new Date();
      const year = now.getFullYear();
      const month = now.getMonth();
      return entries
        .filter((e) => {
          const d = new Date(e.date + 'T12:00:00');
          return d.getFullYear() === year && d.getMonth() === month;
        })
        .reduce((sum, e) => sum + e.amount, 0);
    }

    function renderGigTable(): void {
      gigTableBody.innerHTML = '';

      if (gigEntries.length === 0) {
        gigTableBody.innerHTML = `
          <tr id="gig-empty-row">
            <td colspan="4" class="px-4 py-8 text-center text-sm text-slate-500">
              No gig income logged yet. Add your first entry above.
            </td>
          </tr>
        `;
        gigMonthTotal.textContent = formatInr(0);
        return;
      }

      const sorted = [...gigEntries].sort((a, b) => b.date.localeCompare(a.date));

      sorted.forEach((entry) => {
        const tr = document.createElement('tr');
        tr.className = 'data-row';
        tr.dataset.id = entry.id;
        tr.innerHTML = `
          <td class="whitespace-nowrap text-slate-300">${escapeHtml(formatDisplayDate(entry.date))}</td>
          <td class="max-w-[200px] truncate text-white">${escapeHtml(entry.source)}</td>
          <td class="text-right font-semibold tabular-nums text-emerald-400">${escapeHtml(formatInr(entry.amount))}</td>
          <td class="text-right">
            <button type="button" class="gig-delete rounded-lg px-2 py-1 text-xs text-slate-500 transition hover:bg-rose-950/50 hover:text-rose-400" aria-label="Delete entry">✕</button>
          </td>
        `;
        gigTableBody.appendChild(tr);
      });

      gigMonthTotal.textContent = formatInr(monthTotal(gigEntries));
    }

    function renderEnvelopeTable(): void {
      envelopeTableBody.innerHTML = '';

      if (envelopeEntries.length === 0) {
        envelopeTableBody.innerHTML = `
          <tr id="envelope-empty-row">
            <td colspan="3" class="px-4 py-8 text-center text-sm text-slate-500">
              No envelopes yet. Create categories for rent, food, savings, and more.
            </td>
          </tr>
        `;
        envelopeTotalEl.textContent = formatInr(0);
        return;
      }

      let total = 0;
      envelopeEntries.forEach((entry) => {
        total += entry.amount;
        const tr = document.createElement('tr');
        tr.className = 'data-row';
        tr.dataset.id = entry.id;
        tr.innerHTML = `
          <td class="font-medium text-white">${escapeHtml(entry.name)}</td>
          <td class="text-right font-semibold tabular-nums text-amber-400">${escapeHtml(formatInr(entry.amount))}</td>
          <td class="text-right">
            <button type="button" class="envelope-delete rounded-lg px-2 py-1 text-xs text-slate-500 transition hover:bg-rose-950/50 hover:text-rose-400" aria-label="Remove envelope">✕</button>
          </td>
        `;
        envelopeTableBody.appendChild(tr);
      });

      envelopeTotalEl.textContent = formatInr(total);
    }

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab as TabId;
        if (tab) switchTab(tab);
      });
    });

    gigForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const date = gigDate.value;
      const source = gigSource.value.trim();
      const amount = parseFloat(gigAmount.value);
      if (!date || !source || !Number.isFinite(amount) || amount < 0) return;

      gigEntries.push({ id: createId(), date, source, amount });
      saveGig();
      renderGigTable();

      gigSource.value = '';
      gigAmount.value = '';
      gigSource.focus();
    });

    gigTableBody.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const btn = target.closest('.gig-delete');
      if (!btn) return;
      const row = btn.closest<HTMLElement>('tr');
      const id = row?.dataset.id;
      if (!id) return;
      gigEntries = gigEntries.filter((e) => e.id !== id);
      saveGig();
      renderGigTable();
    });

    envelopeForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const name = envelopeName.value.trim();
      const amount = parseFloat(envelopeAmount.value);
      if (!name || !Number.isFinite(amount) || amount < 0) return;

      envelopeEntries.push({ id: createId(), name, amount });
      saveEnvelopes();
      renderEnvelopeTable();

      envelopeName.value = '';
      envelopeAmount.value = '';
      envelopeName.focus();
    });

    envelopeTableBody.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const btn = target.closest('.envelope-delete');
      if (!btn) return;
      const row = btn.closest<HTMLElement>('tr');
      const id = row?.dataset.id;
      if (!id) return;
      envelopeEntries = envelopeEntries.filter((e) => e.id !== id);
      saveEnvelopes();
      renderEnvelopeTable();
    });

    gigDate.value = new Date().toISOString().slice(0, 10);
    gigEntries = loadGig();
    envelopeEntries = loadEnvelopes();
    renderGigTable();
    renderEnvelopeTable();
    switchTab(loadTab());
  </script>
</ToolsLayout>
