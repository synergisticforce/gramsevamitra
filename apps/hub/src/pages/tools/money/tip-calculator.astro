---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Tip & Split Calculator';
const toolDescription =
  'Split restaurant bills and calculate tips per person — free, instant, and 100% offline in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="money"
>
  <div class="tip-calculator">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/money')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Money &amp; Gig Ledger
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Split the bill fairly — your numbers never leave this device.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="tip-inputs-heading"
      >
        <h2 id="tip-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Bill details
        </h2>

        <div class="mt-5 space-y-6">
          <div>
            <label for="bill-amount" class="mb-2 block text-sm font-medium text-slate-300">Bill amount (₹)</label>
            <input
              id="bill-amount"
              type="number"
              min="0"
              step="1"
              inputmode="decimal"
              placeholder="1500"
              class="input-field w-full tabular-nums"
            />
          </div>

          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <label for="tip-percent" class="text-sm font-medium text-slate-300">Tip percentage</label>
              <span id="tip-percent-display" class="text-sm font-bold tabular-nums text-emerald-400">10%</span>
            </div>
            <input
              id="tip-percent"
              type="range"
              min="0"
              max="30"
              step="1"
              value="10"
              class="w-full accent-emerald-500"
              aria-label="Tip percentage slider"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>0%</span>
              <span>30%</span>
            </div>
            <div class="mt-2 flex flex-wrap gap-2">
              {[5, 10, 15, 20].map((pct) => (
                <button type="button" class="tip-preset" data-tip={pct}>
                  {pct}%
                </button>
              ))}
            </div>
          </div>

          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <label for="people-count" class="text-sm font-medium text-slate-300">Number of people</label>
              <span id="people-display" class="text-sm font-bold tabular-nums text-emerald-400">2</span>
            </div>
            <input
              id="people-count"
              type="range"
              min="1"
              max="20"
              step="1"
              value="2"
              class="w-full accent-emerald-500"
              aria-label="Number of people slider"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>1</span>
              <span>20</span>
            </div>
          </div>
        </div>

        <button type="button" id="reset-tip" class="btn-secondary mt-6 w-full text-sm">
          Reset to defaults
        </button>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="tip-results-heading"
        aria-live="polite"
      >
        <h2 id="tip-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Split summary
        </h2>

        <div class="mt-5 space-y-4">
          <div class="rounded-xl border border-emerald-800/40 bg-slate-950/50 px-4 py-5 text-center">
            <p class="text-xs font-medium uppercase tracking-wider text-slate-400">Per person</p>
            <p id="result-per-person" class="mt-1 text-3xl font-extrabold tabular-nums text-emerald-400 sm:text-4xl">
              ₹0
            </p>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Total tip</p>
              <p id="result-tip" class="mt-1 text-lg font-bold tabular-nums text-amber-400">₹0</p>
            </div>
            <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-3 py-4">
              <p class="text-[10px] font-medium uppercase tracking-wider text-slate-500">Total bill</p>
              <p id="result-total" class="mt-1 text-lg font-bold tabular-nums text-white">₹0</p>
            </div>
          </div>

          <div class="rounded-xl border border-slate-800 bg-slate-950/40 px-4 py-4">
            <dl class="space-y-2 text-sm">
              <div class="flex justify-between gap-2">
                <dt class="text-slate-400">Subtotal (bill)</dt>
                <dd id="result-subtotal" class="font-semibold tabular-nums text-slate-200">₹0</dd>
              </div>
              <div class="flex justify-between gap-2">
                <dt class="text-slate-400">Tip (<span id="result-tip-pct">0</span>%)</dt>
                <dd id="result-tip-line" class="font-semibold tabular-nums text-amber-300">₹0</dd>
              </div>
              <div class="flex justify-between gap-2 border-t border-slate-800 pt-2">
                <dt class="font-medium text-slate-300">Grand total</dt>
                <dd id="result-grand" class="font-bold tabular-nums text-white">₹0</dd>
              </div>
              <div class="flex justify-between gap-2">
                <dt class="text-slate-400">Split among</dt>
                <dd id="result-people" class="font-semibold tabular-nums text-emerald-400">—</dd>
              </div>
            </dl>
          </div>

          <p id="tip-note" class="text-center text-xs text-slate-500">
            Enter a bill amount to calculate the split.
          </p>
        </div>
      </section>
    </div>
  </div>

  <style>
    .tip-preset {
      @apply rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-1.5 text-xs font-semibold text-slate-300 transition hover:border-emerald-600 hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:tip-calculator';

    const DEFAULTS = {
      billAmount: 1500,
      tipPercent: 10,
      people: 2,
    };

    interface SavedState {
      billAmount: number;
      tipPercent: number;
      people: number;
    }

    interface TipResult {
      subtotal: number;
      tipAmount: number;
      grandTotal: number;
      perPerson: number;
      tipPercent: number;
      people: number;
    }

    const billInput = document.getElementById('bill-amount') as HTMLInputElement;
    const tipSlider = document.getElementById('tip-percent') as HTMLInputElement;
    const tipDisplay = document.getElementById('tip-percent-display')!;
    const peopleSlider = document.getElementById('people-count') as HTMLInputElement;
    const peopleDisplay = document.getElementById('people-display')!;
    const resetBtn = document.getElementById('reset-tip') as HTMLButtonElement;

    const resultPerPerson = document.getElementById('result-per-person')!;
    const resultTip = document.getElementById('result-tip')!;
    const resultTotal = document.getElementById('result-total')!;
    const resultSubtotal = document.getElementById('result-subtotal')!;
    const resultTipLine = document.getElementById('result-tip-line')!;
    const resultTipPct = document.getElementById('result-tip-pct')!;
    const resultGrand = document.getElementById('result-grand')!;
    const resultPeople = document.getElementById('result-people')!;
    const tipNote = document.getElementById('tip-note')!;

    function formatInr(value: number): string {
      if (!Number.isFinite(value)) return '₹0';
      return new Intl.NumberFormat('en-IN', {
        style: 'currency',
        currency: 'INR',
        maximumFractionDigits: 2,
        minimumFractionDigits: 0,
      }).format(value);
    }

    function clamp(value: number, min: number, max: number): number {
      return Math.min(max, Math.max(min, value));
    }

    function calculateTip(bill: number, tipPct: number, people: number): TipResult | null {
      if (bill <= 0 || people < 1) return null;

      const subtotal = bill;
      const tipAmount = subtotal * (tipPct / 100);
      const grandTotal = subtotal + tipAmount;
      const perPerson = grandTotal / people;

      return {
        subtotal,
        tipAmount,
        grandTotal,
        perPerson,
        tipPercent: tipPct,
        people,
      };
    }

    function readState(): SavedState {
      return {
        billAmount: Math.max(0, Number(billInput.value) || 0),
        tipPercent: clamp(Number(tipSlider.value) || 0, 0, 30),
        people: clamp(Number(peopleSlider.value) || 1, 1, 20),
      };
    }

    function applyState(state: SavedState): void {
      billInput.value = state.billAmount > 0 ? String(state.billAmount) : '';
      tipSlider.value = String(state.tipPercent);
      peopleSlider.value = String(state.people);
      tipDisplay.textContent = `${state.tipPercent}%`;
      peopleDisplay.textContent = String(state.people);
    }

    function saveState(state: SavedState): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      } catch {
        /* ignore */
      }
    }

    function loadState(): SavedState {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { ...DEFAULTS };
        const parsed = JSON.parse(raw) as Partial<SavedState>;
        return {
          billAmount:
            typeof parsed.billAmount === 'number' && parsed.billAmount >= 0
              ? parsed.billAmount
              : DEFAULTS.billAmount,
          tipPercent:
            typeof parsed.tipPercent === 'number' && parsed.tipPercent >= 0
              ? clamp(parsed.tipPercent, 0, 30)
              : DEFAULTS.tipPercent,
          people:
            typeof parsed.people === 'number' && parsed.people >= 1
              ? clamp(parsed.people, 1, 20)
              : DEFAULTS.people,
        };
      } catch {
        return { ...DEFAULTS };
      }
    }

    function renderResults(result: TipResult | null): void {
      if (!result) {
        resultPerPerson.textContent = '₹0';
        resultTip.textContent = '₹0';
        resultTotal.textContent = '₹0';
        resultSubtotal.textContent = '₹0';
        resultTipLine.textContent = '₹0';
        resultTipPct.textContent = '0';
        resultGrand.textContent = '₹0';
        resultPeople.textContent = '—';
        tipNote.textContent = 'Enter a bill amount to calculate the split.';
        return;
      }

      resultPerPerson.textContent = formatInr(result.perPerson);
      resultTip.textContent = formatInr(result.tipAmount);
      resultTotal.textContent = formatInr(result.grandTotal);
      resultSubtotal.textContent = formatInr(result.subtotal);
      resultTipLine.textContent = formatInr(result.tipAmount);
      resultTipPct.textContent = String(result.tipPercent);
      resultGrand.textContent = formatInr(result.grandTotal);
      resultPeople.textContent = `${result.people} ${result.people === 1 ? 'person' : 'people'}`;
      tipNote.textContent = `Each person pays ${formatInr(result.perPerson)} (bill + ${result.tipPercent}% tip).`;
    }

    function recalculate(): void {
      const state = readState();
      tipDisplay.textContent = `${state.tipPercent}%`;
      peopleDisplay.textContent = String(state.people);
      const result = state.billAmount > 0 ? calculateTip(state.billAmount, state.tipPercent, state.people) : null;
      renderResults(result);
      saveState(state);
    }

    billInput.addEventListener('input', recalculate);
    tipSlider.addEventListener('input', recalculate);
    peopleSlider.addEventListener('input', recalculate);

    document.querySelectorAll<HTMLButtonElement>('.tip-preset').forEach((btn) => {
      btn.addEventListener('click', () => {
        const pct = Number(btn.dataset.tip);
        if (Number.isFinite(pct)) {
          tipSlider.value = String(pct);
          recalculate();
        }
      });
    });

    resetBtn.addEventListener('click', () => {
      applyState({ ...DEFAULTS });
      recalculate();
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    applyState(loadState());
    recalculate();
  </script>
</ToolsLayout>
