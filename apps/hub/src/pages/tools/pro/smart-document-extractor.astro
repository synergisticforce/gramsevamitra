---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import SmartDocumentExtractorTool from '../../../components/pro/SmartDocumentExtractorTool';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Smart Document Extractor';
const toolDescription =
  'Pro-only AI pipeline — extract invoices and bank statements to JSON/CSV, or high-fidelity DOCX via the Smart Router.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Pro AI Tool')}
  description={toolDescription}
  activeNav="home"
  hideWorkspaceNav={true}
>
  <header class="mb-6">
    <a
      href={utilitiesHref('/tools')}
      class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800"
    >
      ← Utilities hub
    </a>
    <div class="mt-3 flex items-start gap-2">
      <span class="rounded-full bg-slate-900 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-white">
        ⚡ Pro
      </span>
      <div>
        <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
        <p class="mt-1 text-sm text-slate-600">{toolDescription}</p>
      </div>
    </div>
  </header>

  <SmartDocumentExtractorTool client:load />
</ToolsLayout>
