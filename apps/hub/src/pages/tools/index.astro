---
import ToolsLayout from '../../layouts/ToolsLayout.astro';
import IntentCard from '../../components/tools/IntentCard.astro';
import { INTENT_WORKSPACES, WORKSPACES } from '../../config/toolsRegistry';
import { formatSeoTitle } from '@shared/config/seo';
import { SITES } from '@shared/config/sites';

const lifeWorkspace = WORKSPACES.find((w) => w.id === 'life')!;
const quickWorkspace = WORKSPACES.find((w) => w.id === 'quick')!;
---

<ToolsLayout
  title={formatSeoTitle('Free Offline Utility Hub for', 'Students & Gig Workers')}
  description="40+ free browser tools for money tracking, writing, career prep, wellness, and quick calculators — zero uploads, built for rural India."
  activeNav="home"
>
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/20 via-slate-950 to-slate-950"
    >
    </div>

    <div class="relative">
      <p
        class="mb-3 inline-flex items-center rounded-full border border-emerald-800/60 bg-emerald-950/50 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-300"
      >
        100% Free · Client-Side · No Server
      </p>
      <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Utilities <span class="text-emerald-400">Super-App</span>
      </h1>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate-400">
        One hub for money ledgers, study writing, career prep, and quick calculators. Every tool runs in your browser
        — your data stays on your device.
      </p>
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Choose your workspace</h2>
    <div class="mt-4 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {INTENT_WORKSPACES.map((workspace) => <IntentCard workspace={workspace} />)}
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <a
      href={lifeWorkspace.path}
      class="group flex items-center gap-4 rounded-2xl border border-slate-800 bg-slate-900/40 p-4 transition hover:border-emerald-800/60 hover:bg-slate-900/70"
    >
      <span class="text-2xl" aria-hidden="true">{lifeWorkspace.emoji}</span>
      <div class="min-w-0 flex-1">
        <p class="font-semibold text-white group-hover:text-emerald-300">{lifeWorkspace.label}</p>
        <p class="mt-0.5 truncate text-xs text-slate-400">Pomodoro, habits, BMI &amp; private wellness</p>
      </div>
      <span class="text-emerald-400">→</span>
    </a>
    <a
      href={quickWorkspace.path}
      class="group flex items-center gap-4 rounded-2xl border border-slate-800 bg-slate-900/40 p-4 transition hover:border-emerald-800/60 hover:bg-slate-900/70"
    >
      <span class="text-2xl" aria-hidden="true">{quickWorkspace.emoji}</span>
      <div class="min-w-0 flex-1">
        <p class="font-semibold text-white group-hover:text-emerald-300">{quickWorkspace.label}</p>
        <p class="mt-0.5 truncate text-xs text-slate-400">QR, passwords, converters &amp; more</p>
      </div>
      <span class="text-emerald-400">→</span>
    </a>
  </section>

  <section class="mt-10 rounded-2xl border border-emerald-900/40 bg-emerald-950/20 p-5 text-center sm:p-6">
    <p class="text-sm text-slate-300">
      Need to compress exam PDFs or merge certificates?
      <a
        href={SITES.pdf.url}
        class="ml-1 font-semibold text-emerald-400 underline decoration-emerald-600 underline-offset-2 hover:text-emerald-300"
      >
        Open the PDF Tools Hub →
      </a>
    </p>
  </section>
</ToolsLayout>
