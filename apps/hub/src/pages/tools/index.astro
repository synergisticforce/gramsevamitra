---
import ToolsLayout from '../../layouts/ToolsLayout.astro';
import IntentCard from '../../components/tools/IntentCard.astro';
import ProFeatureTrigger from '../../components/billing/ProFeatureTrigger.astro';
import { INTENT_WORKSPACES, WORKSPACES } from '../../config/toolsRegistry';
import { formatSeoTitle } from '@shared/config/seo';
import { PRO_PRICE_LABEL, PRO_PRICE_INTERVAL } from '@shared/lib/proUpgrade';
import { SITES } from '@shared/config/sites';

const lifeWorkspace = WORKSPACES.find((w) => w.id === 'life')!;
const quickWorkspace = WORKSPACES.find((w) => w.id === 'quick')!;
---

<ToolsLayout
  title={formatSeoTitle('Free Offline Utility Hub for', 'Students & Gig Workers')}
  description="40+ free browser tools for money tracking, writing, career prep, wellness, and quick calculators — zero uploads, works worldwide."
  activeNav="home"
  hideWorkspaceNav={true}
>
  <section>
    <p
      class="mb-3 inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-800"
    >
      100% Free · Client-Side · No Server
    </p>
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      Utilities <span class="text-emerald-600">Super-App</span>
    </h1>
    <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate-600">
      One hub for money ledgers, study writing, career prep, and quick calculators. Every tool runs in your browser
      — your data stays on your device.
    </p>
  </section>

  <section class="mt-10">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Choose your workspace</h2>
    <div class="mt-4 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {INTENT_WORKSPACES.map((workspace) => <IntentCard workspace={workspace} />)}
    </div>
  </section>

  <section class="mt-10 rounded-2xl border border-amber-200 bg-gradient-to-br from-amber-50 to-white p-5 shadow-sm sm:p-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-amber-800">Serverless AI · Phase 4</p>
        <h2 class="mt-1 text-lg font-bold text-slate-900">Smart Document Extractor</h2>
        <p class="mt-1 max-w-xl text-sm text-slate-600">
          Extract invoices and bank statements to CSV/JSON with vision-language models — Pro only, from {PRO_PRICE_LABEL}{PRO_PRICE_INTERVAL}.
        </p>
      </div>
      <ProFeatureTrigger
        featureId="smart-document-extractor"
        featureName="Smart Document Extractor"
        featureDescription="Route image PDFs through our serverless AI pipeline — PaddleOCR, GLM-4V layout mapping, and high-fidelity DOCX export."
        class="shrink-0 self-start sm:self-center"
      />
    </div>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    <a
      href={lifeWorkspace.path}
      class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-emerald-300 hover:shadow-md"
    >
      <span class="text-2xl" aria-hidden="true">{lifeWorkspace.emoji}</span>
      <div class="min-w-0 flex-1">
        <p class="font-semibold text-slate-900 group-hover:text-emerald-800">{lifeWorkspace.label}</p>
        <p class="mt-0.5 truncate text-xs text-slate-600">Pomodoro, habits, BMI &amp; private wellness</p>
      </div>
      <span class="text-emerald-700">→</span>
    </a>
    <a
      href={quickWorkspace.path}
      class="group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-emerald-300 hover:shadow-md"
    >
      <span class="text-2xl" aria-hidden="true">{quickWorkspace.emoji}</span>
      <div class="min-w-0 flex-1">
        <p class="font-semibold text-slate-900 group-hover:text-emerald-800">{quickWorkspace.label}</p>
        <p class="mt-0.5 truncate text-xs text-slate-600">QR, passwords, converters &amp; more</p>
      </div>
      <span class="text-emerald-700">→</span>
    </a>
  </section>

  <section class="mt-10 rounded-2xl border border-emerald-200 bg-emerald-50/80 p-5 text-center sm:p-6">
    <p class="text-sm text-slate-700">
      Need to compress PDFs or merge documents?
      <a
        href={SITES.pdf.url}
        data-astro-reload
        class="ml-1 font-semibold text-emerald-800 underline decoration-emerald-300 underline-offset-2 hover:text-emerald-900"
      >
        Open the PDF Tools Hub →
      </a>
    </p>
  </section>
</ToolsLayout>
