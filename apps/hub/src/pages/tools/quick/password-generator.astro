---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Password Generator';
const toolDescription =
  'Generate cryptographically strong random passwords with custom length and character sets — 100% offline in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="password-generator">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">Secure random passwords — generated locally, never sent anywhere.</p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="pw-options-heading"
      >
        <h2 id="pw-options-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Options
        </h2>

        <div class="mt-5 space-y-6">
          <label class="block">
            <div class="mb-2 flex items-center justify-between">
              <span class="text-sm font-medium text-slate-300">Length</span>
              <span id="length-label" class="text-sm font-bold tabular-nums text-emerald-400">16</span>
            </div>
            <input
              id="pw-length"
              type="range"
              min="8"
              max="64"
              value="16"
              class="w-full accent-emerald-500"
              aria-describedby="length-label"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>8</span>
              <span>64</span>
            </div>
          </label>

          <fieldset class="space-y-3">
            <legend class="text-sm font-medium text-slate-300">Character sets</legend>
            <label class="flex cursor-pointer items-center gap-3">
              <input id="charset-upper" type="checkbox" checked class="h-4 w-4 accent-emerald-500" />
              <span class="text-sm text-slate-300">Uppercase (A–Z)</span>
            </label>
            <label class="flex cursor-pointer items-center gap-3">
              <input id="charset-lower" type="checkbox" checked class="h-4 w-4 accent-emerald-500" />
              <span class="text-sm text-slate-300">Lowercase (a–z)</span>
            </label>
            <label class="flex cursor-pointer items-center gap-3">
              <input id="charset-numbers" type="checkbox" checked class="h-4 w-4 accent-emerald-500" />
              <span class="text-sm text-slate-300">Numbers (0–9)</span>
            </label>
            <label class="flex cursor-pointer items-center gap-3">
              <input id="charset-special" type="checkbox" checked class="h-4 w-4 accent-emerald-500" />
              <span class="text-sm text-slate-300">Special (!@#$%^&amp;*)</span>
            </label>
          </fieldset>

          <p id="pw-error" class="hidden text-xs text-rose-400" role="alert"></p>
        </div>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="pw-output-heading"
      >
        <h2 id="pw-output-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Your password
        </h2>

        <div class="mt-5">
          <div
            id="pw-output"
            class="break-all rounded-xl border border-slate-700 bg-slate-950/80 px-4 py-4 font-mono text-sm leading-relaxed text-white sm:text-base"
            aria-live="polite"
          >
            —
          </div>
          <p id="pw-feedback" class="mt-2 min-h-[1rem] text-center text-xs text-emerald-400" role="status"></p>
          <button type="button" id="pw-copy" class="btn-primary mt-4 w-full" disabled>Copy to clipboard</button>
        </div>
      </section>
    </div>
  </div>

  <script>
    const CHARSETS = {
      upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lower: 'abcdefghijklmnopqrstuvwxyz',
      numbers: '0123456789',
      special: '!@#$%^&*()-_=+[]{}|;:,.<>?',
    };

    const lengthInput = document.getElementById('pw-length') as HTMLInputElement;
    const lengthLabel = document.getElementById('length-label')!;
    const upperCheck = document.getElementById('charset-upper') as HTMLInputElement;
    const lowerCheck = document.getElementById('charset-lower') as HTMLInputElement;
    const numbersCheck = document.getElementById('charset-numbers') as HTMLInputElement;
    const specialCheck = document.getElementById('charset-special') as HTMLInputElement;
    const outputEl = document.getElementById('pw-output')!;
    const errorEl = document.getElementById('pw-error')!;
    const feedbackEl = document.getElementById('pw-feedback')!;
    const copyBtn = document.getElementById('pw-copy') as HTMLButtonElement;

    function buildPool(): string {
      let pool = '';
      if (upperCheck.checked) pool += CHARSETS.upper;
      if (lowerCheck.checked) pool += CHARSETS.lower;
      if (numbersCheck.checked) pool += CHARSETS.numbers;
      if (specialCheck.checked) pool += CHARSETS.special;
      return pool;
    }

    function secureRandomInt(max: number): number {
      if (max <= 0) return 0;
      const limit = Math.floor(256 / max) * max;
      const buf = new Uint8Array(1);
      let value = 0;
      do {
        crypto.getRandomValues(buf);
        value = buf[0];
      } while (value >= limit);
      return value % max;
    }

    function generatePassword(length: number, pool: string): string {
      const chars: string[] = [];
      for (let i = 0; i < length; i++) {
        chars.push(pool[secureRandomInt(pool.length)]);
      }
      return chars.join('');
    }

    function ensureCharsetCoverage(password: string[], pool: string, requiredSets: string[]): void {
      for (const set of requiredSets) {
        if (!password.some((ch) => set.includes(ch))) {
          const idx = secureRandomInt(password.length);
          password[idx] = set[secureRandomInt(set.length)];
        }
      }
    }

    function regenerate(): void {
      feedbackEl.textContent = '';
      const length = Number(lengthInput.value);
      lengthLabel.textContent = String(length);

      const requiredSets: string[] = [];
      if (upperCheck.checked) requiredSets.push(CHARSETS.upper);
      if (lowerCheck.checked) requiredSets.push(CHARSETS.lower);
      if (numbersCheck.checked) requiredSets.push(CHARSETS.numbers);
      if (specialCheck.checked) requiredSets.push(CHARSETS.special);

      const pool = buildPool();
      if (!pool) {
        errorEl.textContent = 'Select at least one character set.';
        errorEl.classList.remove('hidden');
        outputEl.textContent = '—';
        copyBtn.disabled = true;
        return;
      }

      errorEl.classList.add('hidden');
      const chars = generatePassword(length, pool).split('');
      ensureCharsetCoverage(chars, pool, requiredSets);
      const password = chars.join('');

      outputEl.textContent = password;
      copyBtn.disabled = false;
    }

    async function copyPassword(): Promise<void> {
      const password = outputEl.textContent;
      if (!password || password === '—') return;

      try {
        await navigator.clipboard.writeText(password);
        feedbackEl.textContent = 'Copied to clipboard.';
      } catch {
        feedbackEl.textContent = 'Copy failed — select and copy manually.';
      }
    }

    [lengthInput, upperCheck, lowerCheck, numbersCheck, specialCheck].forEach((el) => {
      el.addEventListener('input', regenerate);
      el.addEventListener('change', regenerate);
    });

    copyBtn.addEventListener('click', () => {
      void copyPassword();
    });

    regenerate();
  </script>
</ToolsLayout>
