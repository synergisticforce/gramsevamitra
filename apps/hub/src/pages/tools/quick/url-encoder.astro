---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'URL Encoder / Decoder';
const toolDescription =
  'Encode and decode URLs and query strings with encodeURIComponent — safe error handling, 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="url-encoder">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">Percent-encoding for URLs — processed locally on your device.</p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
      aria-labelledby="url-heading"
    >
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <h2 id="url-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Text conversion
        </h2>
        <div class="mode-toggle" role="group" aria-label="Encode or decode mode">
          <button type="button" class="mode-btn" data-mode="encode" aria-pressed="true">Encode</button>
          <button type="button" class="mode-btn" data-mode="decode" aria-pressed="false">Decode</button>
        </div>
      </div>

      <label class="block">
        <span id="url-input-label" class="mb-1 block text-sm font-medium text-slate-300">Input</span>
        <textarea
          id="url-input"
          rows="5"
          class="input-field w-full resize-y font-mono text-sm"
          placeholder="https://example.com/search?q=hello world"
          spellcheck="false"
        ></textarea>
      </label>

      <label class="mt-4 block">
        <span class="mb-1 block text-sm font-medium text-emerald-400/90">Output</span>
        <textarea
          id="url-output"
          rows="5"
          readonly
          class="input-field w-full resize-y font-mono text-sm text-slate-300"
          placeholder="Output updates as you type…"
          spellcheck="false"
        ></textarea>
      </label>

      <p id="url-error" class="mt-2 hidden text-xs text-rose-400" role="alert"></p>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="url-copy" class="btn-primary flex-1 text-sm" disabled>Copy result</button>
        <button type="button" id="url-clear" class="btn-secondary text-sm">Clear</button>
      </div>
    </section>
  </div>

  <style>
    .mode-toggle {
      @apply inline-flex rounded-lg border border-slate-700 bg-slate-950/60 p-0.5;
    }
    .mode-btn {
      @apply rounded-md px-4 py-1.5 text-xs font-semibold text-slate-400 transition hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
    .mode-btn[aria-pressed='true'] {
      @apply bg-emerald-600 text-white shadow-sm;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:url-encoder';

    type Mode = 'encode' | 'decode';

    const modeBtns = document.querySelectorAll<HTMLButtonElement>('.mode-btn');
    const inputLabel = document.getElementById('url-input-label')!;
    const inputEl = document.getElementById('url-input') as HTMLTextAreaElement;
    const outputEl = document.getElementById('url-output') as HTMLTextAreaElement;
    const errorEl = document.getElementById('url-error')!;
    const copyBtn = document.getElementById('url-copy') as HTMLButtonElement;
    const clearBtn = document.getElementById('url-clear') as HTMLButtonElement;

    let mode: Mode = 'encode';

    function setMode(next: Mode): void {
      mode = next;
      modeBtns.forEach((btn) => {
        btn.setAttribute('aria-pressed', String(btn.dataset.mode === next));
      });
      inputLabel.textContent = next === 'encode' ? 'Plain text or URL' : 'Encoded URL / text';
      inputEl.placeholder =
        next === 'encode'
          ? 'https://example.com/search?q=hello world'
          : 'https%3A%2F%2Fexample.com%2Fsearch%3Fq%3Dhello%20world';
      convert();
      saveState();
    }

    function convert(): void {
      const input = inputEl.value;
      errorEl.classList.add('hidden');
      errorEl.textContent = '';
      outputEl.value = '';
      copyBtn.disabled = true;

      if (!input) {
        saveState();
        return;
      }

      try {
        outputEl.value = mode === 'encode' ? encodeURIComponent(input) : decodeURIComponent(input);
        copyBtn.disabled = false;
      } catch {
        errorEl.textContent =
          mode === 'decode'
            ? 'Malformed percent-encoding — check for invalid % sequences.'
            : 'Could not encode this input.';
        errorEl.classList.remove('hidden');
      }

      saveState();
    }

    function saveState(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ mode, input: inputEl.value }));
      } catch {
        /* ignore */
      }
    }

    function loadState(): void {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw) as { mode?: Mode; input?: string };
        if (parsed.mode === 'decode') mode = 'decode';
        modeBtns.forEach((btn) => {
          btn.setAttribute('aria-pressed', String(btn.dataset.mode === mode));
        });
        if (typeof parsed.input === 'string') inputEl.value = parsed.input;
      } catch {
        /* ignore */
      }
    }

    modeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = btn.dataset.mode as Mode;
        if (next) setMode(next);
      });
    });

    inputEl.addEventListener('input', convert);

    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      outputEl.value = '';
      errorEl.classList.add('hidden');
      copyBtn.disabled = true;
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    copyBtn.addEventListener('click', async () => {
      if (!outputEl.value) return;
      try {
        await navigator.clipboard.writeText(outputEl.value);
        const original = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.textContent = original;
        }, 2000);
      } catch {
        copyBtn.textContent = 'Copy failed';
        setTimeout(() => {
          copyBtn.textContent = 'Copy result';
        }, 2000);
      }
    });

    loadState();
    convert();
  </script>
</ToolsLayout>
