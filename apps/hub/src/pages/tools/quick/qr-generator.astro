---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'QR Code Generator';
const toolDescription =
  'Create QR codes for URLs, Wi-Fi, plain text, and more — generated instantly in your browser, no upload required.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="qr-generator">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Type any URL or text — your QR code updates live and never leaves this device.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Input panel -->
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="qr-input-heading"
      >
        <h2 id="qr-input-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Your content
        </h2>

        <div class="mt-5 space-y-4">
          <label for="qr-text" class="block">
            <span class="label">Text or URL</span>
            <textarea
              id="qr-text"
              rows="5"
              spellcheck="false"
              placeholder="https://gramsevamitra.com&#10;or any text, phone number, Wi-Fi string…"
              class="input-field min-h-[120px] resize-y leading-relaxed"
            ></textarea>
          </label>

          <p class="text-xs text-slate-500">
            Tip: Paste a full link including <code class="text-emerald-400/80">https://</code> for scannable web
            URLs.
          </p>

          <div class="flex flex-wrap gap-2">
            <button type="button" data-preset="https://gramsevamitra.com" class="preset-btn">
              gramsevamitra.com
            </button>
            <button type="button" data-preset="WIFI:T:WPA;S:MyNetwork;P:password;;" class="preset-btn">
              Wi-Fi sample
            </button>
            <button type="button" id="clear-qr" class="preset-btn border-slate-700 text-slate-400">
              Clear
            </button>
          </div>
        </div>
      </section>

      <!-- Output panel -->
      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="qr-output-heading"
        aria-live="polite"
      >
        <h2 id="qr-output-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          QR preview
        </h2>

        <div class="mt-5 flex flex-col items-center">
          <div
            id="qr-canvas-wrap"
            class="flex min-h-[280px] w-full max-w-[320px] items-center justify-center rounded-2xl border border-slate-700 bg-white p-4 shadow-inner"
          >
            <canvas id="qr-canvas" class="hidden max-w-full" width="280" height="280" aria-hidden="true"></canvas>
            <p id="qr-placeholder" class="px-4 text-center text-sm text-slate-500">
              Start typing to generate your QR code
            </p>
          </div>

          <p id="qr-status" class="mt-3 min-h-[1.25rem] text-center text-xs text-slate-400"></p>

          <button type="button" id="download-qr" class="btn-primary mt-5 w-full max-w-[320px]" disabled>
            Download QR Code (.png)
          </button>
        </div>
      </section>
    </div>
  </div>

  <style>
    .preset-btn {
      @apply rounded-lg border border-emerald-800/50 bg-emerald-950/30 px-3 py-1.5 text-xs font-medium text-emerald-300 transition hover:border-emerald-500 hover:bg-emerald-900/40 hover:text-white;
    }
  </style>

  <script>
    import QRCode from 'qrcode';

    const STORAGE_KEY = 'gsm-tools:qr-generator';
    const MAX_CHARS = 2048;

    const textInput = document.getElementById('qr-text') as HTMLTextAreaElement;
    const canvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
    const canvasWrap = document.getElementById('qr-canvas-wrap')!;
    const placeholder = document.getElementById('qr-placeholder')!;
    const statusEl = document.getElementById('qr-status')!;
    const downloadBtn = document.getElementById('download-qr') as HTMLButtonElement;
    const clearBtn = document.getElementById('clear-qr') as HTMLButtonElement;

    let renderToken = 0;
    let hasValidQr = false;

    function setDownloadEnabled(enabled: boolean): void {
      hasValidQr = enabled;
      downloadBtn.disabled = !enabled;
    }

    function showPlaceholder(message: string): void {
      canvas.classList.add('hidden');
      placeholder.classList.remove('hidden');
      placeholder.textContent = message;
      setDownloadEnabled(false);
    }

    function showCanvas(): void {
      placeholder.classList.add('hidden');
      canvas.classList.remove('hidden');
    }

    async function renderQr(text: string): Promise<void> {
      const token = ++renderToken;
      const trimmed = text.trim();

      if (!trimmed) {
        showPlaceholder('Start typing to generate your QR code');
        statusEl.textContent = '';
        return;
      }

      if (trimmed.length > MAX_CHARS) {
        showPlaceholder('Text is too long for a QR code');
        statusEl.textContent = `Maximum ${MAX_CHARS} characters.`;
        return;
      }

      statusEl.textContent = 'Generating…';

      try {
        await QRCode.toCanvas(canvas, trimmed, {
          width: 280,
          margin: 2,
          errorCorrectionLevel: 'M',
          color: {
            dark: '#000000',
            light: '#ffffff',
          },
        });

        if (token !== renderToken) return;

        showCanvas();
        statusEl.textContent = `${trimmed.length} character${trimmed.length === 1 ? '' : 's'} encoded`;
        setDownloadEnabled(true);
        saveText(trimmed);
      } catch (err) {
        if (token !== renderToken) return;
        showPlaceholder('Could not generate QR code');
        statusEl.textContent = err instanceof Error ? err.message : 'Invalid content for QR encoding.';
        setDownloadEnabled(false);
      }
    }

    function saveText(text: string): void {
      try {
        localStorage.setItem(STORAGE_KEY, text);
      } catch {
        /* ignore */
      }
    }

    function loadText(): string {
      try {
        return localStorage.getItem(STORAGE_KEY) ?? '';
      } catch {
        return '';
      }
    }

    function downloadPng(): void {
      if (!hasValidQr) return;

      const url = canvas.toDataURL('image/png');
      const link = document.createElement('a');
      const slug =
        textInput.value
          .trim()
          .slice(0, 32)
          .replace(/[^a-z0-9]+/gi, '-')
          .replace(/^-|-$/g, '')
          .toLowerCase() || 'qr-code';

      link.href = url;
      link.download = `${slug}.png`;
      link.click();
    }

    let debounceTimer: ReturnType<typeof setTimeout> | undefined;

    function scheduleRender(): void {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        void renderQr(textInput.value);
      }, 80);
    }

    textInput.addEventListener('input', scheduleRender);

    downloadBtn.addEventListener('click', downloadPng);

    clearBtn.addEventListener('click', () => {
      textInput.value = '';
      renderToken++;
      showPlaceholder('Start typing to generate your QR code');
      statusEl.textContent = '';
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    document.querySelectorAll<HTMLButtonElement>('.preset-btn[data-preset]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const preset = btn.getAttribute('data-preset');
        if (!preset) return;
        textInput.value = preset;
        textInput.focus();
        void renderQr(preset);
      });
    });

    const saved = loadText();
    if (saved) {
      textInput.value = saved;
      void renderQr(saved);
    } else {
      showPlaceholder('Start typing to generate your QR code');
    }
  </script>
</ToolsLayout>
