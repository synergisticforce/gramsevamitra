---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Base64 Encoder / Decoder';
const toolDescription =
  'Encode and decode text to Base64 instantly — UTF-8 safe, with error handling. 100% offline in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="base64-tool">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">Native Base64 conversion — your text never leaves this device.</p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
      aria-labelledby="b64-heading"
    >
      <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
        <h2 id="b64-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Input &amp; output
        </h2>
        <div class="mode-toggle" role="group" aria-label="Encode or decode mode">
          <button type="button" class="mode-btn" data-mode="encode" aria-pressed="true">Encode</button>
          <button type="button" class="mode-btn" data-mode="decode" aria-pressed="false">Decode</button>
        </div>
      </div>

      <label class="block">
        <span id="b64-input-label" class="mb-1 block text-sm font-medium text-slate-300">Plain text</span>
        <textarea
          id="b64-input"
          rows="6"
          class="input-field w-full resize-y font-mono text-sm"
          placeholder="Enter text to encode…"
          spellcheck="false"
        ></textarea>
      </label>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="b64-convert" class="btn-primary text-sm">Convert</button>
        <button type="button" id="b64-swap" class="btn-secondary text-sm">Use output as input</button>
        <button type="button" id="b64-clear" class="btn-secondary text-sm">Clear</button>
      </div>

      <label class="mt-5 block">
        <span class="mb-1 block text-sm font-medium text-emerald-400/90">Result</span>
        <textarea
          id="b64-output"
          rows="6"
          readonly
          class="input-field w-full resize-y font-mono text-sm text-slate-300"
          placeholder="Result appears here…"
          spellcheck="false"
        ></textarea>
      </label>

      <p id="b64-error" class="mt-2 hidden text-xs text-rose-400" role="alert"></p>

      <button type="button" id="b64-copy" class="btn-secondary mt-4 w-full text-sm" disabled>Copy result</button>
    </section>
  </div>

  <style>
    .mode-toggle {
      @apply inline-flex rounded-lg border border-slate-700 bg-slate-950/60 p-0.5;
    }
    .mode-btn {
      @apply rounded-md px-4 py-1.5 text-xs font-semibold text-slate-400 transition hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
    .mode-btn[aria-pressed='true'] {
      @apply bg-emerald-600 text-white shadow-sm;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:base64';

    type Mode = 'encode' | 'decode';

    const modeBtns = document.querySelectorAll<HTMLButtonElement>('.mode-btn');
    const inputLabel = document.getElementById('b64-input-label')!;
    const inputEl = document.getElementById('b64-input') as HTMLTextAreaElement;
    const outputEl = document.getElementById('b64-output') as HTMLTextAreaElement;
    const errorEl = document.getElementById('b64-error')!;
    const convertBtn = document.getElementById('b64-convert') as HTMLButtonElement;
    const swapBtn = document.getElementById('b64-swap') as HTMLButtonElement;
    const clearBtn = document.getElementById('b64-clear') as HTMLButtonElement;
    const copyBtn = document.getElementById('b64-copy') as HTMLButtonElement;

    let mode: Mode = 'encode';

    function setMode(next: Mode): void {
      mode = next;
      modeBtns.forEach((btn) => {
        btn.setAttribute('aria-pressed', String(btn.dataset.mode === next));
      });
      inputLabel.textContent = next === 'encode' ? 'Plain text' : 'Base64 string';
      inputEl.placeholder = next === 'encode' ? 'Enter text to encode…' : 'Enter Base64 to decode…';
      saveState();
    }

    function encodeBase64(text: string): string {
      const bytes = new TextEncoder().encode(text);
      let binary = '';
      bytes.forEach((byte) => {
        binary += String.fromCharCode(byte);
      });
      return window.btoa(binary);
    }

    function decodeBase64(b64: string): string {
      const cleaned = b64.replace(/\s/g, '');
      const binary = window.atob(cleaned);
      const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
      return new TextDecoder().decode(bytes);
    }

    function convert(): void {
      const input = inputEl.value;
      errorEl.classList.add('hidden');
      errorEl.textContent = '';
      outputEl.value = '';
      copyBtn.disabled = true;

      if (!input.trim()) return;

      try {
        outputEl.value = mode === 'encode' ? encodeBase64(input) : decodeBase64(input);
        copyBtn.disabled = false;
      } catch {
        errorEl.textContent =
          mode === 'decode'
            ? 'Invalid Base64 input — check for corrupted characters or padding.'
            : 'Could not encode this input.';
        errorEl.classList.remove('hidden');
      }

      saveState();
    }

    function saveState(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ mode, input: inputEl.value }));
      } catch {
        /* ignore */
      }
    }

    function loadState(): void {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw) as { mode?: Mode; input?: string };
        if (parsed.mode === 'decode') setMode('decode');
        if (typeof parsed.input === 'string') inputEl.value = parsed.input;
      } catch {
        /* ignore */
      }
    }

    modeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = btn.dataset.mode as Mode;
        if (next) setMode(next);
      });
    });

    convertBtn.addEventListener('click', convert);
    inputEl.addEventListener('input', () => {
      saveState();
    });

    swapBtn.addEventListener('click', () => {
      if (!outputEl.value) return;
      inputEl.value = outputEl.value;
      setMode(mode === 'encode' ? 'decode' : 'encode');
      convert();
    });

    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      outputEl.value = '';
      errorEl.classList.add('hidden');
      copyBtn.disabled = true;
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    copyBtn.addEventListener('click', async () => {
      if (!outputEl.value) return;
      try {
        await navigator.clipboard.writeText(outputEl.value);
        const original = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.textContent = original;
        }, 2000);
      } catch {
        copyBtn.textContent = 'Copy failed';
        setTimeout(() => {
          copyBtn.textContent = 'Copy result';
        }, 2000);
      }
    });

    loadState();
  </script>
</ToolsLayout>
