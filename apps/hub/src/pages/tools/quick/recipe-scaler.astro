---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Recipe Scaler';
const toolDescription =
  'Scale recipe ingredients from original to target servings — one ingredient per line (name + quantity).';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="recipe-scaler">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Enter ingredients as "name quantity" per line — e.g. <code class="text-emerald-400">flour 2 cups</code>
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="rs-input-heading"
      >
        <h2 id="rs-input-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Original recipe
        </h2>

        <div class="mt-4 grid grid-cols-2 gap-4">
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-300">Original servings</span>
            <input id="rs-original" type="number" min="1" value="4" class="input-field w-full" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-300">Target servings</span>
            <input id="rs-target" type="number" min="1" value="6" class="input-field w-full" />
          </label>
        </div>

        <label class="mt-4 block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Ingredients (one per line)</span>
          <textarea
            id="rs-ingredients"
            rows="10"
            placeholder={`flour 2 cups\nsugar 1 cup\nmilk 500 ml\neggs 3\nbutter 100 g`}
            class="input-field w-full resize-y font-mono text-sm"
          ></textarea>
        </label>

        <button type="button" id="rs-scale" class="btn-primary mt-4 w-full text-sm">Scale recipe</button>
      </section>

      <section aria-labelledby="rs-output-heading">
        <h2 id="rs-output-heading" class="mb-4 text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Scaled ingredients
        </h2>
        <div id="rs-output" class="output-card">
          <p class="text-sm text-slate-500">Scaled quantities appear here.</p>
        </div>
        <p id="rs-factor" class="mt-3 text-center text-xs text-slate-500" aria-live="polite"></p>
      </section>
    </div>
  </div>

  <style>
    .output-card {
      @apply rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/30 to-slate-900/60 p-4 shadow-lg sm:p-5;
    }
    .ingredient-row {
      @apply flex items-baseline justify-between gap-3 border-b border-slate-800/60 py-2 last:border-0;
    }
    .ingredient-name {
      @apply text-sm font-medium text-white;
    }
    .ingredient-qty {
      @apply text-sm text-emerald-400;
    }
    .ingredient-orig {
      @apply text-xs text-slate-500;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:recipe-scaler';

    const originalEl = document.getElementById('rs-original') as HTMLInputElement;
    const targetEl = document.getElementById('rs-target') as HTMLInputElement;
    const ingredientsEl = document.getElementById('rs-ingredients') as HTMLTextAreaElement;
    const outputEl = document.getElementById('rs-output')!;
    const factorEl = document.getElementById('rs-factor')!;
    const scaleBtn = document.getElementById('rs-scale') as HTMLButtonElement;

    const NUM_RE = /^(\d+(?:\.\d+)?(?:\/\d+)?)\s*(.*)$/;

    function parseFraction(s: string): number {
      if (s.includes('/')) {
        const [a, b] = s.split('/').map(Number);
        return b ? a / b : Number(s);
      }
      return parseFloat(s);
    }

    function formatQty(n: number): string {
      if (Number.isInteger(n)) return String(n);
      const frac = n % 1;
      if (Math.abs(frac - 0.5) < 0.01) return `${Math.floor(n)}½`.replace(/^0½/, '½');
      if (Math.abs(frac - 0.25) < 0.01) return `${Math.floor(n)}¼`.replace(/^0¼/, '¼');
      if (Math.abs(frac - 0.75) < 0.01) return `${Math.floor(n)}¾`.replace(/^0¾/, '¾');
      return n.toFixed(2).replace(/\.?0+$/, '');
    }

    interface Ingredient {
      name: string;
      qty: number;
      unit: string;
      raw: string;
    }

    function parseLine(line: string): Ingredient | null {
      const trimmed = line.trim();
      if (!trimmed) return null;

      const parts = trimmed.split(/\s+/);
      for (let i = parts.length - 1; i >= 0; i--) {
        const candidate = parts.slice(i).join(' ');
        const m = candidate.match(NUM_RE);
        if (m) {
          const name = parts.slice(0, i).join(' ') || trimmed;
          return {
            name: name.trim() || trimmed,
            qty: parseFraction(m[1]),
            unit: m[2].trim(),
            raw: trimmed,
          };
        }
      }
      return { name: trimmed, qty: 1, unit: '', raw: trimmed };
    }

    function scale(): void {
      const original = Math.max(1, parseInt(originalEl.value, 10) || 1);
      const target = Math.max(1, parseInt(targetEl.value, 10) || 1);
      const factor = target / original;

      const lines = ingredientsEl.value.split('\n');
      const parsed = lines.map(parseLine).filter(Boolean) as Ingredient[];

      outputEl.innerHTML = '';

      if (parsed.length === 0) {
        outputEl.innerHTML = '<p class="text-sm text-slate-500">Add at least one ingredient line.</p>';
        factorEl.textContent = '';
        return;
      }

      parsed.forEach((ing) => {
        const scaled = ing.qty * factor;
        const unitStr = ing.unit ? ` ${ing.unit}` : '';
        const row = document.createElement('div');
        row.className = 'ingredient-row';
        row.innerHTML = `
          <div>
            <p class="ingredient-name">${ing.name}</p>
            <p class="ingredient-orig">was: ${ing.qty}${unitStr}</p>
          </div>
          <p class="ingredient-qty">${formatQty(scaled)}${unitStr}</p>
        `;
        outputEl.appendChild(row);
      });

      factorEl.textContent = `Scale factor: ×${factor.toFixed(2)} (${original} → ${target} servings)`;

      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          original: originalEl.value,
          target: targetEl.value,
          ingredients: ingredientsEl.value,
        }));
      } catch { /* ignore */ }
    }

    scaleBtn.addEventListener('click', scale);
    [originalEl, targetEl, ingredientsEl].forEach((el) => el.addEventListener('input', scale));

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const data = JSON.parse(saved) as { original: string; target: string; ingredients: string };
        originalEl.value = data.original ?? '4';
        targetEl.value = data.target ?? '6';
        ingredientsEl.value = data.ingredients ?? '';
      }
    } catch { /* ignore */ }

    scale();
  </script>
</ToolsLayout>
