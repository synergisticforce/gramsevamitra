---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import HashGeneratorTool from '../../../components/tools/HashGeneratorTool';
import ToolBackLink from '../../../components/tools/ToolBackLink.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Crypto Hash Generator';
const toolDescription =
  'Live MD5, SHA-1, SHA-256, and SHA-512 digests from any text — Web Crypto API, zero server calls.';
---

<ToolsLayout title={formatSeoTitle(toolName, 'Free Online Tool')} description={toolDescription} activeNav="quick">
  <div>
    <header class="mb-6">
      <ToolBackLink href={utilitiesHref('/tools/quick')} label="← Quick Tools Drawer" />
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">{toolDescription}</p>
    </header>
    <HashGeneratorTool client:load />
  </div>
</ToolsLayout>
