---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Construction Materials Estimator';
const toolDescription =
  'Estimate bricks, cement bags, and sand volume from wall dimensions, brick size, and mortar ratio.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="construction-materials">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Rough material estimate for brick walls — dimensions in feet, standard 50 kg cement bags.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="cm-input-heading"
      >
        <h2 id="cm-input-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Wall dimensions
        </h2>

        <form id="cm-form" class="mt-5 space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">Wall length (ft)</span>
              <input id="cm-length" type="number" min="0.1" step="0.1" value="10" class="input-field w-full" />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">Wall height (ft)</span>
              <input id="cm-height" type="number" min="0.1" step="0.1" value="10" class="input-field w-full" />
            </label>
          </div>

          <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Brick size (inches)</p>
          <div class="grid grid-cols-3 gap-3">
            <label class="block">
              <span class="mb-1 block text-xs text-slate-400">Length</span>
              <input id="cm-brick-l" type="number" min="1" value="9" class="input-field w-full" />
            </label>
            <label class="block">
              <span class="mb-1 block text-xs text-slate-400">Width</span>
              <input id="cm-brick-w" type="number" min="1" value="4.5" step="0.1" class="input-field w-full" />
            </label>
            <label class="block">
              <span class="mb-1 block text-xs text-slate-400">Height</span>
              <input id="cm-brick-h" type="number" min="1" value="3" class="input-field w-full" />
            </label>
          </div>

          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-300">Mortar ratio (cement : sand)</span>
            <select id="cm-ratio" class="input-field w-full">
              <option value="1:4">1 : 4 (standard)</option>
              <option value="1:5">1 : 5</option>
              <option value="1:6" selected>1 : 6 (lean mix)</option>
            </select>
          </label>
        </form>

        <button type="button" id="cm-calc" class="btn-primary mt-4 w-full text-sm">Calculate materials</button>
      </section>

      <section aria-labelledby="cm-results-heading">
        <h2 id="cm-results-heading" class="mb-4 text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Estimates
        </h2>

        <div class="results-grid">
          <article class="result-box">
            <p class="text-xs uppercase text-slate-500">Bricks</p>
            <p id="cm-bricks" class="mt-1 text-3xl font-bold text-white">—</p>
            <p class="text-xs text-slate-500">+ 5% wastage included</p>
          </article>

          <article class="result-box">
            <p class="text-xs uppercase text-slate-500">Cement bags</p>
            <p id="cm-cement" class="mt-1 text-3xl font-bold text-emerald-400">—</p>
            <p class="text-xs text-slate-500">50 kg bags</p>
          </article>

          <article class="result-box col-span-full">
            <p class="text-xs uppercase text-slate-500">Sand volume</p>
            <p id="cm-sand" class="mt-1 text-3xl font-bold text-white">—</p>
            <p class="text-xs text-slate-500">cubic feet (approx.)</p>
          </article>
        </div>

        <p id="cm-detail" class="mt-4 rounded-xl border border-slate-800 bg-slate-950/50 p-3 text-xs text-slate-400" aria-live="polite"></p>
      </section>
    </div>
  </div>

  <style>
    .results-grid {
      @apply grid grid-cols-2 gap-3;
    }
    .result-box {
      @apply rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/30 to-slate-900/60 p-4 shadow-lg;
    }
  </style>

  <script>
    const lengthEl = document.getElementById('cm-length') as HTMLInputElement;
    const heightEl = document.getElementById('cm-height') as HTMLInputElement;
    const brickLEl = document.getElementById('cm-brick-l') as HTMLInputElement;
    const brickWEl = document.getElementById('cm-brick-w') as HTMLInputElement;
    const brickHEl = document.getElementById('cm-brick-h') as HTMLInputElement;
    const ratioEl = document.getElementById('cm-ratio') as HTMLSelectElement;
    const bricksEl = document.getElementById('cm-bricks')!;
    const cementEl = document.getElementById('cm-cement')!;
    const sandEl = document.getElementById('cm-sand')!;
    const detailEl = document.getElementById('cm-detail')!;
    const calcBtn = document.getElementById('cm-calc') as HTMLButtonElement;

    function calculate(): void {
      const wallL = parseFloat(lengthEl.value) || 0;
      const wallH = parseFloat(heightEl.value) || 0;
      const brickL = parseFloat(brickLEl.value) / 12 || 0;
      const brickW = parseFloat(brickWEl.value) / 12 || 0;
      const brickH = parseFloat(brickHEl.value) / 12 || 0;

      if (wallL <= 0 || wallH <= 0 || brickL <= 0 || brickW <= 0 || brickH <= 0) {
        bricksEl.textContent = '—';
        cementEl.textContent = '—';
        sandEl.textContent = '—';
        detailEl.textContent = 'Enter valid dimensions.';
        return;
      }

      const wallArea = wallL * wallH;
      const brickFaceArea = brickL * brickH;
      const bricksPerSqFt = 1 / brickFaceArea;
      const rawBricks = wallArea * bricksPerSqFt;
      const bricksWithWastage = Math.ceil(rawBricks * 1.05);

      const mortarThickness = 0.5 / 12;
      const wallVolume = wallL * wallH * (brickW + mortarThickness);
      const brickVolume = brickL * brickW * brickH;
      const mortarVolume = wallVolume - rawBricks * brickVolume;

      const ratioParts = ratioEl.value.split(':').map(Number);
      const cementPart = ratioParts[0] || 1;
      const sandPart = ratioParts[1] || 6;
      const totalParts = cementPart + sandPart;

      const cementVolume = mortarVolume * (cementPart / totalParts);
      const sandVolume = mortarVolume * (sandPart / totalParts);

      const cementBags = Math.ceil((cementVolume * 40) / 50);

      bricksEl.textContent = bricksWithWastage.toLocaleString('en-IN');
      cementEl.textContent = String(cementBags);
      sandEl.textContent = sandVolume.toFixed(1);

      detailEl.textContent = `Wall area: ${wallArea.toFixed(1)} sq ft · Mortar volume: ~${mortarVolume.toFixed(2)} cu ft · Ratio ${ratioEl.value}`;
    }

    calcBtn.addEventListener('click', calculate);
    [lengthEl, heightEl, brickLEl, brickWEl, brickHEl, ratioEl].forEach((el) => {
      el.addEventListener('input', calculate);
    });

    calculate();
  </script>
</ToolsLayout>
