---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Home Renovation Budget';
const toolDescription =
  'Track renovation costs by room — budget items with description and cost, room totals and grand total in localStorage.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="home-renovation">
    <header class="mb-6">
      <a href="/tools/quick" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">Track renovation spending by room — budget saved on this device only.</p>
    </header>

    <section
      class="mb-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
      aria-labelledby="hr-add-heading"
    >
      <h2 id="hr-add-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
        Add budget item
      </h2>

      <form id="hr-form" class="mt-5 space-y-4">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Room name</span>
          <input id="hr-room" type="text" placeholder="e.g. Kitchen, Bedroom" class="input-field w-full" list="hr-room-list" />
          <datalist id="hr-room-list"></datalist>
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Description</span>
          <input id="hr-desc" type="text" placeholder="e.g. Tiles, paint, labour" class="input-field w-full" />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Cost (₹)</span>
          <input id="hr-cost" type="number" min="0" step="1" placeholder="e.g. 25000" class="input-field w-full" />
        </label>
      </form>

      <button type="button" id="hr-add" class="btn-primary mt-4 w-full text-sm">Add item</button>
    </section>

    <section
      class="mb-6 rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/30 to-slate-900/60 p-5 shadow-lg"
      aria-labelledby="hr-total-heading"
    >
      <h2 id="hr-total-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
        Grand total
      </h2>
      <p id="hr-grand-total" class="mt-2 text-3xl font-bold text-emerald-400">₹0</p>
      <p id="hr-item-count" class="mt-1 text-xs text-slate-500">0 items across 0 rooms</p>
    </section>

    <section aria-labelledby="hr-rooms-heading">
      <h2 id="hr-rooms-heading" class="mb-4 text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
        By room
      </h2>

      <div id="hr-empty" class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/30 px-4 py-10 text-center">
        <p class="text-sm text-slate-500">No budget items yet. Add your first expense above.</p>
      </div>

      <div id="hr-rooms" class="hidden space-y-4" aria-live="polite"></div>
    </section>
  </div>

  <style>
    .room-card {
      @apply rounded-2xl border border-slate-800 bg-slate-900/50 p-4;
    }
    .item-row {
      @apply flex items-center justify-between gap-3 border-b border-slate-800/60 py-2 last:border-0;
    }
    .remove-item {
      @apply shrink-0 rounded border border-slate-700 px-2 py-0.5 text-xs text-slate-500 transition hover:border-rose-700 hover:text-rose-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:home-renovation';

    interface BudgetItem {
      id: string;
      room: string;
      description: string;
      cost: number;
    }

    const roomEl = document.getElementById('hr-room') as HTMLInputElement;
    const descEl = document.getElementById('hr-desc') as HTMLInputElement;
    const costEl = document.getElementById('hr-cost') as HTMLInputElement;
    const addBtn = document.getElementById('hr-add') as HTMLButtonElement;
    const grandTotalEl = document.getElementById('hr-grand-total')!;
    const itemCountEl = document.getElementById('hr-item-count')!;
    const emptyEl = document.getElementById('hr-empty')!;
    const roomsEl = document.getElementById('hr-rooms')!;
    const roomListEl = document.getElementById('hr-room-list')!;

    function loadItems(): BudgetItem[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        return raw ? (JSON.parse(raw) as BudgetItem[]) : [];
      } catch {
        return [];
      }
    }

    function saveItems(items: BudgetItem[]): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      } catch { /* ignore */ }
    }

    function formatINR(n: number): string {
      return '₹' + n.toLocaleString('en-IN');
    }

    function render(): void {
      const items = loadItems();
      const byRoom: Record<string, BudgetItem[]> = {};

      items.forEach((item) => {
        const room = item.room || 'General';
        if (!byRoom[room]) byRoom[room] = [];
        byRoom[room].push(item);
      });

      const rooms = Object.keys(byRoom).sort();
      const grandTotal = items.reduce((sum, i) => sum + i.cost, 0);

      grandTotalEl.textContent = formatINR(grandTotal);
      itemCountEl.textContent = `${items.length} item${items.length !== 1 ? 's' : ''} across ${rooms.length} room${rooms.length !== 1 ? 's' : ''}`;

      roomListEl.innerHTML = '';
      rooms.forEach((room) => {
        const opt = document.createElement('option');
        opt.value = room;
        roomListEl.appendChild(opt);
      });

      emptyEl.classList.toggle('hidden', items.length > 0);
      roomsEl.classList.toggle('hidden', items.length === 0);
      roomsEl.innerHTML = '';

      rooms.forEach((room) => {
        const roomItems = byRoom[room];
        const roomTotal = roomItems.reduce((sum, i) => sum + i.cost, 0);

        const card = document.createElement('article');
        card.className = 'room-card';
        card.innerHTML = `
          <div class="mb-3 flex items-center justify-between">
            <h3 class="font-semibold text-white">${room}</h3>
            <span class="text-sm font-bold text-emerald-400">${formatINR(roomTotal)}</span>
          </div>
          <ul class="item-list"></ul>
        `;

        const list = card.querySelector('.item-list')!;
        roomItems.forEach((item) => {
          const li = document.createElement('li');
          li.className = 'item-row';
          li.innerHTML = `
            <div class="min-w-0">
              <p class="truncate text-sm text-slate-300">${item.description || '—'}</p>
            </div>
            <div class="flex shrink-0 items-center gap-2">
              <span class="text-sm font-medium text-white">${formatINR(item.cost)}</span>
              <button type="button" class="remove-item" data-id="${item.id}" aria-label="Remove item">×</button>
            </div>
          `;
          li.querySelector('.remove-item')!.addEventListener('click', () => {
            saveItems(loadItems().filter((i) => i.id !== item.id));
            render();
          });
          list.appendChild(li);
        });

        roomsEl.appendChild(card);
      });
    }

    addBtn.addEventListener('click', () => {
      const room = roomEl.value.trim();
      const description = descEl.value.trim();
      const cost = parseFloat(costEl.value) || 0;

      if (!room || cost <= 0) return;

      const item: BudgetItem = {
        id: crypto.randomUUID(),
        room,
        description,
        cost,
      };

      const items = loadItems();
      items.push(item);
      saveItems(items);

      descEl.value = '';
      costEl.value = '';
      render();
    });

    render();
  </script>
</ToolsLayout>
