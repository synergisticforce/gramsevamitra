---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import ExamPhotoStudio from '../../../components/tools/ExamPhotoStudio';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Exam Photo & Signature Studio';
const toolDescription =
  'Crop passport photos and signatures to SSC, UPSC, RRB, and IBPS specs — compress strictly under exam KB limits, 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="exam-photo-page">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Upload, crop to exam aspect ratio, and compress to KB limits — your images never leave this device.
      </p>
    </header>

    <ExamPhotoStudio client:load />
  </div>
</ToolsLayout>
