---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Gardening Planner';
const toolDescription =
  'Track plants with sow date and water frequency — localStorage list with next watering date calculation.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="gardening-planner">
    <header class="mb-6">
      <a href="/tools/quick" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">Plan sowing and watering — your garden data stays on this device.</p>
    </header>

    <section
      class="mb-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
      aria-labelledby="gp-add-heading"
    >
      <h2 id="gp-add-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
        Add plant
      </h2>

      <form id="gp-form" class="mt-5 space-y-4">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Plant name</span>
          <input id="gp-name" type="text" placeholder="e.g. Tomato, Tulsi" class="input-field w-full" required />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Sow date</span>
          <input id="gp-sow" type="date" class="input-field w-full" required />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Water every (days)</span>
          <input id="gp-water" type="number" min="1" value="2" class="input-field w-full" />
        </label>
      </form>

      <button type="button" id="gp-add" class="btn-primary mt-4 w-full text-sm">Add to garden</button>
    </section>

    <section aria-labelledby="gp-list-heading">
      <h2 id="gp-list-heading" class="mb-4 text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
        Your plants <span id="gp-count" class="text-slate-500">(0)</span>
      </h2>

      <div id="gp-empty" class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/30 px-4 py-10 text-center">
        <p class="text-sm text-slate-500">No plants yet. Add your first plant above.</p>
      </div>

      <ul id="gp-list" class="hidden space-y-3" aria-live="polite"></ul>
    </section>
  </div>

  <style>
    .plant-card {
      @apply rounded-2xl border border-slate-800 bg-slate-900/50 p-4;
    }
    .plant-card.due {
      @apply border-amber-700/50 bg-amber-950/20;
    }
    .plant-card.overdue {
      @apply border-rose-700/50 bg-rose-950/20;
    }
    .water-btn {
      @apply rounded-lg border border-emerald-700/60 bg-emerald-950/40 px-3 py-1.5 text-xs font-semibold text-emerald-400 transition hover:border-emerald-500 hover:text-emerald-300;
    }
    .remove-btn {
      @apply rounded-lg border border-slate-700 px-3 py-1.5 text-xs font-semibold text-slate-500 transition hover:border-rose-700 hover:text-rose-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:gardening-planner';

    interface Plant {
      id: string;
      name: string;
      sowDate: string;
      waterDays: number;
      lastWatered: string;
    }

    const nameEl = document.getElementById('gp-name') as HTMLInputElement;
    const sowEl = document.getElementById('gp-sow') as HTMLInputElement;
    const waterEl = document.getElementById('gp-water') as HTMLInputElement;
    const addBtn = document.getElementById('gp-add') as HTMLButtonElement;
    const listEl = document.getElementById('gp-list')!;
    const emptyEl = document.getElementById('gp-empty')!;
    const countEl = document.getElementById('gp-count')!;

    function loadPlants(): Plant[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        return raw ? (JSON.parse(raw) as Plant[]) : [];
      } catch {
        return [];
      }
    }

    function savePlants(plants: Plant[]): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(plants));
      } catch { /* ignore */ }
    }

    function daysBetween(a: Date, b: Date): number {
      return Math.floor((b.getTime() - a.getTime()) / (1000 * 60 * 60 * 24));
    }

    function formatDate(iso: string): string {
      return new Date(iso + 'T12:00:00').toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function nextWaterDate(plant: Plant): Date {
      const last = new Date(plant.lastWatered + 'T12:00:00');
      last.setDate(last.getDate() + plant.waterDays);
      return last;
    }

    function render(): void {
      const plants = loadPlants();
      const today = new Date();
      today.setHours(12, 0, 0, 0);

      countEl.textContent = `(${plants.length})`;
      emptyEl.classList.toggle('hidden', plants.length > 0);
      listEl.classList.toggle('hidden', plants.length === 0);
      listEl.innerHTML = '';

      plants
        .sort((a, b) => nextWaterDate(a).getTime() - nextWaterDate(b).getTime())
        .forEach((plant) => {
          const next = nextWaterDate(plant);
          const daysUntil = daysBetween(today, next);
          let statusClass = '';
          let statusText = `Next water: ${formatDate(next.toISOString().slice(0, 10))}`;

          if (daysUntil <= 0) {
            statusClass = daysUntil < 0 ? 'overdue' : 'due';
            statusText = daysUntil < 0 ? `Overdue by ${Math.abs(daysUntil)} day(s)!` : 'Water today!';
          } else if (daysUntil === 1) {
            statusText = 'Water tomorrow';
          }

          const li = document.createElement('li');
          li.className = `plant-card ${statusClass}`;
          li.innerHTML = `
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <p class="font-semibold text-white">${plant.name}</p>
                <p class="mt-1 text-xs text-slate-500">Sown ${formatDate(plant.sowDate)} · Every ${plant.waterDays} day(s)</p>
                <p class="mt-2 text-sm ${statusClass ? 'text-amber-400' : 'text-emerald-400'}">${statusText}</p>
              </div>
              <div class="flex gap-2">
                <button type="button" class="water-btn" data-id="${plant.id}">Watered</button>
                <button type="button" class="remove-btn" data-id="${plant.id}">Remove</button>
              </div>
            </div>
          `;

          li.querySelector('.water-btn')!.addEventListener('click', () => {
            const updated = loadPlants().map((p) =>
              p.id === plant.id ? { ...p, lastWatered: new Date().toISOString().slice(0, 10) } : p
            );
            savePlants(updated);
            render();
          });

          li.querySelector('.remove-btn')!.addEventListener('click', () => {
            savePlants(loadPlants().filter((p) => p.id !== plant.id));
            render();
          });

          listEl.appendChild(li);
        });
    }

    addBtn.addEventListener('click', () => {
      const name = nameEl.value.trim();
      const sowDate = sowEl.value;
      const waterDays = Math.max(1, parseInt(waterEl.value, 10) || 2);

      if (!name || !sowDate) return;

      const plant: Plant = {
        id: crypto.randomUUID(),
        name,
        sowDate,
        waterDays,
        lastWatered: sowDate,
      };

      const plants = loadPlants();
      plants.push(plant);
      savePlants(plants);

      nameEl.value = '';
      sowEl.value = '';
      waterEl.value = '2';
      render();
    });

    sowEl.value = new Date().toISOString().slice(0, 10);
    render();
  </script>
</ToolsLayout>
