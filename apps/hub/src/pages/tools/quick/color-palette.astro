---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Color Palette Generator';
const toolDescription =
  'Generate beautiful 5-color palettes and copy hex codes instantly — free, offline, and private in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="color-palette">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">Tap any swatch to copy its hex code — palettes generated locally.</p>
    </header>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <p class="text-sm text-slate-400">5-color palette — click a swatch to copy</p>
        <button type="button" id="generate-palette" class="btn-primary px-4 py-2 text-sm">
          Generate new palette
        </button>
      </div>

      <p id="palette-feedback" class="mt-2 min-h-[1rem] text-center text-xs text-emerald-400" role="status"></p>

      <div
        id="palette-grid"
        class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-5"
        role="list"
        aria-label="Color palette swatches"
      >
        <!-- Swatches injected by script -->
      </div>
    </section>
  </div>

  <style>
    .swatch-card {
      @apply flex min-h-[140px] cursor-pointer flex-col justify-end overflow-hidden rounded-2xl border border-slate-700/80 shadow-lg transition hover:scale-[1.02] hover:border-emerald-500/50 focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
    .swatch-hex {
      @apply bg-black/40 px-3 py-2 font-mono text-xs font-bold uppercase tracking-wider text-white backdrop-blur-sm;
    }
  </style>

  <script>
    const paletteGrid = document.getElementById('palette-grid')!;
    const generateBtn = document.getElementById('generate-palette') as HTMLButtonElement;
    const feedbackEl = document.getElementById('palette-feedback')!;

    function randomChannel(): number {
      const buf = new Uint8Array(1);
      crypto.getRandomValues(buf);
      return buf[0];
    }

    function hslToHex(h: number, s: number, l: number): string {
      const sat = s / 100;
      const light = l / 100;
      const c = (1 - Math.abs(2 * light - 1)) * sat;
      const x = c * (1 - Math.abs(((h / 60) % 2) - 1));
      const m = light - c / 2;
      let r = 0;
      let g = 0;
      let b = 0;

      if (h < 60) {
        r = c;
        g = x;
      } else if (h < 120) {
        r = x;
        g = c;
      } else if (h < 180) {
        g = c;
        b = x;
      } else if (h < 240) {
        g = x;
        b = c;
      } else if (h < 300) {
        r = x;
        b = c;
      } else {
        r = c;
        b = x;
      }

      const toHex = (n: number) =>
        Math.round((n + m) * 255)
          .toString(16)
          .padStart(2, '0');

      return `#${toHex(r)}${toHex(g)}${toHex(b)}`.toUpperCase();
    }

    function randomHex(): string {
      const r = randomChannel();
      const g = randomChannel();
      const b = randomChannel();
      return `#${r.toString(16).padStart(2, '0')}${g.toString(16).padStart(2, '0')}${b.toString(16).padStart(2, '0')}`.toUpperCase();
    }

    function generateCohesivePalette(): string[] {
      const baseHue = randomChannel() / 255 * 360;
      const useCohesive = randomChannel() % 2 === 0;

      if (!useCohesive) {
        return Array.from({ length: 5 }, () => randomHex());
      }

      return Array.from({ length: 5 }, (_, i) => {
        const hue = (baseHue + i * 28 + (randomChannel() % 20)) % 360;
        const sat = 48 + (randomChannel() % 35);
        const light = 32 + i * 9 + (randomChannel() % 12);
        return hslToHex(hue, sat, Math.min(light, 78));
      });
    }

    function contrastText(hex: string): string {
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
      return luminance > 0.55 ? '#0f172a' : '#ffffff';
    }

    function renderPalette(colors: string[]): void {
      paletteGrid.innerHTML = '';
      colors.forEach((hex) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'swatch-card';
        btn.style.backgroundColor = hex;
        btn.setAttribute('role', 'listitem');
        btn.setAttribute('aria-label', `Copy color ${hex}`);
        btn.innerHTML = `<span class="swatch-hex" style="color:${contrastText(hex)}">${hex}</span>`;
        btn.addEventListener('click', () => {
          void copyHex(hex);
        });
        paletteGrid.appendChild(btn);
      });
    }

    async function copyHex(hex: string): Promise<void> {
      try {
        await navigator.clipboard.writeText(hex);
        feedbackEl.textContent = `Copied ${hex} to clipboard.`;
      } catch {
        feedbackEl.textContent = `Copy failed for ${hex}.`;
      }
    }

    generateBtn.addEventListener('click', () => {
      feedbackEl.textContent = '';
      renderPalette(generateCohesivePalette());
    });

    renderPalette(generateCohesivePalette());
  </script>
</ToolsLayout>
