---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import BabyNameFinderTool from '../../../components/tools/BabyNameFinderTool';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Baby Name Finder';
const toolDescription =
  'Browse diverse baby names by origin, letter, and gender — shortlist favourites saved on this device only.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="baby-names">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">{toolDescription}</p>
    </header>

    <BabyNameFinderTool client:load />
  </div>
</ToolsLayout>
