---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import DocumentRedactor from '../../../components/tools/DocumentRedactor';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Secure Document Redactor';
const toolDescription =
  'Permanently black out sensitive information on images or PDF first pages — draw redaction boxes and export a flattened PNG, fully offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="document-redactor-page">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/quick')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Click and drag black boxes over PII — export a safe, flattened image. Your document never leaves this device.
      </p>
    </header>

    <DocumentRedactor client:load />
  </div>
</ToolsLayout>
