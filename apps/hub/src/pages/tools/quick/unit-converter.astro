---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Unit Converter';
const toolDescription =
  'Convert length, weight, and temperature instantly — dual-direction, real-time, and 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="quick"
>
  <div class="unit-converter">
    <header class="mb-6">
      <a href="/tools/quick" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Quick Tools Drawer
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">Edit either side — conversions update instantly on your device.</p>
    </header>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6">
      <div
        class="flex flex-wrap gap-2"
        role="tablist"
        aria-label="Conversion category"
      >
        <button type="button" class="category-btn" data-category="length" aria-pressed="true">Length</button>
        <button type="button" class="category-btn" data-category="weight" aria-pressed="false">Weight</button>
        <button type="button" class="category-btn" data-category="temperature" aria-pressed="false">
          Temperature
        </button>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
        <label class="min-w-0 block">
          <span class="label">From</span>
          <input
            id="value-from"
            type="number"
            inputmode="decimal"
            step="any"
            value="1"
            class="input-field w-full tabular-nums"
          />
          <select id="unit-from" class="select-field mt-2 w-full"></select>
        </label>

        <div class="hidden text-center text-slate-500 sm:block sm:pb-3" aria-hidden="true">⇄</div>

        <label class="min-w-0 block">
          <span class="label">To</span>
          <input
            id="value-to"
            type="number"
            inputmode="decimal"
            step="any"
            class="input-field w-full tabular-nums"
          />
          <select id="unit-to" class="select-field mt-2 w-full"></select>
        </label>
      </div>
    </section>
  </div>

  <style>
    .category-btn {
      @apply rounded-full border border-slate-700 bg-slate-950/50 px-4 py-2 text-sm font-semibold text-slate-400 transition hover:border-emerald-600 hover:text-white;
    }
    .category-btn[aria-pressed='true'] {
      @apply border-emerald-500 bg-emerald-600 text-white;
    }
  </style>

  <script>
    type Category = 'length' | 'weight' | 'temperature';

    interface UnitDef {
      id: string;
      label: string;
      toBase: (v: number) => number;
      fromBase: (v: number) => number;
    }

    const LENGTH_UNITS: UnitDef[] = [
      { id: 'm', label: 'Meter (m)', toBase: (v) => v, fromBase: (v) => v },
      { id: 'km', label: 'Kilometer (km)', toBase: (v) => v * 1000, fromBase: (v) => v / 1000 },
      { id: 'cm', label: 'Centimeter (cm)', toBase: (v) => v / 100, fromBase: (v) => v * 100 },
      { id: 'mm', label: 'Millimeter (mm)', toBase: (v) => v / 1000, fromBase: (v) => v * 1000 },
      { id: 'mi', label: 'Mile (mi)', toBase: (v) => v * 1609.344, fromBase: (v) => v / 1609.344 },
      { id: 'yd', label: 'Yard (yd)', toBase: (v) => v * 0.9144, fromBase: (v) => v / 0.9144 },
      { id: 'ft', label: 'Foot (ft)', toBase: (v) => v * 0.3048, fromBase: (v) => v / 0.3048 },
      { id: 'in', label: 'Inch (in)', toBase: (v) => v * 0.0254, fromBase: (v) => v / 0.0254 },
    ];

    const WEIGHT_UNITS: UnitDef[] = [
      { id: 'kg', label: 'Kilogram (kg)', toBase: (v) => v, fromBase: (v) => v },
      { id: 'g', label: 'Gram (g)', toBase: (v) => v / 1000, fromBase: (v) => v * 1000 },
      { id: 'mg', label: 'Milligram (mg)', toBase: (v) => v / 1_000_000, fromBase: (v) => v * 1_000_000 },
      { id: 'lb', label: 'Pound (lb)', toBase: (v) => v * 0.45359237, fromBase: (v) => v / 0.45359237 },
      { id: 'oz', label: 'Ounce (oz)', toBase: (v) => v * 0.028349523125, fromBase: (v) => v / 0.028349523125 },
    ];

    const TEMP_UNITS: UnitDef[] = [
      {
        id: 'c',
        label: 'Celsius (°C)',
        toBase: (v) => v,
        fromBase: (v) => v,
      },
      {
        id: 'f',
        label: 'Fahrenheit (°F)',
        toBase: (v) => ((v - 32) * 5) / 9,
        fromBase: (v) => (v * 9) / 5 + 32,
      },
      {
        id: 'k',
        label: 'Kelvin (K)',
        toBase: (v) => v - 273.15,
        fromBase: (v) => v + 273.15,
      },
    ];

    const CATEGORIES: Record<Category, UnitDef[]> = {
      length: LENGTH_UNITS,
      weight: WEIGHT_UNITS,
      temperature: TEMP_UNITS,
    };

    const DEFAULT_UNITS: Record<Category, { from: string; to: string }> = {
      length: { from: 'm', to: 'ft' },
      weight: { from: 'kg', to: 'lb' },
      temperature: { from: 'c', to: 'f' },
    };

    const categoryBtns = document.querySelectorAll<HTMLButtonElement>('.category-btn');
    const valueFrom = document.getElementById('value-from') as HTMLInputElement;
    const valueTo = document.getElementById('value-to') as HTMLInputElement;
    const unitFrom = document.getElementById('unit-from') as HTMLSelectElement;
    const unitTo = document.getElementById('unit-to') as HTMLSelectElement;

    let category: Category = 'length';
    let activeSide: 'from' | 'to' = 'from';
    let syncing = false;

    function getUnit(units: UnitDef[], id: string): UnitDef {
      return units.find((u) => u.id === id) ?? units[0];
    }

    function formatNumber(value: number): string {
      if (!Number.isFinite(value)) return '';
      const abs = Math.abs(value);
      if (abs === 0) return '0';
      if (abs >= 1_000_000 || (abs < 0.0001 && abs > 0)) return value.toExponential(6);
      return String(Math.round(value * 1_000_000) / 1_000_000);
    }

    function populateSelects(units: UnitDef[], fromId: string, toId: string): void {
      const options = units.map((u) => `<option value="${u.id}">${u.label}</option>`).join('');
      unitFrom.innerHTML = options;
      unitTo.innerHTML = options;
      unitFrom.value = fromId;
      unitTo.value = toId;
    }

    function convert(value: number, fromUnit: UnitDef, toUnit: UnitDef): number {
      const base = fromUnit.toBase(value);
      return toUnit.fromBase(base);
    }

    function recalculate(): void {
      if (syncing) return;
      syncing = true;

      const units = CATEGORIES[category];
      const fromUnit = getUnit(units, unitFrom.value);
      const toUnit = getUnit(units, unitTo.value);

      if (activeSide === 'from') {
        const raw = parseFloat(valueFrom.value);
        if (!Number.isFinite(raw)) {
          valueTo.value = '';
        } else {
          valueTo.value = formatNumber(convert(raw, fromUnit, toUnit));
        }
      } else {
        const raw = parseFloat(valueTo.value);
        if (!Number.isFinite(raw)) {
          valueFrom.value = '';
        } else {
          valueFrom.value = formatNumber(convert(raw, toUnit, fromUnit));
        }
      }

      syncing = false;
    }

    function switchCategory(next: Category): void {
      category = next;
      categoryBtns.forEach((btn) => {
        btn.setAttribute('aria-pressed', String(btn.dataset.category === next));
      });

      const defaults = DEFAULT_UNITS[next];
      populateSelects(CATEGORIES[next], defaults.from, defaults.to);
      activeSide = 'from';
      valueFrom.value = '1';
      recalculate();
    }

    categoryBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = btn.dataset.category as Category;
        if (next && next !== category) switchCategory(next);
      });
    });

    valueFrom.addEventListener('input', () => {
      activeSide = 'from';
      recalculate();
    });

    valueTo.addEventListener('input', () => {
      activeSide = 'to';
      recalculate();
    });

    unitFrom.addEventListener('change', recalculate);
    unitTo.addEventListener('change', recalculate);

    switchCategory('length');
  </script>
</ToolsLayout>
