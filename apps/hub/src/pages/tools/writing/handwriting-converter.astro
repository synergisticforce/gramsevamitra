---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Handwriting Converter';
const toolDescription =
  'Turn typed text into a handwritten-style image — choose a script style and download as PNG. Runs entirely in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="handwriting-converter">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/writing')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Preview your text in a handwriting-like style and export a PNG — nothing leaves your device.
      </p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="hw-input-heading"
    >
      <h2 id="hw-input-heading" class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">
        Your text
      </h2>

      <label for="hw-text" class="sr-only">Text to convert</label>
      <textarea
        id="hw-text"
        rows="5"
        spellcheck="true"
        placeholder="Type or paste the note you want to look handwritten…"
        class="input-field w-full resize-y text-sm leading-relaxed"
      ></textarea>

      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Handwriting style</span>
          <select id="hw-font" class="input-field w-full text-sm">
            <option value="cursive">Casual Cursive</option>
            <option value="script">Elegant Script</option>
            <option value="marker">Marker Pen</option>
            <option value="neat">Neat Italic</option>
          </select>
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Ink color</span>
          <select id="hw-ink" class="input-field w-full text-sm">
            <option value="#1e3a5f">Navy blue</option>
            <option value="#1a1a1a">Black</option>
            <option value="#2d4a3e">Forest green</option>
            <option value="#5c2d2d">Burgundy</option>
          </select>
        </label>
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="hw-render" class="btn-primary text-sm">Update preview</button>
        <button type="button" id="hw-download" class="btn-secondary text-sm" disabled>Download PNG</button>
      </div>
      <p id="hw-status" class="mt-2 text-xs text-emerald-400" role="status" aria-live="polite"></p>
    </section>

    <section
      class="mt-4 overflow-hidden rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/30 to-slate-900/60 p-4 shadow-lg"
      aria-label="Handwriting preview"
    >
      <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500">Preview</p>
      <div class="overflow-x-auto rounded-xl border border-slate-800 bg-[#fffef8] p-2">
        <canvas id="hw-canvas" class="mx-auto block max-w-full" width="720" height="400" role="img" aria-label="Handwriting preview canvas"></canvas>
      </div>
    </section>
  </div>

  <script>
    const FONT_STYLES: Record<string, { family: string; size: number; slant: number }> = {
      cursive: { family: 'cursive', size: 28, slant: -0.12 },
      script: { family: '"Segoe Script", "Brush Script MT", cursive', size: 30, slant: -0.08 },
      marker: { family: '"Comic Sans MS", "Chalkboard SE", cursive', size: 26, slant: -0.05 },
      neat: { family: 'Georgia, "Times New Roman", serif', size: 26, slant: -0.15 },
    };

    const textEl = document.getElementById('hw-text') as HTMLTextAreaElement;
    const fontEl = document.getElementById('hw-font') as HTMLSelectElement;
    const inkEl = document.getElementById('hw-ink') as HTMLSelectElement;
    const canvas = document.getElementById('hw-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const renderBtn = document.getElementById('hw-render') as HTMLButtonElement;
    const downloadBtn = document.getElementById('hw-download') as HTMLButtonElement;
    const statusEl = document.getElementById('hw-status')!;

    const PADDING = 32;
    const LINE_HEIGHT_RATIO = 1.45;

    function wrapLines(text: string, maxWidth: number, font: string): string[] {
      ctx.font = font;
      const lines: string[] = [];
      const paragraphs = text.split('\n');

      for (const paragraph of paragraphs) {
        if (!paragraph.trim()) {
          lines.push('');
          continue;
        }
        const words = paragraph.split(/\s+/);
        let current = '';
        for (const word of words) {
          const test = current ? `${current} ${word}` : word;
          if (ctx.measureText(test).width > maxWidth && current) {
            lines.push(current);
            current = word;
          } else {
            current = test;
          }
        }
        if (current) lines.push(current);
      }
      return lines.length ? lines : [''];
    }

    function renderHandwriting(): void {
      const text = textEl.value.trim();
      const styleKey = fontEl.value;
      const style = FONT_STYLES[styleKey] ?? FONT_STYLES.cursive;
      const ink = inkEl.value;
      const font = `italic ${style.size}px ${style.family}`;
      const maxWidth = canvas.width - PADDING * 2;

      const lines = text ? wrapLines(text, maxWidth, font) : [];
      const lineHeight = style.size * LINE_HEIGHT_RATIO;
      const neededHeight = Math.max(200, PADDING * 2 + lines.length * lineHeight);

      canvas.height = neededHeight;
      ctx.fillStyle = '#fffef8';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      if (!text) {
        downloadBtn.disabled = true;
        statusEl.textContent = 'Enter some text to generate a preview.';
        return;
      }

      ctx.font = font;
      ctx.fillStyle = ink;
      ctx.textBaseline = 'top';

      let y = PADDING;
      for (const line of lines) {
        if (!line) {
          y += lineHeight * 0.6;
          continue;
        }
        const jitter = (Math.random() - 0.5) * 1.5;
        ctx.save();
        ctx.translate(PADDING + jitter, y);
        ctx.transform(1, 0, style.slant, 1, 0, 0);
        ctx.fillText(line, 0, 0);
        ctx.restore();
        y += lineHeight;
      }

      downloadBtn.disabled = false;
      statusEl.textContent = 'Preview ready — download as PNG when you like it.';
    }

    function downloadPng(): void {
      canvas.toBlob((blob) => {
        if (!blob) {
          statusEl.textContent = 'Export failed — try again.';
          return;
        }
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'handwriting-note.png';
        link.click();
        URL.revokeObjectURL(url);
        statusEl.textContent = 'PNG downloaded.';
      }, 'image/png');
    }

    renderBtn.addEventListener('click', renderHandwriting);
    downloadBtn.addEventListener('click', downloadPng);

    textEl.addEventListener('input', () => {
      downloadBtn.disabled = true;
      statusEl.textContent = '';
    });

    fontEl.addEventListener('change', renderHandwriting);
    inkEl.addEventListener('change', renderHandwriting);

    renderHandwriting();
  </script>
</ToolsLayout>
