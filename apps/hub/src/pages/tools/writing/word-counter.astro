---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Word & Character Counter';
const toolDescription =
  'Count words, characters, sentences, and paragraphs in real time — with reading time estimates. 100% private, runs offline in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="word-counter">
    <header class="mb-6">
      <a href="/tools/writing" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Distraction-free counting — your draft stays on this device only.
      </p>
    </header>

    <!-- Live stats ribbon -->
    <section
      class="mb-4 rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/40 to-slate-900/60 p-4 shadow-lg sm:p-5"
      aria-label="Live text statistics"
      aria-live="polite"
    >
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 px-3 py-3 text-center">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Words</p>
          <p id="stat-words" class="mt-1 text-2xl font-bold tabular-nums text-emerald-400">0</p>
        </div>
        <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 px-3 py-3 text-center">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Characters</p>
          <p id="stat-chars" class="mt-1 text-2xl font-bold tabular-nums text-white">0</p>
        </div>
        <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 px-3 py-3 text-center">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">No spaces</p>
          <p id="stat-chars-no-space" class="mt-1 text-2xl font-bold tabular-nums text-slate-300">0</p>
        </div>
        <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 px-3 py-3 text-center">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Sentences</p>
          <p id="stat-sentences" class="mt-1 text-2xl font-bold tabular-nums text-amber-400">0</p>
        </div>
        <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 px-3 py-3 text-center">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Paragraphs</p>
          <p id="stat-paragraphs" class="mt-1 text-2xl font-bold tabular-nums text-amber-400">0</p>
        </div>
        <div class="col-span-2 rounded-xl border border-slate-800/80 bg-slate-950/50 px-3 py-3 text-center sm:col-span-1">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Read time</p>
          <p id="stat-reading-time" class="mt-1 text-lg font-bold tabular-nums text-emerald-300 sm:text-xl">0 min</p>
        </div>
      </div>
    </section>

    <!-- Editor -->
    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="editor-heading"
    >
      <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <h2 id="editor-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Your text
        </h2>
        <p id="action-feedback" class="min-h-[1rem] text-xs text-emerald-400" role="status" aria-live="polite"></p>
      </div>

      <label for="draft-text" class="sr-only">Text to analyze</label>
      <textarea
        id="draft-text"
        rows="12"
        spellcheck="true"
        placeholder="Start typing or paste your essay, article, or notes here…"
        class="input-field min-h-[280px] w-full resize-none overflow-hidden leading-relaxed focus:ring-2 focus:ring-emerald-400/40"
      ></textarea>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="btn-copy" class="btn-primary text-sm" disabled>Copy to clipboard</button>
        <button type="button" id="btn-clean-spaces" class="btn-secondary text-sm" disabled>
          Remove extra spaces
        </button>
        <button type="button" id="btn-clear" class="btn-secondary text-sm">Clear</button>
      </div>
    </section>
  </div>

  <script>
    const STORAGE_KEY = 'gsm-tools:word-counter';
    const WORDS_PER_MINUTE = 200;

    const textarea = document.getElementById('draft-text') as HTMLTextAreaElement;
    const statWords = document.getElementById('stat-words')!;
    const statChars = document.getElementById('stat-chars')!;
    const statCharsNoSpace = document.getElementById('stat-chars-no-space')!;
    const statSentences = document.getElementById('stat-sentences')!;
    const statParagraphs = document.getElementById('stat-paragraphs')!;
    const statReadingTime = document.getElementById('stat-reading-time')!;
    const feedback = document.getElementById('action-feedback')!;
    const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;
    const btnCleanSpaces = document.getElementById('btn-clean-spaces') as HTMLButtonElement;
    const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

    interface TextStats {
      words: number;
      characters: number;
      charactersNoSpaces: number;
      sentences: number;
      paragraphs: number;
      readingMinutes: number;
    }

    function countWords(text: string): number {
      const trimmed = text.trim();
      if (!trimmed) return 0;
      const matches = trimmed.match(/\S+/g);
      return matches ? matches.length : 0;
    }

    function countSentences(text: string): number {
      const trimmed = text.trim();
      if (!trimmed) return 0;

      const matches = trimmed.match(/[^.!?]+[.!?]+|[^.!?]+$/g);
      if (!matches) return 0;

      return matches.filter((segment) => /\S/.test(segment)).length;
    }

    function countParagraphs(text: string): number {
      const trimmed = text.trim();
      if (!trimmed) return 0;

      const blocks = trimmed.split(/\n\s*\n+/);
      return blocks.filter((block) => block.trim().length > 0).length;
    }

    function estimateReadingMinutes(wordCount: number): number {
      if (wordCount === 0) return 0;
      return Math.max(1, Math.ceil(wordCount / WORDS_PER_MINUTE));
    }

    function formatReadingTime(minutes: number): string {
      if (minutes === 0) return '0 min';
      if (minutes === 1) return '1 min';
      return `${minutes} min`;
    }

    function analyzeText(text: string): TextStats {
      const words = countWords(text);
      return {
        words,
        characters: text.length,
        charactersNoSpaces: text.replace(/\s/g, '').length,
        sentences: countSentences(text),
        paragraphs: countParagraphs(text),
        readingMinutes: estimateReadingMinutes(words),
      };
    }

    function renderStats(stats: TextStats): void {
      statWords.textContent = String(stats.words);
      statChars.textContent = String(stats.characters);
      statCharsNoSpace.textContent = String(stats.charactersNoSpaces);
      statSentences.textContent = String(stats.sentences);
      statParagraphs.textContent = String(stats.paragraphs);
      statReadingTime.textContent = formatReadingTime(stats.readingMinutes);
    }

    function autoResize(): void {
      textarea.style.height = 'auto';
      textarea.style.height = `${Math.max(280, textarea.scrollHeight)}px`;
    }

    function setActionButtonsEnabled(hasText: boolean): void {
      btnCopy.disabled = !hasText;
      btnCleanSpaces.disabled = !hasText;
    }

    function saveText(text: string): void {
      try {
        localStorage.setItem(STORAGE_KEY, text);
      } catch {
        /* quota / private mode */
      }
    }

    function loadText(): string {
      try {
        return localStorage.getItem(STORAGE_KEY) ?? '';
      } catch {
        return '';
      }
    }

    function showFeedback(message: string, durationMs = 2500): void {
      feedback.textContent = message;
      if (durationMs > 0) {
        window.setTimeout(() => {
          if (feedback.textContent === message) feedback.textContent = '';
        }, durationMs);
      }
    }

    function updateAll(): void {
      const text = textarea.value;
      renderStats(analyzeText(text));
      setActionButtonsEnabled(text.length > 0);
      autoResize();
      saveText(text);
    }

    function removeExtraSpaces(text: string): string {
      const lines = text.split('\n');
      const cleanedLines = lines.map((line) => line.replace(/[ \t]+/g, ' ').trim());
      return cleanedLines
        .join('\n')
        .replace(/\n{3,}/g, '\n\n')
        .trim();
    }

    textarea.addEventListener('input', updateAll);

    btnClear.addEventListener('click', () => {
      textarea.value = '';
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
      updateAll();
      textarea.focus();
      showFeedback('Text cleared.');
    });

    btnCleanSpaces.addEventListener('click', () => {
      const before = textarea.value;
      const after = removeExtraSpaces(before);
      if (after === before) {
        showFeedback('No extra spaces to remove.');
        return;
      }
      textarea.value = after;
      updateAll();
      showFeedback('Extra spaces removed.');
    });

    btnCopy.addEventListener('click', async () => {
      const text = textarea.value;
      if (!text) return;

      try {
        await navigator.clipboard.writeText(text);
        showFeedback('Copied to clipboard.');
      } catch {
        textarea.select();
        const ok = document.execCommand('copy');
        showFeedback(ok ? 'Copied to clipboard.' : 'Copy failed — select text manually.');
      }
    });

    const saved = loadText();
    if (saved) {
      textarea.value = saved;
    }
    updateAll();
    textarea.focus();
  </script>
</ToolsLayout>
