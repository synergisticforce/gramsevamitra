---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import WordCounterTool from '../../../components/tools/WordCounterTool';
import ToolBackLink from '../../../components/tools/ToolBackLink.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Word & Character Counter';
const toolDescription =
  'Count words, characters, sentences, and paragraphs with reading time — 100% private, runs offline.';
---

<ToolsLayout title={formatSeoTitle(toolName, 'Free Online Tool')} description={toolDescription} activeNav="writing">
  <div>
    <header class="mb-6">
      <ToolBackLink href={utilitiesHref('/tools/writing')} label="← Smart Writing Studio" />
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">{toolDescription}</p>
    </header>
    <WordCounterTool client:load />
  </div>
</ToolsLayout>
