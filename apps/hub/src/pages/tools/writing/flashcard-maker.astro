---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Flashcard Maker';
const toolDescription =
  'Build a personal study deck with front/back cards — flip through them in study mode. Saved locally on your device.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="flashcard-maker">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/writing')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Create flashcards for revision — stored in your browser, works offline.
      </p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="fc-add-heading"
    >
      <h2 id="fc-add-heading" class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">
        Add card
      </h2>

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Front (question / term)</span>
          <input id="fc-front" type="text" placeholder="e.g. Photosynthesis" class="input-field w-full text-sm" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Back (answer / definition)</span>
          <input
            id="fc-back"
            type="text"
            placeholder="e.g. Process plants use to convert light to energy"
            class="input-field w-full text-sm"
          />
        </label>
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="fc-add" class="btn-primary text-sm">Add card</button>
        <button type="button" id="fc-study" class="btn-secondary text-sm" disabled>Study mode</button>
      </div>
      <p id="fc-status" class="mt-2 text-xs text-emerald-400" role="status" aria-live="polite"></p>
    </section>

    <!-- Study mode overlay -->
    <section
      id="fc-study-panel"
      class="mt-4 hidden rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/40 to-slate-900/60 p-4 shadow-lg sm:p-6"
      aria-label="Study mode"
    >
      <div class="flex items-center justify-between gap-2">
        <p id="fc-study-progress" class="text-xs font-semibold uppercase tracking-wider text-slate-500">
          Card 1 of 1
        </p>
        <button type="button" id="fc-exit-study" class="text-xs font-semibold text-slate-400 hover:text-white">
          Exit study
        </button>
      </div>

      <button
        type="button"
        id="fc-flip-card"
        class="mt-4 flex min-h-[200px] w-full flex-col items-center justify-center rounded-2xl border border-slate-700 bg-slate-950/60 p-6 text-center transition hover:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-400"
        aria-live="polite"
      >
        <p id="fc-card-face" class="text-lg font-medium text-white sm:text-xl"></p>
        <p class="mt-3 text-xs text-slate-500">Tap to flip</p>
      </button>

      <div class="mt-4 flex flex-wrap justify-center gap-2">
        <button type="button" id="fc-prev" class="btn-secondary text-sm">Previous</button>
        <button type="button" id="fc-shuffle" class="btn-secondary text-sm">Shuffle</button>
        <button type="button" id="fc-next" class="btn-secondary text-sm">Next</button>
      </div>
    </section>

    <section
      class="mt-4 rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="fc-deck-heading"
    >
      <div class="mb-3 flex items-center justify-between gap-2">
        <h2 id="fc-deck-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Your deck (<span id="fc-count">0</span>)
        </h2>
        <button type="button" id="fc-clear-deck" class="text-xs text-slate-500 hover:text-amber-400" disabled>
          Clear deck
        </button>
      </div>
      <ul id="fc-list" class="space-y-2" role="list"></ul>
      <p id="fc-empty" class="text-sm text-slate-500">No cards yet — add your first one above.</p>
    </section>
  </div>

  <style>
    .fc-item {
      @apply flex items-start justify-between gap-3 rounded-xl border border-slate-800 bg-slate-950/50 p-3;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:flashcards';

    interface Flashcard {
      id: string;
      front: string;
      back: string;
    }

    const frontEl = document.getElementById('fc-front') as HTMLInputElement;
    const backEl = document.getElementById('fc-back') as HTMLInputElement;
    const addBtn = document.getElementById('fc-add') as HTMLButtonElement;
    const studyBtn = document.getElementById('fc-study') as HTMLButtonElement;
    const statusEl = document.getElementById('fc-status')!;
    const studyPanel = document.getElementById('fc-study-panel')!;
    const studyProgress = document.getElementById('fc-study-progress')!;
    const exitStudyBtn = document.getElementById('fc-exit-study') as HTMLButtonElement;
    const flipCardBtn = document.getElementById('fc-flip-card') as HTMLButtonElement;
    const cardFaceEl = document.getElementById('fc-card-face')!;
    const prevBtn = document.getElementById('fc-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('fc-next') as HTMLButtonElement;
    const shuffleBtn = document.getElementById('fc-shuffle') as HTMLButtonElement;
    const listEl = document.getElementById('fc-list')!;
    const countEl = document.getElementById('fc-count')!;
    const emptyEl = document.getElementById('fc-empty')!;
    const clearDeckBtn = document.getElementById('fc-clear-deck') as HTMLButtonElement;

    let cards: Flashcard[] = [];
    let studyOrder: Flashcard[] = [];
    let studyIndex = 0;
    let showingBack = false;
    let inStudy = false;

    function uid(): string {
      return `${Date.now()}-${Math.random().toString(36).slice(2, 9)}`;
    }

    function loadCards(): Flashcard[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw) as Flashcard[];
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function saveCards(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(cards));
      } catch {
        statusEl.textContent = 'Could not save — storage may be full.';
      }
    }

    function showStatus(msg: string): void {
      statusEl.textContent = msg;
      window.setTimeout(() => {
        if (statusEl.textContent === msg) statusEl.textContent = '';
      }, 2500);
    }

    function renderDeck(): void {
      countEl.textContent = String(cards.length);
      studyBtn.disabled = cards.length === 0;
      clearDeckBtn.disabled = cards.length === 0;
      emptyEl.classList.toggle('hidden', cards.length > 0);
      listEl.innerHTML = '';

      for (const card of cards) {
        const li = document.createElement('li');
        li.className = 'fc-item';
        li.innerHTML = `
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-white">${escapeHtml(card.front)}</p>
            <p class="mt-0.5 text-xs text-slate-400">${escapeHtml(card.back)}</p>
          </div>
          <button type="button" class="shrink-0 text-xs text-slate-500 hover:text-red-400" data-delete="${card.id}" aria-label="Delete card">Delete</button>
        `;
        listEl.appendChild(li);
      }

      listEl.querySelectorAll<HTMLButtonElement>('[data-delete]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.delete;
          cards = cards.filter((c) => c.id !== id);
          saveCards();
          renderDeck();
          if (inStudy) exitStudy();
          showStatus('Card deleted.');
        });
      });
    }

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderStudyCard(): void {
      if (!studyOrder.length) return;
      const card = studyOrder[studyIndex];
      cardFaceEl.textContent = showingBack ? card.back : card.front;
      studyProgress.textContent = `Card ${studyIndex + 1} of ${studyOrder.length}`;
      prevBtn.disabled = studyIndex === 0;
      nextBtn.disabled = studyIndex === studyOrder.length - 1;
    }

    function enterStudy(): void {
      if (!cards.length) return;
      inStudy = true;
      studyOrder = [...cards];
      studyIndex = 0;
      showingBack = false;
      studyPanel.classList.remove('hidden');
      renderStudyCard();
      studyPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function exitStudy(): void {
      inStudy = false;
      studyPanel.classList.add('hidden');
    }

    addBtn.addEventListener('click', () => {
      const front = frontEl.value.trim();
      const back = backEl.value.trim();
      if (!front || !back) {
        showStatus('Enter both front and back.');
        return;
      }
      cards.push({ id: uid(), front, back });
      saveCards();
      frontEl.value = '';
      backEl.value = '';
      frontEl.focus();
      renderDeck();
      showStatus('Card added.');
    });

    [frontEl, backEl].forEach((el) => {
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') addBtn.click();
      });
    });

    studyBtn.addEventListener('click', enterStudy);
    exitStudyBtn.addEventListener('click', exitStudy);

    flipCardBtn.addEventListener('click', () => {
      showingBack = !showingBack;
      renderStudyCard();
    });

    prevBtn.addEventListener('click', () => {
      if (studyIndex > 0) {
        studyIndex--;
        showingBack = false;
        renderStudyCard();
      }
    });

    nextBtn.addEventListener('click', () => {
      if (studyIndex < studyOrder.length - 1) {
        studyIndex++;
        showingBack = false;
        renderStudyCard();
      }
    });

    shuffleBtn.addEventListener('click', () => {
      for (let i = studyOrder.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [studyOrder[i], studyOrder[j]] = [studyOrder[j], studyOrder[i]];
      }
      studyIndex = 0;
      showingBack = false;
      renderStudyCard();
      showStatus('Deck shuffled.');
    });

    clearDeckBtn.addEventListener('click', () => {
      if (!cards.length) return;
      if (!confirm('Delete all flashcards? This cannot be undone.')) return;
      cards = [];
      saveCards();
      renderDeck();
      exitStudy();
      showStatus('Deck cleared.');
    });

    cards = loadCards();
    renderDeck();
  </script>
</ToolsLayout>
