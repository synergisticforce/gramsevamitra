---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { getWorkspaceMeta } from '../../../config/toolsRegistry';
import { formatSeoTitle } from '@shared/config/seo';

const workspace = getWorkspaceMeta('writing');
---

<ToolsLayout
  title={formatSeoTitle('Smart Writing Studio', 'Markdown Editor')}
  description={workspace.description}
  activeNav="writing"
>
  <div class="writing-studio">
    <header class="mb-5">
      <a href="/tools" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← All utilities
      </a>
      <div class="mt-3 flex items-start gap-3">
        <span class="text-3xl" aria-hidden="true">{workspace.emoji}</span>
        <div>
          <h1 class="text-2xl font-extrabold text-white sm:text-3xl">{workspace.label}</h1>
          <p class="mt-1 max-w-2xl text-sm text-slate-400">
            Write in Markdown on the left — see live preview on the right. Saved automatically on your device.
          </p>
        </div>
      </div>
    </header>

    <div class="grid min-h-[520px] gap-4 lg:grid-cols-2 lg:gap-5">
      <!-- Editor pane -->
      <section
        class="flex min-h-[280px] flex-col rounded-2xl border border-slate-800 bg-slate-900/60 shadow-xl"
        aria-labelledby="editor-heading"
      >
        <div class="flex flex-wrap items-center justify-between gap-2 border-b border-slate-800 px-3 py-2 sm:px-4">
          <h2 id="editor-heading" class="text-xs font-semibold uppercase tracking-wider text-slate-500">
            Markdown
          </h2>
          <div class="flex flex-wrap gap-1" role="toolbar" aria-label="Markdown formatting">
            <button type="button" class="toolbar-btn" data-action="bold" title="Bold">B</button>
            <button type="button" class="toolbar-btn" data-action="italic" title="Italic"><em>I</em></button>
            <button type="button" class="toolbar-btn" data-action="link" title="Link">Link</button>
            <button type="button" class="toolbar-btn" data-action="list" title="Bullet list">• List</button>
            <button type="button" class="toolbar-btn" data-action="h1" title="Heading 1">H1</button>
            <button type="button" class="toolbar-btn" data-action="quote" title="Blockquote">“</button>
          </div>
        </div>

        <label for="md-input" class="sr-only">Markdown source</label>
        <textarea
          id="md-input"
          class="md-input min-h-[240px] flex-1 resize-none border-0 bg-transparent px-4 py-3 font-mono text-sm leading-relaxed text-slate-100 placeholder:text-slate-600 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-emerald-400/40"
          placeholder="# Start writing…&#10;&#10;Use **bold**, *italic*, lists, and &gt; quotes."
          spellcheck="true"
        ></textarea>

        <div class="border-t border-slate-800 px-4 py-2 text-xs text-slate-500">
          <span id="char-count">0 characters</span>
          <span class="mx-2" aria-hidden="true">·</span>
          <span class="text-emerald-500/80">Auto-saved locally</span>
        </div>
      </section>

      <!-- Preview pane -->
      <section
        class="flex min-h-[280px] flex-col rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/30 to-slate-900/60 shadow-xl"
        aria-labelledby="preview-heading"
      >
        <div class="border-b border-emerald-900/30 px-4 py-2">
          <h2 id="preview-heading" class="text-xs font-semibold uppercase tracking-wider text-emerald-400/80">
            Live preview
          </h2>
        </div>
        <div
          id="md-preview"
          class="md-preview flex-1 overflow-y-auto px-4 py-4 text-sm leading-relaxed text-slate-200"
          aria-live="polite"
        >
          <p class="text-slate-500">Preview appears here as you type.</p>
        </div>
      </section>
    </div>
  </div>

  <style>
    .toolbar-btn {
      @apply rounded-lg border border-slate-700 bg-slate-950/60 px-2.5 py-1 text-xs font-semibold text-slate-300 transition hover:border-emerald-600 hover:bg-emerald-950/40 hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
    .md-preview :global(h1) {
      @apply mb-3 mt-1 text-2xl font-bold text-white;
    }
    .md-preview :global(h2) {
      @apply mb-2 mt-4 text-xl font-bold text-white;
    }
    .md-preview :global(h3) {
      @apply mb-2 mt-3 text-lg font-semibold text-emerald-200;
    }
    .md-preview :global(p) {
      @apply mb-3 text-slate-300;
    }
    .md-preview :global(ul) {
      @apply mb-3 list-disc space-y-1 pl-5 text-slate-300;
    }
    .md-preview :global(blockquote) {
      @apply mb-3 border-l-4 border-emerald-600/60 bg-emerald-950/20 py-1 pl-4 italic text-slate-400;
    }
    .md-preview :global(a) {
      @apply font-medium text-emerald-400 underline decoration-emerald-600/50 underline-offset-2 hover:text-emerald-300;
    }
    .md-preview :global(strong) {
      @apply font-bold text-white;
    }
    .md-preview :global(em) {
      @apply italic text-slate-200;
    }
    .md-preview :global(hr) {
      @apply my-4 border-slate-700;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:writing-markdown';

    const textarea = document.getElementById('md-input') as HTMLTextAreaElement;
    const preview = document.getElementById('md-preview')!;
    const charCount = document.getElementById('char-count')!;
    const toolbar = document.querySelector('[role="toolbar"]')!;

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function sanitizeUrl(url: string): string {
      const trimmed = url.trim();
      if (/^https?:\/\//i.test(trimmed) || /^mailto:/i.test(trimmed)) return trimmed;
      if (trimmed.startsWith('/') || trimmed.startsWith('#')) return trimmed;
      return '#';
    }

    function parseInline(text: string): string {
      let out = escapeHtml(text);

      out = out.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_match, label, url) => {
        const safeUrl = sanitizeUrl(String(url));
        const safeLabel = escapeHtml(String(label));
        return `<a href="${safeUrl}" rel="noopener noreferrer">${safeLabel}</a>`;
      });

      out = out.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      out = out.replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '<em>$1</em>');

      return out;
    }

    function closeList(lines: string[], html: string[]): void {
      if (lines.length > 0) {
        html.push(`<ul>${lines.map((li) => `<li>${parseInline(li)}</li>`).join('')}</ul>`);
        lines.length = 0;
      }
    }

    function parseMarkdown(source: string): string {
      const raw = source.replace(/\r\n/g, '\n');
      if (!raw.trim()) {
        return '<p class="text-slate-500">Preview appears here as you type.</p>';
      }

      const html: string[] = [];
      const listBuffer: string[] = [];
      const blocks = raw.split(/\n\n+/);

      for (const block of blocks) {
        const lines = block.split('\n');
        const first = lines[0];

        const heading = first.match(/^(#{1,3})\s+(.+)$/);
        if (heading && lines.length === 1) {
          closeList(listBuffer, html);
          const level = heading[1].length;
          html.push(`<h${level}>${parseInline(heading[2])}</h${level}>`);
          continue;
        }

        if (lines.every((line) => /^>\s?/.test(line))) {
          closeList(listBuffer, html);
          const quoteText = lines.map((line) => line.replace(/^>\s?/, '')).join(' ');
          html.push(`<blockquote><p>${parseInline(quoteText)}</p></blockquote>`);
          continue;
        }

        if (lines.every((line) => /^-\s+/.test(line))) {
          closeList(listBuffer, html);
          lines.forEach((line) => listBuffer.push(line.replace(/^-\s+/, '')));
          closeList(listBuffer, html);
          continue;
        }

        closeList(listBuffer, html);
        const paragraph = lines.join(' ').trim();
        if (paragraph) {
          html.push(`<p>${parseInline(paragraph)}</p>`);
        }
      }

      closeList(listBuffer, html);
      return html.join('') || '<p class="text-slate-500">Preview appears here as you type.</p>';
    }

    function saveMarkdown(value: string): void {
      try {
        localStorage.setItem(STORAGE_KEY, value);
      } catch {
        /* ignore */
      }
    }

    function loadMarkdown(): string {
      try {
        return localStorage.getItem(STORAGE_KEY) ?? '';
      } catch {
        return '';
      }
    }

    function updatePreview(): void {
      const value = textarea.value;
      preview.innerHTML = parseMarkdown(value);
      charCount.textContent = `${value.length} character${value.length === 1 ? '' : 's'}`;
      saveMarkdown(value);
    }

    function insertAtCursor(before: string, after: string, placeholder: string): void {
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const text = textarea.value;
      const selected = text.slice(start, end) || placeholder;
      const next = text.slice(0, start) + before + selected + after + text.slice(end);
      textarea.value = next;
      const cursor = start + before.length + selected.length + after.length;
      textarea.setSelectionRange(cursor, cursor);
      textarea.focus();
      updatePreview();
    }

    function insertLinePrefix(prefix: string): void {
      const start = textarea.selectionStart;
      const text = textarea.value;
      const lineStart = text.lastIndexOf('\n', start - 1) + 1;
      const lineEnd = text.indexOf('\n', start);
      const end = lineEnd === -1 ? text.length : lineEnd;
      const line = text.slice(lineStart, end);
      const stripped = line.replace(/^#+\s+/, '').replace(/^>\s?/, '').replace(/^-\s+/, '');
      const nextLine = prefix + stripped;
      textarea.value = text.slice(0, lineStart) + nextLine + text.slice(end);
      textarea.setSelectionRange(lineStart + nextLine.length, lineStart + nextLine.length);
      textarea.focus();
      updatePreview();
    }

    toolbar.addEventListener('click', (event) => {
      const btn = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-action]');
      if (!btn) return;
      const action = btn.dataset.action;

      switch (action) {
        case 'bold':
          insertAtCursor('**', '**', 'bold text');
          break;
        case 'italic':
          insertAtCursor('*', '*', 'italic text');
          break;
        case 'link':
          insertAtCursor('[', '](https://)', 'link text');
          break;
        case 'list':
          insertLinePrefix('- ');
          break;
        case 'h1':
          insertLinePrefix('# ');
          break;
        case 'quote':
          insertLinePrefix('> ');
          break;
        default:
          break;
      }
    });

    textarea.addEventListener('input', updatePreview);

    const saved = loadMarkdown();
    if (saved) {
      textarea.value = saved;
    } else {
      textarea.value = `# Welcome to Smart Writing Studio

Write in **Markdown** and preview instantly.

- Jot exam notes
- Draft cover letters
- Outline essays

> Your words never leave this device.`;
    }

    updatePreview();
  </script>
</ToolsLayout>
