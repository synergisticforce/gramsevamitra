---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Phonetic Alphabet (IPA)';
const toolDescription =
  'Convert English words to approximate IPA phonetic notation using a client-side letter and digraph mapping table.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="phonetic-alphabet">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/writing')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Rough IPA-style transcription for English words — educational approximation, not dictionary-perfect.
      </p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="ipa-input-heading"
    >
      <h2 id="ipa-input-heading" class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">
        Convert word
      </h2>

      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-300">English word or phrase</span>
        <input
          id="ipa-input"
          type="text"
          spellcheck="false"
          autocomplete="off"
          placeholder="e.g. philosophy, through, thought"
          class="input-field w-full text-sm"
        />
      </label>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="ipa-convert" class="btn-primary text-sm">Convert</button>
        <button type="button" id="ipa-copy" class="btn-secondary text-sm" disabled>Copy IPA</button>
        <button type="button" id="ipa-clear" class="btn-secondary text-sm">Clear</button>
      </div>
    </section>

    <section
      class="mt-4 rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/40 to-slate-900/60 p-4 shadow-lg sm:p-5"
      aria-label="Phonetic output"
    >
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">IPA approximation</p>
      <p id="ipa-output" class="mt-2 font-mono text-2xl text-emerald-300 sm:text-3xl">/ /</p>
      <p id="ipa-breakdown" class="mt-3 text-sm leading-relaxed text-slate-400"></p>
    </section>

    <section
      class="mt-4 rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="ipa-ref-heading"
    >
      <h2 id="ipa-ref-heading" class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">
        Common digraph reference
      </h2>
      <div id="ipa-ref-grid" class="grid grid-cols-2 gap-2 text-xs sm:grid-cols-4"></div>
    </section>
  </div>

  <script>
    const DIGRAPHS: [string, string][] = [
      ['th', 'θ'],
      ['sh', 'ʃ'],
      ['ch', 'tʃ'],
      ['ng', 'ŋ'],
      ['ph', 'f'],
      ['wh', 'w'],
      ['ck', 'k'],
      ['gh', ''],
      ['kn', 'n'],
      ['wr', 'r'],
      ['tion', 'ʃən'],
      ['sion', 'ʒən'],
      ['ough', 'ʌf'],
      ['augh', 'ɔː'],
      ['ea', 'iː'],
      ['ee', 'iː'],
      ['oo', 'uː'],
      ['ou', 'aʊ'],
      ['ow', 'aʊ'],
      ['oi', 'ɔɪ'],
      ['oy', 'ɔɪ'],
      ['ai', 'eɪ'],
      ['ay', 'eɪ'],
      ['ei', 'eɪ'],
      ['ey', 'eɪ'],
      ['au', 'ɔː'],
      ['aw', 'ɔː'],
      ['ie', 'aɪ'],
      ['igh', 'aɪ'],
    ];

    const LETTERS: Record<string, string> = {
      a: 'æ',
      b: 'b',
      c: 'k',
      d: 'd',
      e: 'ɛ',
      f: 'f',
      g: 'ɡ',
      h: 'h',
      i: 'ɪ',
      j: 'dʒ',
      k: 'k',
      l: 'l',
      m: 'm',
      n: 'n',
      o: 'ɒ',
      p: 'p',
      q: 'k',
      r: 'ɹ',
      s: 's',
      t: 't',
      u: 'ʌ',
      v: 'v',
      w: 'w',
      x: 'ks',
      y: 'j',
      z: 'z',
    };

    const VOWEL_HINTS: Record<string, string> = {
      a: 'æ',
      e: 'iː',
      i: 'aɪ',
      o: 'oʊ',
      u: 'juː',
    };

    const inputEl = document.getElementById('ipa-input') as HTMLInputElement;
    const outputEl = document.getElementById('ipa-output')!;
    const breakdownEl = document.getElementById('ipa-breakdown')!;
    const convertBtn = document.getElementById('ipa-convert') as HTMLButtonElement;
    const copyBtn = document.getElementById('ipa-copy') as HTMLButtonElement;
    const clearBtn = document.getElementById('ipa-clear') as HTMLButtonElement;
    const refGrid = document.getElementById('ipa-ref-grid')!;

    interface Segment {
      source: string;
      ipa: string;
    }

    function wordToIpa(word: string): { ipa: string; segments: Segment[] } {
      const lower = word.toLowerCase().replace(/[^a-z']/g, '');
      if (!lower) return { ipa: '', segments: [] };

      const segments: Segment[] = [];
      let i = 0;
      let ipa = '';

      const sortedDigraphs = [...DIGRAPHS].sort((a, b) => b[0].length - a[0].length);

      while (i < lower.length) {
        let matched = false;

        for (const [dig, sound] of sortedDigraphs) {
          if (lower.startsWith(dig, i)) {
            segments.push({ source: dig, ipa: sound || '—' });
            ipa += sound;
            i += dig.length;
            matched = true;
            break;
          }
        }
        if (matched) continue;

        const ch = lower[i];
        if (ch === "'") {
          i++;
          continue;
        }

        let sound = LETTERS[ch] ?? ch;

        if (
          (ch === 'a' || ch === 'e' || ch === 'i' || ch === 'o' || ch === 'u') &&
          i === lower.length - 1 &&
          lower.length > 2
        ) {
          sound = VOWEL_HINTS[ch] ?? sound;
        }

        if (ch === 'e' && i === lower.length - 1 && lower.length > 3) {
          sound = '';
        }

        if (ch === 'y' && i > 0) sound = 'i';

        segments.push({ source: ch, ipa: sound || '—' });
        ipa += sound;
        i++;
      }

      return { ipa: ipa || '—', segments };
    }

    function convertPhrase(text: string): string {
      const words = text.trim().split(/\s+/).filter(Boolean);
      if (!words.length) return '';
      return words
        .map((w) => {
          const { ipa } = wordToIpa(w);
          return ipa ? `/${ipa}/` : '';
        })
        .join(' ');
    }

    function convert(): void {
      const text = inputEl.value.trim();
      if (!text) {
        outputEl.textContent = '/ /';
        breakdownEl.textContent = 'Enter a word or phrase above.';
        copyBtn.disabled = true;
        return;
      }

      const words = text.split(/\s+/).filter(Boolean);
      const allSegments: string[] = [];

      for (const word of words) {
        const { ipa, segments } = wordToIpa(word);
        outputEl.textContent = convertPhrase(text);
        const breakdown = segments.map((s) => `${s.source} → ${s.ipa}`).join(' · ');
        allSegments.push(`<strong class="text-slate-300">${word}</strong>: ${breakdown}`);
      }

      breakdownEl.innerHTML = allSegments.join('<br>');
      copyBtn.disabled = false;
    }

    convertBtn.addEventListener('click', convert);
    inputEl.addEventListener('input', () => {
      if (!inputEl.value.trim()) {
        outputEl.textContent = '/ /';
        breakdownEl.textContent = '';
        copyBtn.disabled = true;
      }
    });
    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') convert();
    });

    copyBtn.addEventListener('click', async () => {
      const text = outputEl.textContent ?? '';
      if (!text || text === '/ /') return;
      try {
        await navigator.clipboard.writeText(text);
        breakdownEl.insertAdjacentHTML('beforeend', '<br><span class="text-emerald-400">Copied!</span>');
        window.setTimeout(convert, 1500);
      } catch {
        breakdownEl.textContent += ' Copy failed.';
      }
    });

    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      outputEl.textContent = '/ /';
      breakdownEl.textContent = '';
      copyBtn.disabled = true;
      inputEl.focus();
    });

    for (const [dig, ipa] of DIGRAPHS.slice(0, 16)) {
      const cell = document.createElement('div');
      cell.className = 'rounded-lg border border-slate-800 bg-slate-950/50 px-2 py-1.5 font-mono';
      cell.innerHTML = `<span class="text-slate-400">${dig}</span> <span class="text-emerald-400">→ ${ipa || '∅'}</span>`;
      refGrid.appendChild(cell);
    }
  </script>
</ToolsLayout>
