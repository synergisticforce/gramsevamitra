---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Case Converter';
const toolDescription =
  'Convert text to UPPERCASE, lowercase, Title Case, Sentence case, or aLtErNaTiNg — copy-ready, 100% offline.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="case-converter">
    <header class="mb-6">
      <a href="/tools/writing" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">Instant text casing — processed locally on your device.</p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
      aria-labelledby="case-heading"
    >
      <h2 id="case-heading" class="sr-only">Text input and case actions</h2>

      <div class="flex flex-wrap gap-2" role="toolbar" aria-label="Case conversion options">
        <button type="button" class="case-btn" data-case="upper">UPPERCASE</button>
        <button type="button" class="case-btn" data-case="lower">lowercase</button>
        <button type="button" class="case-btn" data-case="title">Title Case</button>
        <button type="button" class="case-btn" data-case="sentence">Sentence case</button>
        <button type="button" class="case-btn" data-case="alternating">Alternating</button>
      </div>

      <label class="mt-4 block">
        <span class="mb-1 block text-sm font-medium text-slate-300">Your text</span>
        <textarea
          id="case-input"
          rows="12"
          class="input-field w-full resize-y text-sm leading-relaxed"
          placeholder="Paste or type text here, then tap a case style above…"
          spellcheck="true"
        ></textarea>
      </label>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="case-copy" class="btn-primary flex-1 text-sm" disabled>Copy to clipboard</button>
        <button type="button" id="case-clear" class="btn-secondary text-sm">Clear</button>
      </div>

      <p id="case-status" class="mt-2 text-center text-xs text-slate-500" aria-live="polite"></p>
    </section>
  </div>

  <style>
    .case-btn {
      @apply rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-2 text-xs font-semibold text-slate-300 transition hover:border-emerald-600 hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:case-converter';

    const inputEl = document.getElementById('case-input') as HTMLTextAreaElement;
    const copyBtn = document.getElementById('case-copy') as HTMLButtonElement;
    const clearBtn = document.getElementById('case-clear') as HTMLButtonElement;
    const statusEl = document.getElementById('case-status')!;

    function toTitleCase(text: string): string {
      return text.replace(/\w\S*/g, (word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase());
    }

    function toSentenceCase(text: string): string {
      const lower = text.toLowerCase();
      return lower.replace(/(^\s*\w|[.!?]\s+\w)/g, (match) => match.toUpperCase());
    }

    function toAlternatingCase(text: string): string {
      let upper = true;
      return text
        .split('')
        .map((char) => {
          if (/[a-zA-Z]/.test(char)) {
            const out = upper ? char.toUpperCase() : char.toLowerCase();
            upper = !upper;
            return out;
          }
          return char;
        })
        .join('');
    }

    function applyCase(mode: string): void {
      const text = inputEl.value;
      if (!text) return;

      let next = text;
      switch (mode) {
        case 'upper':
          next = text.toUpperCase();
          break;
        case 'lower':
          next = text.toLowerCase();
          break;
        case 'title':
          next = toTitleCase(text);
          break;
        case 'sentence':
          next = toSentenceCase(text);
          break;
        case 'alternating':
          next = toAlternatingCase(text);
          break;
        default:
          break;
      }

      inputEl.value = next;
      copyBtn.disabled = !next;
      statusEl.textContent = `Applied ${mode} case.`;
      saveText();
    }

    function saveText(): void {
      try {
        localStorage.setItem(STORAGE_KEY, inputEl.value);
      } catch {
        /* ignore */
      }
    }

    document.querySelectorAll<HTMLButtonElement>('.case-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.case;
        if (mode) applyCase(mode);
      });
    });

    inputEl.addEventListener('input', () => {
      copyBtn.disabled = !inputEl.value;
      saveText();
    });

    copyBtn.addEventListener('click', async () => {
      if (!inputEl.value) return;
      try {
        await navigator.clipboard.writeText(inputEl.value);
        statusEl.textContent = 'Copied to clipboard.';
      } catch {
        statusEl.textContent = 'Copy failed — select text manually.';
      }
    });

    clearBtn.addEventListener('click', () => {
      inputEl.value = '';
      copyBtn.disabled = true;
      statusEl.textContent = '';
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        inputEl.value = saved;
        copyBtn.disabled = !saved;
      }
    } catch {
      /* ignore */
    }
  </script>
</ToolsLayout>
