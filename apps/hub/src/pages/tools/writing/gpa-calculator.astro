---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'GPA / SGPA Calculator';
const toolDescription =
  'Calculate semester SGPA from subject credits and Indian 10-point grades (O, A+, A, B+, B, C, P, F) — saved locally on your device.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="gpa-calculator pb-36 md:pb-28">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/writing')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Add your subjects, credits, and grades — SGPA updates instantly. Data stays in your browser only.
      </p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="subjects-heading"
    >
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
        <h2 id="subjects-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Semester subjects
        </h2>
        <button type="button" id="add-subject" class="btn-primary px-4 py-2 text-sm">+ Add subject</button>
      </div>

      <!-- Desktop table header -->
      <div
        class="mb-2 hidden gap-2 px-1 text-[10px] font-semibold uppercase tracking-wider text-slate-500 sm:grid sm:grid-cols-[minmax(0,1fr)_5.5rem_6.5rem_2.5rem]"
        aria-hidden="true"
      >
        <span>Subject</span>
        <span>Credits</span>
        <span>Grade</span>
        <span class="sr-only">Remove</span>
      </div>

      <div id="subjects-container" class="space-y-3"></div>

      <p class="mt-4 text-xs text-slate-500">
        10-point scale: O=10, A+=9, A=8, B+=7, B=6, C=5, P=4, F=0. SGPA = Σ(grade point × credits) ÷ Σ credits.
      </p>
    </section>

    <!-- Sticky results panel -->
    <div
      id="results-panel"
      class="fixed bottom-20 left-0 right-0 z-20 border-t border-slate-800 bg-slate-950/95 px-4 py-4 backdrop-blur-md md:bottom-0"
      role="region"
      aria-label="SGPA results"
      aria-live="polite"
    >
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap items-center gap-4 sm:gap-8">
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Total credits</p>
            <p id="total-credits" class="text-xl font-bold tabular-nums text-white">0</p>
          </div>
          <div>
            <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">SGPA / CGPA</p>
            <p id="sgpa-value" class="text-3xl font-extrabold tabular-nums text-emerald-400">—</p>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <span
            id="sgpa-badge"
            class="rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-wide text-slate-400 border-slate-700 bg-slate-900"
          >
            Enter grades
          </span>
          <button type="button" id="reset-semester" class="btn-secondary px-3 py-2 text-xs">Reset</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const STORAGE_KEY = 'gsm-tools:gpa-calculator';

    const GRADE_POINTS: Record<string, number> = {
      O: 10,
      'A+': 9,
      A: 8,
      'B+': 7,
      B: 6,
      C: 5,
      P: 4,
      F: 0,
    };

    const GRADE_OPTIONS = ['', 'O', 'A+', 'A', 'B+', 'B', 'C', 'P', 'F'] as const;

    interface SubjectRow {
      id: string;
      name: string;
      credits: string;
      grade: string;
    }

    const subjectsContainer = document.getElementById('subjects-container')!;
    const addSubjectBtn = document.getElementById('add-subject') as HTMLButtonElement;
    const resetBtn = document.getElementById('reset-semester') as HTMLButtonElement;
    const totalCreditsEl = document.getElementById('total-credits')!;
    const sgpaValueEl = document.getElementById('sgpa-value')!;
    const sgpaBadgeEl = document.getElementById('sgpa-badge')!;

    let rows: SubjectRow[] = [];

    function createId(): string {
      return `sub-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`;
    }

    function defaultRow(): SubjectRow {
      return { id: createId(), name: '', credits: '', grade: '' };
    }

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function gradeOptionsHtml(selected: string): string {
      return GRADE_OPTIONS.map((g) => {
        const label = g === '' ? 'Grade' : g;
        const sel = g === selected ? ' selected' : '';
        return `<option value="${g}"${sel}>${label}</option>`;
      }).join('');
    }

    function renderRow(row: SubjectRow, index: number): string {
      const canRemove = index > 0;
      return `
        <div class="subject-row rounded-xl border border-slate-800/80 bg-slate-950/40 p-3 sm:border-0 sm:bg-transparent sm:p-0 sm:py-1" data-id="${row.id}">
          <div class="grid gap-2 sm:grid-cols-[minmax(0,1fr)_5.5rem_6.5rem_2.5rem] sm:items-center sm:gap-2">
            <label class="min-w-0">
              <span class="mb-1 block text-[10px] font-medium uppercase text-slate-500 sm:sr-only">Subject</span>
              <input
                type="text"
                class="input-field min-w-0 py-2 text-sm"
                placeholder="Subject name (optional)"
                value="${escapeHtml(row.name)}"
                data-field="name"
                autocomplete="off"
              />
            </label>
            <label class="min-w-0">
              <span class="mb-1 block text-[10px] font-medium uppercase text-slate-500 sm:sr-only">Credits</span>
              <input
                type="number"
                class="input-field w-full min-w-0 py-2 text-sm tabular-nums"
                placeholder="Cr"
                min="0"
                max="30"
                step="0.5"
                inputmode="decimal"
                value="${escapeHtml(row.credits)}"
                data-field="credits"
              />
            </label>
            <label class="min-w-0">
              <span class="mb-1 block text-[10px] font-medium uppercase text-slate-500 sm:sr-only">Grade</span>
              <select class="select-field w-full min-w-0 py-2 text-sm" data-field="grade">
                ${gradeOptionsHtml(row.grade)}
              </select>
            </label>
            <div class="flex items-end justify-end sm:items-center sm:justify-center">
              ${
                canRemove
                  ? `<button type="button" class="remove-row flex h-9 w-9 items-center justify-center rounded-lg border border-rose-900/50 bg-rose-950/30 text-sm font-bold text-rose-400 transition hover:border-rose-500 hover:bg-rose-900/40 hover:text-white" aria-label="Remove subject">✕</button>`
                  : `<span class="hidden h-9 w-9 sm:block" aria-hidden="true"></span>`
              }
            </div>
          </div>
        </div>
      `;
    }

    function renderAll(): void {
      subjectsContainer.innerHTML = rows.map((row, i) => renderRow(row, i)).join('');
    }

    function readRowFromDom(rowEl: HTMLElement): Partial<SubjectRow> {
      const nameInput = rowEl.querySelector<HTMLInputElement>('[data-field="name"]');
      const creditsInput = rowEl.querySelector<HTMLInputElement>('[data-field="credits"]');
      const gradeSelect = rowEl.querySelector<HTMLSelectElement>('[data-field="grade"]');
      return {
        name: nameInput?.value ?? '',
        credits: creditsInput?.value ?? '',
        grade: gradeSelect?.value ?? '',
      };
    }

    function syncFromDom(): void {
      const rowEls = subjectsContainer.querySelectorAll<HTMLElement>('.subject-row');
      rowEls.forEach((el) => {
        const id = el.dataset.id;
        if (!id) return;
        const row = rows.find((r) => r.id === id);
        if (!row) return;
        const partial = readRowFromDom(el);
        row.name = partial.name ?? '';
        row.credits = partial.credits ?? '';
        row.grade = partial.grade ?? '';
      });
    }

    function saveState(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(rows));
      } catch {
        /* ignore */
      }
    }

    function loadState(): SubjectRow[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [defaultRow()];
        const parsed = JSON.parse(raw) as SubjectRow[];
        if (!Array.isArray(parsed) || parsed.length === 0) return [defaultRow()];
        return parsed.map((r) => ({
          id: r.id || createId(),
          name: typeof r.name === 'string' ? r.name : '',
          credits: typeof r.credits === 'string' ? r.credits : String(r.credits ?? ''),
          grade: typeof r.grade === 'string' ? r.grade : '',
        }));
      } catch {
        return [defaultRow()];
      }
    }

    interface SgpaResult {
      totalCredits: number;
      sgpa: number | null;
      gradedSubjects: number;
    }

    function calculateSgpa(): SgpaResult {
      let totalCredits = 0;
      let weightedSum = 0;
      let gradedSubjects = 0;

      for (const row of rows) {
        const credits = parseFloat(row.credits);
        const grade = row.grade;
        if (!grade || !Number.isFinite(credits) || credits <= 0) continue;

        const points = GRADE_POINTS[grade];
        if (points === undefined) continue;

        totalCredits += credits;
        weightedSum += points * credits;
        gradedSubjects += 1;
      }

      const sgpa = totalCredits > 0 ? weightedSum / totalCredits : null;
      return { totalCredits, sgpa, gradedSubjects };
    }

    function applyBadge(sgpa: number | null): void {
      sgpaBadgeEl.className =
        'rounded-full border px-3 py-1 text-xs font-bold uppercase tracking-wide';

      if (sgpa === null) {
        sgpaBadgeEl.textContent = 'Enter grades';
        sgpaBadgeEl.classList.add('border-slate-700', 'bg-slate-900', 'text-slate-400');
        sgpaValueEl.textContent = '—';
        sgpaValueEl.className = 'text-3xl font-extrabold tabular-nums text-slate-500';
        return;
      }

      const formatted = sgpa.toFixed(2);
      sgpaValueEl.textContent = formatted;

      if (sgpa >= 8.0) {
        sgpaValueEl.className = 'text-3xl font-extrabold tabular-nums text-emerald-400';
        sgpaBadgeEl.textContent = 'Excellent';
        sgpaBadgeEl.classList.add('border-emerald-600/50', 'bg-emerald-950/60', 'text-emerald-300');
      } else if (sgpa >= 6.0) {
        sgpaValueEl.className = 'text-3xl font-extrabold tabular-nums text-amber-400';
        sgpaBadgeEl.textContent = 'Good';
        sgpaBadgeEl.classList.add('border-amber-600/50', 'bg-amber-950/60', 'text-amber-300');
      } else {
        sgpaValueEl.className = 'text-3xl font-extrabold tabular-nums text-rose-400';
        sgpaBadgeEl.textContent = 'Needs focus';
        sgpaBadgeEl.classList.add('border-rose-600/50', 'bg-rose-950/60', 'text-rose-300');
      }
    }

    function updateResults(): void {
      const { totalCredits, sgpa } = calculateSgpa();
      totalCreditsEl.textContent = Number.isInteger(totalCredits)
        ? String(totalCredits)
        : totalCredits.toFixed(1);
      applyBadge(sgpa);
    }

    function commit(): void {
      syncFromDom();
      saveState();
      updateResults();
    }

    subjectsContainer.addEventListener('input', commit);
    subjectsContainer.addEventListener('change', commit);

    subjectsContainer.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const removeBtn = target.closest('.remove-row');
      if (!removeBtn) return;

      const rowEl = removeBtn.closest<HTMLElement>('.subject-row');
      if (!rowEl?.dataset.id) return;

      syncFromDom();
      rows = rows.filter((r) => r.id !== rowEl.dataset.id);
      if (rows.length === 0) rows = [defaultRow()];
      renderAll();
      commit();
    });

    addSubjectBtn.addEventListener('click', () => {
      syncFromDom();
      rows.push(defaultRow());
      renderAll();
      commit();

      const lastRow = subjectsContainer.lastElementChild;
      const nameInput = lastRow?.querySelector<HTMLInputElement>('[data-field="name"]');
      nameInput?.focus();
    });

    resetBtn.addEventListener('click', () => {
      rows = [defaultRow()];
      renderAll();
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
      commit();
    });

    rows = loadState();
    renderAll();
    updateResults();
  </script>
</ToolsLayout>
