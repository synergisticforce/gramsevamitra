---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Speech to Text';
const toolDescription =
  'Dictate notes with your microphone using the Web Speech API — live transcript, fully processed in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="speech-to-text">
    <header class="mb-6">
      <a href="/tools/writing" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Speak into your mic and watch words appear — best in Chrome or Edge on desktop.
      </p>
    </header>

    <div
      id="stt-unsupported"
      class="hidden rounded-2xl border border-amber-900/50 bg-amber-950/30 p-4 text-sm text-amber-200"
      role="alert"
    >
      <p class="font-semibold">Speech recognition not supported</p>
      <p class="mt-1 text-amber-300/90">
        Your browser does not expose the Web Speech API. Try Chrome, Edge, or Safari on a device with a microphone.
      </p>
    </div>

    <section
      id="stt-panel"
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="stt-heading"
    >
      <h2 id="stt-heading" class="sr-only">Speech recognition controls</h2>

      <div class="flex flex-wrap items-center gap-3">
        <button type="button" id="stt-toggle" class="btn-primary text-sm">
          <span id="stt-toggle-label">Start listening</span>
        </button>
        <span
          id="stt-indicator"
          class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-950/60 px-3 py-1 text-xs text-slate-400"
        >
          <span id="stt-dot" class="h-2 w-2 rounded-full bg-slate-600" aria-hidden="true"></span>
          <span id="stt-state">Idle</span>
        </span>
      </div>

      <label class="mt-4 block">
        <span class="mb-1 block text-sm font-medium text-slate-300">Live transcript</span>
        <textarea
          id="stt-transcript"
          rows="12"
          spellcheck="true"
          placeholder="Your dictated text will appear here…"
          class="input-field w-full resize-y text-sm leading-relaxed"
        ></textarea>
      </label>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="stt-copy" class="btn-secondary text-sm" disabled>Copy transcript</button>
        <button type="button" id="stt-clear" class="btn-secondary text-sm">Clear</button>
      </div>
      <p id="stt-status" class="mt-2 text-xs text-emerald-400" role="status" aria-live="polite"></p>
    </section>
  </div>

  <script>
    const STORAGE_KEY = 'gsm-tools:speech-to-text';

    const unsupportedEl = document.getElementById('stt-unsupported')!;
    const panelEl = document.getElementById('stt-panel')!;
    const toggleBtn = document.getElementById('stt-toggle') as HTMLButtonElement;
    const toggleLabel = document.getElementById('stt-toggle-label')!;
    const dotEl = document.getElementById('stt-dot')!;
    const stateEl = document.getElementById('stt-state')!;
    const transcriptEl = document.getElementById('stt-transcript') as HTMLTextAreaElement;
    const copyBtn = document.getElementById('stt-copy') as HTMLButtonElement;
    const clearBtn = document.getElementById('stt-clear') as HTMLButtonElement;
    const statusEl = document.getElementById('stt-status')!;

    type SpeechRecognitionCtor = new () => SpeechRecognition;

    const SpeechRecognition =
      (window as Window & { SpeechRecognition?: SpeechRecognitionCtor; webkitSpeechRecognition?: SpeechRecognitionCtor })
        .SpeechRecognition ||
      (window as Window & { webkitSpeechRecognition?: SpeechRecognitionCtor }).webkitSpeechRecognition;

    let recognition: SpeechRecognition | null = null;
    let listening = false;
    let finalTranscript = '';

    function setListeningUI(active: boolean): void {
      listening = active;
      toggleLabel.textContent = active ? 'Stop listening' : 'Start listening';
      toggleBtn.classList.toggle('ring-2', active);
      toggleBtn.classList.toggle('ring-emerald-400/50', active);
      dotEl.className = active
        ? 'h-2 w-2 rounded-full bg-emerald-400 animate-pulse'
        : 'h-2 w-2 rounded-full bg-slate-600';
      stateEl.textContent = active ? 'Listening…' : 'Idle';
    }

    function updateCopyButton(): void {
      copyBtn.disabled = !transcriptEl.value.trim();
    }

    function saveTranscript(): void {
      try {
        localStorage.setItem(STORAGE_KEY, transcriptEl.value);
      } catch {
        /* ignore */
      }
    }

    function showStatus(msg: string): void {
      statusEl.textContent = msg;
      window.setTimeout(() => {
        if (statusEl.textContent === msg) statusEl.textContent = '';
      }, 4000);
    }

    if (!SpeechRecognition) {
      unsupportedEl.classList.remove('hidden');
      panelEl.classList.add('opacity-50', 'pointer-events-none');
    } else {
      recognition = new SpeechRecognition();
      recognition.continuous = true;
      recognition.interimResults = true;
      recognition.lang = navigator.language || 'en-US';

      recognition.onresult = (event: SpeechRecognitionEvent) => {
        let interim = '';
        for (let i = event.resultIndex; i < event.results.length; i++) {
          const result = event.results[i];
          const text = result[0]?.transcript ?? '';
          if (result.isFinal) {
            finalTranscript += text;
          } else {
            interim += text;
          }
        }
        transcriptEl.value = (finalTranscript + interim).trimStart();
        updateCopyButton();
        saveTranscript();
      };

      recognition.onerror = (event: SpeechRecognitionErrorEvent) => {
        if (event.error === 'aborted' || event.error === 'no-speech') return;
        showStatus(`Error: ${event.error}`);
        setListeningUI(false);
      };

      recognition.onend = () => {
        if (listening) {
          try {
            recognition?.start();
          } catch {
            setListeningUI(false);
          }
        } else {
          setListeningUI(false);
        }
      };

      toggleBtn.addEventListener('click', () => {
        if (!recognition) return;
        if (listening) {
          listening = false;
          recognition.stop();
          setListeningUI(false);
          showStatus('Stopped listening.');
        } else {
          finalTranscript = transcriptEl.value ? `${transcriptEl.value.trim()} ` : '';
          try {
            recognition.start();
            setListeningUI(true);
            showStatus('Listening — speak clearly into your microphone.');
          } catch {
            showStatus('Could not start microphone — check permissions.');
          }
        }
      });
    }

    copyBtn.addEventListener('click', async () => {
      const text = transcriptEl.value;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        showStatus('Copied to clipboard.');
      } catch {
        showStatus('Copy failed — select text manually.');
      }
    });

    clearBtn.addEventListener('click', () => {
      if (listening && recognition) {
        listening = false;
        recognition.stop();
        setListeningUI(false);
      }
      finalTranscript = '';
      transcriptEl.value = '';
      updateCopyButton();
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
      showStatus('Transcript cleared.');
    });

    transcriptEl.addEventListener('input', () => {
      finalTranscript = transcriptEl.value;
      updateCopyButton();
      saveTranscript();
    });

    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        transcriptEl.value = saved;
        finalTranscript = saved;
      }
    } catch {
      /* ignore */
    }
    updateCopyButton();
  </script>
</ToolsLayout>
