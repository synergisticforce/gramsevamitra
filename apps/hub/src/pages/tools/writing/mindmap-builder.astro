---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Mind Map Builder';
const toolDescription =
  'Brainstorm on a draggable canvas — add topic nodes, reposition them, and auto-save to your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="mindmap-builder">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/writing')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Drag nodes to arrange ideas — connections draw to a central topic automatically.
      </p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="mm-controls-heading"
    >
      <h2 id="mm-controls-heading" class="sr-only">Mind map controls</h2>

      <div class="flex flex-wrap items-end gap-3">
        <label class="min-w-[200px] flex-1">
          <span class="mb-1 block text-sm font-medium text-slate-300">New node label</span>
          <input id="mm-label" type="text" placeholder="Idea or sub-topic" class="input-field w-full text-sm" />
        </label>
        <button type="button" id="mm-add" class="btn-primary text-sm">Add node</button>
        <button type="button" id="mm-center" class="btn-secondary text-sm">Center view</button>
        <button type="button" id="mm-clear" class="btn-secondary text-sm">Clear map</button>
      </div>
      <p id="mm-status" class="mt-2 text-xs text-emerald-400" role="status" aria-live="polite"></p>
    </section>

    <section
      class="relative mt-4 overflow-hidden rounded-2xl border border-emerald-900/40 bg-slate-950/80 shadow-lg"
      aria-label="Mind map canvas"
    >
      <svg id="mm-lines" class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"></svg>
      <div
        id="mm-canvas"
        class="relative min-h-[420px] w-full touch-none sm:min-h-[480px]"
        role="application"
        aria-label="Draggable mind map nodes"
      ></div>
    </section>
  </div>

  <style>
    .mm-node {
      @apply absolute z-10 max-w-[180px] cursor-grab select-none rounded-xl border border-emerald-700/60 bg-emerald-950/80 px-3 py-2 text-center text-sm font-medium text-emerald-100 shadow-lg active:cursor-grabbing;
    }
    .mm-node-central {
      @apply border-amber-600/60 bg-amber-950/80 text-amber-100;
    }
    .mm-node-delete {
      @apply absolute -right-2 -top-2 flex h-5 w-5 items-center justify-center rounded-full border border-slate-600 bg-slate-900 text-[10px] text-slate-400 hover:border-red-500 hover:text-red-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:mindmap';

    interface MindNode {
      id: string;
      label: string;
      x: number;
      y: number;
      central?: boolean;
    }

    const labelEl = document.getElementById('mm-label') as HTMLInputElement;
    const addBtn = document.getElementById('mm-add') as HTMLButtonElement;
    const centerBtn = document.getElementById('mm-center') as HTMLButtonElement;
    const clearBtn = document.getElementById('mm-clear') as HTMLButtonElement;
    const statusEl = document.getElementById('mm-status')!;
    const canvasEl = document.getElementById('mm-canvas')!;
    const linesEl = document.getElementById('mm-lines') as SVGSVGElement;

    let nodes: MindNode[] = [];
    let dragState: { id: string; offsetX: number; offsetY: number } | null = null;

    function uid(): string {
      return `n-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`;
    }

    function loadNodes(): MindNode[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw) as MindNode[];
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function saveNodes(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(nodes));
      } catch {
        statusEl.textContent = 'Could not save map.';
      }
    }

    function showStatus(msg: string): void {
      statusEl.textContent = msg;
      window.setTimeout(() => {
        if (statusEl.textContent === msg) statusEl.textContent = '';
      }, 2000);
    }

    function ensureCentral(): void {
      if (!nodes.some((n) => n.central)) {
        nodes.unshift({
          id: uid(),
          label: 'Main topic',
          x: 120,
          y: 80,
          central: true,
        });
      }
    }

    function getNodeCenter(nodeEl: HTMLElement): { cx: number; cy: number } {
      const rect = nodeEl.getBoundingClientRect();
      const canvasRect = canvasEl.getBoundingClientRect();
      return {
        cx: rect.left - canvasRect.left + rect.width / 2,
        cy: rect.top - canvasRect.top + rect.height / 2,
      };
    }

    function drawLines(): void {
      linesEl.innerHTML = '';
      const central = nodes.find((n) => n.central);
      if (!central) return;

      const centralEl = canvasEl.querySelector<HTMLElement>(`[data-id="${central.id}"]`);
      if (!centralEl) return;

      const { cx: x1, cy: y1 } = getNodeCenter(centralEl);

      for (const node of nodes) {
        if (node.central) continue;
        const el = canvasEl.querySelector<HTMLElement>(`[data-id="${node.id}"]`);
        if (!el) continue;
        const { cx: x2, cy: y2 } = getNodeCenter(el);

        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', String(x1));
        line.setAttribute('y1', String(y1));
        line.setAttribute('x2', String(x2));
        line.setAttribute('y2', String(y2));
        line.setAttribute('stroke', 'rgba(52, 211, 153, 0.35)');
        line.setAttribute('stroke-width', '2');
        linesEl.appendChild(line);
      }
    }

    function createNodeElement(node: MindNode): HTMLElement {
      const el = document.createElement('div');
      el.className = `mm-node${node.central ? ' mm-node-central' : ''}`;
      el.dataset.id = node.id;
      el.style.left = `${node.x}px`;
      el.style.top = `${node.y}px`;
      el.textContent = node.label;

      if (!node.central) {
        const del = document.createElement('button');
        del.type = 'button';
        del.className = 'mm-node-delete';
        del.setAttribute('aria-label', 'Delete node');
        del.textContent = '×';
        del.addEventListener('pointerdown', (e) => e.stopPropagation());
        del.addEventListener('click', (e) => {
          e.stopPropagation();
          nodes = nodes.filter((n) => n.id !== node.id);
          saveNodes();
          render();
          showStatus('Node removed.');
        });
        el.appendChild(del);
      }

      el.addEventListener('pointerdown', (e) => {
        if ((e.target as HTMLElement).classList.contains('mm-node-delete')) return;
        el.setPointerCapture(e.pointerId);
        const rect = canvasEl.getBoundingClientRect();
        dragState = {
          id: node.id,
          offsetX: e.clientX - rect.left - node.x,
          offsetY: e.clientY - rect.top - node.y,
        };
        el.style.zIndex = '20';
      });

      el.addEventListener('pointermove', (e) => {
        if (!dragState || dragState.id !== node.id) return;
        const rect = canvasEl.getBoundingClientRect();
        const x = Math.max(0, Math.min(e.clientX - rect.left - dragState.offsetX, rect.width - 80));
        const y = Math.max(0, Math.min(e.clientY - rect.top - dragState.offsetY, rect.height - 40));
        node.x = x;
        node.y = y;
        el.style.left = `${x}px`;
        el.style.top = `${y}px`;
        drawLines();
      });

      el.addEventListener('pointerup', () => {
        if (dragState?.id === node.id) {
          dragState = null;
          el.style.zIndex = '10';
          saveNodes();
        }
      });

      return el;
    }

    function render(): void {
      ensureCentral();
      canvasEl.innerHTML = '';
      for (const node of nodes) {
        canvasEl.appendChild(createNodeElement(node));
      }
      requestAnimationFrame(drawLines);
    }

    function addNode(): void {
      const label = labelEl.value.trim();
      if (!label) {
        showStatus('Enter a label for the new node.');
        return;
      }
      const rect = canvasEl.getBoundingClientRect();
      const central = nodes.find((n) => n.central);
      const angle = Math.random() * Math.PI * 2;
      const radius = 100 + Math.random() * 80;
      const baseX = central ? central.x + 60 : rect.width / 2;
      const baseY = central ? central.y + 30 : rect.height / 2;

      nodes.push({
        id: uid(),
        label,
        x: Math.max(8, baseX + Math.cos(angle) * radius),
        y: Math.max(8, baseY + Math.sin(angle) * radius),
      });
      labelEl.value = '';
      saveNodes();
      render();
      showStatus('Node added.');
    }

    addBtn.addEventListener('click', addNode);
    labelEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') addNode();
    });

    centerBtn.addEventListener('click', () => {
      const central = nodes.find((n) => n.central);
      if (!central) return;
      const rect = canvasEl.getBoundingClientRect();
      central.x = Math.max(16, rect.width / 2 - 70);
      central.y = Math.max(16, rect.height / 2 - 24);
      let i = 0;
      const orbit = nodes.filter((n) => !n.central);
      for (const node of orbit) {
        const angle = (i / Math.max(orbit.length, 1)) * Math.PI * 2;
        node.x = central.x + 60 + Math.cos(angle) * 120;
        node.y = central.y + 30 + Math.sin(angle) * 100;
        i++;
      }
      saveNodes();
      render();
      showStatus('Layout centered.');
    });

    clearBtn.addEventListener('click', () => {
      if (!confirm('Clear the entire mind map?')) return;
      nodes = [];
      ensureCentral();
      saveNodes();
      render();
      showStatus('Map cleared.');
    });

    window.addEventListener('resize', drawLines);

    nodes = loadNodes();
    if (!nodes.length) ensureCentral();
    render();
  </script>
</ToolsLayout>
