---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Citation Generator';
const toolDescription =
  'Format book and web references in APA, MLA, and Chicago styles — copy-ready citations generated locally.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="writing"
>
  <div class="citation-generator">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/writing')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Smart Writing Studio
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Fill in source details and copy a formatted citation — no account, no upload.
      </p>
    </header>

    <section
      class="rounded-2xl border border-slate-800 bg-slate-900/60 p-4 shadow-xl sm:p-5"
      aria-labelledby="cite-heading"
    >
      <h2 id="cite-heading" class="sr-only">Citation form</h2>

      <div class="flex flex-wrap gap-2" role="tablist" aria-label="Citation style">
        <button type="button" class="cite-tab cite-tab-active" data-style="apa" role="tab" aria-selected="true">
          APA 7
        </button>
        <button type="button" class="cite-tab" data-style="mla" role="tab" aria-selected="false">MLA 9</button>
        <button type="button" class="cite-tab" data-style="chicago" role="tab" aria-selected="false">
          Chicago
        </button>
      </div>

      <form id="cite-form" class="mt-4 grid gap-4 sm:grid-cols-2" autocomplete="off">
        <label class="block sm:col-span-2">
          <span class="mb-1 block text-sm font-medium text-slate-300">Author(s)</span>
          <input
            id="cite-author"
            type="text"
            placeholder="Last, First M. or Organization Name"
            class="input-field w-full text-sm"
          />
        </label>
        <label class="block sm:col-span-2">
          <span class="mb-1 block text-sm font-medium text-slate-300">Title</span>
          <input id="cite-title" type="text" placeholder="Book or article title" class="input-field w-full text-sm" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Year</span>
          <input id="cite-year" type="text" inputmode="numeric" placeholder="2024" class="input-field w-full text-sm" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Publisher</span>
          <input id="cite-publisher" type="text" placeholder="Publisher name" class="input-field w-full text-sm" />
        </label>
        <label class="block sm:col-span-2">
          <span class="mb-1 block text-sm font-medium text-slate-300">URL (optional)</span>
          <input
            id="cite-url"
            type="url"
            placeholder="https://example.com/article"
            class="input-field w-full text-sm"
          />
        </label>
      </form>

      <div class="mt-4 flex flex-wrap gap-2">
        <button type="button" id="cite-generate" class="btn-primary text-sm">Generate citation</button>
        <button type="button" id="cite-copy" class="btn-secondary text-sm" disabled>Copy citation</button>
      </div>

      <div class="mt-4 rounded-xl border border-emerald-900/40 bg-emerald-950/20 p-4">
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Formatted citation</p>
        <p id="cite-output" class="mt-2 text-sm leading-relaxed text-slate-200">
          Fill in the fields above and tap Generate.
        </p>
      </div>
      <p id="cite-status" class="mt-2 text-xs text-emerald-400" role="status" aria-live="polite"></p>
    </section>
  </div>

  <style>
    .cite-tab {
      @apply rounded-lg border border-slate-700 bg-slate-950/60 px-4 py-2 text-xs font-semibold text-slate-400 transition hover:border-emerald-600 hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
    .cite-tab-active {
      @apply border-emerald-600 bg-emerald-950/40 text-emerald-300;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:citation-generator';

    type CiteStyle = 'apa' | 'mla' | 'chicago';

    const authorEl = document.getElementById('cite-author') as HTMLInputElement;
    const titleEl = document.getElementById('cite-title') as HTMLInputElement;
    const yearEl = document.getElementById('cite-year') as HTMLInputElement;
    const publisherEl = document.getElementById('cite-publisher') as HTMLInputElement;
    const urlEl = document.getElementById('cite-url') as HTMLInputElement;
    const outputEl = document.getElementById('cite-output')!;
    const generateBtn = document.getElementById('cite-generate') as HTMLButtonElement;
    const copyBtn = document.getElementById('cite-copy') as HTMLButtonElement;
    const statusEl = document.getElementById('cite-status')!;
    const tabs = document.querySelectorAll<HTMLButtonElement>('.cite-tab');

    let activeStyle: CiteStyle = 'apa';

    function parseAuthorApa(author: string): string {
      if (!author.includes(',')) return author.trim();
      const parts = author.split(',').map((p) => p.trim());
      const last = parts[0] ?? '';
      const first = parts[1] ?? '';
      const initials = first
        .split(/\s+/)
        .filter(Boolean)
        .map((n) => `${n.charAt(0).toUpperCase()}.`)
        .join(' ');
      return `${last}, ${initials}`.trim();
    }

    function parseAuthorMla(author: string): string {
      if (!author.includes(',')) return author.trim();
      const parts = author.split(',').map((p) => p.trim());
      return `${parts[0]}, ${parts[1] ?? ''}`.trim();
    }

    function formatApa(author: string, title: string, year: string, publisher: string, url: string): string {
      const a = author ? `${parseAuthorApa(author)} ` : '';
      const y = year ? `(${year}). ` : '(n.d.). ';
      const t = title ? `${title}. ` : '';
      const pub = publisher ? `${publisher}.` : '';
      const link = url ? ` ${url}` : '';
      return `${a}${y}${t}${pub}${link}`.replace(/\s+/g, ' ').trim();
    }

    function formatMla(author: string, title: string, year: string, publisher: string, url: string): string {
      const a = author ? `${parseAuthorMla(author)}. ` : '';
      const t = title ? `"${title}." ` : '';
      const pub = publisher ? `${publisher}, ` : '';
      const y = year ? `${year}` : 'n.d.';
      const link = url ? `, ${url}.` : '.';
      return `${a}${t}${pub}${y}${link}`.replace(/\s+/g, ' ').trim();
    }

    function formatChicago(author: string, title: string, year: string, publisher: string, url: string): string {
      const a = author ? `${author}. ` : '';
      const t = title ? `${title}. ` : '';
      const pub = publisher ? `${publisher}, ` : '';
      const y = year ? `${year}.` : 'n.d.';
      const link = url ? ` ${url}.` : '';
      return `${a}${t}${pub}${y}${link}`.replace(/\s+/g, ' ').trim();
    }

    function generate(): string {
      const author = authorEl.value.trim();
      const title = titleEl.value.trim();
      const year = yearEl.value.trim();
      const publisher = publisherEl.value.trim();
      const url = urlEl.value.trim();

      if (!title && !author) {
        return 'Please enter at least an author or title.';
      }

      switch (activeStyle) {
        case 'mla':
          return formatMla(author, title, year, publisher, url);
        case 'chicago':
          return formatChicago(author, title, year, publisher, url);
        default:
          return formatApa(author, title, year, publisher, url);
      }
    }

    function saveForm(): void {
      try {
        localStorage.setItem(
          STORAGE_KEY,
          JSON.stringify({
            style: activeStyle,
            author: authorEl.value,
            title: titleEl.value,
            year: yearEl.value,
            publisher: publisherEl.value,
            url: urlEl.value,
          }),
        );
      } catch {
        /* ignore */
      }
    }

    function setActiveTab(style: CiteStyle): void {
      activeStyle = style;
      tabs.forEach((tab) => {
        const isActive = tab.dataset.style === style;
        tab.classList.toggle('cite-tab-active', isActive);
        tab.setAttribute('aria-selected', String(isActive));
      });
      saveForm();
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const style = tab.dataset.style as CiteStyle;
        if (style) setActiveTab(style);
      });
    });

    generateBtn.addEventListener('click', () => {
      const citation = generate();
      outputEl.textContent = citation;
      copyBtn.disabled = citation.startsWith('Please');
      statusEl.textContent = citation.startsWith('Please') ? '' : `${activeStyle.toUpperCase()} citation generated.`;
      saveForm();
    });

    copyBtn.addEventListener('click', async () => {
      const text = outputEl.textContent ?? '';
      if (!text || text.startsWith('Please') || text.startsWith('Fill')) return;
      try {
        await navigator.clipboard.writeText(text);
        statusEl.textContent = 'Copied to clipboard.';
      } catch {
        statusEl.textContent = 'Copy failed — select text manually.';
      }
    });

    [authorEl, titleEl, yearEl, publisherEl, urlEl].forEach((el) => {
      el.addEventListener('input', saveForm);
    });

    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) {
        const data = JSON.parse(raw) as Record<string, string>;
        if (data.author) authorEl.value = data.author;
        if (data.title) titleEl.value = data.title;
        if (data.year) yearEl.value = data.year;
        if (data.publisher) publisherEl.value = data.publisher;
        if (data.url) urlEl.value = data.url;
        if (data.style === 'mla' || data.style === 'chicago' || data.style === 'apa') {
          setActiveTab(data.style);
        }
      }
    } catch {
      /* ignore */
    }
  </script>
</ToolsLayout>
