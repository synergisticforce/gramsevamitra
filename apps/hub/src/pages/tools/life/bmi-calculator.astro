---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'BMI Calculator';
const toolDescription =
  'Calculate Body Mass Index with kg/lbs and cm/ft-in support — instant results, color-coded categories, 100% private in your browser.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="home"
>
  <div class="bmi-calculator">
    <header class="mb-6">
      <a href="/tools/life" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Life &amp; Focus Tracker
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        Know your BMI baseline instantly — measurements stay on this device only.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Input panel -->
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="bmi-inputs-heading"
      >
        <h2 id="bmi-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Your measurements
        </h2>

        <div class="mt-5 space-y-6">
          <!-- Height -->
          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <span class="text-sm font-medium text-slate-300">Height</span>
              <div class="unit-toggle" role="group" aria-label="Height unit">
                <button type="button" class="unit-btn" data-height-unit="cm" aria-pressed="true">cm</button>
                <button type="button" class="unit-btn" data-height-unit="ftin" aria-pressed="false">ft / in</button>
              </div>
            </div>

            <div id="height-cm-wrap">
              <label for="height-cm" class="sr-only">Height in centimeters</label>
              <input
                id="height-cm"
                type="number"
                min="50"
                max="280"
                step="0.1"
                inputmode="decimal"
                placeholder="e.g. 170"
                class="input-field w-full tabular-nums"
              />
            </div>

            <div id="height-ftin-wrap" class="hidden grid-cols-2 gap-2 sm:grid">
              <label class="min-w-0">
                <span class="mb-1 block text-xs text-slate-500">Feet</span>
                <input
                  id="height-ft"
                  type="number"
                  min="1"
                  max="8"
                  step="1"
                  inputmode="numeric"
                  placeholder="5"
                  class="input-field w-full tabular-nums"
                />
              </label>
              <label class="min-w-0">
                <span class="mb-1 block text-xs text-slate-500">Inches</span>
                <input
                  id="height-in"
                  type="number"
                  min="0"
                  max="11.9"
                  step="0.1"
                  inputmode="decimal"
                  placeholder="7"
                  class="input-field w-full tabular-nums"
                />
              </label>
            </div>
          </div>

          <!-- Weight -->
          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <span class="text-sm font-medium text-slate-300">Weight</span>
              <div class="unit-toggle" role="group" aria-label="Weight unit">
                <button type="button" class="unit-btn" data-weight-unit="kg" aria-pressed="true">kg</button>
                <button type="button" class="unit-btn" data-weight-unit="lbs" aria-pressed="false">lbs</button>
              </div>
            </div>

            <label for="weight-value" class="sr-only">Weight</label>
            <input
              id="weight-value"
              type="number"
              min="1"
              max="500"
              step="0.1"
              inputmode="decimal"
              placeholder="e.g. 70"
              class="input-field w-full tabular-nums"
            />
          </div>
        </div>

        <button type="button" id="reset-bmi" class="btn-secondary mt-6 w-full text-sm">Reset</button>
      </section>

      <!-- Results panel -->
      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="bmi-results-heading"
        aria-live="polite"
      >
        <h2 id="bmi-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Your BMI
        </h2>

        <div class="mt-5 text-center">
          <p id="bmi-value" class="text-5xl font-extrabold tabular-nums text-white sm:text-6xl">—</p>
          <p id="bmi-category" class="mt-2 text-lg font-semibold text-slate-400">Enter height &amp; weight</p>
        </div>

        <!-- BMI spectrum gauge -->
        <div class="mt-8">
          <div class="relative pt-2 pb-6">
            <div
              class="flex h-4 w-full overflow-hidden rounded-full"
              role="img"
              aria-labelledby="bmi-gauge-legend"
            >
              <div class="h-full flex-[3.5] bg-sky-500" title="Underweight &lt; 18.5"></div>
              <div class="h-full flex-[6.4] bg-emerald-500" title="Normal 18.5–24.9"></div>
              <div class="h-full flex-[5] bg-amber-400" title="Overweight 25–29.9"></div>
              <div class="h-full flex-[10] bg-rose-500" title="Obese ≥ 30"></div>
            </div>

            <div
              id="bmi-marker"
              class="pointer-events-none absolute top-0 flex -translate-x-1/2 flex-col items-center transition-all duration-300 ease-out"
              style="left: 50%"
              aria-hidden="true"
            >
              <span class="text-lg leading-none text-white">▼</span>
            </div>

            <div class="mt-2 flex justify-between text-[10px] text-slate-500">
              <span>15</span>
              <span>18.5</span>
              <span>25</span>
              <span>30</span>
              <span>40+</span>
            </div>
          </div>

          <ul id="bmi-gauge-legend" class="grid grid-cols-2 gap-2 text-xs sm:grid-cols-4">
            <li class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 shrink-0 rounded-full bg-sky-500"></span>
              <span class="text-slate-400">&lt; 18.5 Under</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 shrink-0 rounded-full bg-emerald-500"></span>
              <span class="text-slate-400">18.5–24.9 Normal</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 shrink-0 rounded-full bg-amber-400"></span>
              <span class="text-slate-400">25–29.9 Over</span>
            </li>
            <li class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 shrink-0 rounded-full bg-rose-500"></span>
              <span class="text-slate-400">≥ 30 Obese</span>
            </li>
          </ul>
        </div>

        <p id="bmi-detail" class="mt-4 text-center text-sm text-slate-400"></p>
      </section>
    </div>

    <!-- Disclaimer -->
    <aside
      class="mt-6 rounded-2xl border border-sky-900/40 bg-sky-950/20 p-4 sm:p-5"
      aria-labelledby="bmi-disclaimer-heading"
    >
      <h2 id="bmi-disclaimer-heading" class="flex items-center gap-2 text-sm font-semibold text-sky-300">
        <span aria-hidden="true">ℹ️</span> Understanding your result
      </h2>
      <p class="mt-2 text-sm leading-relaxed text-slate-400">
        BMI is a generalized population baseline — it does <strong class="font-medium text-slate-300">not</strong> measure
        body composition, bone density, or fitness level. If you train calisthenics, bodyweight workouts, or strength
        sports without a traditional gym setup, dense muscle mass can push BMI into “overweight” ranges even when body
        fat is low. Use this number as one data point alongside how you feel, move, and perform — not as a verdict on
        your health or physique.
      </p>
    </aside>
  </div>

  <style>
    .unit-toggle {
      @apply inline-flex rounded-lg border border-slate-700 bg-slate-950/60 p-0.5;
    }
    .unit-btn {
      @apply rounded-md px-3 py-1 text-xs font-semibold text-slate-400 transition hover:text-white;
    }
    .unit-btn[aria-pressed='true'] {
      @apply bg-emerald-600 text-white shadow-sm;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:bmi-calculator';

    const LBS_PER_KG = 2.2046226218;
    const CM_PER_INCH = 2.54;

    const BMI_MIN = 15;
    const BMI_MAX = 40;

    type HeightUnit = 'cm' | 'ftin';
    type WeightUnit = 'kg' | 'lbs';

    interface SavedState {
      heightUnit: HeightUnit;
      weightUnit: WeightUnit;
      heightCm: string;
      heightFt: string;
      heightIn: string;
      weightValue: string;
    }

    interface BmiCategory {
      id: string;
      label: string;
      colorClass: string;
      min: number;
      max: number;
    }

    const CATEGORIES: BmiCategory[] = [
      { id: 'under', label: 'Underweight', colorClass: 'text-sky-400', min: 0, max: 18.5 },
      { id: 'normal', label: 'Normal weight', colorClass: 'text-emerald-400', min: 18.5, max: 25 },
      { id: 'over', label: 'Overweight', colorClass: 'text-amber-400', min: 25, max: 30 },
      { id: 'obese', label: 'Obese', colorClass: 'text-rose-400', min: 30, max: Infinity },
    ];

    const heightCmInput = document.getElementById('height-cm') as HTMLInputElement;
    const heightFtInput = document.getElementById('height-ft') as HTMLInputElement;
    const heightInInput = document.getElementById('height-in') as HTMLInputElement;
    const heightCmWrap = document.getElementById('height-cm-wrap')!;
    const heightFtinWrap = document.getElementById('height-ftin-wrap')!;
    const weightInput = document.getElementById('weight-value') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-bmi') as HTMLButtonElement;

    const bmiValueEl = document.getElementById('bmi-value')!;
    const bmiCategoryEl = document.getElementById('bmi-category')!;
    const bmiDetailEl = document.getElementById('bmi-detail')!;
    const bmiMarkerEl = document.getElementById('bmi-marker')!;

    const heightUnitBtns = document.querySelectorAll<HTMLButtonElement>('[data-height-unit]');
    const weightUnitBtns = document.querySelectorAll<HTMLButtonElement>('[data-weight-unit]');

    let heightUnit: HeightUnit = 'cm';
    let weightUnit: WeightUnit = 'kg';

    function getActiveHeightUnit(): HeightUnit {
      return heightUnit;
    }

    function getActiveWeightUnit(): WeightUnit {
      return weightUnit;
    }

    function setHeightUnit(unit: HeightUnit): void {
      heightUnit = unit;
      heightUnitBtns.forEach((btn) => {
        const active = btn.dataset.heightUnit === unit;
        btn.setAttribute('aria-pressed', String(active));
      });

      if (unit === 'cm') {
        heightCmWrap.classList.remove('hidden');
        heightFtinWrap.classList.add('hidden');
        heightFtinWrap.classList.remove('grid');
      } else {
        heightCmWrap.classList.add('hidden');
        heightFtinWrap.classList.remove('hidden');
        heightFtinWrap.classList.add('grid');
      }
    }

    function setWeightUnit(unit: WeightUnit): void {
      weightUnit = unit;
      weightUnitBtns.forEach((btn) => {
        const active = btn.dataset.weightUnit === unit;
        btn.setAttribute('aria-pressed', String(active));
      });
      weightInput.placeholder = unit === 'kg' ? 'e.g. 70' : 'e.g. 154';
    }

    function cmToFtIn(cm: number): { ft: number; inches: number } {
      const totalInches = cm / CM_PER_INCH;
      let ft = Math.floor(totalInches / 12);
      let inches = Math.round((totalInches - ft * 12) * 10) / 10;
      if (inches >= 12) {
        ft += 1;
        inches = 0;
      }
      return { ft, inches };
    }

    function ftInToCm(ft: number, inches: number): number {
      return (ft * 12 + inches) * CM_PER_INCH;
    }

    function getHeightMeters(): number | null {
      if (heightUnit === 'cm') {
        const cm = parseFloat(heightCmInput.value);
        if (!Number.isFinite(cm) || cm <= 0) return null;
        return cm / 100;
      }

      const ft = parseFloat(heightFtInput.value);
      const inches = parseFloat(heightInInput.value);
      if (!Number.isFinite(ft) || ft < 0) return null;
      if (!Number.isFinite(inches) || inches < 0) return null;
      const cm = ftInToCm(ft, inches || 0);
      if (cm <= 0) return null;
      return cm / 100;
    }

    function getWeightKg(): number | null {
      const raw = parseFloat(weightInput.value);
      if (!Number.isFinite(raw) || raw <= 0) return null;
      return weightUnit === 'kg' ? raw : raw / LBS_PER_KG;
    }

    function categorize(bmi: number): BmiCategory {
      for (const cat of CATEGORIES) {
        if (bmi >= cat.min && bmi < cat.max) return cat;
      }
      return CATEGORIES[CATEGORIES.length - 1];
    }

    function bmiToMarkerPercent(bmi: number): number {
      const clamped = Math.min(BMI_MAX, Math.max(BMI_MIN, bmi));
      return ((clamped - BMI_MIN) / (BMI_MAX - BMI_MIN)) * 100;
    }

    function readState(): SavedState {
      return {
        heightUnit,
        weightUnit,
        heightCm: heightCmInput.value,
        heightFt: heightFtInput.value,
        heightIn: heightInInput.value,
        weightValue: weightInput.value,
      };
    }

    function saveState(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(readState()));
      } catch {
        /* ignore */
      }
    }

    function loadState(): SavedState | null {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        return JSON.parse(raw) as SavedState;
      } catch {
        return null;
      }
    }

    function renderEmpty(): void {
      bmiValueEl.textContent = '—';
      bmiCategoryEl.textContent = 'Enter height & weight';
      bmiCategoryEl.className = 'mt-2 text-lg font-semibold text-slate-400';
      bmiDetailEl.textContent = '';
      bmiMarkerEl.style.left = '50%';
      bmiMarkerEl.querySelector('span')!.className = 'text-lg leading-none text-slate-500';
    }

    function renderResult(bmi: number, weightKg: number, heightM: number): void {
      const category = categorize(bmi);
      bmiValueEl.textContent = bmi.toFixed(1);
      bmiCategoryEl.textContent = category.label;
      bmiCategoryEl.className = `mt-2 text-lg font-semibold ${category.colorClass}`;

      const heightCm = heightM * 100;
      const weightDisplay =
        weightUnit === 'kg'
          ? `${weightKg.toFixed(1)} kg`
          : `${(weightKg * LBS_PER_KG).toFixed(1)} lbs`;

      bmiDetailEl.textContent = `${heightCm.toFixed(0)} cm · ${weightDisplay}`;

      const markerPct = bmiToMarkerPercent(bmi);
      bmiMarkerEl.style.left = `${markerPct}%`;
      bmiMarkerEl.querySelector('span')!.className = `text-lg leading-none ${category.colorClass}`;
    }

    function recalculate(): void {
      const heightM = getHeightMeters();
      const weightKg = getWeightKg();

      if (!heightM || !weightKg) {
        renderEmpty();
        saveState();
        return;
      }

      const bmi = weightKg / (heightM * heightM);
      if (!Number.isFinite(bmi)) {
        renderEmpty();
        saveState();
        return;
      }

      renderResult(bmi, weightKg, heightM);
      saveState();
    }

    function convertHeightOnUnitSwitch(next: HeightUnit): void {
      if (next === heightUnit) return;

      if (next === 'ftin') {
        const cm = parseFloat(heightCmInput.value);
        if (Number.isFinite(cm) && cm > 0) {
          const { ft, inches } = cmToFtIn(cm);
          heightFtInput.value = String(ft);
          heightInInput.value = String(inches);
        }
      } else {
        const ft = parseFloat(heightFtInput.value);
        const inches = parseFloat(heightInInput.value);
        if (Number.isFinite(ft) && Number.isFinite(inches)) {
          heightCmInput.value = String(Math.round(ftInToCm(ft, inches) * 10) / 10);
        }
      }

      setHeightUnit(next);
      recalculate();
    }

    function convertWeightOnUnitSwitch(next: WeightUnit): void {
      if (next === weightUnit) return;

      const raw = parseFloat(weightInput.value);
      if (Number.isFinite(raw) && raw > 0) {
        if (next === 'lbs') {
          weightInput.value = String(Math.round(raw * LBS_PER_KG * 10) / 10);
        } else {
          weightInput.value = String(Math.round((raw / LBS_PER_KG) * 10) / 10);
        }
      }

      setWeightUnit(next);
      recalculate();
    }

    heightUnitBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const unit = btn.dataset.heightUnit as HeightUnit;
        if (unit) convertHeightOnUnitSwitch(unit);
      });
    });

    weightUnitBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const unit = btn.dataset.weightUnit as WeightUnit;
        if (unit) convertWeightOnUnitSwitch(unit);
      });
    });

    [heightCmInput, heightFtInput, heightInInput, weightInput].forEach((el) => {
      el.addEventListener('input', recalculate);
    });

    resetBtn.addEventListener('click', () => {
      heightCmInput.value = '';
      heightFtInput.value = '';
      heightInInput.value = '';
      weightInput.value = '';
      setHeightUnit('cm');
      setWeightUnit('kg');
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
      renderEmpty();
    });

    const saved = loadState();
    if (saved) {
      heightCmInput.value = saved.heightCm ?? '';
      heightFtInput.value = saved.heightFt ?? '';
      heightInInput.value = saved.heightIn ?? '';
      weightInput.value = saved.weightValue ?? '';
      setHeightUnit(saved.heightUnit === 'ftin' ? 'ftin' : 'cm');
      setWeightUnit(saved.weightUnit === 'lbs' ? 'lbs' : 'kg');
    } else {
      setHeightUnit('cm');
      setWeightUnit('kg');
    }

    recalculate();
  </script>
</ToolsLayout>
