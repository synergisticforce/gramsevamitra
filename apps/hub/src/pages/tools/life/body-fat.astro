---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Body Fat Calculator';
const toolDescription =
  'Estimate body fat percentage using the U.S. Navy Method — metric or imperial units, color-coded categories, 100% private.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="home"
>
  <div class="body-fat-calculator">
    <header class="mb-6">
      <a href="/tools/life" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Life &amp; Focus Tracker
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        U.S. Navy circumference method — measurements stay on this device only.
      </p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="bf-inputs-heading"
      >
        <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
          <h2 id="bf-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
            Measurements
          </h2>
          <div class="unit-toggle" role="group" aria-label="Measurement system">
            <button type="button" class="unit-btn" data-unit-system="metric" aria-pressed="true">Metric</button>
            <button type="button" class="unit-btn" data-unit-system="imperial" aria-pressed="false">Imperial</button>
          </div>
        </div>

        <div class="space-y-5">
          <fieldset>
            <legend class="mb-2 text-sm font-medium text-slate-300">Gender</legend>
            <div class="flex gap-2" role="radiogroup" aria-label="Gender">
              <label class="gender-pill">
                <input type="radio" name="gender" value="male" class="sr-only peer" checked />
                <span class="gender-pill-label">Male</span>
              </label>
              <label class="gender-pill">
                <input type="radio" name="gender" value="female" class="sr-only peer" />
                <span class="gender-pill-label">Female</span>
              </label>
            </div>
          </fieldset>

          <div class="grid grid-cols-2 gap-3">
            <label class="min-w-0">
              <span class="mb-1 block text-sm font-medium text-slate-300">Age</span>
              <input id="age" type="number" min="18" max="100" step="1" inputmode="numeric" placeholder="25" class="input-field w-full tabular-nums" />
            </label>
            <label class="min-w-0">
              <span id="weight-label" class="mb-1 block text-sm font-medium text-slate-300">Weight (kg)</span>
              <input id="weight" type="number" min="1" step="0.1" inputmode="decimal" placeholder="70" class="input-field w-full tabular-nums" />
            </label>
          </div>

          <label class="block">
            <span id="height-label" class="mb-1 block text-sm font-medium text-slate-300">Height (cm)</span>
            <input id="height" type="number" min="1" step="0.1" inputmode="decimal" placeholder="170" class="input-field w-full tabular-nums" />
          </label>

          <div class="grid grid-cols-2 gap-3">
            <label class="min-w-0">
              <span id="neck-label" class="mb-1 block text-sm font-medium text-slate-300">Neck (cm)</span>
              <input id="neck" type="number" min="1" step="0.1" inputmode="decimal" placeholder="38" class="input-field w-full tabular-nums" />
            </label>
            <label class="min-w-0">
              <span id="waist-label" class="mb-1 block text-sm font-medium text-slate-300">Waist (cm)</span>
              <input id="waist" type="number" min="1" step="0.1" inputmode="decimal" placeholder="80" class="input-field w-full tabular-nums" />
            </label>
          </div>

          <label id="hip-wrap" class="hidden block">
            <span id="hip-label" class="mb-1 block text-sm font-medium text-slate-300">Hip (cm)</span>
            <input id="hip" type="number" min="1" step="0.1" inputmode="decimal" placeholder="95" class="input-field w-full tabular-nums" />
            <p class="mt-1 text-xs text-slate-500">Required for the Navy method (women).</p>
          </label>
        </div>

        <button type="button" id="reset-bf" class="btn-secondary mt-6 w-full text-sm">Reset</button>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="bf-results-heading"
        aria-live="polite"
      >
        <h2 id="bf-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Body fat estimate
        </h2>

        <div class="mt-5 text-center">
          <p id="bf-value" class="text-5xl font-extrabold tabular-nums text-white sm:text-6xl">—</p>
          <p id="bf-category" class="mt-2 text-lg font-semibold text-slate-400">Enter measurements</p>
          <span id="bf-badge" class="mt-3 inline-block hidden rounded-full px-4 py-1 text-sm font-bold"></span>
        </div>

        <div class="mt-8 space-y-2 text-sm">
          <div id="bf-range-bar" class="flex h-3 w-full overflow-hidden rounded-full opacity-40" aria-hidden="true">
            <div class="h-full flex-[2] bg-violet-500" title="Essential"></div>
            <div class="h-full flex-[3] bg-sky-500" title="Athletes"></div>
            <div class="h-full flex-[2] bg-emerald-500" title="Fitness"></div>
            <div class="h-full flex-[3] bg-amber-400" title="Average"></div>
            <div class="h-full flex-[4] bg-rose-500" title="Obese"></div>
          </div>
          <ul class="grid grid-cols-2 gap-2 text-xs sm:grid-cols-3">
            <li class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-violet-500"></span><span class="text-slate-400">Essential</span></li>
            <li class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-sky-500"></span><span class="text-slate-400">Athletes</span></li>
            <li class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-emerald-500"></span><span class="text-slate-400">Fitness</span></li>
            <li class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-amber-400"></span><span class="text-slate-400">Average</span></li>
            <li class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-rose-500"></span><span class="text-slate-400">Obese</span></li>
          </ul>
        </div>

        <p id="bf-detail" class="mt-4 text-center text-sm text-slate-400"></p>
      </section>
    </div>

    <aside class="mt-6 rounded-2xl border border-sky-900/40 bg-sky-950/20 p-4 sm:p-5" aria-labelledby="bf-disclaimer-heading">
      <h2 id="bf-disclaimer-heading" class="flex items-center gap-2 text-sm font-semibold text-sky-300">
        <span aria-hidden="true">ℹ️</span> Health disclaimer
      </h2>
      <p class="mt-2 text-sm leading-relaxed text-slate-400">
        This is an estimate based on circumference measurements, not a clinical body composition test. Results vary with
        measurement technique and individual physiology. Consult a healthcare professional for personalized advice.
      </p>
    </aside>
  </div>

  <style>
    .unit-toggle {
      @apply inline-flex rounded-lg border border-slate-700 bg-slate-950/60 p-0.5;
    }
    .unit-btn {
      @apply rounded-md px-3 py-1 text-xs font-semibold text-slate-400 transition hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400;
    }
    .unit-btn[aria-pressed='true'] {
      @apply bg-emerald-600 text-white shadow-sm;
    }
    .gender-pill-label {
      @apply inline-flex cursor-pointer items-center rounded-full border border-slate-700 bg-slate-950/60 px-4 py-2 text-sm font-semibold text-slate-300 transition hover:border-emerald-600 hover:text-white;
    }
    .gender-pill :global(input:checked) + .gender-pill-label {
      @apply border-emerald-500 bg-emerald-950/50 text-emerald-300 ring-2 ring-emerald-400/40;
    }
    .gender-pill :global(input:focus-visible) + .gender-pill-label {
      @apply outline-none ring-2 ring-emerald-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:body-fat-calculator';
    const CM_PER_INCH = 2.54;
    const LBS_PER_KG = 2.2046226218;

    type UnitSystem = 'metric' | 'imperial';
    type Gender = 'male' | 'female';

    interface BfCategory {
      id: string;
      label: string;
      badgeClass: string;
      textClass: string;
      maleMin: number;
      maleMax: number;
      femaleMin: number;
      femaleMax: number;
    }

    const CATEGORIES: BfCategory[] = [
      { id: 'essential', label: 'Essential fat', badgeClass: 'bg-violet-500/20 text-violet-300 ring-violet-500/40', textClass: 'text-violet-400', maleMin: 2, maleMax: 5, femaleMin: 10, femaleMax: 13 },
      { id: 'athletes', label: 'Athletes', badgeClass: 'bg-sky-500/20 text-sky-300 ring-sky-500/40', textClass: 'text-sky-400', maleMin: 6, maleMax: 13, femaleMin: 14, femaleMax: 20 },
      { id: 'fitness', label: 'Fitness', badgeClass: 'bg-emerald-500/20 text-emerald-300 ring-emerald-500/40', textClass: 'text-emerald-400', maleMin: 14, maleMax: 17, femaleMin: 21, femaleMax: 24 },
      { id: 'average', label: 'Average', badgeClass: 'bg-amber-500/20 text-amber-300 ring-amber-500/40', textClass: 'text-amber-400', maleMin: 18, maleMax: 24, femaleMin: 25, femaleMax: 31 },
      { id: 'obese', label: 'Obese', badgeClass: 'bg-rose-500/20 text-rose-300 ring-rose-500/40', textClass: 'text-rose-400', maleMin: 25, maleMax: Infinity, femaleMin: 32, femaleMax: Infinity },
    ];

    interface SavedState {
      unitSystem: UnitSystem;
      gender: Gender;
      age: string;
      weight: string;
      height: string;
      neck: string;
      waist: string;
      hip: string;
    }

    const unitBtns = document.querySelectorAll<HTMLButtonElement>('[data-unit-system]');
    const hipWrap = document.getElementById('hip-wrap')!;
    const weightLabel = document.getElementById('weight-label')!;
    const heightLabel = document.getElementById('height-label')!;
    const neckLabel = document.getElementById('neck-label')!;
    const waistLabel = document.getElementById('waist-label')!;
    const hipLabel = document.getElementById('hip-label')!;
    const ageInput = document.getElementById('age') as HTMLInputElement;
    const weightInput = document.getElementById('weight') as HTMLInputElement;
    const heightInput = document.getElementById('height') as HTMLInputElement;
    const neckInput = document.getElementById('neck') as HTMLInputElement;
    const waistInput = document.getElementById('waist') as HTMLInputElement;
    const hipInput = document.getElementById('hip') as HTMLInputElement;
    const resetBtn = document.getElementById('reset-bf') as HTMLButtonElement;
    const bfValue = document.getElementById('bf-value')!;
    const bfCategory = document.getElementById('bf-category')!;
    const bfBadge = document.getElementById('bf-badge')!;
    const bfDetail = document.getElementById('bf-detail')!;

    let unitSystem: UnitSystem = 'metric';

    function getGender(): Gender {
      const checked = document.querySelector<HTMLInputElement>('input[name="gender"]:checked');
      return checked?.value === 'female' ? 'female' : 'male';
    }

    function setUnitSystem(system: UnitSystem): void {
      unitSystem = system;
      unitBtns.forEach((btn) => {
        btn.setAttribute('aria-pressed', String(btn.dataset.unitSystem === system));
      });
      const isMetric = system === 'metric';
      weightLabel.textContent = isMetric ? 'Weight (kg)' : 'Weight (lbs)';
      heightLabel.textContent = isMetric ? 'Height (cm)' : 'Height (in)';
      neckLabel.textContent = isMetric ? 'Neck (cm)' : 'Neck (in)';
      waistLabel.textContent = isMetric ? 'Waist (cm)' : 'Waist (in)';
      hipLabel.textContent = isMetric ? 'Hip (cm)' : 'Hip (in)';
    }

    function updateGenderUi(): void {
      const female = getGender() === 'female';
      hipWrap.classList.toggle('hidden', !female);
    }

    function toInches(value: number): number {
      return unitSystem === 'metric' ? value / CM_PER_INCH : value;
    }

    function categorize(pct: number, gender: Gender): BfCategory {
      if (gender === 'male') {
        if (pct <= 5) return CATEGORIES[0];
        if (pct <= 13) return CATEGORIES[1];
        if (pct <= 17) return CATEGORIES[2];
        if (pct <= 24) return CATEGORIES[3];
        return CATEGORIES[4];
      }
      if (pct <= 13) return CATEGORIES[0];
      if (pct <= 20) return CATEGORIES[1];
      if (pct <= 24) return CATEGORIES[2];
      if (pct <= 31) return CATEGORIES[3];
      return CATEGORIES[4];
    }

    /**
     * U.S. Navy Method (measurements in inches, log base 10)
     * Men: 86.010×log10(waist−neck) − 70.041×log10(height) + 36.76
     * Women: 163.205×log10(waist+hip−neck) − 97.684×log10(height) − 78.387
     */
    function calculateBodyFat(
      gender: Gender,
      heightRaw: number,
      neckRaw: number,
      waistRaw: number,
      hipRaw: number
    ): number | null {
      const height = toInches(heightRaw);
      const neck = toInches(neckRaw);
      const waist = toInches(waistRaw);
      const hip = toInches(hipRaw);

      if (height <= 0 || neck <= 0 || waist <= 0) return null;

      let pct: number;
      if (gender === 'male') {
        const abdomen = waist - neck;
        if (abdomen <= 0) return null;
        pct = 86.01 * Math.log10(abdomen) - 70.041 * Math.log10(height) + 36.76;
      } else {
        if (hip <= 0) return null;
        const composite = waist + hip - neck;
        if (composite <= 0) return null;
        pct = 163.205 * Math.log10(composite) - 97.684 * Math.log10(height) - 78.387;
      }

      if (!Number.isFinite(pct)) return null;
      return Math.min(60, Math.max(2, pct));
    }

    function readState(): SavedState {
      return {
        unitSystem,
        gender: getGender(),
        age: ageInput.value,
        weight: weightInput.value,
        height: heightInput.value,
        neck: neckInput.value,
        waist: waistInput.value,
        hip: hipInput.value,
      };
    }

    function saveState(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(readState()));
      } catch {
        /* ignore */
      }
    }

    function loadState(): SavedState | null {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        return raw ? (JSON.parse(raw) as SavedState) : null;
      } catch {
        return null;
      }
    }

    function renderEmpty(): void {
      bfValue.textContent = '—';
      bfCategory.textContent = 'Enter measurements';
      bfCategory.className = 'mt-2 text-lg font-semibold text-slate-400';
      bfBadge.classList.add('hidden');
      bfDetail.textContent = '';
    }

    function renderResult(pct: number, gender: Gender): void {
      const cat = categorize(pct, gender);
      bfValue.textContent = `${pct.toFixed(1)}%`;
      bfCategory.textContent = cat.label;
      bfCategory.className = `mt-2 text-lg font-semibold ${cat.textClass}`;
      bfBadge.textContent = cat.label;
      bfBadge.className = `mt-3 inline-block rounded-full px-4 py-1 text-sm font-bold ring-1 ${cat.badgeClass}`;

      const age = ageInput.value;
      const weight = weightInput.value;
      const unit = unitSystem === 'metric' ? 'kg' : 'lbs';
      const measureUnit = unitSystem === 'metric' ? 'cm' : 'in';
      bfDetail.textContent = [
        age ? `Age ${age}` : null,
        weight ? `${weight} ${unit}` : null,
        `Navy method · ${measureUnit} inputs`,
      ]
        .filter(Boolean)
        .join(' · ');
    }

    function recalculate(): void {
      updateGenderUi();
      const gender = getGender();
      const height = parseFloat(heightInput.value);
      const neck = parseFloat(neckInput.value);
      const waist = parseFloat(waistInput.value);
      const hip = parseFloat(hipInput.value);

      if (!Number.isFinite(height) || !Number.isFinite(neck) || !Number.isFinite(waist)) {
        renderEmpty();
        saveState();
        return;
      }

      const pct = calculateBodyFat(gender, height, neck, waist, hip);
      if (pct === null) {
        renderEmpty();
        if (gender === 'female' && (!Number.isFinite(hip) || hip <= 0)) {
          bfDetail.textContent = 'Enter hip measurement for female calculation.';
        }
        saveState();
        return;
      }

      renderResult(pct, gender);
      saveState();
    }

    function convertValueOnUnitSwitch(next: UnitSystem): void {
      if (next === unitSystem) return;

      const convert = (raw: string, toImperial: boolean): string => {
        const val = parseFloat(raw);
        if (!Number.isFinite(val) || val <= 0) return raw;
        if (toImperial) {
          return String(Math.round((val / CM_PER_INCH) * 10) / 10);
        }
        return String(Math.round(val * CM_PER_INCH * 10) / 10);
      };

      const toImperial = next === 'imperial';
      if (toImperial) {
        heightInput.value = convert(heightInput.value, true);
        neckInput.value = convert(neckInput.value, true);
        waistInput.value = convert(waistInput.value, true);
        hipInput.value = convert(hipInput.value, true);
        const w = parseFloat(weightInput.value);
        if (Number.isFinite(w) && w > 0) {
          weightInput.value = String(Math.round(w * LBS_PER_KG * 10) / 10);
        }
      } else {
        heightInput.value = convert(heightInput.value, false);
        neckInput.value = convert(neckInput.value, false);
        waistInput.value = convert(waistInput.value, false);
        hipInput.value = convert(hipInput.value, false);
        const w = parseFloat(weightInput.value);
        if (Number.isFinite(w) && w > 0) {
          weightInput.value = String(Math.round((w / LBS_PER_KG) * 10) / 10);
        }
      }

      setUnitSystem(next);
      recalculate();
    }

    unitBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const system = btn.dataset.unitSystem as UnitSystem;
        if (system) convertValueOnUnitSwitch(system);
      });
    });

    document.querySelectorAll<HTMLInputElement>('input[name="gender"]').forEach((el) => {
      el.addEventListener('change', recalculate);
    });

    [ageInput, weightInput, heightInput, neckInput, waistInput, hipInput].forEach((el) => {
      el.addEventListener('input', recalculate);
    });

    resetBtn.addEventListener('click', () => {
      ageInput.value = '';
      weightInput.value = '';
      heightInput.value = '';
      neckInput.value = '';
      waistInput.value = '';
      hipInput.value = '';
      const maleRadio = document.querySelector<HTMLInputElement>('input[name="gender"][value="male"]');
      if (maleRadio) maleRadio.checked = true;
      setUnitSystem('metric');
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
      renderEmpty();
      updateGenderUi();
    });

    const saved = loadState();
    if (saved) {
      setUnitSystem(saved.unitSystem === 'imperial' ? 'imperial' : 'metric');
      const genderRadio = document.querySelector<HTMLInputElement>(
        `input[name="gender"][value="${saved.gender === 'female' ? 'female' : 'male'}"]`
      );
      if (genderRadio) genderRadio.checked = true;
      ageInput.value = saved.age ?? '';
      weightInput.value = saved.weight ?? '';
      heightInput.value = saved.height ?? '';
      neckInput.value = saved.neck ?? '';
      waistInput.value = saved.waist ?? '';
      hipInput.value = saved.hip ?? '';
    } else {
      setUnitSystem('metric');
    }

    updateGenderUi();
    recalculate();
  </script>
</ToolsLayout>
