---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Event Countdown';
const toolDescription =
  'Count down to exams, birthdays, and milestones — save multiple events offline with live day/hour/minute/second timers.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="life"
>
  <div class="event-countdown">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/life')} class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
        ← Life &amp; Focus Tracker
      </a>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-600">
        Track what matters — events stay on this device only.
      </p>
    </header>

    <section
      class="mb-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
      aria-labelledby="countdown-form-heading"
    >
      <h2 id="countdown-form-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
        Add countdown
      </h2>

      <form id="countdown-form" class="mt-4 space-y-4">
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Event name</span>
          <input
            id="event-name"
            type="text"
            maxlength="80"
            placeholder="e.g. Board exam results"
            class="input-field w-full"
            required
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Target date &amp; time</span>
          <input id="event-datetime" type="datetime-local" class="input-field w-full" required />
        </label>

        <button type="submit" class="btn-primary w-full">Start countdown</button>
      </form>
    </section>

    <section aria-labelledby="countdown-list-heading">
      <div class="mb-4 flex items-center justify-between gap-2">
        <h2 id="countdown-list-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Active countdowns
        </h2>
        <span id="countdown-count" class="text-xs text-slate-500">0 events</span>
      </div>

      <div id="countdown-empty" class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/30 px-4 py-10 text-center">
        <p class="text-sm text-slate-500">No countdowns yet. Add an event above to get started.</p>
      </div>

      <div id="countdown-grid" class="hidden grid gap-4 sm:grid-cols-2 lg:grid-cols-3" aria-live="polite"></div>
    </section>
  </div>

  <style>
    .countdown-card {
      @apply relative rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/40 to-slate-900/60 p-4 shadow-lg;
    }
    .countdown-card.is-past {
      @apply border-slate-700 from-slate-900/60 to-slate-900/40 opacity-80;
    }
    .countdown-unit {
      @apply rounded-xl border border-slate-800 bg-slate-950/50 px-2 py-3 text-center;
    }
    .countdown-unit-value {
      @apply text-2xl font-extrabold tabular-nums text-emerald-400 sm:text-3xl;
    }
    .countdown-unit-label {
      @apply mt-0.5 text-[10px] font-semibold uppercase tracking-wider text-slate-500;
    }
    .delete-btn {
      @apply absolute right-3 top-3 rounded-lg border border-slate-700 bg-slate-950/60 p-1.5 text-slate-400 transition hover:border-rose-600 hover:bg-rose-950/40 hover:text-rose-400 focus:outline-none focus:ring-2 focus:ring-rose-400;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:life-countdowns';

    interface CountdownEvent {
      id: string;
      name: string;
      targetIso: string;
    }

    const form = document.getElementById('countdown-form') as HTMLFormElement;
    const nameInput = document.getElementById('event-name') as HTMLInputElement;
    const datetimeInput = document.getElementById('event-datetime') as HTMLInputElement;
    const grid = document.getElementById('countdown-grid')!;
    const emptyState = document.getElementById('countdown-empty')!;
    const countLabel = document.getElementById('countdown-count')!;

    let events: CountdownEvent[] = [];
    let tickTimer: ReturnType<typeof setInterval> | null = null;

    function generateId(): string {
      return `evt-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    }

    function loadEvents(): CountdownEvent[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw) as CountdownEvent[];
        return Array.isArray(parsed) ? parsed.filter((e) => e.id && e.name && e.targetIso) : [];
      } catch {
        return [];
      }
    }

    function saveEvents(): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(events));
      } catch {
        /* ignore */
      }
    }

    function pad(n: number): string {
      return String(n).padStart(2, '0');
    }

    function getRemaining(targetIso: string): { days: number; hours: number; minutes: number; seconds: number; past: boolean } {
      const diff = new Date(targetIso).getTime() - Date.now();
      if (diff <= 0) {
        return { days: 0, hours: 0, minutes: 0, seconds: 0, past: true };
      }
      const totalSeconds = Math.floor(diff / 1000);
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((totalSeconds % 86400) / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      return { days, hours, minutes, seconds, past: false };
    }

    function formatTargetDate(iso: string): string {
      try {
        return new Intl.DateTimeFormat('en-IN', {
          dateStyle: 'medium',
          timeStyle: 'short',
        }).format(new Date(iso));
      } catch {
        return iso;
      }
    }

    function renderCard(event: CountdownEvent): string {
      const remaining = getRemaining(event.targetIso);
      const pastClass = remaining.past ? ' is-past' : '';
      const statusText = remaining.past ? 'Event has passed' : 'Time remaining';

      return `
        <article class="countdown-card${pastClass}" data-id="${event.id}">
          <button type="button" class="delete-btn" data-delete="${event.id}" aria-label="Delete ${event.name}">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          </button>
          <h3 class="pr-8 text-base font-bold text-white">${escapeHtml(event.name)}</h3>
          <p class="mt-1 text-xs text-slate-500">${formatTargetDate(event.targetIso)}</p>
          <p class="mt-3 text-[10px] font-semibold uppercase tracking-wider text-emerald-400/70">${statusText}</p>
          <div class="mt-2 grid grid-cols-4 gap-2" data-countdown="${event.id}">
            <div class="countdown-unit">
              <div class="countdown-unit-value" data-part="days">${pad(remaining.days)}</div>
              <div class="countdown-unit-label">Days</div>
            </div>
            <div class="countdown-unit">
              <div class="countdown-unit-value" data-part="hours">${pad(remaining.hours)}</div>
              <div class="countdown-unit-label">Hrs</div>
            </div>
            <div class="countdown-unit">
              <div class="countdown-unit-value" data-part="minutes">${pad(remaining.minutes)}</div>
              <div class="countdown-unit-label">Min</div>
            </div>
            <div class="countdown-unit">
              <div class="countdown-unit-value" data-part="seconds">${pad(remaining.seconds)}</div>
              <div class="countdown-unit-label">Sec</div>
            </div>
          </div>
        </article>
      `;
    }

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderAll(): void {
      const hasEvents = events.length > 0;
      emptyState.classList.toggle('hidden', hasEvents);
      grid.classList.toggle('hidden', !hasEvents);
      countLabel.textContent = `${events.length} event${events.length === 1 ? '' : 's'}`;

      if (!hasEvents) {
        grid.innerHTML = '';
        return;
      }

      events.sort((a, b) => new Date(a.targetIso).getTime() - new Date(b.targetIso).getTime());
      grid.innerHTML = events.map(renderCard).join('');

      grid.querySelectorAll<HTMLButtonElement>('[data-delete]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.delete;
          if (!id) return;
          events = events.filter((e) => e.id !== id);
          saveEvents();
          renderAll();
        });
      });
    }

    function tickAll(): void {
      events.forEach((event) => {
        const container = grid.querySelector(`[data-countdown="${event.id}"]`);
        if (!container) return;
        const remaining = getRemaining(event.targetIso);
        const card = grid.querySelector(`[data-id="${event.id}"]`);
        card?.classList.toggle('is-past', remaining.past);

        container.querySelector('[data-part="days"]')!.textContent = pad(remaining.days);
        container.querySelector('[data-part="hours"]')!.textContent = pad(remaining.hours);
        container.querySelector('[data-part="minutes"]')!.textContent = pad(remaining.minutes);
        container.querySelector('[data-part="seconds"]')!.textContent = pad(remaining.seconds);
      });
    }

    function startTicker(): void {
      if (tickTimer) clearInterval(tickTimer);
      tickTimer = setInterval(tickAll, 1000);
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = nameInput.value.trim();
      const target = datetimeInput.value;
      if (!name || !target) return;

      const targetDate = new Date(target);
      if (Number.isNaN(targetDate.getTime())) return;

      events.push({
        id: generateId(),
        name,
        targetIso: targetDate.toISOString(),
      });

      saveEvents();
      nameInput.value = '';
      datetimeInput.value = '';
      renderAll();
    });

    events = loadEvents();
    renderAll();
    startTicker();

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') tickAll();
    });
  </script>
</ToolsLayout>
