---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import AgeCalculatorTool from '../../../components/tools/AgeCalculatorTool';
import ToolBackLink from '../../../components/tools/ToolBackLink.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Age & Date Calculator';
const toolDescription =
  'Calculate exact age in years, months, and days with leap-year accuracy — 100% private, offline.';
---

<ToolsLayout title={formatSeoTitle(toolName, 'Free Online Tool')} description={toolDescription} activeNav="life">
  <div>
    <header class="mb-6">
      <ToolBackLink href={utilitiesHref('/tools/life')} label="← Life & Focus Tracker" />
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">{toolDescription}</p>
      <a
        href={utilitiesHref('/tools/life/exam-age-eligibility')}
        data-astro-reload
        class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-emerald-400 transition hover:text-emerald-300"
      >
        Need exam cutoff eligibility? Try Exam Age Eligibility →
      </a>
    </header>
    <AgeCalculatorTool client:load />
  </div>
</ToolsLayout>
