---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Mood & Daily Log';
const toolDescription =
  'Private daily mood check-ins with short notes — one entry per day, stored only on your device.';

const MOODS = [
  { id: 1, label: 'Terrible', emoji: '😞', color: 'rose' },
  { id: 2, label: 'Low', emoji: '😕', color: 'orange' },
  { id: 3, label: 'Okay', emoji: '😐', color: 'amber' },
  { id: 4, label: 'Good', emoji: '🙂', color: 'emerald' },
  { id: 5, label: 'Awesome', emoji: '🤩', color: 'sky' },
] as const;
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="home"
>
  <div class="mood-tracker">
    <header class="mb-6">
      <a href="/tools/life" class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Life &amp; Focus Tracker
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">
        One check-in per day — your feelings stay on this device only.
      </p>
    </header>

    <section
      class="mb-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
      aria-labelledby="mood-checkin-heading"
    >
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
        <h2 id="mood-checkin-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Today's check-in
        </h2>
        <span id="today-label" class="text-xs font-medium text-emerald-400"></span>
      </div>

      <p class="mb-3 text-sm text-slate-400">How are you feeling today?</p>

      <div class="grid grid-cols-5 gap-2 sm:gap-3" role="radiogroup" aria-label="Select mood">
        {MOODS.map((mood) => (
          <label class={`mood-btn mood-btn-${mood.color}`}>
            <input
              type="radio"
              name="mood"
              value={mood.id}
              class="sr-only peer"
            />
            <span class="mood-btn-inner" title={mood.label}>
              <span class="text-2xl sm:text-3xl" aria-hidden="true">{mood.emoji}</span>
              <span class="mt-1 text-[10px] font-semibold leading-tight sm:text-xs">{mood.label}</span>
            </span>
          </label>
        ))}
      </div>

      <label class="mt-5 block">
        <span class="mb-1 block text-sm font-medium text-slate-300">Brief note (optional)</span>
        <textarea
          id="mood-note"
          rows="3"
          maxlength="500"
          placeholder="What stood out today?"
          class="input-field w-full resize-none text-sm"
        ></textarea>
      </label>

      <button type="button" id="save-mood" class="btn-primary mt-4 w-full">
        Save today's log
      </button>
      <p id="save-status" class="mt-2 text-center text-xs text-slate-500" aria-live="polite"></p>
    </section>

    <section aria-labelledby="mood-history-heading">
      <h2 id="mood-history-heading" class="mb-4 text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
        Past entries
      </h2>

      <div id="history-empty" class="rounded-2xl border border-dashed border-slate-700 bg-slate-900/30 px-4 py-10 text-center">
        <p class="text-sm text-slate-500">No mood logs yet. Save your first check-in above.</p>
      </div>

      <ul id="history-list" class="hidden space-y-3" aria-live="polite"></ul>
    </section>
  </div>

  <style>
    .mood-btn-inner {
      @apply flex min-h-[72px] cursor-pointer flex-col items-center justify-center rounded-xl border border-slate-700 bg-slate-950/60 px-1 py-2 text-slate-400 transition hover:border-slate-600 hover:text-white sm:min-h-[80px];
    }
    .mood-btn :global(input:focus-visible) + .mood-btn-inner {
      @apply outline-none ring-2 ring-emerald-400;
    }
    .mood-btn-rose :global(input:checked) + .mood-btn-inner {
      @apply border-rose-500 bg-rose-950/40 text-rose-300 ring-2 ring-rose-400/40;
    }
    .mood-btn-orange :global(input:checked) + .mood-btn-inner {
      @apply border-orange-500 bg-orange-950/40 text-orange-300 ring-2 ring-orange-400/40;
    }
    .mood-btn-amber :global(input:checked) + .mood-btn-inner {
      @apply border-amber-500 bg-amber-950/40 text-amber-300 ring-2 ring-amber-400/40;
    }
    .mood-btn-emerald :global(input:checked) + .mood-btn-inner {
      @apply border-emerald-500 bg-emerald-950/40 text-emerald-300 ring-2 ring-emerald-400/40;
    }
    .mood-btn-sky :global(input:checked) + .mood-btn-inner {
      @apply border-sky-500 bg-sky-950/40 text-sky-300 ring-2 ring-sky-400/40;
    }
    .history-item {
      @apply rounded-2xl border border-slate-800 bg-slate-900/50 px-4 py-3;
    }
  </style>

  <script>
    const STORAGE_KEY = 'gsm-tools:life-mood';

    const MOOD_META: Record<number, { label: string; emoji: string; colorClass: string }> = {
      1: { label: 'Terrible', emoji: '😞', colorClass: 'text-rose-400' },
      2: { label: 'Low', emoji: '😕', colorClass: 'text-orange-400' },
      3: { label: 'Okay', emoji: '😐', colorClass: 'text-amber-400' },
      4: { label: 'Good', emoji: '🙂', colorClass: 'text-emerald-400' },
      5: { label: 'Awesome', emoji: '🤩', colorClass: 'text-sky-400' },
    };

    interface MoodEntry {
      date: string;
      mood: number;
      note: string;
      updatedAt: string;
    }

    const todayLabel = document.getElementById('today-label')!;
    const noteInput = document.getElementById('mood-note') as HTMLTextAreaElement;
    const saveBtn = document.getElementById('save-mood') as HTMLButtonElement;
    const saveStatus = document.getElementById('save-status')!;
    const historyEmpty = document.getElementById('history-empty')!;
    const historyList = document.getElementById('history-list')!;

    function todayKey(): string {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, '0');
      const d = String(now.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    }

    function formatDisplayDate(dateKey: string): string {
      const [y, m, d] = dateKey.split('-').map(Number);
      const date = new Date(y, m - 1, d);
      return new Intl.DateTimeFormat('en-IN', {
        weekday: 'short',
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).format(date);
    }

    function loadEntries(): MoodEntry[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw) as MoodEntry[];
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function saveEntries(entries: MoodEntry[]): void {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
      } catch {
        /* ignore */
      }
    }

    function getSelectedMood(): number | null {
      const checked = document.querySelector<HTMLInputElement>('input[name="mood"]:checked');
      if (!checked) return null;
      const val = Number(checked.value);
      return val >= 1 && val <= 5 ? val : null;
    }

    function setSelectedMood(mood: number): void {
      const radio = document.querySelector<HTMLInputElement>(`input[name="mood"][value="${mood}"]`);
      if (radio) radio.checked = true;
    }

    function escapeHtml(text: string): string {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function renderHistory(entries: MoodEntry[]): void {
      const sorted = [...entries].sort((a, b) => b.date.localeCompare(a.date));
      const hasEntries = sorted.length > 0;

      historyEmpty.classList.toggle('hidden', hasEntries);
      historyList.classList.toggle('hidden', !hasEntries);

      if (!hasEntries) {
        historyList.innerHTML = '';
        return;
      }

      historyList.innerHTML = sorted
        .map((entry) => {
          const meta = MOOD_META[entry.mood] ?? MOOD_META[3];
          const isToday = entry.date === todayKey();
          const noteHtml = entry.note
            ? `<p class="mt-2 text-sm leading-relaxed text-slate-400">${escapeHtml(entry.note)}</p>`
            : '';

          return `
            <li class="history-item${isToday ? ' border-emerald-800/50 bg-emerald-950/20' : ''}">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-medium text-slate-500">${formatDisplayDate(entry.date)}${isToday ? ' · Today' : ''}</p>
                  <p class="mt-1 flex items-center gap-2 text-sm font-semibold ${meta.colorClass}">
                    <span aria-hidden="true">${meta.emoji}</span>
                    <span>${meta.label}</span>
                  </p>
                </div>
              </div>
              ${noteHtml}
            </li>
          `;
        })
        .join('');
    }

    function loadTodayIntoForm(entries: MoodEntry[]): void {
      const today = todayKey();
      todayLabel.textContent = formatDisplayDate(today);
      const existing = entries.find((e) => e.date === today);
      if (existing) {
        setSelectedMood(existing.mood);
        noteInput.value = existing.note ?? '';
        saveStatus.textContent = "Today's log loaded — saving will update it.";
      } else {
        document.querySelectorAll<HTMLInputElement>('input[name="mood"]').forEach((r) => {
          r.checked = false;
        });
        noteInput.value = '';
        saveStatus.textContent = '';
      }
    }

    saveBtn.addEventListener('click', () => {
      const mood = getSelectedMood();
      if (!mood) {
        saveStatus.textContent = 'Please select a mood first.';
        saveStatus.className = 'mt-2 text-center text-xs text-amber-400';
        return;
      }

      const entries = loadEntries();
      const today = todayKey();
      const note = noteInput.value.trim();
      const next: MoodEntry = {
        date: today,
        mood,
        note,
        updatedAt: new Date().toISOString(),
      };

      const idx = entries.findIndex((e) => e.date === today);
      if (idx >= 0) {
        entries[idx] = next;
        saveStatus.textContent = "Today's log updated.";
      } else {
        entries.push(next);
        saveStatus.textContent = "Today's log saved.";
      }
      saveStatus.className = 'mt-2 text-center text-xs text-emerald-400';

      saveEntries(entries);
      renderHistory(entries);
    });

    const entries = loadEntries();
    loadTodayIntoForm(entries);
    renderHistory(entries);
  </script>
</ToolsLayout>
