---
import ToolsLayout from '../../../layouts/ToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const toolName = 'Menstrual & Ovulation Calculator';
const toolDescription =
  'Estimate next period and fertile window from cycle length — private, offline, with a clear health disclaimer.';
---

<ToolsLayout
  title={formatSeoTitle(toolName, 'Free Online Tool')}
  description={toolDescription}
  activeNav="life"
>
  <div class="menstrual-tracker">
    <header class="mb-6">
      <a href={utilitiesHref('/tools/life')} class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
        ← Life &amp; Focus Tracker
      </a>
      <h1 class="mt-2 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
      <p class="mt-1 text-sm text-slate-400">Calendar-based estimates — your data never leaves this device.</p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <section
        class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="cycle-inputs-heading"
      >
        <h2 id="cycle-inputs-heading" class="text-sm font-semibold uppercase tracking-wider text-slate-500">
          Cycle details
        </h2>

        <div class="mt-5 space-y-6">
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-300">First day of last period</span>
            <input id="last-period" type="date" class="input-field w-full" />
          </label>

          <div>
            <div class="mb-2 flex items-center justify-between gap-2">
              <label for="cycle-length" class="text-sm font-medium text-slate-300">Average cycle length</label>
              <span id="cycle-display" class="text-sm font-bold tabular-nums text-emerald-400">28 days</span>
            </div>
            <input
              id="cycle-length"
              type="range"
              min="21"
              max="40"
              step="1"
              value="28"
              class="w-full accent-emerald-500"
              aria-label="Average cycle length in days"
            />
            <div class="mt-1 flex justify-between text-[10px] text-slate-500">
              <span>21 days</span>
              <span>40 days</span>
            </div>
          </div>
        </div>

        <button type="button" id="reset-cycle" class="btn-secondary mt-6 w-full text-sm">Reset</button>
      </section>

      <section
        class="rounded-2xl border border-emerald-900/40 bg-gradient-to-br from-emerald-950/50 to-slate-900/60 p-5 shadow-xl sm:p-6"
        aria-labelledby="cycle-results-heading"
        aria-live="polite"
      >
        <h2 id="cycle-results-heading" class="text-sm font-semibold uppercase tracking-wider text-emerald-400/80">
          Predictions
        </h2>

        <dl class="mt-5 space-y-4 text-sm">
          <div class="rounded-xl border border-slate-800 bg-slate-950/50 px-4 py-3">
            <dt class="text-xs font-semibold uppercase tracking-wider text-slate-500">Next period (est.)</dt>
            <dd id="next-period" class="mt-1 text-lg font-bold text-white">—</dd>
          </div>
          <div class="rounded-xl border border-amber-900/40 bg-amber-950/20 px-4 py-3">
            <dt class="text-xs font-semibold uppercase tracking-wider text-amber-400/80">Ovulation window (est.)</dt>
            <dd id="ovulation-window" class="mt-1 font-semibold text-amber-200">—</dd>
            <dd id="ovulation-day" class="mt-1 text-xs text-slate-400">Peak ovulation: —</dd>
          </div>
        </dl>

        <div class="mt-6">
          <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500">Cycle timeline</p>
          <div
            id="cycle-timeline"
            class="flex h-8 w-full overflow-hidden rounded-full border border-slate-800 bg-slate-950/60"
            role="img"
            aria-labelledby="timeline-legend"
          ></div>
          <ul id="timeline-legend" class="mt-3 grid grid-cols-2 gap-2 text-xs sm:grid-cols-4">
            <li class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-rose-500"></span><span class="text-slate-400">Period</span></li>
            <li class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-sky-500"></span><span class="text-slate-400">Lower risk</span></li>
            <li class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span><span class="text-slate-400">Fertile</span></li>
            <li class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span><span class="text-slate-400">Ovulation</span></li>
          </ul>
          <p id="timeline-note" class="mt-3 text-center text-xs text-slate-500">Enter your last period date to see the timeline.</p>
        </div>
      </section>
    </div>

    <aside
      class="mt-6 rounded-2xl border border-rose-900/50 bg-rose-950/20 p-4 sm:p-5"
      aria-labelledby="cycle-disclaimer-heading"
    >
      <h2 id="cycle-disclaimer-heading" class="flex items-center gap-2 text-sm font-semibold text-rose-300">
        <span aria-hidden="true">⚠️</span> Important medical disclaimer
      </h2>
      <p class="mt-2 text-sm leading-relaxed text-slate-400">
        This tool provides <strong class="font-medium text-slate-300">calendar estimates only</strong> and is not a
        medical device. Cycle length, ovulation timing, and fertility vary widely between individuals and can change
        due to stress, illness, hormones, and other factors. The “fertile window” shown here is a simplified model and
        must <strong class="font-medium text-slate-300">not</strong> be used as contraception or as a substitute for
        professional medical advice, diagnosis, or treatment. Always consult a qualified healthcare provider for
        reproductive health decisions.
      </p>
    </aside>
  </div>

  <script>
    const STORAGE_KEY = 'gsm-tools:menstrual-tracker';
    const PERIOD_DAYS = 5;
    const FERTILE_DAYS_BEFORE = 5;
    const FERTILE_DAYS_AFTER = 1;
    const LUTEAL_PHASE = 14;

    const lastPeriodInput = document.getElementById('last-period') as HTMLInputElement;
    const cycleSlider = document.getElementById('cycle-length') as HTMLInputElement;
    const cycleDisplay = document.getElementById('cycle-display')!;
    const resetBtn = document.getElementById('reset-cycle') as HTMLButtonElement;
    const nextPeriodEl = document.getElementById('next-period')!;
    const ovulationWindowEl = document.getElementById('ovulation-window')!;
    const ovulationDayEl = document.getElementById('ovulation-day')!;
    const timelineEl = document.getElementById('cycle-timeline')!;
    const timelineNote = document.getElementById('timeline-note')!;

    function parseDateOnly(iso: string): Date | null {
      if (!iso) return null;
      const [y, m, d] = iso.split('-').map(Number);
      if (!y || !m || !d) return null;
      return new Date(y, m - 1, d);
    }

    function addDays(date: Date, days: number): Date {
      const next = new Date(date);
      next.setDate(next.getDate() + days);
      return next;
    }

    function formatDate(date: Date): string {
      return new Intl.DateTimeFormat('en-IN', {
        weekday: 'short',
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).format(date);
    }

    function formatRange(start: Date, end: Date): string {
      return `${formatDate(start)} – ${formatDate(end)}`;
    }

    type SegmentKind = 'period' | 'safe' | 'fertile' | 'ovulation';

    function segmentClass(kind: SegmentKind): string {
      switch (kind) {
        case 'period':
          return 'bg-rose-500';
        case 'fertile':
          return 'bg-amber-400';
        case 'ovulation':
          return 'bg-emerald-500';
        default:
          return 'bg-sky-500/70';
      }
    }

    function dayKind(dayIndex: number, cycleLen: number, ovulationOffset: number): SegmentKind {
      if (dayIndex < PERIOD_DAYS) return 'period';
      const fertileStart = ovulationOffset - FERTILE_DAYS_BEFORE;
      const fertileEnd = ovulationOffset + FERTILE_DAYS_AFTER;
      if (dayIndex === ovulationOffset) return 'ovulation';
      if (dayIndex >= fertileStart && dayIndex <= fertileEnd) return 'fertile';
      return 'safe';
    }

    function renderTimeline(cycleLen: number, ovulationOffset: number): void {
      timelineEl.innerHTML = '';
      for (let i = 0; i < cycleLen; i++) {
        const seg = document.createElement('div');
        seg.className = `h-full flex-1 ${segmentClass(dayKind(i, cycleLen, ovulationOffset))}`;
        seg.title = `Day ${i + 1}`;
        timelineEl.appendChild(seg);
      }
    }

    function renderEmpty(): void {
      nextPeriodEl.textContent = '—';
      ovulationWindowEl.textContent = '—';
      ovulationDayEl.textContent = 'Peak ovulation: —';
      timelineEl.innerHTML = '';
      timelineNote.textContent = 'Enter your last period date to see the timeline.';
    }

    function recalculate(): void {
      const lastPeriod = parseDateOnly(lastPeriodInput.value);
      const cycleLen = Number(cycleSlider.value) || 28;
      cycleDisplay.textContent = `${cycleLen} days`;

      if (!lastPeriod) {
        renderEmpty();
        saveState();
        return;
      }

      const nextPeriod = addDays(lastPeriod, cycleLen);
      const ovulationDay = addDays(nextPeriod, -LUTEAL_PHASE);
      const fertileStart = addDays(ovulationDay, -FERTILE_DAYS_BEFORE);
      const fertileEnd = addDays(ovulationDay, FERTILE_DAYS_AFTER);
      const ovulationOffset = cycleLen - LUTEAL_PHASE;

      nextPeriodEl.textContent = formatDate(nextPeriod);
      ovulationWindowEl.textContent = formatRange(fertileStart, fertileEnd);
      ovulationDayEl.textContent = `Peak ovulation (est.): ${formatDate(ovulationDay)}`;
      renderTimeline(cycleLen, ovulationOffset);
      timelineNote.textContent = `${cycleLen}-day cycle · period days 1–${PERIOD_DAYS} · ovulation ~day ${ovulationOffset + 1}`;

      saveState();
    }

    function saveState(): void {
      try {
        localStorage.setItem(
          STORAGE_KEY,
          JSON.stringify({ lastPeriod: lastPeriodInput.value, cycleLength: cycleSlider.value })
        );
      } catch {
        /* ignore */
      }
    }

    function loadState(): void {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw) as { lastPeriod?: string; cycleLength?: string };
        if (parsed.lastPeriod) lastPeriodInput.value = parsed.lastPeriod;
        if (parsed.cycleLength) cycleSlider.value = parsed.cycleLength;
      } catch {
        /* ignore */
      }
    }

    lastPeriodInput.addEventListener('change', recalculate);
    cycleSlider.addEventListener('input', recalculate);

    resetBtn.addEventListener('click', () => {
      lastPeriodInput.value = '';
      cycleSlider.value = '28';
      renderEmpty();
      cycleDisplay.textContent = '28 days';
      try {
        localStorage.removeItem(STORAGE_KEY);
      } catch {
        /* ignore */
      }
    });

    loadState();
    recalculate();
  </script>
</ToolsLayout>
