---
import AppShellLayout from '../../layouts/AppShellLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { SITES } from '@shared/config/sites';

const pageTitle = formatSeoTitle('Welcome to Pro', 'GramSeva Mitra');
---

<AppShellLayout title={pageTitle} description="Your GramSeva Mitra Pro subscription is being activated." activeWorkspace="documents">
  <div class="px-4 py-12 text-center sm:px-6 sm:py-16">
    <p class="text-5xl" aria-hidden="true">⚡</p>
    <h1 class="mt-4 text-2xl font-bold text-slate-900 sm:text-3xl">Payment successful</h1>
    <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-slate-600">
      Thank you! Razorpay confirmed your payment. Your account will show Pro within a few seconds once our
      webhook updates Cloudflare D1.
    </p>
    <p id="session-hint" class="mt-4 text-xs text-slate-400"></p>
    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <a
        href="/workspace/documents"
        class="inline-flex items-center justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800"
      >
        Back to app
      </a>
      <a
        href={`${SITES.pdf.url}/studio`}
        data-astro-reload
        class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
      >
        Open PDF Studio
      </a>
    </div>
  </div>
</AppShellLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const paymentId = params.get('payment_id');
  const orderId = params.get('order_id');
  const hint = document.getElementById('session-hint');
  if (hint && (paymentId || orderId)) {
    const parts = [];
    if (paymentId) parts.push(`Payment: ${paymentId.slice(0, 20)}…`);
    if (orderId) parts.push(`Order: ${orderId.slice(0, 20)}…`);
    hint.textContent = parts.join(' · ');
  }
</script>
