---
import '@shared/styles/global.css';
import AppShellLayout from '../layouts/AppShellLayout.astro';
---

<AppShellLayout
  title="You Are Offline | GramSeva Mitra"
  description="GramSeva Mitra works offline. Most free calculators and client-side PDF tools remain available without a network connection."
  activeWorkspace="documents"
>
  <section class="px-4 py-12 text-center sm:px-6 sm:py-16">
    <div class="mx-auto max-w-lg rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
      <p class="text-4xl" aria-hidden="true">📡</p>
      <h1 class="mt-4 text-2xl font-bold text-slate-900">You&apos;re offline</h1>
      <p class="mt-3 text-sm leading-relaxed text-slate-600">
        No internet connection detected. The good news: most GramSeva Mitra <strong>free tools</strong> run
        entirely in your browser — calculators, converters, baby names, and client-side PDF tasks keep
        working offline once cached.
      </p>
      <p class="mt-3 text-sm text-slate-500">
        Pro serverless features and the contact form require a connection. Reconnect and refresh to sync
        the latest updates.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <button
          type="button"
          onclick="window.location.reload()"
          class="inline-flex items-center justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800"
        >
          Try again
        </button>
        <a
          href="/workspace/documents"
          class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
        >
          Open offline app
        </a>
      </div>
    </div>
  </section>
</AppShellLayout>
