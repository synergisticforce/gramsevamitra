---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import NotFoundContent from '@shared/components/NotFoundContent.astro';
import { SITES, utilitiesHref } from '@shared/config/sites';
---

<BaseLayout
  title="Page Not Found | GramSeva Mitra"
  description="The page you requested could not be found on GramSeva Mitra."
  site="hub"
>
  <Header slot="header" active="hub" />
  <NotFoundContent
    homeHref={SITES.hub.url}
    homeLabel="Back to Main Hub"
    extraLinks={[
      { href: utilitiesHref('/tools'), label: 'Open Utilities Super-App' },
      { href: SITES.pdf.url, label: 'PDF Tools' },
    ]}
  />
  <Footer slot="footer" />
</BaseLayout>
