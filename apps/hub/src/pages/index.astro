---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import { SITES, utilitiesHref } from '@shared/config/sites';
import { SITE_HOME_SEO } from '@shared/config/seo';
---

<BaseLayout
  title={SITE_HOME_SEO.hub.title}
  description={SITE_HOME_SEO.hub.description}
  site="hub"
>
  <Header slot="header" active="hub" />

  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/30 via-slate-950 to-slate-950"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 inline-flex items-center rounded-full border border-emerald-800/60 bg-emerald-950/50 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-300">
          Free · Private · Offline-Ready
        </p>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl">
          Gram<span class="text-emerald-400">Seva</span> Mitra
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-400 sm:text-xl">
          Your Free Global Document &amp; Productivity Toolkit. No Sign-Up, Works Offline.
        </p>
      </div>

      <div class="product-grid mt-12">
        <a
          href={utilitiesHref('/tools')}
          data-astro-reload
          class="group card flex flex-col transition hover:border-emerald-700/60 hover:bg-slate-900"
        >
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-600/20 text-2xl">
            🧰
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-emerald-300">
            Utilities Super-App
          </h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400">
            40+ free offline tools for money, writing, career, wellness, and quick calculators — all in your browser.
          </p>
          <span class="mt-6 inline-flex items-center text-sm font-semibold text-emerald-400">
            Explore Tools Hub
            <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>

        <a
          href={SITES.optimizer.url}
          data-astro-reload
          class="group card flex flex-col transition hover:border-emerald-700/60 hover:bg-slate-900"
        >
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-600/20 text-2xl">
            📄
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-emerald-300">
            Document Photo Optimizer
          </h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400">
            Resize photos and signatures for visa applications, government exams, and National ID uploads — exact dimensions and file sizes, processed locally.
          </p>
          <span class="mt-6 inline-flex items-center text-sm font-semibold text-emerald-400">
            Open Optimizer
            <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>

        <a
          href={SITES.resume.url}
          data-astro-reload
          class="group card flex flex-col transition hover:border-emerald-700/60 hover:bg-slate-900"
        >
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-600/20 text-2xl">
            🎯
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-emerald-300">
            ATS Resume Scanner &amp; Keyword Checker
          </h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400">
            Paste a job description, upload your resume, and get an instant ATS match score with missing keywords and structural feedback.
          </p>
          <span class="mt-6 inline-flex items-center text-sm font-semibold text-emerald-400">
            Open Scanner
            <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>

        <a
          href={SITES.pdf.url}
          data-astro-reload
          class="group card flex flex-col transition hover:border-emerald-700/60 hover:bg-slate-900"
        >
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-600/20 text-2xl">
            📑
          </div>
          <h2 class="text-xl font-bold text-white group-hover:text-emerald-300">
            PDF Tools &amp; Document Utilities
          </h2>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400">
            Compress, merge, split, watermark, sign, and unlock PDFs — 100% free utilities that run on your device, built for mobile.
          </p>
          <span class="mt-6 inline-flex items-center text-sm font-semibold text-emerald-400">
            Open PDF Tools
            <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      </div>

      <div class="mt-20 grid gap-8 sm:grid-cols-3">
        <div class="text-center">
          <p class="text-3xl font-bold text-emerald-400">100%</p>
          <p class="mt-1 text-sm text-slate-400">On-device processing</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-bold text-emerald-400">0</p>
          <p class="mt-1 text-sm text-slate-400">Files uploaded to servers</p>
        </div>
        <div class="text-center">
          <p class="text-3xl font-bold text-emerald-400">Offline</p>
          <p class="mt-1 text-sm text-slate-400">Works without a connection</p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .product-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }
  @media (min-width: 1024px) {
    .product-grid {
      gap: 2rem;
    }
  }
</style>
