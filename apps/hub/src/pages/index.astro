---
import { DEFAULT_APP_WORKSPACE } from '../config/appWorkspaces';

const signIn = Astro.url.searchParams.get('signIn');
const returnTo = Astro.url.searchParams.get('returnTo');

if (signIn === '1') {
  const safeReturn =
    returnTo && returnTo.startsWith('/') && !returnTo.startsWith('//') ? returnTo : null;
  const targetPath = safeReturn ?? DEFAULT_APP_WORKSPACE.href;
  const url = new URL(targetPath, Astro.url.origin);
  url.searchParams.set('signIn', '1');
  if (safeReturn) url.searchParams.set('returnTo', safeReturn);
  return Astro.redirect(`${url.pathname}${url.search}`, 302);
}

/** Day-Zero: root is the App Model — no legacy marketing / product grid. */
return Astro.redirect(DEFAULT_APP_WORKSPACE.href, 302);
---
