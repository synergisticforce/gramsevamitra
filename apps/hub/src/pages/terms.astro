---
import '@shared/styles/global.css';
import SaaSLayout from '../layouts/SaaSLayout.astro';
import SaaSLegalPage from '../components/saas/SaaSLegalPage.astro';
import SegmentedControl from '../components/saas/SegmentedControl.astro';
import TermsOfServiceContent from '@shared/components/legal/TermsOfServiceContent.astro';
import { LEGAL_SEO } from '@shared/config/seo';
import { LEGAL_SEGMENTS } from '../components/saas/saasNav.ts';
---

<SaaSLayout
  title={LEGAL_SEO.terms.hub.title}
  description={LEGAL_SEO.terms.hub.description}
  activeNav="legal"
>
  <SaaSLegalPage title="Terms of Service">
    <SegmentedControl slot="nav" items={LEGAL_SEGMENTS} activeId="terms" />
    <TermsOfServiceContent />
  </SaaSLegalPage>
</SaaSLayout>
