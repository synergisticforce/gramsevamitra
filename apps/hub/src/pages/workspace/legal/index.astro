---
import AppShellLayout from '../../../layouts/AppShellLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
---

<AppShellLayout
  title={formatSeoTitle('Legal', 'GramSeva Mitra')}
  description="Privacy Policy, Terms of Service, and Refund Policy for GramSeva Mitra."
  activeWorkspace="documents"
>
  <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-10">
    <header class="mb-8">
      <p class="text-xs font-semibold uppercase tracking-wider text-violet-700">Legal</p>
      <h1 class="mt-2 text-2xl font-bold text-slate-900 sm:text-3xl">Policies &amp; compliance</h1>
      <p class="mt-2 text-sm text-slate-600">
        Documents required for Razorpay Live mode and transparent use of GramSeva Mitra.
      </p>
    </header>
    <ul class="space-y-3">
      <li>
        <a
          href="/workspace/legal/privacy"
          class="block rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm font-semibold text-slate-900 shadow-sm transition hover:border-violet-300 hover:text-violet-800"
        >
          Privacy Policy →
        </a>
      </li>
      <li>
        <a
          href="/workspace/legal/terms"
          class="block rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm font-semibold text-slate-900 shadow-sm transition hover:border-violet-300 hover:text-violet-800"
        >
          Terms of Service →
        </a>
      </li>
      <li>
        <a
          href="/workspace/legal/refund"
          class="block rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm font-semibold text-slate-900 shadow-sm transition hover:border-violet-300 hover:text-violet-800"
        >
          Refund &amp; Cancellation Policy →
        </a>
      </li>
    </ul>
    <p class="mt-6 text-sm text-slate-600">
      Support:{' '}
      <a href="mailto:support@gramsevamitra.in" class="font-medium text-violet-700 underline">
        support@gramsevamitra.in
      </a>
    </p>
  </div>
</AppShellLayout>
