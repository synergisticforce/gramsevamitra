---
import AppShellLayout from '../../layouts/AppShellLayout.astro';
import FinanceHubCanvas from '../../components/canvas/FinanceHubCanvas';
import { APP_WORKSPACES } from '../../config/appWorkspaces';
import { formatSeoTitle } from '@shared/config/seo';

const workspace = APP_WORKSPACES.find((ws) => ws.id === 'finance')!;
---

<AppShellLayout
  title={formatSeoTitle(workspace.label, 'GramSeva Mitra App')}
  description={workspace.description}
  activeWorkspace="finance"
>
  <FinanceHubCanvas client:load />
</AppShellLayout>
