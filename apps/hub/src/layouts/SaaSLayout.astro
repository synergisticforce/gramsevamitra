---
import SaaSLayout from '@shared/layouts/SaaSLayout.astro';
import HubOmniSearchPalette from '../components/saas/HubOmniSearchPalette.tsx';
import ProUpgradeModal from '../components/billing/ProUpgradeModal.tsx';
import type { SaaSNavKey } from '@shared/components/saas/saasNav.ts';

interface Props {
  title: string;
  description?: string;
  activeNav?: SaaSNavKey;
  padMobileNav?: boolean;
  wide?: boolean;
}

const {
  title,
  description = 'Free privacy-first productivity tools — offline calculators, document utilities, and career prep.',
  activeNav = 'home',
  padMobileNav = true,
  wide = false,
} = Astro.props;
---

<SaaSLayout
  site="hub"
  title={title}
  description={description}
  activeNav={activeNav}
  padMobileNav={padMobileNav}
  wide={wide}
>
  <slot name="head" slot="head" />
  <slot />
  <HubOmniSearchPalette client:load slot="footer" />
  <ProUpgradeModal client:load slot="footer" />
</SaaSLayout>
