---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import AppGlobalHeader from '../components/app/AppGlobalHeader';
import AppSidebar from '../components/app/AppSidebar';
import AppShellFooter from '../components/app/AppShellFooter';
import FeedbackWidget from '../components/app/FeedbackWidget';
import ProPricingModal from '../components/billing/ProPricingModal.tsx';
import AuthModal from '../components/billing/AuthModal.tsx';
import PwaRegister from '../components/tools/PwaRegister';
import WorkspaceAuthBoundary from '../components/app/WorkspaceAuthBoundary';
import type { AppWorkspaceId } from '../config/appWorkspaces';

interface Props {
  title: string;
  description?: string;
  activeWorkspace: AppWorkspaceId;
  /** When true, workspace tool UI is replaced with a sign-in prompt for logged-out users. */
  requireAuth?: boolean;
}

const {
  title,
  description = 'GramSeva Mitra — unified workspace for documents, media, career, finance, and quick tools.',
  activeWorkspace,
  requireAuth = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description} site="hub">
  <slot name="head" slot="head" />

  <div class="flex min-h-screen flex-col bg-canvas-bg text-slate-200 leading-relaxed">
    <AppGlobalHeader client:load />
    <div class="flex min-h-0 flex-1 flex-col lg:flex-row">
      <AppSidebar client:load activeWorkspace={activeWorkspace} currentPath={currentPath} />
      <main class="flex min-w-0 flex-1 flex-col">
      <WorkspaceAuthBoundary client:load requireAuth={requireAuth}>
        <div class="min-h-0 flex-1">
          <slot />
        </div>
      </WorkspaceAuthBoundary>
      <AppShellFooter client:load />
      </main>
    </div>
  </div>

  <FeedbackWidget client:load />
  <AuthModal client:load />
  <ProPricingModal client:load />
  <PwaRegister client:load />
</BaseLayout>
