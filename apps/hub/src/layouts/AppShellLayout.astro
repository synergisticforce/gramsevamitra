---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import AppSidebar from '../components/app/AppSidebar';
import ProUpgradeModal from '../components/billing/ProUpgradeModal.tsx';
import PwaRegister from '../components/tools/PwaRegister';
import type { AppWorkspaceId } from '../config/appWorkspaces';

interface Props {
  title: string;
  description?: string;
  activeWorkspace: AppWorkspaceId;
}

const {
  title,
  description = 'GramSeva Mitra — unified workspace for documents, media, career, finance, and quick tools.',
  activeWorkspace,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description} site="hub">
  <div class="flex min-h-screen flex-col bg-slate-50 lg:flex-row">
    <AppSidebar client:load activeWorkspace={activeWorkspace} currentPath={currentPath} />
    <main class="min-w-0 flex-1">
      <slot />
    </main>
  </div>

  <ProUpgradeModal client:load slot="footer" />
  <PwaRegister client:load slot="footer" />
</BaseLayout>
