---
import '@shared/styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import SaaSLayout from './SaaSLayout.astro';
import WorkspaceSegmentNav from '../components/saas/WorkspaceSegmentNav.astro';
import PwaRegister from '../components/tools/PwaRegister';
import {
  resolveSegmentId,
} from '../config/workspaceSegments';
import type { ToolWorkspace, ToolsLayoutNav } from '../config/toolsRegistry';

interface Props {
  title: string;
  description?: string;
  activeNav?: ToolsLayoutNav;
  /** Override auto-detected workspace segment (e.g. money dashboard tabs). */
  segmentId?: string;
  /** Hide workspace segment bar (e.g. utilities hub home). */
  hideWorkspaceNav?: boolean;
}

const {
  title,
  description = 'Free browser utilities for students, gig workers, and job seekers — money trackers, writing tools, career prep, and quick calculators. 100% offline.',
  activeNav = 'home',
  segmentId,
  hideWorkspaceNav = false,
} = Astro.props;

const workspace: ToolWorkspace | null =
  activeNav === 'home' ? null : (activeNav as ToolWorkspace);

const activeSegmentId =
  segmentId ?? (workspace ? resolveSegmentId(Astro.url.pathname, workspace) : 'all');

const showWorkspaceNav = Boolean(workspace) && !hideWorkspaceNav;

const isWorkspaceIndex =
  workspace != null &&
  (Astro.url.pathname === `/tools/${workspace}` || Astro.url.pathname === `/tools/${workspace}/`);
---

<SaaSLayout title={title} description={description} activeNav="utilities">
  <ViewTransitions slot="head" />

  <div class="px-4 py-6 sm:px-6 sm:py-8">
    {
      showWorkspaceNav && workspace && (
        <WorkspaceSegmentNav
          workspace={workspace}
          activeSegmentId={activeSegmentId}
          showBackLink={isWorkspaceIndex}
        />
      )
    }
    <slot />
  </div>

  <PwaRegister client:load slot="footer" />
</SaaSLayout>
