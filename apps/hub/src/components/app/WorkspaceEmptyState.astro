---
import type { AppWorkspace } from '../../config/appWorkspaces';

interface Props {
  workspace: AppWorkspace;
}

const { workspace } = Astro.props;
---

<section class="px-4 py-8 sm:px-6 sm:py-10">
  <div class="mx-auto max-w-2xl">
    <p class="text-xs font-semibold uppercase tracking-wider text-emerald-700">Workspace</p>
    <div class="mt-2 flex items-center gap-3">
      <span class="text-3xl" aria-hidden="true">{workspace.emoji}</span>
      <div>
        <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">{workspace.label}</h1>
        <p class="mt-1 text-sm text-slate-600">{workspace.description}</p>
      </div>
    </div>

    <div class="mt-8 rounded-2xl border-2 border-dashed border-slate-200 bg-white p-8 text-center shadow-sm">
      <p class="text-4xl" aria-hidden="true">✨</p>
      <p class="mt-3 text-base font-semibold text-slate-900">Magic Dropzone — Phase 2</p>
      <p class="mx-auto mt-2 max-w-sm text-sm leading-relaxed text-slate-500">
        Drag and drop files here, or tap to upload on mobile. Contextual toolbars will appear once a file
        is loaded.
      </p>
    </div>
  </div>
</section>
