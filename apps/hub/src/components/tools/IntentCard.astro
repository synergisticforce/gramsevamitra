---
import type { WorkspaceMeta } from '../../config/toolsRegistry';
import { utilitiesHref } from '@shared/config/sites';

interface Props {
  workspace: WorkspaceMeta;
}

const { workspace } = Astro.props;
---

<a
  href={utilitiesHref(workspace.path)}
  class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-emerald-300 hover:shadow-md"
>
  <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-2xl">
    {workspace.emoji}
  </div>
  <h2 class="text-lg font-bold text-slate-900 group-hover:text-emerald-800 sm:text-xl">{workspace.label}</h2>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{workspace.description}</p>
  <span class="mt-5 inline-flex items-center text-sm font-semibold text-emerald-700">
    Open workspace
    <svg
      class="ml-2 h-4 w-4 transition group-hover:translate-x-1"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </svg>
  </span>
</a>
