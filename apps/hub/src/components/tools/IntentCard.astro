---
import type { WorkspaceMeta } from '../../config/toolsRegistry';

interface Props {
  workspace: WorkspaceMeta;
}

const { workspace } = Astro.props;
---

<a
  href={workspace.path}
  class="group card flex flex-col transition hover:border-emerald-700/60 hover:bg-slate-900/80"
>
  <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-600/20 text-2xl">
    {workspace.emoji}
  </div>
  <h2 class="text-lg font-bold text-white group-hover:text-emerald-300 sm:text-xl">{workspace.label}</h2>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-400">{workspace.description}</p>
  <span class="mt-5 inline-flex items-center text-sm font-semibold text-emerald-400">
    Open workspace
    <svg
      class="ml-2 h-4 w-4 transition group-hover:translate-x-1"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </svg>
  </span>
</a>
