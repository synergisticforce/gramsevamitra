---
import { WORKSPACES } from '../../config/toolsRegistry';
import { utilitiesHref } from '@shared/config/sites';

interface Props {
  active?: 'home' | 'money' | 'writing' | 'career' | 'life' | 'quick' | 'search';
}

const { active = 'home' } = Astro.props;

function navLabel(id: (typeof WORKSPACES)[number]['id']): string {
  if (id === 'writing') return 'Write';
  if (id === 'life') return 'Life';
  return id === 'money' ? 'Money' : id === 'career' ? 'Career' : 'Quick';
}

const navItems = [
  { id: 'home' as const, label: 'Home', emoji: '🏠', path: utilitiesHref('/tools'), reload: false },
  ...WORKSPACES.map((w) => ({
    id: w.id as 'money' | 'writing' | 'career' | 'life' | 'quick',
    label: navLabel(w.id),
    emoji: w.emoji,
    path: utilitiesHref(w.path),
    reload: false,
  })),
];
---

<nav
  class="fixed bottom-0 left-0 right-0 z-40 border-t border-slate-800/80 bg-slate-950/95 backdrop-blur-md pb-[env(safe-area-inset-bottom)] md:hidden"
  aria-label="Tools workspace navigation"
>
  <ul class="mx-auto flex max-w-lg items-stretch justify-around gap-0.5 overflow-x-auto px-1">
    {
      navItems.map((item) => (
        <li class="min-w-0 flex-1">
          <a
            href={item.path}
            data-astro-reload={item.reload ? true : undefined}
            class:list={[
              'flex flex-col items-center justify-center gap-0.5 px-0.5 py-2 text-[9px] font-semibold transition sm:text-[10px]',
              active === item.id ? 'text-emerald-400' : 'text-slate-400 hover:text-slate-200',
            ]}
            aria-current={active === item.id ? 'page' : undefined}
          >
            <span class="text-base leading-none sm:text-lg" aria-hidden="true">
              {item.emoji}
            </span>
            <span class="truncate">{item.label}</span>
          </a>
        </li>
      ))
    }
    <li class="min-w-0 flex-1">
      <button
        type="button"
        id="tools-search-trigger"
        class:list={[
          'flex w-full flex-col items-center justify-center gap-0.5 px-0.5 py-2 text-[9px] font-semibold transition focus:outline-none focus:ring-2 focus:ring-inset focus:ring-emerald-400 sm:text-[10px]',
          active === 'search' ? 'text-emerald-400' : 'text-slate-400 hover:text-slate-200',
        ]}
        aria-label="Search tools"
      >
        <span class="text-base leading-none sm:text-lg" aria-hidden="true">🔍</span>
        <span>Search</span>
      </button>
    </li>
  </ul>
</nav>
