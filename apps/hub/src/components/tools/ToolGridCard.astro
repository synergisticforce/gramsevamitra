---
import type { ToolEntry } from '../../config/toolsRegistry';
import { utilitiesHref } from '@shared/config/sites';

interface Props {
  tool: ToolEntry;
}

const { tool } = Astro.props;
---

<a
  href={utilitiesHref(tool.path)}
  class="group flex min-h-[140px] flex-col rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-emerald-300 hover:shadow-md"
>
  <h3 class="text-base font-bold text-slate-900 group-hover:text-emerald-800">{tool.name}</h3>
  <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-600">{tool.description}</p>
  <span class="mt-3 text-xs font-semibold text-emerald-700">Open tool →</span>
</a>
