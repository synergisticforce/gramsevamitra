---
import type { ToolEntry } from '../../config/toolsRegistry';
import { utilitiesHref } from '@shared/config/sites';

interface Props {
  tool: ToolEntry;
}

const { tool } = Astro.props;
---

<a
  href={utilitiesHref(tool.path)}
  class="group flex min-h-[140px] flex-col rounded-2xl border border-slate-800 bg-slate-900/50 p-4 transition hover:border-emerald-700/60 hover:bg-slate-900/80"
>
  <h3 class="text-base font-bold text-white group-hover:text-emerald-300">{tool.name}</h3>
  <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-400">{tool.description}</p>
  <span class="mt-3 text-xs font-semibold text-emerald-400">Open tool →</span>
</a>
