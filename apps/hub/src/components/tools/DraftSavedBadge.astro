---
interface Props {
  id?: string;
}

const { id = 'draft-saved-badge' } = Astro.props;
---

<p
  id={id}
  class="draft-saved-badge mt-2 flex items-center gap-1.5 text-xs text-emerald-400/90"
  aria-live="polite"
  hidden
>
  <span class="inline-flex h-4 w-4 items-center justify-center rounded-full bg-emerald-500/20 text-[10px]" aria-hidden="true">✓</span>
  <span>Draft saved locally — safe to refresh</span>
</p>
