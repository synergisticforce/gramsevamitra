---
import ToolsLayout from '../../layouts/ToolsLayout.astro';
import ToolGridCard from './ToolGridCard.astro';
import {
  activeNavForWorkspace,
  getWorkspaceMeta,
  type ToolWorkspace,
} from '../../config/toolsRegistry';
import { getToolsForSegment, WORKSPACE_SEGMENT_DEFS } from '../../config/workspaceSegments';
import { formatSeoTitle } from '@shared/config/seo';

interface Props {
  workspaceId: ToolWorkspace;
}

const { workspaceId } = Astro.props;
const workspace = getWorkspaceMeta(workspaceId);
const segmentDefs = WORKSPACE_SEGMENT_DEFS[workspaceId].filter((s) => s.id !== 'all');
---

<ToolsLayout
  title={formatSeoTitle(workspace.label, 'Free Offline Tools')}
  description={workspace.description}
  activeNav={activeNavForWorkspace(workspaceId)}
>
  <section>
    {
      segmentDefs.map((segment) => {
        const tools = getToolsForSegment(workspaceId, segment.id);
        if (tools.length === 0) return null;
        return (
          <div id={segment.id} class="scroll-mt-24 not-first:mt-10">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">{segment.label}</h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {tools.map((tool) => (
                <ToolGridCard tool={tool} />
              ))}
            </div>
          </div>
        );
      })
    }
  </section>
</ToolsLayout>
