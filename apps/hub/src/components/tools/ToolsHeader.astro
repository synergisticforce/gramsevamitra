---
import { SITES, utilitiesHref } from '@shared/config/sites';
---

<header class="sticky top-0 z-40 border-b border-slate-800/80 bg-slate-950/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6">
    <a href={utilitiesHref('/tools')} class="group flex min-w-0 items-center gap-2 transition hover:opacity-90">
      <span
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-emerald-600 text-sm font-bold text-white transition group-hover:bg-emerald-500"
        aria-hidden="true"
      >
        GS
      </span>
      <span class="truncate text-base font-bold tracking-tight text-white sm:text-lg">
        Gram<span class="text-emerald-400">Seva</span> Mitra
        <span class="ml-1 hidden text-sm font-medium text-slate-400 sm:inline">Utilities</span>
      </span>
    </a>

    <div class="flex shrink-0 items-center gap-2">
      <a
        href={SITES.hub.url}
        class="hidden rounded-full border border-slate-700 bg-slate-900/60 px-3 py-1.5 text-xs font-semibold text-slate-300 transition hover:border-emerald-700 hover:text-white sm:inline-flex"
      >
        Main Hub
      </a>
      <button
        type="button"
        id="tools-install-trigger"
        class="hidden rounded-full border border-emerald-800/60 bg-emerald-950/40 px-3 py-1.5 text-xs font-semibold text-emerald-300 transition hover:border-emerald-500 hover:bg-emerald-900/40 hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-400 md:inline-flex"
        aria-label="Install GramSeva Mitra app"
      >
        Install App
      </button>
      <a
        href={SITES.pdf.url}
        class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-emerald-800/60 bg-emerald-950/40 px-3 py-1.5 text-xs font-semibold text-emerald-300 transition hover:border-emerald-500 hover:bg-emerald-900/40 hover:text-white sm:px-4 sm:text-sm"
      >
        <span class="hidden sm:inline">PDF Tools</span>
        <span class="sm:hidden">PDF</span>
        <span aria-hidden="true">➔</span>
      </a>
    </div>
  </div>
</header>

<script>
  import { initPwaInstall, isStandalone, triggerPwaInstall } from '@shared/lib/pwaInstall';

  initPwaInstall();

  const installBtn = document.getElementById('tools-install-trigger');
  if (installBtn && !isStandalone()) {
    installBtn.classList.remove('hidden');
    installBtn.addEventListener('click', () => {
      void triggerPwaInstall();
    });
  }
</script>
