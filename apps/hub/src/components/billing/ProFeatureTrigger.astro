---
interface Props {
  featureId?: string;
  featureName: string;
  featureDescription?: string;
  class?: string;
}

const { featureId, featureName, featureDescription, class: className = '' } = Astro.props;
---

<button
  type="button"
  class:list={[
    'pro-feature-trigger inline-flex items-center gap-1.5 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-900 transition hover:border-amber-300 hover:bg-amber-100',
    className,
  ]}
  data-feature-id={featureId}
  data-feature-name={featureName}
  data-feature-description={featureDescription}
>
  <span aria-hidden="true">⚡</span>
  <span>Pro</span>
</button>

<script>
  import { openProUpgrade } from '@shared/lib/proUpgrade';

  document.querySelectorAll<HTMLButtonElement>('.pro-feature-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      openProUpgrade({
        featureId: btn.dataset.featureId,
        featureName: btn.dataset.featureName ?? 'Pro Feature',
        featureDescription: btn.dataset.featureDescription,
      });
    });
  });
</script>
