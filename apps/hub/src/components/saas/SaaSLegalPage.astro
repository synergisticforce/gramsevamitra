---
interface Props {
  title: string;
  lastUpdated?: string;
}

const { title, lastUpdated = 'June 2026' } = Astro.props;
---

<article class="px-4 py-10 sm:px-6 sm:py-12">
  <header class="mb-8">
    <slot name="nav" />
    <h1 class="mt-6 text-3xl font-bold tracking-tight text-canvas-text">{title}</h1>
    <p class="mt-2 text-sm text-canvas-subtle">Last updated: {lastUpdated}</p>
  </header>
  <div class="saas-legal-content prose prose-slate max-w-none text-canvas-muted prose-headings:text-canvas-text prose-a:text-canvas-accent">
    <slot />
  </div>
</article>

<style>
  .saas-legal-content :global(h2) {
    @apply mt-6 text-xl font-semibold text-canvas-text;
  }
  .saas-legal-content :global(p) {
    @apply text-canvas-muted;
  }
  .saas-legal-content :global(strong) {
    @apply text-canvas-text;
  }
</style>
