---
import SegmentedControl from '@shared/components/saas/SegmentedControl.astro';
import { getWorkspaceMeta, type ToolWorkspace } from '../../config/toolsRegistry';
import { getWorkspaceSegments } from '../../config/workspaceSegments';
import { utilitiesHref } from '@shared/config/sites';

interface Props {
  workspace: ToolWorkspace;
  activeSegmentId: string;
  /** Show link back to /tools hub (workspace index pages only). */
  showBackLink?: boolean;
}

const { workspace, activeSegmentId, showBackLink = true } = Astro.props;
const meta = getWorkspaceMeta(workspace);
const segments = getWorkspaceSegments(workspace);
---

<div class="mb-6 space-y-4">
  {
    showBackLink && (
      <a
        href={utilitiesHref('/tools')}
        class="inline-flex text-xs font-semibold text-emerald-700 transition hover:text-emerald-800"
      >
        ← All utilities
      </a>
    )
  }

  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-2.5">
      <span class="text-2xl" aria-hidden="true">
        {meta.emoji}
      </span>
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">{meta.label}</p>
        <p class="text-sm text-slate-600">{meta.description}</p>
      </div>
    </div>
    <SegmentedControl items={segments} activeId={activeSegmentId} ariaLabel={`${meta.label} sections`} />
  </div>
</div>
