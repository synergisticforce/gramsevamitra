---
import { SITES } from '@shared/config/sites';
---

<section class="px-4 py-12 text-center sm:px-6 sm:py-16">
  <p class="text-6xl font-extrabold tabular-nums text-slate-200" aria-hidden="true">404</p>
  <h1 class="mt-4 text-2xl font-bold text-slate-900 sm:text-3xl">Page not found</h1>
  <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-slate-600">
    This page does not exist or may have moved. Return to the workspace or contact support.
  </p>

  <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
    <a
      href="/workspace/documents"
      class="inline-flex w-full max-w-xs items-center justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800 sm:w-auto"
    >
      Back to workspace
    </a>
    <a
      href={`${SITES.hub.url}/contact`}
      class="inline-flex w-full max-w-xs items-center justify-center rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 sm:w-auto"
    >
      Contact support
    </a>
  </div>
</section>
