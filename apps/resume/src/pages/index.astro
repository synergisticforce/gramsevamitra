---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import AtsScannerTool from '../components/AtsScannerTool';
import { SITE_HOME_SEO } from '@shared/config/seo';

const toolName = 'ATS Resume Scanner';
const toolDescription =
  'Upload your resume (PDF, DOCX, or image), paste the job description, and get an instant keyword match score — 100% private, runs in your browser.';
---

<BaseLayout
  title={SITE_HOME_SEO.resume.title}
  description={SITE_HOME_SEO.resume.description}
  site="resume"
  showCrossPromo={true}
>
  <Header slot="header" active="resume" />

  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/20 via-slate-950 to-slate-950"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
      <header class="mb-8 text-center">
        <p
          class="mb-3 inline-flex items-center rounded-full border border-emerald-800/60 bg-emerald-950/50 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-300"
        >
          100% Private · Zero Uploads
        </p>
        <h1 class="text-3xl font-bold text-white sm:text-4xl">{toolName}</h1>
        <p class="mx-auto mt-3 max-w-2xl text-sm text-slate-400 sm:text-base">{toolDescription}</p>
      </header>

      <AtsScannerTool client:load />
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
