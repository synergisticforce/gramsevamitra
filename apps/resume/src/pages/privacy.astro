---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import LegalPage from '@shared/components/LegalPage.astro';
import PrivacyPolicyContent from '@shared/components/legal/PrivacyPolicyContent.astro';
import { LEGAL_SEO } from '@shared/config/seo';
---

<BaseLayout
  title={LEGAL_SEO.privacy.resume.title}
  description={LEGAL_SEO.privacy.resume.description}
  site="resume"
>
  <Header slot="header" active="resume" />
  <LegalPage title="Privacy Policy">
    <PrivacyPolicyContent />
  </LegalPage>
  <Footer slot="footer" />
</BaseLayout>
