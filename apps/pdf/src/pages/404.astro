---
import PdfToolsLayout from '../layouts/PdfToolsLayout.astro';
import NotFoundContent from '@shared/components/NotFoundContent.astro';
import { SITES, utilitiesHref } from '@shared/config/sites';
---

<PdfToolsLayout
  title="Page Not Found | PDF Tools — GramSeva Mitra"
  description="The PDF tool page you requested could not be found."
  activeNav="home"
  hideWorkspaceNav={true}
>
  <NotFoundContent
    homeHref="/"
    homeLabel="PDF Tools Home"
    extraLinks={[
      { href: '/compress', label: 'Compress PDF' },
      { href: '/merge', label: 'Merge PDF' },
      { href: utilitiesHref('/tools'), label: 'Utilities Super-App' },
      { href: SITES.hub.url, label: 'Main Hub' },
    ]}
  />
</PdfToolsLayout>
