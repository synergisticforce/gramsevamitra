---
import PdfToolsLayout from '../layouts/PdfToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const pageDescription =
  'Convert JPEG and PNG images to a single PDF — reorder pages, choose A4 or Letter, 100% offline in your browser.';
---

<PdfToolsLayout
  title={formatSeoTitle('JPG & PNG to PDF', 'Free Online Converter')}
  description={pageDescription}
  activeNav="home"
>
<header class="mb-6">
        <a href="/" data-astro-reload class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
          ← PDF Tools Home
        </a>
        <h1 class="mt-3 text-2xl font-bold text-slate-900 sm:text-3xl">Image to PDF</h1>
        <p class="mt-1 text-sm text-slate-600">
          Combine JPG and PNG images into one PDF — aspect ratio preserved, processed locally on your device.
        </p>
      </header>

      <div
        id="drop-zone"
        class="drop-zone"
        role="button"
        tabindex="0"
        aria-label="Drop JPG or PNG images here or click to browse"
      >
        <input
          id="file-input"
          type="file"
          accept="image/jpeg,image/png"
          multiple
          class="sr-only"
          aria-hidden="true"
        />
        <div class="pointer-events-none flex flex-col items-center px-4 py-10 text-center sm:py-12">
          <span class="text-5xl" aria-hidden="true">🖼️</span>
          <p class="mt-4 text-lg font-bold text-white">Drop JPG or PNG images</p>
          <p class="mt-1 text-sm text-slate-600">or click to browse · WebP and HEIC not supported</p>
        </div>
      </div>

      <p id="file-error" class="mt-3 hidden text-sm text-rose-400" role="alert"></p>

      <div id="options-panel" class="mt-6 hidden grid gap-4 sm:grid-cols-2">
        <fieldset>
          <legend class="mb-2 text-sm font-medium text-slate-300">Page size</legend>
          <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="Page size">
            <label class="opt-pill">
              <input type="radio" name="page-size" value="a4" class="sr-only peer" checked />
              <span class="opt-pill-label">A4</span>
            </label>
            <label class="opt-pill">
              <input type="radio" name="page-size" value="letter" class="sr-only peer" />
              <span class="opt-pill-label">Letter</span>
            </label>
          </div>
        </fieldset>
        <fieldset>
          <legend class="mb-2 text-sm font-medium text-slate-300">Orientation</legend>
          <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="Orientation">
            <label class="opt-pill">
              <input type="radio" name="orientation" value="portrait" class="sr-only peer" checked />
              <span class="opt-pill-label">Portrait</span>
            </label>
            <label class="opt-pill">
              <input type="radio" name="orientation" value="landscape" class="sr-only peer" />
              <span class="opt-pill-label">Landscape</span>
            </label>
          </div>
        </fieldset>
      </div>

      <div id="grid-section" class="mt-6 hidden">
        <div class="mb-3 flex items-center justify-between gap-2">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Page order</h2>
          <span id="image-count" class="text-xs text-slate-500">0 images</span>
        </div>
        <p class="mb-3 text-xs text-emerald-400/80">Drag thumbnails to reorder pages in the PDF</p>
        <ul id="image-grid" class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4"></ul>
      </div>

      <div class="mt-6">
        <button type="button" id="convert-btn" class="btn-primary w-full py-3 text-base font-bold" disabled>
          Create PDF
        </button>
        <p id="convert-status" class="mt-3 text-center text-xs text-slate-500" aria-live="polite"></p>
      </div>

      <div id="loading-overlay" class="loading-overlay hidden" aria-hidden="true">
        <div class="flex flex-col items-center gap-3 rounded-2xl border border-emerald-800/50 bg-slate-900/95 px-8 py-6 shadow-2xl">
          <div class="spinner" aria-hidden="true"></div>
          <p id="loading-label" class="text-sm font-medium text-emerald-300">Converting…</p>
        </div>
      </div>
</PdfToolsLayout>

<style>
  .drop-zone {
    @apply cursor-pointer rounded-2xl border-2 border-dashed border-emerald-700/50 bg-gradient-to-br from-emerald-950/40 to-slate-900/60 transition hover:border-emerald-500 hover:bg-emerald-950/50 focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2 focus:ring-offset-slate-950;
  }
  .drop-zone.is-dragover {
    @apply border-emerald-400 bg-emerald-950/60 ring-2 ring-emerald-400/40;
  }
  .opt-pill-label {
    @apply inline-flex cursor-pointer items-center rounded-full border border-slate-700 bg-slate-950/60 px-4 py-2 text-sm font-semibold text-slate-300 transition hover:border-emerald-600 hover:text-white;
  }
  .opt-pill :global(input:checked) + .opt-pill-label {
    @apply border-emerald-500 bg-emerald-950/50 text-emerald-300 ring-2 ring-emerald-400/40;
  }
  .opt-pill :global(input:focus-visible) + .opt-pill-label {
    @apply outline-none ring-2 ring-emerald-400;
  }
  .image-card {
    @apply cursor-grab overflow-hidden rounded-xl border border-slate-800 bg-slate-900/80 active:cursor-grabbing;
  }
  .image-card.sortable-ghost {
    @apply opacity-40;
  }
  .image-card.sortable-chosen {
    @apply border-emerald-600 ring-2 ring-emerald-400/30;
  }
  .thumb-wrap {
    @apply relative aspect-[3/4] bg-slate-950;
  }
  .thumb-wrap img {
    @apply h-full w-full object-contain;
  }
  .remove-btn {
    @apply shrink-0 rounded px-1 text-xs transition hover:bg-rose-950/40;
  }
  .loading-overlay {
    @apply fixed inset-0 z-50 flex items-center justify-center bg-slate-950/70 backdrop-blur-sm;
  }
  .loading-overlay.hidden {
    display: none !important;
  }
  .spinner {
    @apply h-10 w-10 animate-spin rounded-full border-4 border-slate-700 border-t-emerald-400;
  }
</style>

<script>
  import Sortable from 'sortablejs';
  import { PDFDocument } from 'pdf-lib';

  const PAGE_SIZES = {
    a4: { width: 595.28, height: 841.89 },
    letter: { width: 612, height: 792 },
  } as const;

  interface ImageItem {
    id: string;
    file: File;
    previewUrl: string;
  }

  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileError = document.getElementById('file-error')!;
  const optionsPanel = document.getElementById('options-panel')!;
  const gridSection = document.getElementById('grid-section')!;
  const imageGrid = document.getElementById('image-grid')!;
  const imageCount = document.getElementById('image-count')!;
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement;
  const convertStatus = document.getElementById('convert-status')!;
  const loadingOverlay = document.getElementById('loading-overlay')!;
  const loadingLabel = document.getElementById('loading-label')!;

  let items: ImageItem[] = [];
  let sortable: Sortable | null = null;

  function isAllowedImage(file: File): boolean {
    const type = file.type.toLowerCase();
    return type === 'image/jpeg' || type === 'image/png';
  }

  function createId(): string {
    return `img-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
  }

  function escapeHtml(text: string): string {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function showError(message: string): void {
    fileError.textContent = message;
    fileError.classList.remove('hidden');
  }

  function clearError(): void {
    fileError.textContent = '';
    fileError.classList.add('hidden');
  }

  function getPageSize(): { width: number; height: number } {
    const sizeRadio = document.querySelector<HTMLInputElement>('input[name="page-size"]:checked');
    const orientRadio = document.querySelector<HTMLInputElement>('input[name="orientation"]:checked');
    const key = sizeRadio?.value === 'letter' ? 'letter' : 'a4';
    const base = PAGE_SIZES[key];
    const landscape = orientRadio?.value === 'landscape';
    return landscape ? { width: base.height, height: base.width } : base;
  }

  function setLoading(active: boolean, label = 'Converting…'): void {
    loadingOverlay.classList.toggle('hidden', !active);
    loadingOverlay.setAttribute('aria-hidden', String(!active));
    loadingLabel.textContent = label;
    convertBtn.disabled = active || items.length === 0;
  }

  function revokePreviews(): void {
    items.forEach((item) => URL.revokeObjectURL(item.previewUrl));
  }

  function addFiles(files: FileList | File[]): void {
    clearError();
    const rejected: string[] = [];
    const accepted: ImageItem[] = [];

    Array.from(files).forEach((file) => {
      if (!isAllowedImage(file)) {
        rejected.push(file.name);
        return;
      }
      accepted.push({
        id: createId(),
        file,
        previewUrl: URL.createObjectURL(file),
      });
    });

    if (rejected.length > 0) {
      showError(`Only JPG and PNG allowed. Skipped: ${rejected.join(', ')}`);
    }

    if (accepted.length === 0) return;

    items = [...items, ...accepted];
    renderGrid();
    convertStatus.textContent = '';
  }

  function removeItem(id: string): void {
    const item = items.find((x) => x.id === id);
    if (item) URL.revokeObjectURL(item.previewUrl);
    items = items.filter((x) => x.id !== id);
    renderGrid();
  }

  function renderGrid(): void {
    const hasItems = items.length > 0;
    optionsPanel.classList.toggle('hidden', !hasItems);
    gridSection.classList.toggle('hidden', !hasItems);
    convertBtn.disabled = items.length === 0;
    imageCount.textContent = `${items.length} image${items.length === 1 ? '' : 's'}`;

    imageGrid.innerHTML = items
      .map(
        (item, index) => `
        <li class="image-card" data-id="${item.id}">
          <div class="thumb-wrap">
            <img src="${item.previewUrl}" alt="Image ${index + 1}: ${escapeHtml(item.file.name)}" loading="lazy" />
          </div>
          <div class="flex items-center justify-between gap-1 px-2 py-2">
            <span class="truncate text-[10px] text-slate-400">${index + 1}. ${escapeHtml(item.file.name)}</span>
            <button type="button" class="remove-btn" data-remove="${item.id}" aria-label="Remove">🗑️</button>
          </div>
        </li>
      `
      )
      .join('');

    imageGrid.querySelectorAll<HTMLButtonElement>('[data-remove]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.dataset.remove;
        if (id) removeItem(id);
      });
    });

    if (sortable) sortable.destroy();
    if (hasItems) {
      sortable = Sortable.create(imageGrid, {
        animation: 150,
        ghostClass: 'sortable-ghost',
        chosenClass: 'sortable-chosen',
        onEnd: () => {
          const order: ImageItem[] = [];
          imageGrid.querySelectorAll<HTMLElement>('[data-id]').forEach((el) => {
            const id = el.dataset.id;
            const found = items.find((x) => x.id === id);
            if (found) order.push(found);
          });
          items = order;
          renderGrid();
        },
      });
    }
  }

  function downloadBlob(bytes: Uint8Array, filename: string): void {
    const blob = new Blob([bytes as BlobPart], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
  }

  async function convertToPdf(): Promise<void> {
    if (items.length === 0) {
      showError('Add at least one JPG or PNG image.');
      return;
    }

    clearError();
    setLoading(true);

    try {
      const pdf = await PDFDocument.create();
      const { width: pageW, height: pageH } = getPageSize();

      for (let i = 0; i < items.length; i++) {
        setLoading(true, `Processing image ${i + 1} of ${items.length}…`);
        const file = items[i].file;
        const bytes = await file.arrayBuffer();

        let embedded;
        if (file.type === 'image/png') {
          embedded = await pdf.embedPng(bytes);
        } else {
          embedded = await pdf.embedJpg(bytes);
        }

        const page = pdf.addPage([pageW, pageH]);
        const imgW = embedded.width;
        const imgH = embedded.height;
        const scale = Math.min(pageW / imgW, pageH / imgH);
        const drawW = imgW * scale;
        const drawH = imgH * scale;
        const x = (pageW - drawW) / 2;
        const y = (pageH - drawH) / 2;

        page.drawImage(embedded, { x, y, width: drawW, height: drawH });
      }

      setLoading(true, 'Saving PDF…');
      const out = await pdf.save();
      downloadBlob(out, 'converted-images.pdf');
      convertStatus.textContent = `Created PDF with ${items.length} page${items.length === 1 ? '' : 's'}.`;
      convertStatus.className = 'mt-3 text-center text-xs text-emerald-400';
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Conversion failed.';
      showError(message);
      convertStatus.textContent = '';
    } finally {
      setLoading(false);
    }
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) addFiles(fileInput.files);
    fileInput.value = '';
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('is-dragover');
  });

  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('is-dragover'));

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('is-dragover');
    if (e.dataTransfer?.files?.length) addFiles(e.dataTransfer.files);
  });

  convertBtn.addEventListener('click', () => {
    void convertToPdf();
  });

  window.addEventListener('beforeunload', () => revokePreviews());
</script>
