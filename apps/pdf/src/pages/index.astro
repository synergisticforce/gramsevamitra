---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import { formatSeoTitle } from '@shared/config/seo';

const featuredTools = [
  {
    name: 'Merge PDF',
    description: 'Drag, reorder, and combine multiple PDFs into one submission-ready file.',
    href: '/merge',
    icon: '📎',
  },
  {
    name: 'Compress PDF',
    description: 'Shrink file size for strict upload limits — extreme, balanced, or high-quality presets.',
    href: '/compress',
    icon: '📉',
  },
];

const tools = [
  {
    name: 'Split PDF',
    description: 'Extract or split pages from a PDF — select exactly what you need.',
    href: '/split',
    icon: '✂️',
  },
  {
    name: 'Watermark PDF',
    description: 'Add a draft or personal watermark across every page locally.',
    href: '/watermark',
    icon: '💧',
  },
  {
    name: 'Image to PDF',
    description: 'Convert JPG photos and scans into a crisp PDF document.',
    href: '/image-to-pdf',
    icon: '🖼️',
  },
  {
    name: 'Protect PDF',
    description: 'Lock your PDF with a password — AES encryption runs entirely on your device.',
    href: '/protect',
    icon: '🔒',
  },
  {
    name: 'Unlock PDF',
    description: 'Remove password protection from an encrypted PDF using the open password.',
    href: '/unlock',
    icon: '🔓',
  },
];
---

<BaseLayout
  title={formatSeoTitle('Free PDF Tools', 'Merge, Split & More')}
  description="Merge, split, compress, watermark, and convert PDFs entirely in your browser — zero uploads, built for professionals and teams."
  site="pdf"
>
  <Header slot="header" active="pdf" />

  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/30 via-slate-950 to-slate-950"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <p
          class="mb-4 inline-flex items-center rounded-full border border-emerald-800/60 bg-emerald-950/50 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-300"
        >
          100% Private · Zero Uploads
        </p>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Professional <span class="text-emerald-400">PDF Utilities</span>
        </h1>
        <p class="mt-5 text-base leading-relaxed text-slate-400 sm:text-lg">
          Merge documents, compress uploads, split pages, watermark drafts, and convert photos — every operation runs locally
          on your device. No server, no paywall, no app install.
        </p>
      </div>

      <!-- Top tier: Merge + Compress -->
      <div class="mt-12 grid gap-4 sm:grid-cols-2">
        {
          featuredTools.map((tool) => (
            <a
              href={tool.href}
              data-astro-reload
              class="group flex min-h-[200px] flex-col rounded-2xl border-2 border-emerald-700/50 bg-gradient-to-br from-emerald-950/50 to-slate-900/70 p-6 transition hover:border-emerald-500 hover:from-emerald-950/70 focus:outline-none focus:ring-2 focus:ring-emerald-400"
            >
              <span class="text-4xl" aria-hidden="true">
                {tool.icon}
              </span>
              <h2 class="mt-4 text-xl font-bold text-white group-hover:text-emerald-300">{tool.name}</h2>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-400">{tool.description}</p>
              <span class="mt-4 text-sm font-semibold text-emerald-400">Open tool →</span>
            </a>
          ))
        }
      </div>

      <!-- Secondary tools -->
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          tools.map((tool) => (
            <a
              href={tool.href}
              data-astro-reload
              class="group flex min-h-[180px] flex-col rounded-2xl border border-slate-800 bg-slate-900/60 p-5 transition hover:border-emerald-700/60 hover:bg-slate-900/80 focus:outline-none focus:ring-2 focus:ring-emerald-400"
            >
              <span class="text-3xl" aria-hidden="true">
                {tool.icon}
              </span>
              <h2 class="mt-3 text-lg font-bold text-white group-hover:text-emerald-300">{tool.name}</h2>
              <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-400">{tool.description}</p>
              <span class="mt-4 text-xs font-semibold text-emerald-400">Open tool →</span>
            </a>
          ))
        }
      </div>

      <div class="mt-10 text-center">
        <a
          href="/studio"
          data-astro-reload
          class="inline-flex items-center gap-2 rounded-xl border border-emerald-800/50 bg-emerald-950/30 px-5 py-3 text-sm font-semibold text-emerald-300 transition hover:border-emerald-600 hover:bg-emerald-950/50"
        >
          Browse all 20+ PDF utilities
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
