---
import PdfToolsLayout from '../layouts/PdfToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';
import { utilitiesHref } from '@shared/config/sites';

const featuredTools = [
  {
    name: 'Merge PDF',
    description: 'Drag, reorder, and combine multiple PDFs into one submission-ready file.',
    href: '/merge',
    icon: '📎',
  },
  {
    name: 'Compress PDF',
    description: 'Shrink file size for strict upload limits — extreme, balanced, or high-quality presets.',
    href: '/compress',
    icon: '📉',
  },
];

const tools = [
  {
    name: 'Split PDF',
    description: 'Extract or split pages from a PDF — select exactly what you need.',
    href: '/split',
    icon: '✂️',
  },
  {
    name: 'Watermark PDF',
    description: 'Add a draft or personal watermark across every page locally.',
    href: '/watermark',
    icon: '💧',
  },
  {
    name: 'Image to PDF',
    description: 'Convert JPG photos and scans into a crisp PDF document.',
    href: '/image-to-pdf',
    icon: '🖼️',
  },
  {
    name: 'Protect PDF',
    description: 'Lock your PDF with a password — AES encryption runs entirely on your device.',
    href: '/protect',
    icon: '🔒',
  },
  {
    name: 'Unlock PDF',
    description: 'Remove password protection from an encrypted PDF using the open password.',
    href: '/unlock',
    icon: '🔓',
  },
];
---

<PdfToolsLayout
  title={formatSeoTitle('Free PDF Tools', 'Merge, Split & More')}
  description="Merge, split, compress, watermark, and convert PDFs entirely in your browser — zero uploads, built for professionals and teams."
  activeNav="home"
  hideWorkspaceNav={true}
>
  <section>
    <p
      class="mb-3 inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-800"
    >
      100% Private · Zero Uploads
    </p>
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      Professional <span class="text-emerald-600">PDF Utilities</span>
    </h1>
    <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate-600">
      Merge documents, compress uploads, split pages, watermark drafts, and convert photos — every operation runs locally
      on your device.
    </p>
  </section>

  <section class="mt-10 grid gap-4 sm:grid-cols-2">
    {
      featuredTools.map((tool) => (
        <a
          href={tool.href}
          data-astro-reload
          class="group flex min-h-[180px] flex-col rounded-2xl border border-emerald-200 bg-white p-5 shadow-sm transition hover:border-emerald-300 hover:shadow-md"
        >
          <span class="text-3xl" aria-hidden="true">
            {tool.icon}
          </span>
          <h2 class="mt-3 text-lg font-bold text-slate-900 group-hover:text-emerald-800">{tool.name}</h2>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{tool.description}</p>
          <span class="mt-4 text-sm font-semibold text-emerald-700">Open tool →</span>
        </a>
      ))
    }
  </section>

  <section class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      tools.map((tool) => (
        <a
          href={tool.href}
          data-astro-reload
          class="group flex min-h-[160px] flex-col rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-emerald-300 hover:shadow-md"
        >
          <span class="text-2xl" aria-hidden="true">
            {tool.icon}
          </span>
          <h2 class="mt-2 text-base font-bold text-slate-900 group-hover:text-emerald-800">{tool.name}</h2>
          <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-600">{tool.description}</p>
          <span class="mt-3 text-xs font-semibold text-emerald-700">Open tool →</span>
        </a>
      ))
    }
  </section>

  <section class="mt-10 text-center">
    <a
      href="/studio"
      data-astro-reload
      class="inline-flex items-center gap-2 rounded-xl border border-emerald-200 bg-emerald-50 px-5 py-3 text-sm font-semibold text-emerald-800 transition hover:border-emerald-300 hover:bg-emerald-100"
    >
      Browse all 26 PDF utilities
      <span aria-hidden="true">→</span>
    </a>
  </section>

  <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm sm:p-6">
    <p class="text-sm text-slate-600">
      Need calculators, writing tools, or career prep?
      <a
        href={utilitiesHref('/tools')}
        class="ml-1 font-semibold text-emerald-800 underline decoration-emerald-300 underline-offset-2 hover:text-emerald-900"
      >
        Open the Utilities Hub →
      </a>
    </p>
  </section>
</PdfToolsLayout>
