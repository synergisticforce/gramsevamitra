---
import PdfToolsLayout from '../layouts/PdfToolsLayout.astro';
import CompressPage from '../components/CompressPage';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Compress PDF';
const toolDescription =
  'Shrink PDF file size for exam uploads — extreme, balanced, and high-quality presets. 100% private, runs in your browser.';
---

<PdfToolsLayout
  title={formatSeoTitle('Compress PDF Size', 'Free Online Tool')}
  description={toolDescription}
  activeNav="home"
>
  <header class="mb-6">
    <a href="/" data-astro-reload class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
      ← PDF Tools Home
    </a>
    <h1 class="mt-3 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
    <p class="mt-1 text-sm text-slate-600">{toolDescription}</p>
  </header>

  <div class="relative overflow-visible rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
    <CompressPage client:load />
  </div>

  <p class="mt-6 text-center text-xs text-slate-500">
    Need more tools?
    <a href="/merge" data-astro-reload class="font-semibold text-emerald-700 hover:text-emerald-800">Merge PDF</a>
    ·
    <a href="/studio" data-astro-reload class="font-semibold text-emerald-700 hover:text-emerald-800">Full PDF Studio</a>
  </p>
</PdfToolsLayout>
