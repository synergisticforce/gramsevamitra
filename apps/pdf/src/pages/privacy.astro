---
import PdfToolsLayout from '../layouts/PdfToolsLayout.astro';
import LegalPage from '@shared/components/LegalPage.astro';
import PrivacyPolicyContent from '@shared/components/legal/PrivacyPolicyContent.astro';
import { LEGAL_SEO } from '@shared/config/seo';
---

<PdfToolsLayout
  title={LEGAL_SEO.privacy.pdf.title}
  description={LEGAL_SEO.privacy.pdf.description}
  activeNav="legal"
  hideWorkspaceNav={true}
>
  <LegalPage title="Privacy Policy">
    <PrivacyPolicyContent />
  </LegalPage>
</PdfToolsLayout>
