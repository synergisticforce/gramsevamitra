---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import PdfUniverse from '../components/PdfUniverse';
import { SITE_HOME_SEO } from '@shared/config/seo';
---

<BaseLayout
  title={SITE_HOME_SEO.pdf.title}
  description={SITE_HOME_SEO.pdf.description}
  site="pdf"
>
  <Header slot="header" active="pdf" />

  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#064e3b]/40 via-slate-950 to-slate-950"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
      <div class="mb-8 text-center sm:mb-10">
        <p
          class="mb-3 inline-flex items-center rounded-full border border-emerald-600/50 bg-[#064e3b]/50 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-300"
        >
          Full PDF Studio
        </p>
        <h1 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          All PDF <span class="text-emerald-400">Utilities</span>
        </h1>
        <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-slate-300 sm:text-base">
          Search and open every compress, edit, and convert tool — 100% in your browser.
        </p>
        <a href="/" class="mt-4 inline-block text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
          ← Back to PDF home
        </a>
      </div>

      <PdfUniverse client:load />
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
