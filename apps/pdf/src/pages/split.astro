---
import PdfToolsLayout from '../layouts/PdfToolsLayout.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Split PDF';
const toolDescription =
  'Extract page ranges or specific pages from a PDF — processed locally in your browser, never uploaded.';
---

<PdfToolsLayout
  title={formatSeoTitle('Split & Extract PDF Pages', 'Free Online Tool')}
  description={toolDescription}
  activeNav="home"
>
<header class="mb-6">
        <a href="/" data-astro-reload class="text-xs font-semibold text-emerald-700 transition hover:text-emerald-800">
          ← PDF Tools Home
        </a>
        <h1 class="mt-3 text-2xl font-bold text-slate-900 sm:text-3xl">{toolName}</h1>
        <p class="mt-1 text-sm text-slate-600">{toolDescription}</p>
      </header>

      <div
        id="drop-zone"
        class="drop-zone"
        role="button"
        tabindex="0"
        aria-label="Drop a PDF file here or click to browse"
      >
        <input id="file-input" type="file" accept="application/pdf,.pdf" class="sr-only" aria-hidden="true" />
        <div class="pointer-events-none flex flex-col items-center px-4 py-10 text-center sm:py-12">
          <span class="text-5xl" aria-hidden="true">✂️</span>
          <p class="mt-4 text-lg font-bold text-white">Drop a PDF here</p>
          <p class="mt-1 text-sm text-slate-600">or click to browse · one file at a time</p>
        </div>
      </div>

      <p id="file-error" class="mt-3 hidden text-sm text-rose-400" role="alert"></p>

      <div id="file-meta" class="mt-5 hidden rounded-xl border border-slate-800 bg-slate-900/60 px-4 py-4">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Loaded file</h2>
        <p id="meta-name" class="mt-2 truncate text-sm font-semibold text-white"></p>
        <p id="meta-size" class="text-xs text-slate-500"></p>
        <p id="meta-pages" class="mt-2 text-sm font-bold text-emerald-400"></p>
        <button type="button" id="clear-file" class="btn-secondary mt-3 w-full text-sm">Choose a different file</button>
      </div>

      <div id="split-panel" class="mt-6 hidden space-y-5">
        <fieldset>
          <legend class="mb-2 text-sm font-medium text-slate-300">Extraction mode</legend>
          <div class="flex flex-wrap gap-2" role="radiogroup" aria-label="Split mode">
            <label class="mode-pill">
              <input type="radio" name="split-mode" value="range" class="sr-only peer" checked />
              <span class="mode-pill-label">Extract range</span>
            </label>
            <label class="mode-pill">
              <input type="radio" name="split-mode" value="specific" class="sr-only peer" />
              <span class="mode-pill-label">Specific pages</span>
            </label>
          </div>
        </fieldset>

        <div id="range-panel" class="grid grid-cols-2 gap-3">
          <label class="min-w-0">
            <span class="mb-1 block text-sm font-medium text-slate-300">From page</span>
            <input id="page-from" type="number" min="1" step="1" inputmode="numeric" class="input-field w-full tabular-nums" />
          </label>
          <label class="min-w-0">
            <span class="mb-1 block text-sm font-medium text-slate-300">To page</span>
            <input id="page-to" type="number" min="1" step="1" inputmode="numeric" class="input-field w-full tabular-nums" />
          </label>
        </div>

        <label id="specific-panel" class="hidden block">
          <span class="mb-1 block text-sm font-medium text-slate-300">Page numbers (comma-separated)</span>
          <input
            id="page-specific"
            type="text"
            placeholder="e.g. 1, 3, 5"
            class="input-field w-full"
            inputmode="numeric"
          />
          <p class="mt-1 text-xs text-slate-500">Use 1-based page numbers as shown in a PDF reader.</p>
        </label>

        <button type="button" id="split-btn" class="btn-primary w-full py-3 text-base font-bold">
          Extract &amp; Download PDF
        </button>
        <p id="split-status" class="text-center text-xs text-slate-500" aria-live="polite"></p>
      </div>

      <div id="loading-overlay" class="loading-overlay hidden" aria-hidden="true">
        <div class="flex flex-col items-center gap-3 rounded-2xl border border-emerald-800/50 bg-slate-900/95 px-8 py-6 shadow-2xl">
          <div class="spinner" aria-hidden="true"></div>
          <p id="loading-label" class="text-sm font-medium text-emerald-300">Processing…</p>
        </div>
      </div>
</PdfToolsLayout>

<style>
  .drop-zone {
    @apply cursor-pointer rounded-2xl border-2 border-dashed border-emerald-700/50 bg-gradient-to-br from-emerald-950/40 to-slate-900/60 transition hover:border-emerald-500 hover:bg-emerald-950/50 focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2 focus:ring-offset-slate-950;
  }
  .drop-zone.is-dragover {
    @apply border-emerald-400 bg-emerald-950/60 ring-2 ring-emerald-400/40;
  }
  .mode-pill-label {
    @apply inline-flex cursor-pointer items-center rounded-full border border-slate-700 bg-slate-950/60 px-4 py-2 text-sm font-semibold text-slate-300 transition hover:border-emerald-600 hover:text-white;
  }
  .mode-pill :global(input:checked) + .mode-pill-label {
    @apply border-emerald-500 bg-emerald-950/50 text-emerald-300 ring-2 ring-emerald-400/40;
  }
  .mode-pill :global(input:focus-visible) + .mode-pill-label {
    @apply outline-none ring-2 ring-emerald-400;
  }
  .loading-overlay {
    @apply fixed inset-0 z-50 flex items-center justify-center bg-slate-950/70 backdrop-blur-sm;
  }
  .loading-overlay.hidden {
    display: none !important;
  }
  .spinner {
    @apply h-10 w-10 animate-spin rounded-full border-4 border-slate-700 border-t-emerald-400;
  }
</style>

<script>
  import { PDFDocument } from 'pdf-lib';

  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileError = document.getElementById('file-error')!;
  const fileMeta = document.getElementById('file-meta')!;
  const metaName = document.getElementById('meta-name')!;
  const metaSize = document.getElementById('meta-size')!;
  const metaPages = document.getElementById('meta-pages')!;
  const clearFileBtn = document.getElementById('clear-file') as HTMLButtonElement;
  const splitPanel = document.getElementById('split-panel')!;
  const rangePanel = document.getElementById('range-panel')!;
  const specificPanel = document.getElementById('specific-panel')!;
  const pageFrom = document.getElementById('page-from') as HTMLInputElement;
  const pageTo = document.getElementById('page-to') as HTMLInputElement;
  const pageSpecific = document.getElementById('page-specific') as HTMLInputElement;
  const splitBtn = document.getElementById('split-btn') as HTMLButtonElement;
  const splitStatus = document.getElementById('split-status')!;
  const loadingOverlay = document.getElementById('loading-overlay')!;
  const loadingLabel = document.getElementById('loading-label')!;

  let currentFile: File | null = null;
  let totalPages = 0;
  let pdfBytes: ArrayBuffer | null = null;

  function isPdfFile(file: File): boolean {
    return file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf');
  }

  function formatSize(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  }

  function showError(message: string): void {
    fileError.textContent = message;
    fileError.classList.remove('hidden');
  }

  function clearError(): void {
    fileError.textContent = '';
    fileError.classList.add('hidden');
  }

  function setLoading(active: boolean, label = 'Processing…'): void {
    loadingOverlay.classList.toggle('hidden', !active);
    loadingOverlay.setAttribute('aria-hidden', String(!active));
    loadingLabel.textContent = label;
    splitBtn.disabled = active;
  }

  function getMode(): 'range' | 'specific' {
    const checked = document.querySelector<HTMLInputElement>('input[name="split-mode"]:checked');
    return checked?.value === 'specific' ? 'specific' : 'range';
  }

  function updateModeUi(): void {
    const mode = getMode();
    rangePanel.classList.toggle('hidden', mode !== 'range');
    specificPanel.classList.toggle('hidden', mode !== 'specific');
  }

  function resetState(): void {
    currentFile = null;
    pdfBytes = null;
    totalPages = 0;
    fileMeta.classList.add('hidden');
    splitPanel.classList.add('hidden');
    dropZone.classList.remove('hidden');
    splitStatus.textContent = '';
    fileInput.value = '';
  }

  async function loadPdf(file: File): Promise<void> {
    clearError();
    if (!isPdfFile(file)) {
      showError('Please select a valid PDF file.');
      return;
    }

    setLoading(true, 'Reading PDF…');

    try {
      pdfBytes = await file.arrayBuffer();
      const pdf = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      totalPages = pdf.getPageCount();

      if (totalPages === 0) {
        showError('This PDF has no pages.');
        resetState();
        return;
      }

      currentFile = file;
      metaName.textContent = file.name;
      metaSize.textContent = formatSize(file.size);
      metaPages.textContent = `${totalPages} page${totalPages === 1 ? '' : 's'} total`;

      pageFrom.min = '1';
      pageFrom.max = String(totalPages);
      pageTo.min = '1';
      pageTo.max = String(totalPages);
      pageFrom.value = '1';
      pageTo.value = String(totalPages);

      dropZone.classList.add('hidden');
      fileMeta.classList.remove('hidden');
      splitPanel.classList.remove('hidden');
      updateModeUi();
    } catch {
      showError('Could not read this PDF. It may be corrupted or password-protected.');
      resetState();
    } finally {
      setLoading(false);
    }
  }

  /** Returns 0-based page indices for copyPages */
  function resolvePageIndices(): number[] | null {
    const mode = getMode();

    if (mode === 'range') {
      const from = Number(pageFrom.value);
      const to = Number(pageTo.value);
      if (!Number.isFinite(from) || !Number.isFinite(to)) {
        showError('Enter valid from and to page numbers.');
        return null;
      }
      if (from < 1 || to < 1 || from > totalPages || to > totalPages) {
        showError(`Page numbers must be between 1 and ${totalPages}.`);
        return null;
      }
      const start = Math.min(from, to);
      const end = Math.max(from, to);
      const indices: number[] = [];
      for (let p = start; p <= end; p++) indices.push(p - 1);
      return indices;
    }

    const raw = pageSpecific.value.trim();
    if (!raw) {
      showError('Enter at least one page number.');
      return null;
    }

    const parts = raw.split(',').map((s) => s.trim()).filter(Boolean);
    const indices: number[] = [];
    const seen = new Set<number>();

    for (const part of parts) {
      const num = Number(part);
      if (!Number.isInteger(num) || num < 1 || num > totalPages) {
        showError(`Invalid page "${part}". Use numbers from 1 to ${totalPages}.`);
        return null;
      }
      const zeroBased = num - 1;
      if (!seen.has(zeroBased)) {
        seen.add(zeroBased);
        indices.push(zeroBased);
      }
    }

    if (indices.length === 0) {
      showError('No valid pages selected.');
      return null;
    }

    return indices;
  }

  function downloadBlob(bytes: Uint8Array, filename: string): void {
    const blob = new Blob([bytes as BlobPart], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
  }

  async function splitPdf(): Promise<void> {
    if (!pdfBytes || !currentFile) {
      showError('Load a PDF file first.');
      return;
    }

    clearError();
    const indices = resolvePageIndices();
    if (!indices) return;

    setLoading(true, 'Extracting pages…');

    try {
      const source = await PDFDocument.load(pdfBytes, { ignoreEncryption: true });
      const output = await PDFDocument.create();
      const pages = await output.copyPages(source, indices);
      pages.forEach((page) => output.addPage(page));

      setLoading(true, 'Saving PDF…');
      const bytes = await output.save();
      downloadBlob(bytes, 'split-document.pdf');
      splitStatus.textContent = `Extracted ${indices.length} page${indices.length === 1 ? '' : 's'} successfully.`;
      splitStatus.className = 'text-center text-xs text-emerald-400';
    } catch (err) {
      showError("Oops! We couldn't process this file. Ensure it is a valid, unlocked document.");
      splitStatus.textContent = '';
    } finally {
      setLoading(false);
    }
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) void loadPdf(file);
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('is-dragover');
  });

  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('is-dragover'));

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('is-dragover');
    const file = e.dataTransfer?.files?.[0];
    if (file) void loadPdf(file);
  });

  document.querySelectorAll<HTMLInputElement>('input[name="split-mode"]').forEach((el) => {
    el.addEventListener('change', () => {
      clearError();
      updateModeUi();
    });
  });

  clearFileBtn.addEventListener('click', () => {
    clearError();
    resetState();
  });

  splitBtn.addEventListener('click', () => {
    void splitPdf();
  });
</script>
