---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import { formatSeoTitle } from '@shared/config/seo';

const toolName = 'Merge PDF';
const toolDescription =
  'Combine multiple PDF files in any order — drag to reorder, merge locally, and download instantly. No uploads.';
---

<BaseLayout
  title={formatSeoTitle('Merge PDF Files', 'Free Online Tool')}
  description={toolDescription}
  site="pdf"
>
  <Header slot="header" active="pdf" />

  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/20 via-slate-950 to-slate-950"
    >
    </div>

    <div class="relative mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12">
      <header class="mb-6">
        <a href="/" data-astro-reload class="text-xs font-semibold text-emerald-400 transition hover:text-emerald-300">
          ← PDF Tools Home
        </a>
        <h1 class="mt-3 text-2xl font-bold text-white sm:text-3xl">{toolName}</h1>
        <p class="mt-1 text-sm text-slate-400">{toolDescription}</p>
      </header>

      <div
        id="drop-zone"
        class="drop-zone"
        role="button"
        tabindex="0"
        aria-label="Drop PDF files here or click to browse"
      >
        <input
          id="file-input"
          type="file"
          accept="application/pdf,.pdf"
          multiple
          class="sr-only"
          aria-hidden="true"
        />
        <div class="pointer-events-none flex flex-col items-center px-4 py-10 text-center sm:py-14">
          <span class="text-5xl" aria-hidden="true">📎</span>
          <p class="mt-4 text-lg font-bold text-white">Drop PDFs here</p>
          <p class="mt-1 text-sm text-slate-400">or click to browse from your device</p>
          <p class="mt-3 text-xs text-emerald-400/80">Files stay on your device — never uploaded</p>
        </div>
      </div>

      <p id="file-error" class="mt-3 hidden text-sm text-rose-400" role="alert"></p>

      <div id="file-list-section" class="mt-6 hidden">
        <div class="mb-3 flex items-center justify-between gap-2">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Merge order</h2>
          <span id="file-count" class="text-xs text-slate-500">0 files</span>
        </div>
        <p class="mb-3 text-xs text-emerald-400/80">Drag cards to reorder · first file appears first in output</p>
        <ul id="file-list" class="space-y-2" aria-label="PDF files to merge"></ul>
      </div>

      <div class="mt-6">
        <button type="button" id="merge-btn" class="btn-primary w-full py-3 text-base font-bold" disabled>
          <span id="merge-btn-label">Merge PDFs</span>
        </button>
        <p id="merge-status" class="mt-3 text-center text-xs text-slate-500" aria-live="polite"></p>
      </div>

      <div id="loading-overlay" class="loading-overlay hidden" aria-hidden="true">
        <div class="flex flex-col items-center gap-3 rounded-2xl border border-emerald-800/50 bg-slate-900/95 px-8 py-6 shadow-2xl">
          <div class="spinner" aria-hidden="true"></div>
          <p id="loading-label" class="text-sm font-medium text-emerald-300">Merging PDFs…</p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .drop-zone {
    @apply cursor-pointer rounded-2xl border-2 border-dashed border-emerald-700/50 bg-gradient-to-br from-emerald-950/40 to-slate-900/60 transition hover:border-emerald-500 hover:bg-emerald-950/50 focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2 focus:ring-offset-slate-950;
  }
  .drop-zone.is-dragover {
    @apply border-emerald-400 bg-emerald-950/60 ring-2 ring-emerald-400/40;
  }
  .file-card {
    @apply flex cursor-grab items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/80 px-4 py-3 shadow-sm active:cursor-grabbing;
  }
  .file-card.sortable-ghost {
    @apply opacity-40;
  }
  .file-card.sortable-chosen {
    @apply border-emerald-600 ring-2 ring-emerald-400/30;
  }
  .remove-btn {
    @apply shrink-0 rounded-lg border border-slate-700 bg-slate-950/60 px-2.5 py-1.5 text-xs font-semibold text-slate-400 transition hover:border-rose-600 hover:bg-rose-950/40 hover:text-rose-400 focus:outline-none focus:ring-2 focus:ring-rose-400;
  }
  .loading-overlay {
    @apply fixed inset-0 z-50 flex items-center justify-center bg-slate-950/70 backdrop-blur-sm;
  }
  .loading-overlay.hidden {
    display: none !important;
  }
  .spinner {
    @apply h-10 w-10 animate-spin rounded-full border-4 border-slate-700 border-t-emerald-400;
  }
</style>

<script>
  import Sortable from 'sortablejs';
  import { PDFDocument } from 'pdf-lib';

  interface PdfFileItem {
    id: string;
    file: File;
  }

  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const fileError = document.getElementById('file-error')!;
  const fileListSection = document.getElementById('file-list-section')!;
  const fileList = document.getElementById('file-list')!;
  const fileCount = document.getElementById('file-count')!;
  const mergeBtn = document.getElementById('merge-btn') as HTMLButtonElement;
  const mergeStatus = document.getElementById('merge-status')!;
  const loadingOverlay = document.getElementById('loading-overlay')!;
  const loadingLabel = document.getElementById('loading-label')!;

  let items: PdfFileItem[] = [];
  let sortable: Sortable | null = null;

  function isPdfFile(file: File): boolean {
    const type = file.type.toLowerCase();
    const name = file.name.toLowerCase();
    return type === 'application/pdf' || name.endsWith('.pdf');
  }

  function formatSize(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  }

  function showError(message: string): void {
    fileError.textContent = message;
    fileError.classList.remove('hidden');
  }

  function clearError(): void {
    fileError.textContent = '';
    fileError.classList.add('hidden');
  }

  function createId(): string {
    return `pdf-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
  }

  function escapeHtml(text: string): string {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function addFiles(files: FileList | File[]): void {
    clearError();
    const rejected: string[] = [];
    const accepted: PdfFileItem[] = [];

    Array.from(files).forEach((file) => {
      if (!isPdfFile(file)) {
        rejected.push(file.name);
        return;
      }
      accepted.push({ id: createId(), file });
    });

    if (rejected.length > 0) {
      showError(`Skipped non-PDF file(s): ${rejected.join(', ')}`);
    }

    if (accepted.length === 0) return;

    items = [...items, ...accepted];
    renderList();
    mergeStatus.textContent = '';
  }

  function removeItem(id: string): void {
    items = items.filter((item) => item.id !== id);
    renderList();
  }

  function renderList(): void {
    const hasFiles = items.length > 0;
    fileListSection.classList.toggle('hidden', !hasFiles);
    mergeBtn.disabled = items.length < 2;
    fileCount.textContent = `${items.length} file${items.length === 1 ? '' : 's'}`;

    fileList.innerHTML = items
      .map(
        (item) => `
        <li class="file-card" data-id="${item.id}">
          <span class="text-lg text-slate-500" aria-hidden="true">⠿</span>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-semibold text-white">${escapeHtml(item.file.name)}</p>
            <p class="text-xs text-slate-500">${formatSize(item.file.size)}</p>
          </div>
          <button type="button" class="remove-btn" data-remove="${item.id}" aria-label="Remove ${escapeHtml(item.file.name)}">🗑️ Remove</button>
        </li>
      `
      )
      .join('');

    fileList.querySelectorAll<HTMLButtonElement>('[data-remove]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.dataset.remove;
        if (id) removeItem(id);
      });
    });

    if (sortable) sortable.destroy();
    sortable = Sortable.create(fileList, {
      animation: 150,
      ghostClass: 'sortable-ghost',
      chosenClass: 'sortable-chosen',
      onEnd: () => {
        const order: PdfFileItem[] = [];
        fileList.querySelectorAll<HTMLElement>('[data-id]').forEach((el) => {
          const id = el.dataset.id;
          const found = items.find((x) => x.id === id);
          if (found) order.push(found);
        });
        items = order;
      },
    });
  }

  function setLoading(active: boolean, label = 'Merging PDFs…'): void {
    loadingOverlay.classList.toggle('hidden', !active);
    loadingOverlay.setAttribute('aria-hidden', String(!active));
    loadingLabel.textContent = label;
    mergeBtn.disabled = active || items.length < 2;
  }

  function downloadBlob(bytes: Uint8Array, filename: string): void {
    const blob = new Blob([bytes as BlobPart], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
  }

  async function mergePdfs(): Promise<void> {
    if (items.length < 2) {
      showError('Select at least two PDF files to merge.');
      return;
    }

    clearError();
    setLoading(true);

    try {
      const merged = await PDFDocument.create();
      let totalPages = 0;

      for (let i = 0; i < items.length; i++) {
        setLoading(true, `Merging file ${i + 1} of ${items.length}…`);
        const buffer = await items[i].file.arrayBuffer();
        const pdf = await PDFDocument.load(buffer, { ignoreEncryption: true });
        const pageIndices = pdf.getPageIndices();
        const pages = await merged.copyPages(pdf, pageIndices);
        pages.forEach((page) => merged.addPage(page));
        totalPages += pageIndices.length;
      }

      setLoading(true, 'Saving merged PDF…');
      const bytes = await merged.save();
      downloadBlob(bytes, 'merged-document.pdf');
      mergeStatus.textContent = `Success! Merged ${items.length} files (${totalPages} pages total).`;
      mergeStatus.className = 'mt-3 text-center text-xs text-emerald-400';
    } catch (err) {
      showError("Oops! We couldn't process this file. Ensure it is a valid, unlocked document.");
      mergeStatus.textContent = '';
    } finally {
      setLoading(false);
    }
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) addFiles(fileInput.files);
    fileInput.value = '';
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('is-dragover');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('is-dragover');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('is-dragover');
    if (e.dataTransfer?.files?.length) addFiles(e.dataTransfer.files);
  });

  mergeBtn.addEventListener('click', () => {
    void mergePdfs();
  });
</script>
