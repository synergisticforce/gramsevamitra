---
import SegmentedControl from '@shared/components/saas/SegmentedControl.astro';
import { PDF_WORKSPACE_SEGMENTS } from '../../config/pdfWorkspaceSegments';

interface Props {
  activeSegmentId: string;
  showBackLink?: boolean;
}

const { activeSegmentId, showBackLink = true } = Astro.props;
---

<div class="mb-6 space-y-4">
  {
    showBackLink && (
      <a
        href="/"
        data-astro-reload
        class="inline-flex text-xs font-semibold text-emerald-700 transition hover:text-emerald-800"
      >
        ← PDF Tools Home
      </a>
    )
  }

  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">PDF Workspaces</p>
      <p class="text-sm text-slate-600">Convert, compress, edit, and secure documents — 100% in your browser.</p>
    </div>
    <SegmentedControl
      items={PDF_WORKSPACE_SEGMENTS}
      activeId={activeSegmentId}
      ariaLabel="PDF workspace sections"
    />
  </div>
</div>
