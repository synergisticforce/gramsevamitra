---
import '@shared/styles/global.css';
import MarketingLayout from '@shared/layouts/MarketingLayout.astro';
import OptimizerApp from '../components/OptimizerApp';
import { SITE_HOME_SEO } from '@shared/config/seo';
---

<MarketingLayout
  title={SITE_HOME_SEO.optimizer.title}
  description={SITE_HOME_SEO.optimizer.description}
  site="optimizer"
  active="optimizer"
>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-14">
    <div class="mb-10 text-center">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Exam Document Optimizer</h1>
      <p class="mt-3 text-slate-400">
        Upload your photo or signature — we resize, crop, and compress to exact exam specifications.
        Processing stays on your device.
      </p>
    </div>
    <OptimizerApp client:load />
  </section>
</MarketingLayout>
