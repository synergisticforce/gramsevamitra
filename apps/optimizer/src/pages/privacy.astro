import LegalPage from '@shared/components/LegalPage.astro';
import PrivacyPolicyContent from '@shared/components/legal/PrivacyPolicyContent.astro';
import { LEGAL_SEO } from '@shared/config/seo';
---

<MarketingLayout
  title={LEGAL_SEO.privacy.optimizer.title}
  description={LEGAL_SEO.privacy.optimizer.description}
  site="optimizer"
  active="optimizer"
>
  <LegalPage title="Privacy Policy">
