---
import '@shared/styles/global.css';
import BaseLayout from '@shared/layouts/BaseLayout.astro';
import Header from '@shared/components/Header.astro';
import Footer from '@shared/components/Footer.astro';
import NotFoundContent from '@shared/components/NotFoundContent.astro';
import { SITES } from '@shared/config/sites';
---

<BaseLayout
  title="Page Not Found | Document Optimizer — GramSeva Mitra"
  description="The page you requested could not be found."
  site="optimizer"
>
  <Header slot="header" active="optimizer" />
  <NotFoundContent
    homeHref="/"
    homeLabel="Document Optimizer Home"
    extraLinks={[
      { href: SITES.hub.url, label: 'Main Hub' },
      { href: SITES.pdf.url, label: 'PDF Tools' },
    ]}
  />
  <Footer slot="footer" />
</BaseLayout>
