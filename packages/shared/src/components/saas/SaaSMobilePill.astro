---
import { SITES, utilitiesHref } from '../../config/sites';
import type { SaaSSiteId } from './saasNav.ts';

interface Props {
  site: SaaSSiteId;
}

const { site } = Astro.props;

const isPdf = site === 'pdf';
---

<div class="pointer-events-none fixed inset-x-0 bottom-6 z-40 flex justify-center px-4 lg:hidden">
  <nav
    class="pointer-events-auto flex items-center gap-1 rounded-full border border-canvas-border bg-canvas-surface/80 px-2 py-1.5 shadow-none backdrop-blur-md"
    aria-label="Mobile navigation"
  >
    {
      isPdf ? (
        <>
          <a
            href="/"
            data-astro-reload
            class="rounded-full px-3 py-2 text-xs font-semibold text-canvas-muted transition hover:bg-canvas-elevated hover:text-canvas-text"
          >
            Home
          </a>
          <a
            href="/studio"
            data-astro-reload
            class="rounded-full px-3 py-2 text-xs font-semibold text-canvas-muted transition hover:bg-canvas-elevated hover:text-canvas-text"
          >
            Studio
          </a>
        </>
      ) : (
        <>
          <a
            href={SITES.hub.url}
            class="rounded-full px-3 py-2 text-xs font-semibold text-canvas-muted transition hover:bg-canvas-elevated hover:text-canvas-text"
          >
            Home
          </a>
          <a
            href={utilitiesHref('/tools')}
            class="rounded-full px-3 py-2 text-xs font-semibold text-canvas-muted transition hover:bg-canvas-elevated hover:text-canvas-text"
          >
            Tools
          </a>
        </>
      )
    }
    <button
      type="button"
      id="saas-mobile-search-trigger"
      class="rounded-full bg-canvas-accent-muted px-3 py-2 text-xs font-semibold text-canvas-text transition hover:bg-canvas-elevated"
      aria-label="Open quick tools search"
    >
      ⚡
    </button>
    {
      isPdf ? (
        <a
          href={utilitiesHref('/tools')}
          class="rounded-full px-3 py-2 text-xs font-semibold text-canvas-muted transition hover:bg-canvas-elevated hover:text-canvas-text"
        >
          Hub
        </a>
      ) : (
        <a
          href={`${SITES.hub.url}/contact`}
          class="rounded-full px-3 py-2 text-xs font-semibold text-canvas-muted transition hover:bg-canvas-elevated hover:text-canvas-text"
        >
          Contact
        </a>
      )
    }
  </nav>
</div>
