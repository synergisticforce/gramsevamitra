---
export interface SegmentItem {
  id: string;
  label: string;
  href: string;
}

interface Props {
  items: SegmentItem[];
  activeId: string;
  ariaLabel?: string;
}

const { items, activeId, ariaLabel = 'Section navigation' } = Astro.props;
---

<nav
  class="inline-flex w-full max-w-md rounded-lg bg-slate-100 p-1"
  aria-label={ariaLabel}
>
  {
    items.map((item) => {
      const isActive = item.id === activeId;
      return (
        <a
          href={item.href}
          class:list={[
            'flex-1 rounded-md px-3 py-2 text-center text-xs font-semibold transition sm:text-sm',
            isActive
              ? 'bg-white text-slate-900 shadow-sm'
              : 'text-slate-600 hover:text-slate-900',
          ]}
          aria-current={isActive ? 'page' : undefined}
        >
          {item.label}
        </a>
      );
    })
  }
</nav>
