---
interface LinkItem {
  href: string;
  label: string;
}

interface Props {
  title?: string;
  message?: string;
  homeHref: string;
  homeLabel: string;
  extraLinks?: LinkItem[];
}

const {
  title = 'Page not found',
  message = 'This page does not exist or may have moved. Try one of the links below.',
  homeHref,
  homeLabel,
  extraLinks = [],
} = Astro.props;
---

<section class="relative overflow-hidden">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/20 via-slate-950 to-slate-950"
  >
  </div>
  <div class="relative mx-auto flex min-h-[50vh] max-w-lg flex-col items-center justify-center px-4 py-20 text-center sm:px-6">
    <p class="text-6xl font-extrabold tabular-nums text-canvas-accent/30" aria-hidden="true">404</p>
    <h1 class="mt-4 text-2xl font-bold text-canvas-text sm:text-3xl">{title}</h1>
    <p class="mt-3 text-sm leading-relaxed text-canvas-subtle">{message}</p>
    <div class="mt-8 flex w-full flex-col gap-3">
      <a href={homeHref} class="btn-primary w-full py-3 text-center text-sm font-semibold">
        {homeLabel}
      </a>
      {
        extraLinks.map((link) => (
          <a
            href={link.href}
            class="btn-secondary w-full py-3 text-center text-sm font-semibold"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</section>
