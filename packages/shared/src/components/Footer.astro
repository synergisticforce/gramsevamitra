---
import { SITES, utilitiesHref } from '../config/sites';
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <p class="text-lg font-bold text-white">GramSeva Mitra</p>
        <p class="mt-2 max-w-sm text-sm text-slate-400">
          Empowering professionals, students, and creators worldwide with fast, privacy-first tools.
        </p>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-slate-500">Tools</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href={utilitiesHref('/tools')} data-astro-reload class="text-slate-300 hover:text-emerald-400">
              Utilities Super-App
            </a>
          </li>
          <li>
            <a href={SITES.optimizer.url} data-astro-reload class="text-slate-300 hover:text-emerald-400">
              Exam Document Optimizer
            </a>
          </li>
          <li>
            <a href={SITES.resume.url} data-astro-reload class="text-slate-300 hover:text-emerald-400">
              ATS Resume Scanner
            </a>
          </li>
          <li>
            <a href={SITES.pdf.url} data-astro-reload class="text-slate-300 hover:text-emerald-400">
              PDF Tools
            </a>
          </li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-slate-500">Legal</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a href="/privacy" class="text-slate-300 hover:text-emerald-400">Privacy Policy</a>
          </li>
          <li>
            <a href="/terms" class="text-slate-300 hover:text-emerald-400">Terms of Service</a>
          </li>
        </ul>
      </div>
    </div>
    <p class="mt-10 border-t border-slate-800 pt-6 text-center text-xs text-slate-500">
      © {new Date().getFullYear()} GramSeva Mitra. All processing runs on your device — your files never leave your browser.
    </p>
  </div>
</footer>
