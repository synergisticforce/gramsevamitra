---
import { SITES, utilitiesHref } from '../config/sites';
import MobileNavMenu from './MobileNavMenu';

interface Props {
  active?: 'hub' | 'utilities' | 'optimizer' | 'resume' | 'pdf';
}

const { active = 'hub' } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/90 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6" aria-label="Main navigation">
    <a href={SITES.hub.url} data-astro-reload class="group flex items-center gap-2">
      <span
        class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-600 text-sm font-bold text-white transition group-hover:bg-emerald-500"
        aria-hidden="true"
      >
        GS
      </span>
      <span class="text-lg font-bold tracking-tight text-white">
        Gram<span class="text-emerald-400">Seva</span> Mitra
      </span>
    </a>

    <ul class="hidden items-center gap-6 text-sm font-medium sm:flex">
      <li>
        <a
          href={SITES.hub.url}
          data-astro-reload
          class:list={[
            'transition hover:text-emerald-400',
            active === 'hub' ? 'text-emerald-400' : 'text-slate-300',
          ]}
        >
          Home
        </a>
      </li>
      <li>
        <a
          href={utilitiesHref('/tools')}
          data-astro-reload={active !== 'utilities' ? true : undefined}
          class:list={[
            'transition hover:text-emerald-400',
            active === 'utilities' ? 'text-emerald-400' : 'text-slate-300',
          ]}
        >
          Utilities
        </a>
      </li>
      <li>
        <a
          href={SITES.optimizer.url}
          data-astro-reload={active !== 'optimizer' ? true : undefined}
          class:list={[
            'transition hover:text-emerald-400',
            active === 'optimizer' ? 'text-emerald-400' : 'text-slate-300',
          ]}
        >
          Doc Optimizer
        </a>
      </li>
      <li>
        <a
          href={SITES.resume.url}
          data-astro-reload={active !== 'resume' ? true : undefined}
          class:list={[
            'transition hover:text-emerald-400',
            active === 'resume' ? 'text-emerald-400' : 'text-slate-300',
          ]}
        >
          Resume Scanner
        </a>
      </li>
      <li>
        <a
          href={SITES.pdf.url}
          data-astro-reload={active !== 'pdf' ? true : undefined}
          class:list={[
            'transition hover:text-emerald-400',
            active === 'pdf' ? 'text-emerald-400' : 'text-slate-300',
          ]}
        >
          PDF Tools
        </a>
      </li>
      <li>
        <a
          href={`${SITES.hub.url}/contact`}
          data-astro-reload={active !== 'hub' ? true : undefined}
          class="text-slate-300 transition hover:text-emerald-400"
        >
          Contact
        </a>
      </li>
    </ul>

    <MobileNavMenu client:load active={active} />
  </nav>
</header>
