---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InstallAppBanner from '../components/InstallAppBanner';

interface Props {
  title: string;
  description?: string;
  site: 'optimizer' | 'resume';
  active: 'hub' | 'optimizer' | 'resume' | 'pdf';
}

const { title, description, site, active } = Astro.props;
---

<BaseLayout title={title} description={description} site={site}>
  <div class="flex min-h-screen flex-col bg-slate-950 text-slate-100">
    <Header active={active} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <InstallAppBanner client:load />
  </div>
</BaseLayout>
