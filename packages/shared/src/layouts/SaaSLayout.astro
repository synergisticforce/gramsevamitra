---
import BaseLayout from './BaseLayout.astro';
import SaaSSidebar from '../components/saas/SaaSSidebar.astro';
import SaaSMobilePill from '../components/saas/SaaSMobilePill.astro';
import type { SaaSNavKey, SaaSSiteId } from '../components/saas/saasNav.ts';

interface Props {
  site: SaaSSiteId;
  title: string;
  description?: string;
  activeNav?: SaaSNavKey;
  /** Extra bottom padding on mobile for the floating pill nav */
  padMobileNav?: boolean;
  /** Use wider center canvas (e.g. PDF studio grid) */
  wide?: boolean;
}

const {
  site,
  title,
  description = 'Free privacy-first productivity tools — offline calculators, document utilities, and career prep.',
  activeNav = 'home',
  padMobileNav = true,
  wide = false,
} = Astro.props;

const canvasClass = wide ? 'max-w-6xl' : 'max-w-4xl';
const brandHref = site === 'pdf' ? '/' : '/';
---

<BaseLayout title={title} description={description} site={site}>
  <slot name="head" slot="head" />

  <div class="flex min-h-screen bg-white">
    <SaaSSidebar site={site} active={activeNav} />

    <div class="flex min-w-0 flex-1 flex-col">
      <header class="flex items-center justify-between border-b border-slate-200 bg-white px-4 py-3 lg:hidden">
        <a href={brandHref} class="text-sm font-bold text-slate-900" data-astro-reload={site === 'pdf' ? true : undefined}>
          Gram<span class="text-emerald-600">Seva</span> Mitra
        </a>
        <button
          type="button"
          id="saas-cmdk-trigger-mobile-header"
          class="rounded-lg border border-slate-200 px-2.5 py-1.5 text-xs font-semibold text-slate-600"
        >
          ⌘K
        </button>
      </header>

      <main class:list={['flex-1 bg-slate-50', padMobileNav && 'pb-24 lg:pb-0']}>
        <div class:list={['mx-auto w-full', canvasClass]}>
          <slot />
        </div>
      </main>
    </div>
  </div>

  <SaaSMobilePill site={site} slot="footer" />
  <slot name="footer" slot="footer" />
</BaseLayout>

<script>
  import { OMNI_SEARCH_OPEN_EVENT } from '../components/saas/saasNav.ts';

  function openOmniSearch() {
    window.dispatchEvent(new CustomEvent(OMNI_SEARCH_OPEN_EVENT));
  }

  document.getElementById('saas-cmdk-trigger-mobile-header')?.addEventListener('click', openOmniSearch);
  document.getElementById('saas-cmdk-trigger')?.addEventListener('click', openOmniSearch);
  document.getElementById('saas-mobile-search-trigger')?.addEventListener('click', openOmniSearch);
</script>
