---
import { SITES } from '../config/sites';
import { canonicalUrl, getRobotsDirective } from '../config/seo';
import InstallAppBanner from '../components/InstallAppBanner';

interface Props {
  title: string;
  description?: string;
  site?: 'hub' | 'optimizer' | 'resume' | 'pdf';
  showCrossPromo?: boolean;
}

const {
  title,
  description = 'Digital empowerment suite for Indian aspirants — exam document optimization and ATS resume scanning.',
  site = 'hub',
  showCrossPromo = false,
} = Astro.props;

const siteConfig = SITES[site];
const canonical = canonicalUrl(site, Astro.url.pathname);
const robots = getRobotsDirective();
const ogImage = new URL('/favicon.svg', siteConfig.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020617" />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GramSeva Mitra" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_IN" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    {showCrossPromo && (
      <div class="border-b border-emerald-900/50 bg-emerald-950/80 px-4 py-2 text-center text-sm text-emerald-100">
        Need exam photo/signature sizing?
        <a
          href={SITES.optimizer.url}
          class="ml-1 font-semibold underline decoration-emerald-400 underline-offset-2 hover:text-white"
        >
          Try the Document Optimizer →
        </a>
      </div>
    )}
    <slot name="header" />
    <main class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
    <InstallAppBanner client:load />
  </body>
</html>
