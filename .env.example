# GramSeva Mitra — environment

PAYMENT_ENV=TEST
PUBLIC_PAYMENTS_ENABLED=true

# Legacy stubs (unused — satisfy build-time references only)
PUBLIC_RAZORPAY_KEY_ID=disabled
PUBLIC_INSTAMOJO_PAYMENT_LINK=https://example.com/disabled
PUBLIC_OPTIMIZER_PRICE_PAISE=0
PUBLIC_RESUME_SINGLE_PRICE_PAISE=0
PUBLIC_RESUME_MONTHLY_PRICE_PAISE=0

# Preview deployments (Cloudflare Pages branch previews)
# PUBLIC_ROBOTS=noindex, nofollow

# Optional — Zone DNS Edit + Cache Purge (required for npm run configure:routing)
# CLOUDFLARE_API_TOKEN=your_token_here

# Contact form (Cloudflare Pages Functions — set as Pages secrets in production)
# TURNSTILE_SECRET_KEY=your_turnstile_secret
# RESEND_API_KEY=your_resend_api_key

# Better Auth / Google OAuth (Cloudflare Pages secrets in production)
# BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
# BETTER_AUTH_URL=https://gramsevamitra.com
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Stripe — Test Mode (Cloudflare Pages secrets in production)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: use a pre-created Stripe Price ID instead of inline price_data (₹199/mo)
# STRIPE_PRICE_ID=price_...
